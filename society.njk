<div class="charttip" id="charttip"></div>

<script type="module">
import { loadSeries, S, EVENTS, NEWS, tile, mrow, staticRow, construccion, sectionHead, exhibit, dataTable, timeChart, fwd, qtrOf, relTime, evDate, tagChip, wireCharts, renderDevelopments, srcBadge, storyBlock, projectionChart } from '/assets/mb.js?v=12';

/* series this section reads — the Q6 numbers plus the same-file living-standards /
   demography series (World Bank). loadSeries also pulls the news wire + events. */
const SOCIETY_SERIES=['banxico-salario-minimo','banxico-remesas','cre-gasolina-regular','wb-unemployment','wb-gdp-per-capita','wb-population'];

/* Poverty is a static, human-entered figure (no live series). Authored ONCE here and
   rendered into BOTH the board tile and the Background staticRow, so the two can never
   disagree — the same "same-source" law the live tiles follow. Migrated verbatim from Q6. */
const POVERTY={
  rate:'29.6', unit:'% of population', tileUnit:'% of pop.', year:'2024',
  prior:'41.9', priorYear:'2018', dropPp:'12.3', fewer:'13.4M',
  stamp:'ANNUAL · 2024',
  srcName:'INEGI — Multidimensional Poverty 2024',
  srcUrl:'https://www.inegi.org.mx/contenidos/saladeprensa/boletines/2025/pm/pm2025_08.pdf'
};
function povertyTile(P){
  return `<div class="tile"><div class="tl">Poverty · national</div>`+
    `<div class="tv">${P.rate} <small>${P.tileUnit}</small></div>`+
    `<span class="dl dn">−${P.dropPp}pp <small>vs ${P.priorYear}</small></span>`+
    `<div class="tb">lowest on record</div>`+
    `<span class="stamp">${P.stamp}</span><span class="tsrc">INEGI / CONEVAL</span><div class="tbadge">${srcBadge('INEGI / CONEVAL')}</div></div>`;
}

/* the live tile board (block 2) — poverty headline + the same JSON as the metric rows below */
const TILES=[
  {id:'banxico-salario-minimo',l:'Minimum wage · daily',per:'vs prior year'},
  {id:'banxico-remesas',l:'Remittances · month',per:'vs prior month'},
  {id:'wb-unemployment',l:'Unemployment',per:'vs prior year'},
  {id:'wb-gdp-per-capita',l:'GDP per person',per:'vs prior year'},
  // population lives in the demographics block below (CONAPO, Mexican-official, with the census anchor) —
  // we don't also show the World Bank estimate as a tile, so a reader never sees two population numbers.
];

/* block 3 — the migrated Q6 "are people better off?" exhibit + metric rows + poverty +
   the IMSS not-yet-wired row + forward line + gloss, built exactly as index.njk builds it. */
function renderBackground(){
  const sal=S['banxico-salario-minimo'];
  let ex='';
  if(sal){
    const svg=timeChart([{name:'Min wage',color:'green',pts:sal.data.slice(-14)}],{unit:'$',xfmt:(d)=>String(new Date(d).getUTCFullYear())});
    ex=exhibit('6.1','The government has doubled the minimum wage since 2018','General minimum wage, MXN per day (nominal)',svg,
      `Source: <a href="https://www.banxico.org.mx" target="_blank" rel="noopener">Banco de México (SIE)</a> / CONASAMI.`);
  }
  const P=POVERTY;
  return sectionHead('Background','Wages, remittances and poverty since 2018','The minimum wage reached 315 pesos a day in 2026, double its 2018 level. Remittances hit $5.6bn in May 2026. Poverty fell to 29.6% in 2024, down from 41.9% in 2018.')+
    ex+
    mrow({id:'banxico-salario-minimo',label:'General minimum wage'})+
    mrow({id:'banxico-remesas',label:'Remittances (family, monthly)'})+
    mrow({id:'cre-gasolina-regular',label:'Gasoline · regular (national avg)'})+
    staticRow({label:'Poverty (national)',value:P.rate,unit:P.unit,stamp:P.stamp,
      verdict:`Multidimensional poverty fell to <b>${P.rate}%</b> in ${P.year}, the lowest on record, down ${P.dropPp} points from ${P.prior}% in ${P.priorYear}. The drop moved ${P.fewer} people out of poverty. INEGI published the figure as its first poverty measurement since taking over from CONEVAL.`,
      bench:`vs ${P.prior}% in ${P.priorYear}`,srcName:P.srcName,srcUrl:P.srcUrl})+
    construccion({l:'Formal jobs & average formal wage (IMSS)',src:'IMSS (Datos Abiertos)',cad:'monthly',eta:'National totals. Feed not yet connected.'})+
    fwd(`No official forecast exists for household welfare. The government sets the nominal minimum wage each year, and slow GDP growth (<a href="/#q4">Q4</a>) limits gains beyond it.`)+
    `<div class="ctxline">Gloss: <b>CONEVAL</b> = the agency that measured poverty before INEGI took it over · <b>multidimensional poverty</b> = a measure that counts income plus access to food, health care, housing and schooling · <b>IMSS</b> = social security, i.e. the formal-jobs registry · <b>remittances</b> = money Mexicans abroad send home · <b>nominal</b> = not adjusted for inflation.</div>`;
}

/* block 4 — society-relevant catalyst calendar (poverty / wages / jobs / migration) */
function renderWatch(){
  const ev=(EVENTS&&EVENTS.events)||[];
  const rx=/pobreza|salario|salarial|empleo|desempleo|desigualdad|migraci|migrante|remesas|remittance|poblaci|imss|trabajador|informal|welfare|bienestar|coneval|conasami|censo|census|wage|poverty|inequality/i;
  const soc=ev.filter(e=>rx.test((e.label||'')+' '+(e.mechanism||'')+' '+(e.kind||'')));
  const now=Date.now();
  const up=soc.filter(e=>new Date(e.date)>=now-864e5).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,6);
  if(!up.length) return `<div class="cb-empty">Nothing is on the society calendar yet. Poverty, wage and jobs releases appear here once they're scheduled.</div>`;
  return `<div class="watchtbl">`+up.map(e=>{const d=evDate(e);
    return `<div class="wtr"><div class="wd">${d.mo} ${d.day}, ${d.y}${e.approx?' ~':''}</div><div class="wk ${e.kind||''}"></div><div class="wt">${e.label}<div class="wm">${e.mechanism||''}${e.sourceUrl?` · <a class="wsrc" href="${e.sourceUrl}" target="_blank" rel="noopener" style="color:var(--green)">${e.source||'source'}</a>`:''}</div></div></div>`;}).join('')+`</div>`;
}

/* block 2.5 — demographics: the flagship births-vs-deaths "demographic turn" chart (INEGI
   vital statistics, MEASURED) + a stat strip mixing the CONAPO population PROJECTION with the
   measured vital-stat headlines. Every number carries a Projection/Measured badge so the reader
   never mistakes a 2023-base model output for a count. No number is hand-typed — all read from
   data/demographics.json + data/vitals.json. */
function dstat(label,value,sub,tier){
  const b=tier==='projection'?'<span class="dbadge proj">Projection</span>':'<span class="dbadge meas">Measured</span>';
  return `<div class="dstat"><div class="dsl">${label}</div><div class="dsv">${value}</div><div class="dss">${sub}</div>${b}</div>`;
}
function renderDemographics(DEMO,VIT){
  if(!DEMO&&!VIT) return '';
  let out=sectionHead('Population','Mexico’s demographic turn',
    'Births have fallen since 2010 while deaths rise. CONAPO projects the population peaks near 2053, then shrinks.');
  if(VIT&&VIT.births&&VIT.deaths){
    const toPts=s=>s.series.map(p=>({date:p.year+'-07-01',value:p.value/1e6}));   // millions
    const svg=timeChart([
      {name:'Deaths',color:'var(--red)',pts:toPts(VIT.deaths)},
      {name:'Births',color:'green',pts:toPts(VIT.births)},
    ],{unit:'M',xfmt:(d)=>String(new Date(d).getUTCFullYear())});
    out+=exhibit('Vital signs','The yearly gap between births and deaths has narrowed by two-thirds since 2010',
      'Registered births and deaths per year. Births 2010–2024. Deaths 1990–2024. The 2020–21 jump in deaths is COVID excess mortality. The 2020 dip in births is a registration effect, not a fertility drop: civil-registry offices closed and recorded births late, so the 2021 count rebounded.',svg,
      `Source: <a href="${VIT.deaths.sourceUrl}" target="_blank" rel="noopener">INEGI</a>, Estadísticas de Nacimientos y Defunciones Registradas.`);
  }
  // stat strip — population/median/dependency are CONAPO projection; births/deaths are measured
  let strip='';
  if(DEMO){
    strip+=dstat('Population',(DEMO.population.latest/1e6).toFixed(1)+'M',`${DEMO.latestYear} · CONAPO`,'projection');
    if(DEMO.medianAge) strip+=dstat('Median age',DEMO.medianAge,'years',projTierFor(DEMO.latestYear));
    if(DEMO.dependencyRatio) strip+=dstat('Dependency ratio',DEMO.dependencyRatio,'per 100 of working age',projTierFor(DEMO.latestYear));
  }
  if(VIT&&VIT.births) strip+=dstat('Births',(VIT.births.latest.value/1e6).toFixed(2)+'M',`${VIT.births.latest.year} · INEGI`,'measured');
  if(VIT&&VIT.deaths) strip+=dstat('Deaths',Math.round(VIT.deaths.latest.value/1e3)+'k',`${VIT.deaths.latest.year} · INEGI`,'measured');
  if(strip) out+=`<div class="dstrip">${strip}</div>`;
  // population trajectory — the interactive projection (horizon buttons re-scale to 2050 / 2070)
  if(DEMO&&DEMO.population&&DEMO.population.series&&DEMO.population.series.length>2){
    const SR=DEMO.population.series; let peak=SR[0]; for(const p of SR) if(p.value>peak.value) peak=p;
    const chart=projectionChart({series:SR.map(p=>({year:p.year,value:p.value/1e6})),seamYear:2020,unit:'M',peak:{year:peak.year,value:peak.value/1e6},xmax:2070});
    out+=exhibit('Trajectory','CONAPO projects the population keeps rising to about '+(peak.value/1e6).toFixed(0)+'M near '+peak.year+', then slowly declines',
      'Total population, millions: observed to 2020, then CONAPO’s projection to 2070. Set the horizon to look further out.',
      `<div id="pop-explorer"><div class="horizon"><span class="hz-lbl">Look ahead to</span><button type="button" data-xmax="2050">2050</button><button type="button" data-xmax="2070" class="on">2070</button></div>${chart}</div>`,
      `Source: <a href="https://www.gob.mx/conapo" target="_blank" rel="noopener">CONAPO</a> — Proyecciones de la Población de México 2020–2070. A projection is CONAPO’s model output, not a measurement. The Mexico Brief publishes no forecasts of its own.`);
  }
  // census anchor line — kept separate from the projection, never mixed
  if(DEMO&&DEMO.censusAnchor) out+=`<p class="ctxline">The ${DEMO.censusAnchor.year} Census counted <b>${(DEMO.censusAnchor.population/1e6).toFixed(1)}M</b> people (INEGI). Figures for years after the census are CONAPO's 2023-base projection, not a measurement.</p>`;
  return out;
}
// interactive population explorer — horizon buttons re-render the projection chart; hover any point
function wirePopExplorer(DEMO){
  const box=document.getElementById('pop-explorer'); if(!box||!DEMO||!DEMO.population||!DEMO.population.series) return;
  const SR=DEMO.population.series; let peak=SR[0]; for(const p of SR) if(p.value>peak.value) peak=p;
  const tip=document.getElementById('charttip');
  const wireHover=()=>{ const svg=box.querySelector('svg'); if(!svg||!tip) return;
    svg.addEventListener('pointermove',(e)=>{ const c=e.target.closest('.pph'); if(!c){tip.style.opacity=0;return;}
      const y=c.getAttribute('data-year'),v=(+c.getAttribute('data-value')).toFixed(1),pr=c.getAttribute('data-proj')==='1';   // data-value is already in millions
      tip.innerHTML=`<b>${y}</b><div class="tr"><span class="nm">Population</span><span class="vv">${v}M</span></div><div class="tr"><span class="nm">${pr?'Projected':'Observed'}</span><span class="vv">CONAPO</span></div>`;
      tip.style.opacity=1; tip.style.left=Math.min(e.clientX+14,innerWidth-160)+'px'; tip.style.top=(e.clientY+14)+'px'; });
    svg.addEventListener('pointerleave',()=>{tip.style.opacity=0;}); };
  box.querySelector('.horizon').addEventListener('click',(e)=>{ const b=e.target.closest('button'); if(!b) return;
    box.querySelectorAll('.horizon button').forEach(x=>x.classList.toggle('on',x===b));
    const svg=projectionChart({series:SR.map(p=>({year:p.year,value:p.value/1e6})),seamYear:2020,unit:'M',peak:{year:peak.year,value:peak.value/1e6},xmax:+b.dataset.xmax});
    const old=box.querySelector('svg'); if(old) old.outerHTML=svg; wireHover(); });
  wireHover();
}
// a year past CONAPO's 2023 base is a projected year; 2020–2023 are the reconciled/measured base
function projTierFor(y){ return y>2023?'projection':'measured'; }

/* block 5 — latest society headlines (wages, jobs, poverty, migration) */
function renderWire(){ return renderDevelopments('society'); }   // curated events for this section, not the raw wire

/* boot */
(async()=>{
  await loadSeries(SOCIETY_SERIES);
  // demographics is small static JSON (CONAPO projection + INEGI vital stats), not part of the series feed
  const [DEMO,VIT]=await Promise.all([
    fetch('/data/demographics.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('/data/vitals.json').then(r=>r.ok?r.json():null).catch(()=>null),
  ]);
  // as-of = freshest fetch across the loaded society series
  const times=Object.values(S).map(s=>new Date(s.meta.fetchedAt).getTime()).filter(t=>t);
  if(times.length){
    const newest=new Date(Math.max(...times));
    document.getElementById('asof').textContent=newest.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    document.getElementById('board-asof').textContent='as of '+newest.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  }
  document.getElementById('tablero').innerHTML=povertyTile(POVERTY)+TILES.map(t=>tile(t,{src:true})).join('');
  document.getElementById('demographics').innerHTML=renderDemographics(DEMO,VIT);
  wirePopExplorer(DEMO);
  document.getElementById('background').innerHTML=renderBackground()+storyBlock({asof:'Poverty 2024 · wages May 2026',
    p1:`Poverty fell to <b>29.6%</b> in 2024, the lowest on record, down <b>12.3 points</b> from 41.9% in 2018. The drop moved about <b>13.4M</b> people out of poverty. INEGI published the figure as its first poverty measurement since taking over from CONEVAL. The minimum wage stands at <b>315 pesos a day</b> in 2026, roughly double its 2018 level. Remittances reached <b>$5.6bn</b> in May 2026.`,
    p2:`Poverty fell 12.3 points between 2018 and 2024 while GDP grew slowly. The gains rest on wage policy, which limits how much further living standards can rise without faster growth.`,
    src:'INEGI / CONEVAL, Banco de México (SIE), CONASAMI'});
  document.getElementById('watch-list').innerHTML=renderWatch();
  document.getElementById('wire-list').innerHTML=renderWire();
  wireCharts();
  // tile → scroll to its metric row in Background
  document.getElementById('tablero').addEventListener('click',(e)=>{const t=e.target.closest('[data-go]');if(!t)return;const row=document.querySelector('[data-metric="'+t.getAttribute('data-go')+'"]');if(row)row.scrollIntoView({behavior:'smooth',block:'center'});});
})().catch(e=>{
  const h=document.getElementById('background'); if(h)h.innerHTML='<p style="font-family:var(--mono);font-size:12px;color:var(--red)">Error loading society data: '+e.message+'</p>';
});
</script>
