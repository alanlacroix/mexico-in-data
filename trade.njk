<script type="module">
import { loadSeries, S, EVENTS, pageIntro, tile, mrow, sectionHead, exhibit, dataTable, timeChart, hbarChart, treemapSVG, storyBlock, wireCharts } from '/assets/mb.js?v=15';

/* Trade data: Banxico CE125 series (into S) + three reconciled JSON datasets fetched alongside. */
const CE125=['banxico-exports-total','banxico-imports-total','banxico-trade-balance','banxico-imports-intermediate','banxico-imports-capital','banxico-imports-consumer'];
let PROD=null,PART=null,REG=null,HS4=null,TMROOT=null;
const J=(p)=>fetch(p).then(r=>r.ok?r.json():null).catch(()=>null);
const esc=(s)=>String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));

const has=(id)=>!!(S[id]&&S[id].data&&S[id].data.length);
const bn=(k)=>k/1e6;                                    /* thousand US$ -> billion US$ */
const ttm=(id)=>(has(id)&&S[id].data.length>=12)?S[id].data.slice(-12).reduce((a,p)=>a+p.value,0):null;
const ttmPrior=(id)=>(has(id)&&S[id].data.length>=24)?S[id].data.slice(-24,-12).reduce((a,p)=>a+p.value,0):null;
const yoy=(id)=>{const c=ttm(id),p=ttmPrior(id);return (c&&p)?(c-p)/p*100:null;};
const yr=(iso)=>String(iso).slice(0,4);
const moLbl=(iso)=>{const d=new Date(iso);return isNaN(d)?iso:d.toLocaleDateString('en-US',{month:'short',year:'numeric',timeZone:'UTC'});};

/* annual totals (US$ bn) from a monthly CE125 series — complete calendar years only */
function annual(id){ if(!has(id))return []; const sum={},cnt={};
  for(const p of S[id].data){const y=p.date.slice(0,4);sum[y]=(sum[y]||0)+p.value;cnt[y]=(cnt[y]||0)+1;}
  return Object.keys(sum).filter(y=>cnt[y]>=12).sort().map(y=>({date:y+'-01-01',value:+bn(sum[y]).toFixed(1)})); }
function topN(items,n){ if(items.length<=n)return items.slice(); const h=items.slice(0,n),t=items.slice(n);
  return [...h,{name:'Other',share:+t.reduce((s,i)=>s+(i.share||0),0).toFixed(1),value:t.reduce((s,i)=>s+i.value,0)}]; }

/* computed tile in the standard .tile markup */
function ctile(o){ return `<div class="tile"><div class="tl">${o.l}</div><div class="tv">${o.v}${o.s?' <small>'+o.s+'</small>':''}</div>${o.dl||''}<div class="tb">${o.tb||''}</div><span class="stamp">${o.stamp||''}</span></div>`; }
function deltaSpan(pct){ if(pct==null)return ''; const cls=pct>=0?'up':'dn'; return `<span class="dl ${cls}">${pct>=0?'+':''}${pct.toFixed(1)}% <small>vs prior 12m</small></span>`; }

function renderTiles(){
  const mo=has('banxico-exports-total')?moLbl(S['banxico-exports-total'].data.at(-1).date):'';
  const x=ttm('banxico-exports-total'),m=ttm('banxico-imports-total');
  let out='';
  if(x!=null) out+=ctile({l:'Exports · last 12 months',v:'$'+Math.round(bn(x))+'bn',dl:deltaSpan(yoy('banxico-exports-total')),tb:'Goods only, services not included',stamp:'BANXICO · 12m to '+mo});
  if(m!=null) out+=ctile({l:'Imports · last 12 months',v:'$'+Math.round(bn(m))+'bn',dl:deltaSpan(yoy('banxico-imports-total')),tb:'Goods only, services not included',stamp:'BANXICO · 12m to '+mo});
  if(x!=null&&m!=null){const b=bn(x-m);out+=ctile({l:'Trade balance · last 12 months',v:(b>=0?'+$':'−$')+Math.abs(Math.round(b))+'bn',tb:'Exports minus imports',stamp:'BANXICO · 12m to '+mo});}
  if(PART&&PART.exports) out+=ctile({l:'Exports to the U.S.',v:'~'+Math.round(PART.exports.items[0].share),s:'% of total',tb:'Four of five export dollars go to the United States',stamp:'COMTRADE · '+PART.year});
  if(REG&&REG.metrics&&REG.metrics.exportsPctGdp){const mx=REG.metrics.exportsPctGdp.values.find(v=>v.iso==='MEX');if(mx)out+=ctile({l:'Exports · share of GDP',v:mx.value.toFixed(0),s:'%',tb:'Higher than Brazil, Colombia, and Chile',stamp:'WORLD BANK · '+mx.year});}
  if(PROD&&PROD.items){const t=PROD.items[0];out+=ctile({l:'Top export',v:Math.round(t.share),s:'% · '+t.name.toLowerCase(),tb:'Vehicles and parts are the largest export',stamp:'COMTRADE · '+PROD.year});}
  return out;
}

const SIE='https://www.banxico.org.mx/SieInternet/';
const bx=(ids)=>`Source: <a href="${SIE}" target="_blank" rel="noopener">Banco de México (SIE)</a> · ${ids}`;
const comtrade=(rc)=>`Source: <a href="https://comtradeapi.un.org" target="_blank" rel="noopener">UN COMTRADE</a>, reconciled to Banxico CE125${rc?` (gap ${rc.deltaPct}%)`:''}.`;

/* Our own product-space treemap. The 97 HS2 chapters, grouped into 9 readable sectors and colored
   like a product map (agri warm, chemicals violet, machinery blue, transport indigo, instruments cyan).
   This is the Harvard Atlas view, built on our own COMTRADE-reconciled data instead of linking out. */
const TSECT=[
  {max:24,key:'Food & agriculture',c:'#d9b13a'},
  {max:27,key:'Minerals & fuels',c:'#b07a52'},
  {max:40,key:'Chemicals & plastics',c:'#b184cf'},
  {max:67,key:'Textiles & leather',c:'#5fb885'},
  {max:83,key:'Metals, stone & gems',c:'#e0776d'},
  {max:85,key:'Machinery & electronics',c:'#4f9ed0'},
  {max:89,key:'Transport equipment',c:'#8a8ae0'},
  {max:92,key:'Precision instruments',c:'#63c6cf'},
  {max:99,key:'Other manufactures',c:'#4a6f92'},
];
const tsectOf=(code)=>{const c=parseInt(code,10);return TSECT.find(s=>c<=s.max)||TSECT[TSECT.length-1];};
function basketItems(){
  // Fable's floor: anything under 0.5% of exports folds into one "Everything else" box (kills unreadable
  // slivers), whose tooltip names its top 5 so it's legible before anyone clicks.
  const items=[]; const small=[];
  for(const p of PROD.items){
    if(p.share>=0.5){ const s=tsectOf(p.code); items.push({name:p.name,value:p.value,share:p.share,color:s.c,key:s.key,code:String(p.code).padStart(2,'0')}); }
    else small.push(p);
  }
  if(small.length){
    const ov=small.reduce((a,p)=>a+p.value,0), os=small.reduce((a,p)=>a+p.share,0);
    const top=small.slice().sort((a,b)=>b.value-a.value);
    const more=top.slice(0,5).map(p=>p.name).join(' · ')+(top.length>5?`, and ${top.length-5} more`:'');
    // Not drillable: opening a 60-chapter tail into a grid of unlabeled slivers is unreadable (Alan).
    // The box stays, and its tooltip names the top 5, but there is no zoom into microscopic chapters.
    items.push({name:`Everything else (${small.length} groups)`,value:ov,share:os,color:'#9aa6b0',key:'Everything else',more});
  }
  return items;
}
// Mix a hex color toward white (f>0) or black (f<0) — gives a chapter's products a readable monochrome
// ramp (Atlas-style shades of the sector color) instead of one flat block of the identical color.
function mix(hex,f){
  hex=String(hex||'#888').replace('#',''); if(hex.length===3)hex=hex.split('').map(c=>c+c).join('');
  const t=f>=0?255:0, a=Math.min(1,Math.abs(f));
  const ch=(i)=>{const v=parseInt(hex.slice(i,i+2),16);return Math.round(v+(t-v)*a).toString(16).padStart(2,'0');};
  return '#'+ch(0)+ch(2)+ch(4);
}
// HS4 children of a chapter, as treemap items (Fable: one level deep). Named products get a shade of the
// parent sector color so they read apart; the COMTRADE residual and any sub-0.15% lines fold into ONE
// honest gray "Rest of this group" box, never a big sector-colored block that reads like a real product.
function hs4Items(chap,parentColor){
  const kids=(HS4&&HS4.byChapter&&HS4.byChapter[chap])||[];
  const named=[]; let rv=0,rShare=0,rsp=0;
  for(const k of kids){
    const isRest=/xx$/.test(k.code||'')||/^other in chapter$/i.test(k.name||'');
    if(!isRest && k.shareTotal>=0.15) named.push(k);
    else { rv+=k.value; rShare+=k.shareTotal; rsp+=k.shareParent; }
  }
  named.sort((a,b)=>b.value-a.value);
  const N=named.length;
  const items=named.map((k,i)=>({name:k.name,value:k.value,share:k.shareTotal,shareParent:k.shareParent,full:k.full,
    color:mix(parentColor, N>1?(i/(N-1))*0.52-0.06:0.12), key:''}));
  if(rv>0) items.push({name:'Rest of this group',value:rv,share:rShare,shareParent:rsp,
    color:'#c2c8ce',key:'',full:'Smaller product lines in this group, combined'});
  return items;
}
// the sub-0.5% chapters, as their own treemap (what "Everything else" opens into), colored by sector
function elseChapters(smallList){
  return (smallList||[]).map(p=>{ const s=tsectOf(p.code); return {name:p.name,value:p.value,share:p.share,color:s.c,key:s.key}; });
}
function basketLegend(){
  const present=new Set(PROD.items.filter(p=>p.share>=0.5).map(p=>tsectOf(p.code).key));
  return `<div class="tmleg">`+TSECT.filter(s=>present.has(s.key)).map(s=>`<span class="tmlg"><i style="background:${s.c}"></i>${s.key}</span>`).join('')+`</div>`;
}

function renderBackground(){
  let ex='';
  const xa=annual('banxico-exports-total'),ma=annual('banxico-imports-total');
  if(xa.length>=3){
    const tbl=dataTable(['Year','Exports $bn','Imports $bn'],xa.slice(-8).map((p)=>{const im=ma.find(q=>q.date===p.date);return [yr(p.date),p.value.toFixed(0),im?im.value.toFixed(0):'—'];}));
    ex+=exhibit('1','Exports ran $617.7bn in 2024, about even with imports','Goods exports vs imports, US$ bn per year',
      timeChart([{name:'Exports',color:'green',pts:xa},{name:'Imports',color:'var(--ink)',pts:ma}],{unit:'$',xfmt:yr}),
      bx('CE125 (SE36593, SE36595). The 2024 sum, $617.7bn, matches the official INEGI total.'),tbl,true);
  }
  if(PROD&&PROD.items){
    ex+=exhibit('2','Vehicles, electronics and machinery are roughly 60% of exports','Every product group, sized by value. Click a block to open its products. Share of goods exports, '+PROD.year,
      `<div id="tm-crumb"></div><div id="tm-basket">`+treemapSVG(basketItems(),{W:720,H:460})+`</div>`+basketLegend(),
      comtrade(PROD.reconciliation),dataTable(['Product','Share'],topN(PROD.items,12).map(i=>[i.name,i.share+'%'])),true);
  }
  if(PART&&PART.exports){const it=topN(PART.exports.items.map(i=>({name:i.name,share:i.share,value:i.value})),8);
    ex+=exhibit('3','Four-fifths of exports go to the United States','Export destinations, share of goods exports, '+PART.year,
      hbarChart(it.map(i=>({label:i.name.length>24?i.name.slice(0,23)+'…':i.name,value:i.share,hi:i===it[0]})),{vfmt:(v)=>v+'%'}),
      comtrade(PART.exports.reconciliation),dataTable(['Destination','Share'],it.map(i=>[i.name,i.share+'%'])),true);
  }
  const ii=annual('banxico-imports-intermediate'),ic=annual('banxico-imports-capital'),io=annual('banxico-imports-consumer');
  if(ii.length>=2){
    ex+=exhibit('4','Imports are inputs: Mexico buys parts to export goods','Imports by economic use, US$ bn per year',
      timeChart([{name:'Intermediate',color:'green',pts:ii},{name:'Capital',color:'var(--ink)',pts:ic},{name:'Consumer',color:'var(--ink-2)',pts:io}],{unit:'$',xfmt:yr}),
      bx('CE125 (SE36597–99). Intermediate goods, meaning parts and materials, are most of the bill.'),'',true);
  }
  if(REG&&REG.metrics&&REG.metrics.exportsPctGdp&&REG.metrics.exportsPctGdp.series){
    const s=REG.metrics.exportsPctGdp.series, pick=(iso,c)=>{const r=s.find(x=>x.iso===iso);return r?{name:iso,color:c,pts:r.pts}:null;};
    const series=[pick('MEX','green'),pick('BRA','var(--ink-2)'),pick('COL','var(--ink-2)'),pick('CHL','var(--ink-2)'),pick('USA','var(--ink)')].filter(Boolean);
    ex+=exhibit('5','Mexico exports a larger share of GDP than Brazil, Colombia or Chile, and the gap has widened','Exports as a share of GDP, %, Mexico vs regional peers',
      timeChart(series,{unit:'%',xfmt:yr}),
      `Source: <a href="https://data.worldbank.org" target="_blank" rel="noopener">World Bank</a> · World Development Indicators (NE.EXP.GNFS.ZS).`,'',true);
  }
  let ht='';
  if(REG&&REG.metrics&&REG.metrics.highTechPct){const v=REG.metrics.highTechPct.values,mx=v.find(x=>x.iso==='MEX'),us=v.find(x=>x.iso==='USA');
    ht=`<div class="mrow"><div class="mr-top"><span class="mr-label">High-tech goods · share of manufactured exports</span><span class="stamp">WORLD BANK · ${mx?mx.year:''}</span></div>`+
      `<div class="mr-main"><span class="mr-val">${mx?mx.value.toFixed(0):'—'} <small>%</small></span></div>`+
      `<div class="mr-verdict">Mexico ranks second to the United States, where the share is ${us?us.value.toFixed(0):'—'}%, and above its regional peers. Mexico exports advanced goods, not raw materials.</div></div>`;
  }
  return sectionHead('Background',"Exports, imports, and trading partners","Mexico buys parts and materials abroad, assembles them, and sells the finished goods, mostly to the United States. Vehicles, electronics and machinery make up roughly 60% of exports.")+ex+ht;
}

(async()=>{
  await loadSeries(CE125);
  [PROD,PART,REG]=await Promise.all([J('./data/trade/exports-by-product.json'),J('./data/trade/exports-by-partner.json'),J('./data/trade/regional.json')]);
  const times=CE125.filter(has).map(id=>{const v=S[id].meta.vintage;const d=new Date(String(v).length===7?v+'-01':v);return isNaN(d)?0:+d;}).filter(Boolean);
  if(times.length){const nw=new Date(Math.max(...times));
    document.getElementById('asof').textContent=nw.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    document.getElementById('board-asof').textContent='as of '+nw.toLocaleDateString('en-US',{month:'short',day:'numeric'});}
  document.getElementById('tablero').innerHTML=renderTiles();

  /* WHAT / NOW / NEXT — orientation block, all computed live from this page's own data + shared calendar */
  const piX=ttm('banxico-exports-total'), piYoy=yoy('banxico-exports-total');
  const piUS=(PART&&PART.exports&&PART.exports.items&&PART.exports.items.length)?PART.exports.items[0].share:null;
  let piNow=null;
  if(piX!=null){
    let s=`Mexico exported <b>$${Math.round(bn(piX))}bn</b> of goods over the past 12 months`;
    if(piYoy!=null) s+=`, ${piYoy>=0?'up':'down'} ${Math.abs(piYoy).toFixed(1)}% from the prior 12 months`;
    if(piUS!=null)  s+=`, and about ${Math.round(piUS)}% of it went to the United States`;
    piNow=s+'.';
  }
  /* NEXT: next upcoming trade-relevant scheduled event, from the shared EVENTS calendar (same pattern as /usmexico) */
  const RE_TRADE=/usmca|t-?mec|arancel|tariff|comercio|exportaci|importaci|\btrade\b|\bexport|\bimport/i;
  let piNext=null;
  { const evs=(EVENTS&&EVENTS.events)||[];
    const rel=evs.filter(e=>e.kind==='trade'||RE_TRADE.test((e.label||'')+' '+(e.mechanism||'')))
      .filter(e=>new Date(e.date)>=Date.now()-864e5)
      .sort((a,b)=>String(a.date).localeCompare(String(b.date)));
    if(rel.length){ const e=rel[0], d=new Date(e.date+'T00:00:00Z');
      const lbl=String(e.label||'').split(/[—(]/)[0].trim();
      const ds=d.toLocaleDateString('en-US',{month:'long',day:'numeric',timeZone:'UTC'})+(d.getUTCFullYear()!==new Date().getUTCFullYear()?', '+d.getUTCFullYear():'');
      if(lbl) piNext=`${lbl} on ${ds}.`;
    }
  }
  document.getElementById('pageintro').innerHTML=pageIntro({
    what:'What Mexico sells and buys, and how much of it depends on the United States.',
    now:piNow,
    next:piNext
  });

  document.getElementById('story').innerHTML=storyBlock({asof:'2024',
    p1:`Mexico's goods exports and imports run close to balanced, and about <b>four-fifths of exports go to the United States</b>. Vehicles, electronics and machinery are roughly <b>60%</b> of what the country sells abroad. Mexico imports parts and materials, adds work, and ships finished manufactured goods.`,
    p2:`Mexico's export mix has shifted over two decades toward machines and instruments and away from raw materials. Its high-tech share of manufactured exports trails only the United States among the economies compared here.`,
    src:'Banco de México (CE125), UN COMTRADE, World Bank WDI'});
  document.getElementById('background').innerHTML=renderBackground();
  wireCharts();
  TMROOT=basketItems(); wireTM();
  // mobile: a dense treemap needs the area and hover a phone lacks (Fable), so default the export
  // exhibit to its sortable table under 640px; the CHART toggle stays available for a tap.
  if(innerWidth<640){ const wrap=document.getElementById('tm-basket')&&document.getElementById('tm-basket').closest('.exwrap'); const tb=wrap&&wrap.querySelector('.ex-toggle button[data-t="table"]'); if(tb) tb.click(); }
})().catch(e=>{ const b=document.getElementById('background'); if(b) b.innerHTML='<p style="font-family:var(--mono);font-size:var(--fs-label);color:var(--red)">Error loading trade data: '+e.message+'</p>'; });

// hover any treemap cell → the shared chart tooltip with product, share, value, sector
// Drill-down (Fable: one level, HS2 -> HS4). Click a chapter to zoom into its products; a breadcrumb
// zooms back out. HS4 data is fetched once, on the first click. "Everything else" opens its own chapters.
function tmCrumb(parentName){
  return parentName?`<a href="#" class="tmcrumb-root">All exports</a> <span class="tmcrumb-sep">&rsaquo;</span> <span class="tmcrumb-cur">${esc(parentName)}</span>`:'<span class="tmcrumb-cur">All exports</span>';
}
function drawTreemap(items,parentName){
  const host=document.getElementById('tm-basket'); if(!host) return;
  host.innerHTML=treemapSVG(items,{W:720,H:460});
  const cr=document.getElementById('tm-crumb'); if(cr) cr.innerHTML=tmCrumb(parentName);
  wireTM();
}
function wireTM(){
  const tm=document.querySelector('#tm-basket svg.treemap'); const tip=document.getElementById('charttip');
  if(!tm) return;
  if(tip) tm.addEventListener('pointermove',(e)=>{ const g=e.target.closest('.tmc'); if(!g){tip.style.opacity=0;return;}
    const nm=g.getAttribute('data-nm'),sh=+g.getAttribute('data-share'),val=+g.getAttribute('data-val'),sec=g.getAttribute('data-sec'),more=g.getAttribute('data-more'),sp=g.getAttribute('data-sp'),full=g.getAttribute('data-full'),drill=g.getAttribute('data-code')||g.getAttribute('data-else');
    const valTxt=val>=1e9?'$'+(val/1e9).toFixed(1)+'bn':'$'+Math.round(val/1e6)+'m';
    let rows=`<div class="tr"><span class="nm">Share of exports</span><span class="vv">${sh.toFixed(1)}%</span></div><div class="tr"><span class="nm">Value ${PROD.year}</span><span class="vv">${valTxt}</span></div>`;
    if(sp!=null) rows+=`<div class="tr"><span class="nm">Of its group</span><span class="vv">${(+sp).toFixed(0)}%</span></div>`;
    if(more) rows+=`<div class="tr" style="display:block;margin-top:4px;max-width:220px;white-space:normal;line-height:1.4"><span class="nm">${more}</span></div>`;
    else if(full) rows+=`<div class="tr" style="display:block;margin-top:4px;max-width:220px;white-space:normal;line-height:1.35"><span class="nm">${esc(full)}</span></div>`;
    else if(sec) rows+=`<div class="tr"><span class="nm">Sector</span><span class="vv">${sec}</span></div>`;
    if(drill) rows+=`<div class="tr" style="margin-top:5px"><span class="nm" style="color:#7fd6a8">click to open &rarr;</span></div>`;
    tip.innerHTML=`<b>${nm}</b>${rows}`;
    tip.style.opacity=1; tip.style.left=Math.min(e.clientX+14,innerWidth-190)+'px'; tip.style.top=(e.clientY+14)+'px';
  });
  if(tip) tm.addEventListener('pointerleave',()=>{ tip.style.opacity=0; });
  tm.addEventListener('click',async(e)=>{ const g=e.target.closest('.tmc'); if(!g) return;
    const code=g.getAttribute('data-code'), isElse=g.getAttribute('data-else'), pc=g.querySelector('rect')&&g.querySelector('rect').getAttribute('fill');
    if(code){
      if(!HS4) HS4=await J('./data/trade/exports-hs4.json');
      if(HS4&&HS4.byChapter&&HS4.byChapter[code]){ if(tip)tip.style.opacity=0; drawTreemap(hs4Items(code,pc), g.getAttribute('data-nm')); }
    } else if(isElse){
      const els=(TMROOT||basketItems()).find(x=>x.isElse); if(tip)tip.style.opacity=0; drawTreemap(elseChapters(els&&els._small), 'Everything else');
    }
  });
  const rootLink=document.querySelector('#tm-crumb .tmcrumb-root');
  if(rootLink) rootLink.addEventListener('click',(ev)=>{ ev.preventDefault(); drawTreemap(TMROOT||basketItems(), null); });
}
</script>
