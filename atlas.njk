</style>
<div class="wrap">
  <section class="hero">
    <span class="eyebrow">Atlas · 32 states</span>
    <h1>Mexico, state by state</h1>
    <p class="dek">Compare the states by output, output per person, poverty, or informal employment. Pick one for the exact value, its rank, the national comparison, and the original source. Municipal poverty is available one level deeper.</p>

    <div class="controls">
      <div class="searchcol">
        <label class="control-label" for="q">Find a place</label>
        <div class="searchbox">
          <svg class="mag" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
          <input id="q" type="text" inputmode="search" placeholder="State or municipality…" autocomplete="off" role="combobox" aria-autocomplete="list" aria-controls="sugg" aria-expanded="false">
          <div class="sugg" id="sugg" role="listbox" hidden></div>
        </div>
      </div>
      <div class="metriccol">
        <span class="control-label">Color states by</span>
        <div class="metricsel" id="metricsel" role="group" aria-label="Map metric">
          <button type="button" data-m="gdppc" class="on" aria-pressed="true">GDP / person</button>
          <button type="button" data-m="gdp" aria-pressed="false">Total GDP</button>
          <button type="button" data-m="pov" aria-pressed="false">Poverty</button>
          <button type="button" data-m="inf" aria-pressed="false">Informality</button>
        </div>
      </div>
    </div>
    <div class="metricmeta" id="metricmeta"></div>
  </section>

  <div class="crumb" id="crumb"></div>
  <div class="statesum" id="statesum" aria-live="polite"></div>

  <div class="mapgrid">
    <div class="mapcol">
      <div class="mapstage">
        <svg id="map" viewBox="0 0 800 560" role="img" aria-labelledby="map-title map-desc"></svg>
        <div class="zoomctl" id="zoomctl">
          <button class="zbtn zsq" id="zin" type="button" aria-label="Zoom in">+</button>
          <button class="zbtn zsq" id="zout" type="button" aria-label="Zoom out">&minus;</button>
        </div>
      </div>
      <div class="legend" id="legend"></div>
      <div class="sourcestrip" id="source-strip"></div>
    </div>
    <section id="ficha-wrap" aria-live="polite" hidden></section>
  </div>

  <section class="ranksec" aria-labelledby="rank-title">
    <div class="rankhead">
      <div><h2 id="rank-title">All 32 states</h2><div class="ranknote" id="rank-note"></div></div>
      <button class="ranktoggle" id="rank-toggle" type="button">Show all 32</button>
    </div>
    <div class="ranklist" id="rank-list"></div>
  </section>

</div>

<div class="maptip" id="maptip"></div>
<div class="miniback" id="miniback"><span class="mb-n" id="mb-name"></span><button class="mb-a" id="mb-act" type="button">See profile ↑</button></div>

