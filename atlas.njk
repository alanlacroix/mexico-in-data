  .atlaserr{border:1px solid var(--line-2);border-left:3px solid var(--red);padding:14px 16px;margin:12px 0;font-size:var(--fs-small);line-height:1.5;color:var(--ink-2)}.atlaserr button{display:block;min-height:44px;margin-top:10px;padding:0 14px;border:1px solid var(--green-d);border-radius:7px;background:var(--paper);color:var(--green-d);font-family:var(--mono);font-size:var(--fs-label);cursor:pointer}
