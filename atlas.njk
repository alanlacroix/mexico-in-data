  .sourcestrip{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);line-height:1.55;margin-top:10px}.sourcestrip a{color:var(--green-d)}
  .ficha{margin:18px 0 0;border:1px solid var(--line-2);border-radius:9px;overflow:hidden}.fhead{padding:15px 17px 13px;border-bottom:1px solid var(--line);background:var(--paper-2)}.fh-name{font-family:var(--sans);font-size:var(--fs-h3);font-weight:650;color:var(--ink);line-height:1.1;padding-right:68px}.fh-ent{font-size:var(--fs-meta);color:var(--ink-2);margin-top:3px}.fh-pob{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);margin-top:7px}.fh-pob a{color:var(--green-d)}.fh-x{float:right;min-height:44px;border:0;background:transparent;color:var(--green-d);font-family:var(--mono);font-size:var(--fs-label);cursor:pointer;padding:0}.fstand{padding:13px 17px;border-bottom:1px solid var(--line);background:var(--green-bg);font-size:13px;line-height:1.5;color:var(--ink-2)}.fstand-label{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--green-d);margin-bottom:5px}.fstand b{color:var(--ink)}.fmetric{padding:13px 17px;border-bottom:1px solid var(--line)}.fm-l{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--mut)}.fm-v{font-family:var(--sans);font-size:26px;color:var(--ink);font-variant-numeric:tabular-nums;line-height:1.05;margin-top:4px}.fm-v small{font-size:12px;color:var(--mut)}.fm-verdict{font-size:13px;color:var(--ink-2);margin-top:7px;line-height:1.45}.fm-src{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);margin-top:7px;line-height:1.45}.fm-src a{color:var(--green-d)}.fclose{padding:12px 17px;font-size:var(--fs-meta);color:var(--mut);background:var(--paper-2);line-height:1.5}.drillbtn{display:block;width:100%;min-height:46px;margin-top:10px;border:1px solid var(--green);border-radius:7px;background:var(--paper);color:var(--green-d);font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.03em;cursor:pointer}.drillbtn:hover{background:var(--green-bg)}.drillbtn:disabled{cursor:wait;opacity:.65}
  .ranksec{border-top:2px solid var(--green);margin:34px 0 4px;padding-top:18px}.rankhead{display:flex;align-items:flex-end;justify-content:space-between;gap:16px}.rankhead h2{font-family:var(--sans);font-size:var(--fs-h2);line-height:1.1;color:var(--ink)}.ranknote{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);margin-top:5px}.ranktoggle{min-height:44px;border:1px solid var(--line-2);border-radius:7px;background:var(--paper);color:var(--ink-2);font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.03em;padding:8px 12px;cursor:pointer}.ranklist{margin-top:14px;border-top:1px solid var(--line)}.rankrow{display:grid;grid-template-columns:42px minmax(0,1fr) auto;gap:10px;align-items:center;width:100%;min-height:45px;padding:8px 6px;border:0;border-bottom:1px solid var(--line);background:var(--paper);text-align:left;color:var(--ink);cursor:pointer}.rankrow:hover,.rankrow.sel{background:var(--green-bg)}.ranknum{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}.rankname{font-size:14px}.rankval{font-family:var(--mono);font-size:12px;font-variant-numeric:tabular-nums;color:var(--ink-2);text-align:right}.rankbreak{padding:8px 6px;border-bottom:1px solid var(--line);font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);text-transform:uppercase;letter-spacing:.03em}
