---
layout: base.njk
permalink: /model.html
title: "The Model · The Mexico Brief"
description: "Change a few external assumptions and see the direction of pressure on Mexico's peso, inflation, policy rate, and growth. A causal map, not a forecast."
---
{% raw %}
<style>
  body{font-size:var(--fs-small)}
  .hero{padding:24px 0 8px}
  .hero h1{font-family:var(--sans);font-size:var(--fs-display);line-height:1.04;letter-spacing:-.025em;margin:8px 0 0;color:var(--ink)}
  .hero .dek{font-size:17px;color:var(--ink-2);line-height:1.55;margin-top:10px;max-width:70ch}
  .stamp{display:inline-block;font-family:var(--mono);font-size:10px;line-height:1;letter-spacing:.07em;text-transform:uppercase;color:var(--green-d);border:1px solid #bcd8c8;border-radius:4px;padding:4px 6px;vertical-align:.18em}
  .modelnote{font-size:var(--fs-meta);color:var(--ink-2);background:var(--paper-2);border-left:3px solid var(--green);padding:12px 14px;margin:16px 0 0;line-height:1.55;max-width:86ch}
  .modelnote b{color:var(--ink)}

  .refs{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border:1px solid var(--line-2);border-radius:8px;overflow:hidden;margin:20px 0 0}
  .ref{display:block;color:inherit;text-decoration:none;padding:12px 14px;min-height:96px;border-right:1px solid var(--line-2);background:var(--paper)}
  .ref:last-child{border-right:0}
  .ref:hover{background:var(--paper-2)}
  .ref-l{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--mut)}
  .ref-v{font-family:var(--sans);font-size:23px;line-height:1.1;color:var(--ink);font-variant-numeric:tabular-nums;margin-top:6px}
  .ref-m{font-family:var(--mono);font-size:10px;line-height:1.45;color:var(--ink-2);margin-top:6px}

  .preset-label{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--green-d);margin:24px 0 8px}
  .presetbar{display:flex;gap:8px;flex-wrap:wrap}
  .presetbar button{font-family:var(--mono);font-size:11px;padding:0 13px;min-height:44px;border:1.5px solid var(--line-2);background:var(--paper);border-radius:8px;color:var(--ink-2);cursor:pointer}
  .presetbar button:hover,.presetbar button:focus-visible{border-color:var(--green);color:var(--green-d);outline:none}
  .presetbar button.reset{color:var(--mut)}
  .baseline{font-family:var(--mono);font-size:var(--fs-label);line-height:1.5;color:var(--ink-2);margin:9px 0 0}

  .panel{display:grid;grid-template-columns:minmax(0,.92fr) minmax(0,1.08fr);gap:16px;margin-top:16px}
  .card{border:1px solid var(--line-2);border-radius:8px;padding:18px}
  .card h2{font-family:var(--sans);font-size:var(--fs-h3);line-height:1.15;color:var(--ink);margin:0}
  .card .csub{font-family:var(--mono);font-size:10px;color:var(--mut);line-height:1.45;margin:5px 0 14px}
  .lever{padding:14px 0;border-top:1px solid var(--line)}
  .lever:first-child{border-top:0;padding-top:4px}
  .lv-top{display:flex;justify-content:space-between;align-items:baseline;gap:12px}
  .lv-l{font-size:14px;font-weight:600;color:var(--ink)}
  .lv-v{font-family:var(--mono);font-size:13px;color:var(--green-d);font-variant-numeric:tabular-nums;white-space:nowrap}
  .lever input[type=range]{display:block;width:100%;height:40px;margin:5px 0 0;accent-color:var(--green)}
  .lever details{margin-top:3px}
  .lever summary{font-family:var(--mono);font-size:10px;color:var(--mut);cursor:pointer;min-height:28px;display:flex;align-items:center;list-style:none}
  .lever summary::-webkit-details-marker{display:none}
  .lever summary::before{content:'+ ';color:var(--green-d)}
  .lever details[open] summary::before{content:'− '}
  .lv-hint{font-size:12px;color:var(--ink-2);line-height:1.5;padding:2px 0 3px}

  .outputs{display:grid;grid-template-columns:1fr 1fr;gap:0 16px}
  .out{padding:13px 0;border-top:1px solid var(--line);min-height:128px}
  .out:nth-child(-n+2){border-top:0;padding-top:4px}
  .o-top{display:flex;align-items:center;justify-content:space-between;gap:10px}
  .o-l{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:var(--mut)}
  .o-link{font-family:var(--mono);font-size:10px;color:var(--green-d);white-space:nowrap}
  .o-main{display:flex;align-items:center;gap:9px;margin-top:7px}
  .o-arrow{font-family:var(--mono);font-size:18px;color:var(--ink-2);width:20px}
  .o-v{font-family:var(--sans);font-size:25px;line-height:1;color:var(--ink);letter-spacing:-.02em}
  .o-note{font-size:12px;line-height:1.45;color:var(--ink-2);margin-top:8px}
  .o-ref{font-family:var(--mono);font-size:10px;line-height:1.4;color:var(--mut);margin-top:6px}

  .section-head{border-top:2px solid var(--green);padding-top:12px;margin:26px 0 10px}
  .section-head h2{font-family:var(--sans);font-size:var(--fs-h3);line-height:1.15;color:var(--ink);margin:0}
  .section-head p{font-size:var(--fs-meta);color:var(--ink-2);line-height:1.5;margin:6px 0 0;max-width:76ch}

  .flow{display:grid;grid-template-columns:minmax(0,1fr) 36px minmax(0,1fr) 36px minmax(0,1fr);align-items:stretch;border:1px solid var(--line-2);border-radius:8px;padding:16px;background:var(--paper)}
  .flow-col{display:grid;align-content:start;gap:8px}
  .flow-title{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--mut);margin-bottom:2px}
  .flow-node{min-height:44px;display:flex;align-items:center;padding:9px 11px;border:1px solid var(--line-2);border-radius:6px;background:var(--paper-2);font-size:13px;color:var(--ink-2);line-height:1.25}
  .flow-node.active{border-color:var(--green);background:var(--green-bg);color:var(--ink)}
  .flow-arrow{display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:19px;color:var(--mut)}
  .flow-note{font-family:var(--mono);font-size:10px;color:var(--mut);line-height:1.5;margin-top:8px}

  details.box{border:1px solid var(--line-2);border-radius:8px;margin:16px 0 0;background:var(--paper)}
  details.box>summary{cursor:pointer;list-style:none;min-height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;font-family:var(--sans);font-size:15px;font-weight:600;color:var(--ink)}
  details.box>summary::-webkit-details-marker{display:none}
  details.box>summary::after{content:'+';font-family:var(--mono);font-size:18px;color:var(--green-d)}
  details.box[open]>summary::after{content:'−'}
  .box-body{border-top:1px solid var(--line);padding:16px}
  .box-intro{font-size:var(--fs-meta);color:var(--ink-2);line-height:1.5;max-width:78ch;margin:0 0 12px}
  .scen-save{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
  .scen-save input{flex:1 1 260px;min-width:0;font-family:var(--sans);font-size:14px;padding:10px 12px;min-height:44px;border:1.5px solid var(--line-2);border-radius:8px;background:var(--paper);color:var(--ink)}
  .scen-save input:focus{outline:none;border-color:var(--green)}
  .scen-save button{font-family:var(--mono);font-size:10px;min-height:44px;padding:0 16px;border:1.5px solid var(--green-d);background:var(--green-d);color:#fff;border-radius:8px;cursor:pointer}
  .scen-list{display:grid;gap:8px;margin-top:12px}
  .scen-empty{font-family:var(--mono);font-size:10px;color:var(--mut);padding:4px 0}
  .scen-item{display:flex;border:1px solid var(--line-2);border-radius:7px;overflow:hidden}
  .scen-restore{flex:1;min-width:0;text-align:left;background:none;border:0;padding:10px 12px;cursor:pointer}
  .scen-restore:hover{background:var(--paper-2)}
  .scen-name{font-size:14px;font-weight:600;color:var(--ink)}
  .scen-meta{font-family:var(--mono);font-size:10px;color:var(--ink-2);line-height:1.5;margin-top:4px}
  .scen-del{width:44px;border:0;border-left:1px solid var(--line);background:var(--paper);color:var(--mut);font-size:18px;cursor:pointer}
  .scen-del:hover{color:var(--red);background:var(--red-bg)}
  .rules{width:100%;border-collapse:collapse;font-size:12px}
  .rules th,.rules td{text-align:left;vertical-align:top;padding:10px 12px;border-bottom:1px solid var(--line);line-height:1.45}
  .rules th{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:var(--mut)}
  .rules td:first-child{font-weight:600;color:var(--ink)}
  .rules tr:last-child td{border-bottom:0}

  @media(max-width:820px){
    .refs{grid-template-columns:1fr 1fr}.ref:nth-child(2){border-right:0}.ref:nth-child(-n+2){border-bottom:1px solid var(--line-2)}
    .panel{grid-template-columns:1fr}
  }
  @media(max-width:620px){
    .hero{padding-top:18px}.hero .dek{font-size:16px}
    .refs{margin-top:16px}.ref{min-height:94px;padding:11px 12px}.ref-v{font-size:20px}.ref-m{font-size:11px}
    .panel{gap:12px}.card{padding:15px}
    .panel .card:nth-child(2){order:-1}
    .outputs{grid-template-columns:1fr}.out:nth-child(2){border-top:1px solid var(--line);padding-top:13px}.out{min-height:0}
    .flow{grid-template-columns:1fr;padding:13px;gap:6px}
    .flow-col{grid-template-columns:1fr 1fr;gap:6px}
    .flow-title{grid-column:1/-1;margin:2px 0}
    .flow-arrow{min-height:20px}.flow-arrow::before{content:'↓'}.flow-arrow span{display:none}
    .flow-node{min-height:40px;padding:7px 9px;font-size:12px}
    .rules{display:block;overflow-x:auto;white-space:normal}
  }
</style>

<div class="wrap">
  <section class="hero">
    <span class="eyebrow">Scenario tool</span>
    <h1>The Model <span class="stamp">directional</span></h1>
    <p class="dek">Change an assumption about the United States and see where the pressure goes in Mexico: the peso, inflation, Banxico, and growth.</p>
    <div class="modelnote"><b>This is a causal map, not a forecast.</b> It does not make up a target for the peso or GDP. The links are more defensible than a pretend-precise coefficient. When the forces disagree, the answer is “mixed.”</div>
  </section>

  <div class="refs" id="baselines" aria-label="Current reference readings"></div>

  <div class="preset-label">Try an assumption</div>
  <div class="presetbar" id="presetbar" aria-label="Preset assumptions"></div>
  <p class="baseline">Baseline: no additional US tariff; no change to the current Fed rate or US growth path. Every slider is a change from that baseline.</p>

  <div class="panel">
    <section class="card" aria-labelledby="lever-title">
      <h2 id="lever-title">Change the assumptions</h2>
      <div class="csub">Each slider is a change from the current setting, not a prediction.</div>
      <div id="levers"></div>
    </section>
    <section class="card" aria-labelledby="result-title">
      <h2 id="result-title">Direction of pressure <span class="stamp">model</span></h2>
      <div class="csub">No magnitude or timing is implied.</div>
      <div class="outputs" id="outputs" aria-live="polite"></div>
    </section>
  </div>

  <section class="transmission">
    <div class="section-head">
      <h2>How the change travels</h2>
      <p>The useful part of the model is the chain. Start with the assumption, follow the mechanism, then check the live reading above.</p>
    </div>
    <div class="flow" id="flow">
      <div class="flow-col">
        <div class="flow-title">Assumption</div>
        <div class="flow-node" data-driver="tariff">US tariff on Mexican goods</div>
        <div class="flow-node" data-driver="fed">Fed policy rate</div>
        <div class="flow-node" data-driver="usg">US economic growth</div>
      </div>
      <div class="flow-arrow" aria-hidden="true"><span>→</span></div>
      <div class="flow-col">
        <div class="flow-title">Main channels</div>
        <div class="flow-node" data-channel="exports">Demand for Mexican exports</div>
        <div class="flow-node" data-channel="peso">Rate gap and the peso</div>
        <div class="flow-node" data-channel="prices">Imported prices</div>
        <div class="flow-node" data-channel="policy">Banxico's response</div>
      </div>
      <div class="flow-arrow" aria-hidden="true"><span>→</span></div>
      <div class="flow-col">
        <div class="flow-title">Readings to watch</div>
        <div class="flow-node" data-reading="peso">USD/MXN</div>
        <div class="flow-node" data-reading="infl">Headline and core inflation</div>
        <div class="flow-node" data-reading="rate">Banxico policy rate</div>
        <div class="flow-node" data-reading="growth">GDP and IGAE</div>
      </div>
    </div>
    <div class="flow-note">Green marks the path activated by the assumptions above. It does not mean good or bad.</div>
  </section>

  <details class="box">
    <summary>Saved scenarios</summary>
    <div class="box-body">
      <p class="box-intro">Save a set of assumptions and come back to it later. It stays in this browser and is never uploaded.</p>
      <div class="scen-save">
        <input id="scen-name" type="text" maxlength="80" placeholder="Name this scenario" aria-label="Scenario name">
        <button id="scen-save-btn" type="button">Save scenario</button>
      </div>
      <div class="scen-list" id="scen-list"></div>
    </div>
  </details>

  <details class="box">
    <summary>Rules and limits</summary>
    <div class="box-body">
      <p class="box-intro">The model records the sign of each link. If two active assumptions push a reading in opposite directions, it reports “mixed.” It deliberately says nothing about size, timing, probability, or what Banxico will actually do.</p>
      <div class="tblwrap">
        <table class="rules">
          <thead><tr><th>Change</th><th>Direction used here</th><th>Main reason</th></tr></thead>
          <tbody>
            <tr><td>Higher US tariff</td><td>Weaker peso · higher inflation pressure · higher Banxico pressure · slower growth</td><td>Less export demand and a weaker external balance. Mexican inflation is affected through the peso, not because a US tariff is itself a Mexican price.</td></tr>
            <tr><td>Higher US policy rate</td><td>Weaker peso · higher inflation pressure · higher Banxico pressure · slower growth</td><td>A smaller Mexico–US rate advantage puts pressure on the peso and limits room for Banxico to ease.</td></tr>
            <tr><td>Faster US growth</td><td>Stronger peso · lower inflation pressure · ambiguous Banxico pressure · faster growth</td><td>The United States buys most Mexican exports, so stronger US demand supports Mexican activity. For Banxico, stronger demand and a firmer peso pull in opposite directions.</td></tr>
          </tbody>
        </table>
      </div>
      <p class="box-intro" style="margin-top:12px">The current readings come from the same Banxico and INEGI series used elsewhere on the site. See the <a href="./sources.html">Sources</a> page and each linked chart to inspect them.</p>
    </div>
  </details>
</div>

<script>
const $=(s)=>document.querySelector(s);
const esc=(s)=>String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));

const BASE={tariff:0,fed:0,usg:0};
let ST={...BASE};
const LEVERS=[
  {k:'tariff',l:'Additional US tariff',min:0,max:25,step:1,unit:' percentage points',short:'pp',
   why:'This tests a new tariff on top of the current trade regime. Most qualifying trade still moves under USMCA. A higher tariff would first hit export demand and the external balance.'},
  {k:'fed',l:'Change in the Fed policy rate',min:-3,max:3,step:.25,unit:' percentage points',short:'pp',
   why:'This changes the US rate relative to Mexico. Higher US rates narrow Mexico\'s rate advantage; lower US rates widen it and give Banxico more room.'},
  {k:'usg',l:'Change in US real growth',min:-3,max:2,step:.25,unit:' percentage points',short:'pp',
   why:'The United States buys most Mexican exports. Faster US growth usually raises demand for Mexican goods; a US slowdown works in the other direction.'}
];
const PRESETS=[
  {name:'Additional 20% tariff',set:{tariff:20,fed:0,usg:0}},
  {name:'Fed cuts 2pp',set:{tariff:0,fed:-2,usg:0}},
  {name:'US growth falls 2pp',set:{tariff:0,fed:0,usg:-2}},
  {name:'US growth rises 1pp',set:{tariff:0,fed:0,usg:1}},
  {name:'Reset',set:{...BASE},reset:true}
];

const REFS=[
  {k:'peso',label:'Peso',series:'banxico-usdmxn-fix',unit:'MXN/USD',dp:2,period:'day',chart:'banxico-usdmxn-fix',source:'Banxico'},
  {k:'infl',label:'Inflation',series:'banxico-inflacion',unit:'% annual',dp:2,period:'month',chart:'banxico-inflacion',source:'INEGI / Banxico'},
  {k:'rate',label:'Banxico rate',series:'banxico-tasa-objetivo',unit:'%',dp:2,period:'day',chart:'banxico-tasa-objetivo',source:'Banxico'},
  {k:'growth',label:'GDP growth',series:'banxico-pib-crecimiento',unit:'% annual',dp:2,period:'quarter',chart:'banxico-pib-crecimiento',source:'INEGI / Banxico'}
];
const REFSTATE=Object.fromEntries(REFS.map(r=>[r.k,{loading:true}]));

// +1 means upward pressure on the reading. For the peso that means a higher USD/MXN, or a weaker peso.
const RULES={
  peso:{tariff:1,fed:1,usg:-1},
  infl:{tariff:1,fed:1,usg:-1},
  rate:{tariff:1,fed:1,usg:null},
  growth:{tariff:-1,fed:-1,usg:1}
};
const OUTS=[
  {k:'peso',label:'Peso',up:'Weaker',down:'Stronger',flat:'No new pressure',link:'banxico-usdmxn-fix'},
  {k:'infl',label:'Inflation',up:'Higher',down:'Lower',flat:'No new pressure',link:'banxico-inflacion'},
  {k:'rate',label:'Banxico rate',up:'Higher',down:'Lower',flat:'No new pressure',link:'banxico-tasa-objetivo'},
  {k:'growth',label:'Growth',up:'Faster',down:'Slower',flat:'No new pressure',link:'banxico-pib-crecimiento'}
];

function fmtDate(value){
  const d=new Date(String(value).length===10?value+'T12:00:00Z':value);
  if(Number.isNaN(d.getTime()))return String(value||'');
  return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric',timeZone:'UTC'});
}
function periodLabel(def,value){
  const d=new Date(String(value).length===10?value+'T12:00:00Z':value);
  if(Number.isNaN(d.getTime()))return String(value||'');
  if(def.period==='month')return d.toLocaleDateString('en-US',{month:'short',year:'numeric',timeZone:'UTC'});
  if(def.period==='quarter')return `Q${Math.floor(d.getUTCMonth()/3)+1} ${d.getUTCFullYear()}`;
  return fmtDate(value);
}
function signed(value){
  if(value===0)return '0pp';
  const clean=Number.isInteger(value)?String(value):String(value).replace(/0+$/,'').replace(/\.$/,'');
  return `${value>0?'+':''}${clean}pp`;
}
function driverName(k,v){
  if(k==='tariff')return 'the additional US tariff';
  if(k==='fed')return v>0?'higher US rates':'lower US rates';
  return v>0?'faster US growth':'slower US growth';
}
function pressureFor(key){
  const parts=[],uncertain=[];
  for(const [lever,rule] of Object.entries(RULES[key])){
    const value=ST[lever];
    if(!value)continue;
    if(rule==null){uncertain.push({lever,name:driverName(lever,value)});continue;}
    parts.push({lever,name:driverName(lever,value),sign:Math.sign(value)*rule});
  }
  const signs=new Set(parts.map(p=>p.sign));
  const state=signs.size===0?(uncertain.length?'unclear':'flat'):(signs.size>1||uncertain.length?'mixed':([...signs][0]>0?'up':'down'));
  return {state,parts,uncertain};
}
function pressureLabel(def,state){
  if(state==='unclear')return 'Unclear';
  if(state==='mixed')return 'Mixed';
  return state==='up'?def.up:state==='down'?def.down:def.flat;
}
function pressureNote(result){
  if(!result.parts.length&&!result.uncertain.length)return 'Move a lever to activate the chain.';
  if(result.state==='unclear')return 'US growth lifts demand but can also strengthen the peso. Those channels pull Banxico in different directions.';
  const names=result.parts.concat(result.uncertain).map(p=>p.name);
  const joined=names.length===1?names[0]:names.length===2?`${names[0]} and ${names[1]}`:`${names.slice(0,-1).join(', ')}, and ${names.at(-1)}`;
  return result.state==='mixed'?`The active forces disagree: ${joined}.`:`Pressure comes from ${joined}.`;
}
function refLine(key){
  const state=REFSTATE[key];
  if(state.loading)return 'Current reference loading…';
  if(state.error)return 'Current reference unavailable';
  const def=REFS.find(r=>r.k===key);
  return `Current: ${state.value.toFixed(def.dp)} ${def.unit} · ${periodLabel(def,state.date)}`;
}
function renderRefs(){
  $('#baselines').innerHTML=REFS.map(def=>{
    const state=REFSTATE[def.k];
    const value=state.loading?'…':state.error?'Unavailable':`${state.value.toFixed(def.dp)} ${def.unit}`;
    const meta=state.loading?'Loading observation date':state.error?'Could not load this series':`${periodLabel(def,state.date)} · ${esc(state.source||def.source)}`;
    return `<a class="ref" href="./chart?v=${def.chart}&r=1Y"><div class="ref-l">${def.label}</div><div class="ref-v">${value}</div><div class="ref-m">${meta} →</div></a>`;
  }).join('');
}
async function loadRefs(){
  await Promise.all(REFS.map(async def=>{
    try{
      const response=await fetch(`./data/series/${def.series}.json`);
      if(!response.ok)throw new Error(String(response.status));
      const series=await response.json();
      const point=Array.isArray(series.data)?series.data.at(-1):null;
      if(!point||!Number.isFinite(Number(point.value)))throw new Error('no observation');
      REFSTATE[def.k]={value:Number(point.value),date:point.date,source:series.meta?.source||def.source};
    }catch(error){REFSTATE[def.k]={error:true};window.reportMexicoDataError?.(`./data/series/${def.series}.json`);}
  }));
  renderRefs();renderOutputs();
}

function renderPresets(){
  $('#presetbar').innerHTML=PRESETS.map((p,i)=>`<button type="button" class="${p.reset?'reset':''}" data-i="${i}">${p.reset?'↺ ':''}${p.name}</button>`).join('');
  $('#presetbar').addEventListener('click',event=>{
    const button=event.target.closest('button[data-i]');if(!button)return;
    ST={...BASE,...PRESETS[Number(button.dataset.i)].set};
    LEVERS.forEach(l=>{const input=$(`#lv-${l.k}`);if(input)input.value=ST[l.k];});
    update();
  });
}
function renderLevers(){
  $('#levers').innerHTML=LEVERS.map(l=>`<div class="lever">
    <div class="lv-top"><label class="lv-l" for="lv-${l.k}">${l.l}</label><output class="lv-v" id="lvv-${l.k}"></output></div>
    <input type="range" id="lv-${l.k}" min="${l.min}" max="${l.max}" step="${l.step}" value="${ST[l.k]}">
    <details><summary>Why this lever</summary><div class="lv-hint">${l.why}</div></details>
  </div>`).join('');
  LEVERS.forEach(l=>$('#lv-'+l.k).addEventListener('input',event=>{ST[l.k]=Number(event.target.value);update();}));
}
function renderOutputs(){
  const host=$('#outputs');if(!host)return;
  host.innerHTML=OUTS.map(def=>{
    const result=pressureFor(def.k);
    const arrow=result.state==='up'?'↗':result.state==='down'?'↘':result.state==='mixed'?'↔':result.state==='unclear'?'?':'—';
    return `<div class="out"><div class="o-top"><span class="o-l">${def.label}</span><a class="o-link" href="./chart?v=${def.link}&r=1Y">chart →</a></div>
      <div class="o-main"><span class="o-arrow" aria-hidden="true">${arrow}</span><span class="o-v">${pressureLabel(def,result.state)}</span></div>
      <div class="o-note">${pressureNote(result)}</div><div class="o-ref">${refLine(def.k)}</div></div>`;
  }).join('');
}
function renderFlow(){
  const active=new Set(Object.keys(ST).filter(k=>ST[k]!==0));
  document.querySelectorAll('[data-driver]').forEach(node=>node.classList.toggle('active',active.has(node.dataset.driver)));
  const channelMap={tariff:['exports','peso','prices','policy'],fed:['peso','prices','policy'],usg:['exports','peso','prices','policy']};
  const channels=new Set([...active].flatMap(k=>channelMap[k]||[]));
  document.querySelectorAll('[data-channel]').forEach(node=>node.classList.toggle('active',channels.has(node.dataset.channel)));
  document.querySelectorAll('[data-reading]').forEach(node=>node.classList.toggle('active',active.size>0));
}
function update(){
  LEVERS.forEach(l=>{const out=$('#lvv-'+l.k);if(out)out.textContent=signed(ST[l.k]);});
  renderOutputs();renderFlow();
}

const LS_KEY='mb_directional_scenarios';
function loadScenarios(){try{const value=JSON.parse(localStorage.getItem(LS_KEY)||'[]');return Array.isArray(value)?value.filter(s=>s&&s.levers):[];}catch{return [];}}
function saveScenarios(rows){try{localStorage.setItem(LS_KEY,JSON.stringify(rows));return true;}catch{return false;}}
function scenarioSummary(levers){
  return LEVERS.filter(l=>levers[l.k]).map(l=>`${l.l}: ${signed(levers[l.k])}`).join(' · ')||'No changes';
}
function renderScenarios(){
  const rows=loadScenarios();
  $('#scen-list').innerHTML=rows.length?rows.map(s=>`<div class="scen-item"><button type="button" class="scen-restore" data-id="${esc(s.id)}"><div class="scen-name">${esc(s.name)}</div><div class="scen-meta">${esc(scenarioSummary(s.levers))}</div></button><button type="button" class="scen-del" data-id="${esc(s.id)}" aria-label="Delete ${esc(s.name)}">×</button></div>`).join(''):'<div class="scen-empty">No saved scenarios.</div>';
}
function addScenario(){
  const input=$('#scen-name');const rows=loadScenarios();const name=input.value.trim()||`Scenario ${rows.length+1}`;
  rows.unshift({id:'s_'+Date.now().toString(36),name,levers:{...ST},savedAt:new Date().toISOString()});
  if(saveScenarios(rows)){input.value='';renderScenarios();}
}
function wireScenarios(){
  $('#scen-save-btn').addEventListener('click',addScenario);
  $('#scen-name').addEventListener('keydown',event=>{if(event.key==='Enter'){event.preventDefault();addScenario();}});
  $('#scen-list').addEventListener('click',event=>{
    const del=event.target.closest('.scen-del');
    if(del){saveScenarios(loadScenarios().filter(s=>s.id!==del.dataset.id));renderScenarios();return;}
    const restore=event.target.closest('.scen-restore');if(!restore)return;
    const found=loadScenarios().find(s=>s.id===restore.dataset.id);if(!found)return;
    ST={...BASE,...found.levers};LEVERS.forEach(l=>{$('#lv-'+l.k).value=ST[l.k];});update();
  });
}

renderRefs();renderPresets();renderLevers();renderScenarios();wireScenarios();update();loadRefs();
</script>
{% endraw %}
