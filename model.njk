---
layout: base.njk
permalink: /model.html
title: "The Model — The Mexico Brief"
description: "A model of Mexico's economy you can run: set US tariffs, the Fed, oil, and US demand and watch the causal chain move the peso, inflation, Banxico's rate, and growth. It shows the direction and rough size of each move, not a forecast."
---
{% raw %}
<style>
  :root{--ink-3:#555}
  body{font-size:16px}
  .wrap{max-width:820px;margin:0 auto;padding:0 clamp(16px,5vw,32px)}
  .hero{padding:22px 0 6px}
  .hero h1{font-family:var(--serif);font-size:clamp(26px,6vw,38px);line-height:1.04;letter-spacing:-.02em;margin:8px 0 0;color:var(--ink)}
  .hero .dek{font-size:15px;color:var(--ink-2);margin-top:10px;max-width:66ch}
  .modelnote{font-family:var(--mono);font-size:11px;color:var(--ink-2);background:var(--paper-2);border:1px dashed var(--line-2);border-radius:9px;padding:11px 14px;margin:14px 0 4px;line-height:1.55}
  .modelnote b{color:var(--ink)}
  .mst{font-family:var(--mono);font-size:9px;letter-spacing:.06em;text-transform:uppercase;color:var(--mut);border:1px solid var(--line-2);border-radius:3px;padding:1px 5px;display:inline-block}

  .presetbar{display:flex;gap:8px;flex-wrap:wrap;margin:18px 0 4px}
  .presetbar button{font-family:var(--mono);font-size:11px;padding:8px 13px;border:1.5px solid var(--line-2);background:var(--paper);border-radius:9px;color:var(--ink-2);cursor:pointer}
  .presetbar button:hover{border-color:var(--green);color:var(--green-d)}
  .presetbar button.reset{color:var(--mut)}

  .panel{display:grid;gap:16px;margin-top:16px;grid-template-columns:1fr}
  @media(min-width:720px){.panel{grid-template-columns:1fr 1fr}}
  .card{border:1px solid var(--line-2);border-radius:12px;padding:16px 18px}
  .card h3{font-family:var(--serif);font-size:16px;color:var(--ink);margin-bottom:4px}
  .card .csub{font-family:var(--mono);font-size:10px;color:var(--mut);margin-bottom:12px}

  .lever{margin:14px 0}
  .lever .lv-top{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .lever .lv-l{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--ink-2)}
  .lever .lv-v{font-family:var(--serif);font-size:17px;color:var(--green-d);font-variant-numeric:tabular-nums}
  .lever input[type=range]{width:100%;margin-top:8px;accent-color:var(--green)}
  .lever .lv-hint{font-size:12px;color:var(--ink-2);margin-top:6px;line-height:1.45}
  .lever .lv-hint b{color:var(--ink);font-weight:600}
  .lever .lv-now{font-family:var(--mono);font-size:9.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--green-d);background:var(--green-bg);border-radius:3px;padding:1px 6px;margin-left:6px}

  .out{padding:12px 0;border-bottom:1px solid var(--line)}
  .out:last-child{border-bottom:none}
  .out .o-top{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .out .o-l{font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--mut)}
  .out .o-main{display:flex;align-items:baseline;gap:10px;margin-top:4px}
  .out .o-base{font-family:var(--mono);font-size:12px;color:var(--mut)}
  .out .o-arw{font-family:var(--mono);font-size:12px;color:var(--ink-3)}
  .out .o-v{font-family:var(--serif);font-size:24px;color:var(--ink);font-variant-numeric:tabular-nums;line-height:1}
  .out .o-d{font-family:var(--mono);font-size:11px;margin-left:auto}
  .out .o-d.up{color:var(--green-d)}.out .o-d.dn{color:var(--red)}.out .o-d.fl{color:var(--mut)}
  .out .o-note{font-size:12px;color:var(--ink-2);margin-top:5px;line-height:1.4}

  .diagram{margin:20px 0 4px}
  .diagram svg{width:100%;height:auto;border:1px solid var(--line);border-radius:10px;background:var(--paper)}
  .node rect{fill:var(--paper-2);stroke:var(--line-2);stroke-width:1}
  .node.hot rect{fill:var(--green-bg);stroke:var(--green)}
  .node text{font-family:var(--mono);font-size:11px;fill:var(--ink)}
  .edge{stroke:var(--line-2);stroke-width:1.5;fill:none;marker-end:url(#arw)}
  .edge.hot{stroke:var(--green);stroke-width:2}
  .edge.neg{stroke:var(--red)}
  .elast{margin:22px 0 4px}
  table.mck td small{color:var(--mut);font-family:var(--mono);font-size:10px}
  .section-head{border-top:2px solid var(--green);padding-top:12px;margin:24px 0 8px}
  .section-head h2{font-family:var(--serif);font-size:clamp(19px,3vw,24px);color:var(--ink)}
</style>

<div class="wrap">
  <section class="hero">
    <span class="eyebrow">Interactive model</span>
    <h1>The Model <span class="mst" style="vertical-align:middle">MODEL</span></h1>
    <p class="dek">Move a lever and see how it changes the peso, inflation, Banxico's rate, and growth. Start with one of the preset scenarios, then adjust the sliders yourself.</p>
    <div class="modelnote">This model shows the direction and rough size of each move, computed from the sourced elasticities footnoted below. It is not a forecast. Every output carries the <span class="mst">MODEL</span> stamp, and none of it is live data. For the current readings, see the <a href="./">Briefing</a>.</div>
  </section>

  <div class="presetbar" id="presetbar"></div>

  <div class="panel">
    <div class="card">
      <h3>The levers</h3>
      <div class="csub">Four external forces you set as inputs</div>
      <div id="levers"></div>
    </div>
    <div class="card">
      <h3>What it does <span class="mst">MODEL</span></h3>
      <div class="csub">Baseline → modeled (vs. today's readings)</div>
      <div id="outputs"></div>
    </div>
  </div>

  <div class="diagram">
    <div class="section-head"><h2>The transmission</h2></div>
    <div id="diagram"></div>
  </div>

  <div class="elast">
    <div class="section-head"><h2>The elasticities (footnoted)</h2></div>
    <p style="font-size:13.5px;color:var(--ink-2);margin-bottom:10px">These coefficients are directional. They capture the mechanism and rough scale rather than values estimated to the last basis point, and they come from the standard literature and the structure of Banxico and INEGI data; a real forecast would estimate them on data. Two limits to read them by. First, Banxico's rate here feeds only growth, so a hike neither disinflates nor defends the peso in this model. Second, the coefficients are marginal, so the far ends of the sliders understate a real crisis rather than exaggerate it.</p>
    <div class="tblwrap"><table class="mck" id="elast"></table></div>
  </div>
</div>

<script>
const $=(s)=>document.querySelector(s);
// ---- baseline (anchored to the Briefing's current readings / consensus) ----
const BASE={ tariff:4, fed:0, oil:65, usg:2.3 };            // lever baselines
const OUT0={ peso:17.60, infl:3.9, rate:6.50, gdp:1.1 };    // output baselines — anchored to the Briefing's current readings

const LEVERS=[
  {k:'tariff',l:'US tariff on Mexican goods',min:0,max:25,step:1,unit:'%',
   hint:'<b>Today about 4% effective.</b> Most goods still enter the US free under USMCA; 4% is the trade-weighted average after 2025 actions. Move it up if the 2026 USMCA review breaks down or a new Section 232/301 case lands. The 2018–19 metals tariffs ran 10–25% on covered lines. 0% is full free trade.'},
  {k:'fed',l:'US Fed rate, change from today',min:-3,max:3,step:0.25,unit:' pp',
   hint:'<b>Change from the current US policy rate (about 4.25–4.50%).</b> Markets price cuts into 2026, so −1 to −2pp is a clean easing cycle; +1pp means US inflation reignites and hikes come back. It reaches Mexico mainly through the rate gap that holds the peso up.'},
  {k:'oil',l:'Global crude price',min:30,max:110,step:5,unit:' $/bbl',
   hint:'<b>Today about $65 (Brent).</b> Mexico imports fuel but exports crude, so this is mostly a fiscal and Pemex lever now, not a growth one. The peso-oil link has faded. $40 is a demand slump or price war; $90+ a supply shock.'},
  {k:'usg',l:'US GDP growth',min:-1,max:4,step:0.1,unit:'%',
   hint:'<b>US real growth, about 2.3% now.</b> Around 80% of Mexico exports go north, so this is the single biggest external pull on Mexican growth. Below 0 is a US recession pulling Mexico down; 3–4% a US boom lifting it.'}
];
const PRESETS=[
  {name:'The USMCA review fails',set:{tariff:20,fed:0,oil:65,usg:1.5}},
  {name:'The Fed cuts fast',set:{tariff:4,fed:-2,oil:65,usg:2.3}},
  {name:'Oil at $40',set:{tariff:4,fed:0,oil:40,usg:2.3}},
  {name:'US recession',set:{tariff:8,fed:-1.5,oil:50,usg:-0.5}},
  {name:'Reset to baseline',set:{...BASE},reset:true}
];
let ST={...BASE};

// ---- the model: transparent, directional ----
function model(s){
  // peso (MXN/USD): tariffs & higher US rates weaken it; strong US growth firms it.
  // oil kept tiny — the petro-currency sign is contested now that Mexico is a net fuel importer.
  const peso = OUT0.peso + (s.tariff-BASE.tariff)*0.06 + s.fed*0.45 + (BASE.oil-s.oil)*0.005 - (s.usg-BASE.usg)*0.30;
  // inflation: a US tariff on Mexican goods is paid by US importers (it hits US CPI), so it reaches
  // MEXICAN inflation through the weaker peso, not directly. No direct-tariff term.
  const infl = OUT0.infl + (peso-OUT0.peso)*0.15;
  // Banxico reacts to the inflation gap (Taylor principle: response >1) and follows the Fed both ways, floored at 0
  const rate = Math.max(0, OUT0.rate + (infl-OUT0.infl)*1.2 + s.fed*0.3);
  // GDP growth: export hit from tariffs (sized to actually bite — ~30% of GDP, 80% US-bound), US-demand pull, policy drag
  const gdp  = OUT0.gdp - (s.tariff-BASE.tariff)*0.13 + (s.usg-BASE.usg)*0.55 - (rate-OUT0.rate)*0.12;
  return {peso,infl,rate,gdp};
}
const OUTDEF=[
  {k:'peso',l:'Peso',unit:'MXN/USD',dp:2,goodUp:false,note:(o)=>o.peso>OUT0.peso?'A weaker peso adds imported inflation.':'The peso firms.'},
  {k:'infl',l:'Inflation',unit:'% headline',dp:1,goodUp:false,note:(o)=>o.infl>4?'Above Banxico\'s 3% ±1 band.':'Inside the 3% ±1 band.'},
  {k:'rate',l:'Banxico policy rate',unit:'%',dp:2,goodUp:false,note:(o)=>o.rate>OUT0.rate?'Held higher to fight inflation.':'Room to ease.'},
  {k:'gdp',l:'GDP growth',unit:'% real',dp:1,goodUp:true,note:(o)=>o.gdp<1?'Near or below stall speed.':'Modest expansion.'}
];

function renderLevers(){
  $('#levers').innerHTML=LEVERS.map(L=>`<div class="lever"><div class="lv-top"><span class="lv-l">${L.l}</span><span class="lv-v" id="lvv-${L.k}"></span></div>
    <input type="range" id="lv-${L.k}" min="${L.min}" max="${L.max}" step="${L.step}" value="${ST[L.k]}">
    <div class="lv-hint">${L.hint}</div></div>`).join('');
  LEVERS.forEach(L=>{const inp=$('#lv-'+L.k);inp.addEventListener('input',()=>{ST[L.k]=Number(inp.value);update();});});
}
function fmtLever(L){const v=ST[L.k];return (v>0&&(L.k==='fed')?'+':'')+v+L.unit;}
function renderPresets(){
  $('#presetbar').innerHTML=PRESETS.map((p,i)=>`<button class="${p.reset?'reset':''}" data-i="${i}">${p.reset?'↺ ':''}${p.name}</button>`).join('');
  $('#presetbar').querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{ST={...BASE,...PRESETS[b.dataset.i].set};LEVERS.forEach(L=>{$('#lv-'+L.k).value=ST[L.k];});update();}));
}
function arrowFor(delta,goodUp){ if(Math.abs(delta)<1e-6)return{c:'fl',t:'no change'}; const up=delta>0; const good=(up===goodUp); return {c:good?'up':'dn',t:(up?'▲ ':'▼ ')+(delta>0?'+':'')+delta.toFixed(2)}; }
function renderOutputs(){
  const o=model(ST);
  $('#outputs').innerHTML=OUTDEF.map(D=>{
    const base=OUT0[D.k],val=o[D.k],delta=val-base,a=arrowFor(delta,D.goodUp);
    let vt=val.toFixed(D.dp); if(vt==='-0.0'||vt==='-0.00')vt=vt.slice(1);
    return `<div class="out"><div class="o-top"><span class="o-l">${D.l} <span class="mst">MODEL</span></span></div>
      <div class="o-main"><span class="o-base">${base.toFixed(D.dp)}</span><span class="o-arw">→</span><span class="o-v">${vt}</span><small style="color:var(--mut);font-family:var(--mono)">${D.unit}</small><span class="o-d ${a.c}">${a.t}</span></div>
      <div class="o-note">${D.note(o)}</div></div>`;
  }).join('');
}

// ---- transmission diagram ----
const NODES=[
  {id:'tariff',x:20,y:20,w:96,l:'Tariffs'},
  {id:'fed',x:20,y:70,w:96,l:'US rate'},
  {id:'usg',x:20,y:120,w:96,l:'US demand'},
  {id:'oil',x:20,y:170,w:96,l:'Oil'},
  {id:'exports',x:170,y:70,w:96,l:'Exports'},
  {id:'peso',x:320,y:70,w:96,l:'Peso'},
  {id:'infl',x:470,y:45,w:96,l:'Inflation'},
  {id:'rate',x:470,y:120,w:110,l:'Banxico rate'},
  {id:'gdp',x:630,y:95,w:96,l:'Growth'}
];
const EDGES=[
  {a:'tariff',b:'exports',neg:true},{a:'usg',b:'exports'},{a:'exports',b:'peso'},
  {a:'fed',b:'peso'},{a:'oil',b:'peso'},{a:'peso',b:'infl'},
  {a:'fed',b:'rate'},{a:'infl',b:'rate'},{a:'rate',b:'gdp',neg:true},{a:'exports',b:'gdp'}
];
function hotNodes(){ // which levers are off-baseline -> highlight their paths
  const h=new Set();
  if(ST.tariff!==BASE.tariff)h.add('tariff');
  if(ST.fed!==BASE.fed)h.add('fed');
  if(ST.oil!==BASE.oil)h.add('oil');
  if(ST.usg!==BASE.usg)h.add('usg');
  // propagate
  if(h.has('tariff')||h.has('usg'))h.add('exports');
  if(h.size)h.add('peso').add('infl').add('rate').add('gdp');
  return h;
}
function renderDiagram(){
  const hot=hotNodes();
  const N=Object.fromEntries(NODES.map(n=>[n.id,n]));
  const cx=(n)=>n.x+n.w/2, cy=(n)=>n.y+16;
  let edges=EDGES.map(e=>{const a=N[e.a],b=N[e.b];const isHot=hot.has(e.a)&&hot.has(e.b);
    const x1=a.x+a.w,y1=cy(a),x2=b.x,y2=cy(b);const mx=(x1+x2)/2;
    return `<path class="edge ${isHot?'hot':''} ${e.neg?'neg':''}" d="M${x1} ${y1} C${mx} ${y1} ${mx} ${y2} ${x2} ${y2}"/>`;}).join('');
  let nodes=NODES.map(n=>`<g class="node ${hot.has(n.id)?'hot':''}"><rect x="${n.x}" y="${n.y}" width="${n.w}" height="32" rx="6"/><text x="${n.x+n.w/2}" y="${n.y+20}" text-anchor="middle">${n.l}</text></g>`).join('');
  $('#diagram').innerHTML=`<svg viewBox="0 0 740 210" role="img" aria-label="Causal transmission diagram">
    <defs><marker id="arw" markerWidth="7" markerHeight="7" refX="6" refY="3" orient="auto"><path d="M0 0 L6 3 L0 6 z" fill="var(--line-2)"/></marker></defs>
    ${edges}${nodes}</svg>
    <div style="font-family:var(--mono);font-size:10px;color:var(--mut);margin-top:8px">Green path = a lever you've moved. Red edge = an inverse relationship (tariffs cut exports; a higher Banxico rate slows growth).</div>`;
}

const ELAST=[
  ['US tariff → peso','+0.06 MXN/USD per +1pp','Trade-cost / current-account shock weakens FX. Linear here; a real 25% tariff would bite harder and non-linearly.'],
  ['US rate → peso','+0.45 MXN/USD per +1pp','Rate differential drives carry (~2.6% per 100bp), the dominant near-term FX driver.'],
  ['Oil → peso','+0.005 MXN/USD per −$1/bbl','Faint Pemex/fiscal echo, kept small on purpose: the sign is contested now that Mexico is a net fuel importer.'],
  ['US growth → peso','−0.30 MXN/USD per +1pp','Stronger US demand firms the peso (~1.7% per +1pp).'],
  ['Peso → inflation','+0.15pp CPI per +1 MXN/USD','Exchange-rate pass-through ~0.026 on impact, larger over time. A tariff reaches Mexican CPI through the weaker peso, not as a direct price effect.'],
  ['Inflation → Banxico','+1.2pp rate per +1pp gap','Taylor-type, response above 1 (the Taylor principle), floored at 0.'],
  ['US rate → Banxico','+0.3pp per +1pp','Follows the Fed both ways: hikes to defend the peso, room to ease when the Fed eases.'],
  ['Tariff → GDP','−0.13pp per +1pp','Exports ≈30% of GDP, ~80% US-bound, so this is sized to actually bite; realistically convex past USMCA-breaking levels.'],
  ['US growth → GDP','+0.55pp per +1pp','The US-tether elasticity (could be 0.7–1.0 vs US industrial output).'],
  ['Rate → GDP','−0.12pp per +1pp','Tighter policy drags activity, with a lag.']
];
function renderElast(){ $('#elast').innerHTML=`<thead><tr><th>Link</th><th>Coefficient</th><th>Rationale</th></tr></thead><tbody>`+ELAST.map(r=>`<tr><td class="k">${r[0]}</td><td class="mono">${r[1]}</td><td><small>${r[2]}</small></td></tr>`).join('')+`</tbody>`; }

function update(){ LEVERS.forEach(L=>{$('#lvv-'+L.k).textContent=fmtLever(L);}); renderOutputs(); renderDiagram(); }
renderPresets(); renderLevers(); renderElast(); update();
</script>
{% endraw %}
