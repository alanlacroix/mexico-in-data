<script type="module">
import { loadSeries, S, EVENTS, fmt, valueAgo, stampFor, srcBadge, relTime, evDate, enNum } from '/assets/mb.js?v=15';
const $=(id)=>document.getElementById(id);
const esc=(s)=>String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const nd=(s)=>String(s==null?'':s).replace(/\s*—\s*/g,', ');           // strip em-dashes (voice law)
const firstSentence=(s)=>{ const t=nd(s); const m=t.match(/^.*?[.?!](\s|$)/); return (m?m[0]:t).trim(); };

/* old #q anchors → their section pages */
const RD={'#q3':'/money.html','#q4':'/economy.html','#q5':'/economy.html','#q6':'/society.html','#q7':'/politics.html','#q8':'/trade.html','#q9':'/security.html','#q10':'/economy.html'};
if(RD[location.hash]){ location.replace(RD[location.hash]); }

/* ============ BLOCK 1 · WHAT CHANGED ============
   Two deterministic inputs merged, ranked, capped at 5 (Fable 2026-07-13):
   (a) curated event headlines (rubric-passed, from brief.json) — the week's stories;
   (b) data movers (from the facts pack, computed from the series) — what moved in the numbers,
       each carrying a computed cross-series connection as a second clause when one applies.
   Quiet day is a designed state, not a fallback: if nothing crossed the bar, say so. */
function renderChanged(facts, brief){
  const rows=[];
  // (a) curated headlines: lead first, then items, in rubric order. Anchor into their What-matters card.
  if(brief && brief.lead && brief.lead.h1){
    rows.push({ kind:'event', headline: nd(brief.lead.h1).replace(/\.\s*$/,''), src: brief.lead.source, href:'#wm-lead' });
  }
  (brief && brief.items || []).forEach((it,i)=>{
    rows.push({ kind:'event', headline: nd(it.headline).replace(/\.\s*$/,''), src: it.source, href:(i<2?`#wm-${i}`:(it.href||null)) });
  });
  // (b) data movers, ranked by |z|. Skip a mover whose topic a headline already carries (light dedupe).
  const movers=((facts && facts.whatMoved && facts.whatMoved.items) || []).slice().sort((a,b)=>Math.abs(b.z||0)-Math.abs(a.z||0));
  const cx=(facts && facts.cross) || {};
  movers.forEach(m=>{
    const dir=m.dir<0?'fell to':(m.dir>0?'rose to':'held at');
    const val=/%/.test(m.units)?`${m.value}%`:`${enNum(m.value)} ${m.units}`;
    const flag=(m.flags&&m.flags[0])?` (${nd(m.flags[0])})`:'';
    let conn='';
    if(/inflaci|inflation|core/i.test(m.label) && cx.realRate && cx.realRate.value!=null) conn=` The real policy rate holds at ${cx.realRate.value}%.`;
    else if(/rate|tasa/i.test(m.label) && cx.rateSpread && cx.rateSpread.value!=null) conn=` That is ${cx.rateSpread.value} points above the US Fed.`;
    rows.push({ kind:'data', headline:`${m.label} ${dir} ${val}${flag}`, conn, src:'chart', href:`/chart.html?v=${m.id}` });
  });
  const capped=rows.slice(0,5);
  // quiet day: no curated stories AND the pack flags the data quiet
  const quiet = (!brief || !((brief.items||[]).length) || !brief.lead) && facts && facts.whatMoved && facts.whatMoved.quiet;
  if(!capped.length || quiet){
    const next=nextEventLabel();
    return { n:0, html:`<div class="chg-quiet"><b>Quiet day.</b> No major official releases moved the numbers.${next?` Next up: ${esc(next)}.`:''}</div>` };
  }
  const html=`<div class="chg">`+capped.map((r,i)=>{
    const srcEl = r.kind==='data' ? `<span class="ck">chart</span>` :
      (r.src?`<span class="cs">${esc(r.src)}</span>`:'');
    const body = r.kind==='data'
      ? `<span class="ct"><b>${esc(r.headline)}.</b>${r.conn?`<span class="conn">${esc(r.conn)}</span>`:''}</span>`
      : `<span class="ct"><b>${esc(r.headline)}.</b></span>`;
    const href = r.href||'#';
    return `<a class="chgrow" href="${esc(href)}"><span class="cn">${i+1}</span><span class="cb">${body}</span>${srcEl}</a>`;
  }).join('')+`</div>`;
  return { n:capped.length, html };
}
function nextEventLabel(){ const ev=(EVENTS&&EVENTS.events)||[]; const up=ev.filter(e=>new Date(e.date)>=Date.now()-864e5).sort((a,b)=>a.date.localeCompare(b.date)); return up.length?nd(up[0].label):''; }

/* ============ BLOCK 2 · MEXICO NOW ============ the small set Alan uses to orient. 6 tiles, all honest. */
function seriesLast(id){ const s=S[id]; return (s&&s.data&&s.data.length)?s.data[s.data.length-1]:null; }
function tileDelta(id){ const s=S[id]; if(!s||!s.data||s.data.length<3)return ''; const last=s.data.at(-1).value, ago=valueAgo(s.data,365);
  const isRate=/%/.test(s.meta.units||'')||/tasa|inflac|rate|igae|pib/.test(id);
  if(isRate){ const d=last-ago; return Math.abs(d)<0.05?'held vs a year ago':`${d>0?'+':'−'}${Math.abs(d).toFixed(2)} pp vs a year ago`; }
  const p=(last-ago)/Math.abs(ago)*100; return `${p>=0?'▲':'▼'} ${Math.abs(p).toFixed(1)}% vs a year ago`; }
function srcShort(id){ const s=S[id]; return ((s&&s.meta&&s.meta.source)||'').replace(/\s*\(SIE\)/,'').split(' / ')[0].replace('Banco de México','Banxico'); }
function btile(id,label,href,opts){ opts=opts||{}; const last=seriesLast(id);
  if(!last) return `<a class="btile" href="${href}"><div class="bt-l">${label}</div><div class="bt-v" style="font-size:16px;color:var(--amber2)">—</div><div class="bt-s">feed unavailable</div></a>`;
  const s=S[id], f=opts.valOverride||fmt(id,last.value,s.meta.units), st=stampFor(s.meta,id);
  return `<a class="btile" href="${href}"><div class="bt-l">${label}</div>`+
    `<div class="bt-v">${f.v} <small>${f.s}</small></div>`+
    (opts.sub?`<div class="bt-sub">${opts.sub}</div>`:'')+
    (opts.delta!==false?`<div class="bt-d">${tileDelta(id)}</div>`:'')+
    `<div class="bt-s">${st.t} · ${esc(srcShort(id))}</div></a>`; }
function renderBoard(trade){
  // inflation: 2-decimal to match the rest of the site (3.37 / 4.03), core as subline
  const infL=seriesLast('banxico-inflacion'); const infOv=infL?{v:infL.value.toFixed(2),s:'%'}:null;
  const coreL=seriesLast('banxico-inflacion-subyacente'); const core=coreL?coreL.value.toFixed(2):null;
  // growth: IGAE primary, GDP quarterly subline
  const gdpL=seriesLast('banxico-pib-crecimiento'); const gdpSub=gdpL?`GDP ${fmt('banxico-pib-crecimiento',gdpL.value,'% YoY').v}% · ${qLabel(gdpL.date)}`:'';
  // exports: US share subline (Census US-imports-from-Mexico ÷ Banxico total exports)
  const expL=seriesLast('banxico-exports-total'); let usSub='about 80% to the US';
  if(trade&&trade.latest&&expL){ const totBn=expL.value/1e6; const usBn=trade.latest.imports_bn; if(totBn>0&&usBn>0) usSub=`≈${Math.round(usBn/totBn*100)}% to the US`; }
  let h='';
  h+=btile('banxico-usdmxn-fix','Peso','/chart.html?v=banxico-usdmxn-fix');
  h+=btile('banxico-inflacion','Inflation','/chart.html?v=banxico-inflacion,banxico-inflacion-subyacente',{sub:core?`Core ${core}%`:'',valOverride:infOv});
  h+=btile('banxico-tasa-objetivo','Policy rate','/chart.html?v=banxico-tasa-objetivo',{delta:false});
  h+=btile('banxico-igae','Growth (IGAE)','/chart.html?v=banxico-igae,banxico-pib-crecimiento',{sub:gdpSub});
  h+=btile('banxico-exports-total','Exports','/chart.html?v=banxico-exports-total',{sub:usSub});
  // approval: a dated poll anchor, not a live feed — marked honestly
  h+=`<a class="btile" href="/politics.html"><div class="bt-l">Approval</div>`+
     `<div class="bt-v">49–68 <small>%</small></div><div class="bt-sub">pollsters differ ~20 pts</div>`+
     `<div class="bt-s"><span class="dated">POLL · JUN 2026</span> · AS/COA tracker</div></a>`;
  return h;
}
function qLabel(iso){ const d=new Date((iso&&iso.length<=7)?iso+'-01':iso); if(isNaN(d))return''; return 'Q'+(Math.floor(d.getUTCMonth()/3)+1)+' '+d.getUTCFullYear(); }

/* ============ BLOCK 3 · WHAT MATTERS ============ top 3 developments, full info model + anchors. */
function renderMatters(brief){
  if(!brief||!brief.lead) return '';
  const src=(o)=>{ if(!o||!o.href) return ''; const ext=/^https?:/.test(o.href), d=o.date?(' · '+shortDate(o.date)):'';
    return `<a class="msrc" href="${esc(o.href)}"${ext?' target="_blank" rel="noopener"':''}>${esc(o.source||'source')}${d} &rarr;</a>`; };
  const view=(o)=>{ if(!o||!o.view) return ''; return `<div class="mv"><span class="mvk">Alan's view</span>${esc(nd(o.view))}</div>`; };
  const card=(o,id)=>`<article class="mi" id="${id}"><h3 class="mh">${esc(nd(o.headline||o.h1))}</h3>`+
    `<p class="mx">${esc(nd(o.context||''))}</p>${view(o)}${src(o)}</article>`;
  let h=card(brief.lead,'wm-lead');
  (brief.items||[]).slice(0,2).forEach((it,i)=>{ h+=card(it,`wm-${i}`); });
  return h;
}
function shortDate(d){ if(!d)return''; const x=new Date(d+'T00:00:00'); return isNaN(x)?'':x.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }

/* ============ BLOCK 4 · COMING NEXT ============ up to 5 meaningful dated events. */
function renderComing(){
  const ev=(EVENTS&&EVENTS.events)||[]; const now=Date.now();
  const up=ev.filter(e=>new Date(e.date)>=now-864e5).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,5);
  if(!up.length) return `<div class="cb-empty">Nothing dated on the calendar yet.</div>`;
  return up.map(e=>{ const d=evDate(e);
    const s=e.sourceUrl?`<a class="nusrc" href="${esc(e.sourceUrl)}" target="_blank" rel="noopener">${esc(e.source||'source')}</a>`:(e.source?`<span class="nusrc">${esc(e.source)}</span>`:'');
    return `<div class="nur"><div class="nud">${d.mo} ${d.day}<small>${d.y}${e.approx?' ~':''}</small></div><div class="nut">${esc(nd(e.label))}</div>${s}</div>`;
  }).join('');
}

/* ============ boot ============ */
(async()=>{
  await loadSeries(['banxico-usdmxn-fix','banxico-inflacion','banxico-inflacion-subyacente','banxico-tasa-objetivo','banxico-igae','banxico-pib-crecimiento','banxico-exports-total']);
  const [health,trade,brief,facts]=await Promise.all([
    fetch('./data/health.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('./data/trade-us.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('./data/brief.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('./data/analysis/facts.json').then(r=>r.ok?r.json():null).catch(()=>null),
  ]);

  // masthead: updated <date> · N meaningful changes  (no feed-count boast)
  const upd=$('mb-updated'); if(upd){ const times=Object.values(S).map(s=>new Date(s.meta.fetchedAt).getTime()).filter(t=>t&&!isNaN(t)); const newest=times.length?Math.max(...times):0;
    upd.textContent='Updated '+(newest?relTime(newest):new Date().toLocaleDateString('en-US',{month:'short',day:'numeric'})); }

  // Block 1
  const chg=renderChanged(facts, brief); $('changed').innerHTML=chg.html;
  const nEl=$('mb-nchg'); if(nEl) nEl.innerHTML = chg.n>0 ? `${chg.n} meaningful change${chg.n>1?'s':''}` : 'Quiet day';
  const cao=$('changed-asof'); if(cao&&facts&&facts.generatedAt){ const d=new Date(facts.generatedAt); if(!isNaN(d)) cao.textContent=d.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }

  // Block 2
  $('board').innerHTML=renderBoard(trade);
  const bao=$('board-asof'); const times2=Object.values(S).map(s=>new Date(s.meta.fetchedAt).getTime()).filter(t=>t&&!isNaN(t)); const newest2=times2.length?Math.max(...times2):0;
  if(bao&&newest2) bao.textContent='as of '+new Date(newest2).toLocaleDateString('en-US',{month:'short',day:'numeric'});

  // Block 3
  const mEl=$('matters'); if(mEl){ const h=renderMatters(brief); if(h){ mEl.innerHTML=h; const mao=$('matters-asof'); if(mao&&brief.meta) mao.textContent='as of '+(brief.meta.asOf||''); } else { const sec=$('matters-sec'); if(sec) sec.remove(); } }

  // Block 4
  $('coming').innerHTML=renderComing();

  try{ localStorage.setItem('mb_lastvisit',new Date().toISOString()); }catch(e){}
})().catch(e=>{ const c=$('changed'); if(c) c.innerHTML='<div class="hp-err">Error loading data: '+esc(e.message)+'</div>'; });
</script>
