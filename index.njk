---
layout: base.njk
permalink: /
title: "The Mexico Brief: Mexico in official numbers"
description: "A daily starting point for Mexico's economy, politics, trade, society, and relationship with the US, with dates and links to the original sources."
ogTitle: "The Mexico Brief"
ogDescription: "Mexico's important numbers, what changed, and the original sources."
---
<style>
  body{font-size:var(--fs-body)}
  .home{max-width:var(--maxw);margin:0 auto;padding:0 clamp(18px,4vw,44px)}
  .home a{text-underline-offset:2px}
  .home-hero{padding:28px 0 18px}
  .home-topline{display:flex;align-items:center;justify-content:space-between;gap:10px 24px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.035em;text-transform:uppercase;color:var(--mut)}
  .home-topline .fresh{display:inline-flex;align-items:center;gap:7px;color:var(--mut);text-decoration:none}
  .home-topline .fresh:hover{color:var(--green-d)}
  .home-topline .dot{width:6px;height:6px;border-radius:50%;background:var(--green)}
  .home-topline .fresh.has-expected .dot{background:#a87813}
  .home-topline .fresh.has-issue .dot{background:var(--red)}
  .home-hero h1{font-size:clamp(34px,4.5vw,52px);line-height:1.04;letter-spacing:-.025em;margin:10px 0 6px}
  .section-k{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.055em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .morning-summary{border-top:2px solid var(--green);border-bottom:1px solid var(--line);padding:13px 0 15px}
  .morning-summary p{font-size:var(--fs-body);line-height:1.52;color:var(--ink-2);max-width:82ch}

  .top-grid{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(330px,.85fr);gap:36px;margin-top:30px}
  .section-rule{border-top:2px solid var(--green);padding-top:12px}
  .section-headline{display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:4px}
  .section-headline .asof{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .section-title{font-size:clamp(27px,3vw,var(--fs-h2));line-height:1.12;margin:4px 0 8px}

  .brief-list{border-top:1px solid var(--line)}
  .brief-row{padding:19px 0 18px;border-bottom:1px solid var(--line)}
  .story-meta{display:flex;align-items:center;gap:6px 10px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.025em;text-transform:uppercase;color:var(--mut);margin-bottom:6px}
  .story-meta .beat{color:var(--green-d);font-weight:600}
  .brief-row h3{font-size:clamp(20px,2vw,22px);line-height:1.25;letter-spacing:-.006em;margin:0 0 6px;max-width:42ch}
  .brief-row>p{font-size:16px;line-height:1.5;color:var(--ink-2);max-width:67ch}
  .story-foot{display:flex;align-items:center;gap:2px 14px;flex-wrap:wrap;margin-top:10px;min-height:44px;font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .story-foot a{color:var(--green-d)}

  .now-group{margin-top:15px}
  .now-group+.now-group{margin-top:22px}
  .now-group-head{display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:7px}
  .now-group-title{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.045em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .now-group-note{font-family:var(--mono);font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.025em}
  .metric-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:4px;overflow:hidden}
  .metric-card{display:flex;flex-direction:column;min-width:0;background:var(--paper);padding:12px 13px 10px;color:var(--ink)}
  .metric-card:last-child:nth-child(odd){grid-column:1 / -1}
  .metric-main{display:block;color:var(--ink);text-decoration:none;min-width:0}
  .metric-main:hover{text-decoration:none}
  .metric-top{display:flex;align-items:baseline;justify-content:space-between;gap:8px}
  .metric-name,.metric-cadence{font-family:var(--mono);font-size:10px;line-height:1.25;letter-spacing:.035em;text-transform:uppercase}
  .metric-name{color:var(--mut);font-weight:600}
  .metric-cadence{color:var(--green-d);white-space:nowrap}
  .metric-main:hover .metric-name{color:var(--green-d)}
  .metric-value{font-size:clamp(25px,2.1vw,31px);line-height:1;font-weight:650;letter-spacing:-.02em;font-variant-numeric:tabular-nums;margin-top:9px;white-space:nowrap}
  .metric-value small{font-family:var(--mono);font-size:10px;letter-spacing:0;color:var(--mut);font-weight:400;margin-left:3px}
  .metric-move{font-size:13px;line-height:1.3;font-weight:650;margin-top:8px;font-variant-numeric:tabular-nums}
  .metric-move.good{color:var(--green-d)}
  .metric-move.bad{color:var(--red)}
  .metric-move.neutral{color:var(--ink-2)}
  .metric-compare{font-size:11px;line-height:1.35;color:var(--ink-2);margin-top:3px;min-height:29px}
  .metric-stamp{font-family:var(--mono);font-size:10px;line-height:1.35;color:var(--mut);text-transform:uppercase;letter-spacing:.02em;margin-top:7px}
  .now-more{margin-top:auto;padding-top:8px}
  .now-more summary{display:flex;align-items:center;justify-content:space-between;gap:8px;min-height:24px;font-family:var(--mono);font-size:10px;line-height:1.3;color:var(--green-d);cursor:pointer;list-style:none}
  .now-more summary::-webkit-details-marker{display:none}
  .now-more summary::after{content:"+";font-size:14px}
  .now-more[open] summary::after{content:"–"}
  .now-more p{font-size:12px;line-height:1.45;color:var(--ink-2);margin-top:6px}
  .section-link{display:inline-block;margin-top:11px;font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d)}
  .now-loading{border-top:1px solid var(--line);padding:16px 0;font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}

  .companies,.topics,.coming,.subscribe-section{margin-top:42px}
  .company-list{border-top:1px solid var(--line)}
  .company-row{display:grid;grid-template-columns:130px minmax(0,1.1fr) minmax(250px,.9fr) auto;gap:14px 20px;align-items:start;padding:17px 0;border-bottom:1px solid var(--line)}
  .company-name{font-family:var(--mono);font-size:var(--fs-label);line-height:1.45;text-transform:uppercase;letter-spacing:.035em;color:var(--green-d);font-weight:600}
  .company-name span{display:block;color:var(--mut);font-weight:400;text-transform:none;letter-spacing:0}
  .company-thesis h3{font-size:var(--fs-body);line-height:1.3;margin:0 0 3px}
  .company-thesis p,.company-signal{font-size:var(--fs-meta);line-height:1.48;color:var(--ink-2)}
  .company-signal b{color:var(--ink);font-weight:600}
  .company-source{font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d);white-space:nowrap}

  .areas{display:grid;grid-template-columns:1fr;gap:8px;border-top:1px solid var(--line);padding-top:1px}
  @media(min-width:760px){.areas{grid-template-columns:1fr 1fr;gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:4px;overflow:hidden;padding-top:0}}
  .area{background:var(--paper);padding:21px 21px 19px}
  @media(max-width:759px){.area{border:1px solid var(--line-2);border-radius:4px}}
  .area-h{display:flex;align-items:baseline;justify-content:space-between;gap:8px;text-decoration:none;margin-bottom:8px}
  .area-k{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .area-go{font-family:var(--mono);font-size:11px;color:var(--mut);white-space:nowrap}
  .area-h:hover .area-go{color:var(--green-d)}
  .area-syn{font-size:var(--fs-small);line-height:1.6;color:var(--ink-2);margin:0 0 13px}
  .area-hl .hl{display:block;padding:9px 0;border-top:1px solid var(--line);text-decoration:none}
  .area-hl .hl:first-child{border-top:none;padding-top:1px}
  .hl-t{display:block;font-size:var(--fs-small);color:var(--ink);font-weight:500;line-height:1.36}
  .area-hl .hl:hover .hl-t{color:var(--green-d)}
  .hl-m{display:block;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.02em;text-transform:uppercase;color:var(--mut);margin-top:3px}

  .timeline{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .timeline-item{padding:16px 18px 17px 0}
  .timeline-item+.timeline-item{border-left:1px solid var(--line);padding-left:18px}
  .timeline-date{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.035em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .timeline-title{font-size:var(--fs-small);line-height:1.35;color:var(--ink);font-weight:600;margin-top:6px}
  .timeline-why{font-size:var(--fs-meta);line-height:1.45;color:var(--ink-2);margin-top:5px}
  .timeline-source{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);margin-top:7px}

  .sub{border:1.5px solid var(--line);border-radius:12px;padding:20px 22px 16px;background:#fbfaf6}
  .sub .lab{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);font-weight:700}
  .sub .line{font-size:var(--fs-small);color:var(--ink-2);margin-top:8px;line-height:1.5;max-width:76ch}
  .sub form{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
  .sub input[type=email]{flex:1;min-width:220px;font-family:var(--sans);font-size:var(--fs-small);padding:12px 14px;border:1.5px solid var(--line);border-radius:9px;background:#fff;color:var(--ink)}
  .sub input[type=email]:focus{outline:none;border-color:var(--green)}
  .sub button{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:#fff;background:var(--green);border:none;border-radius:9px;padding:12px 24px;cursor:pointer}
  .sub button:hover{background:var(--green-d)}
  .sub .fine{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:11px;line-height:1.6}

  @media(max-width:900px){
    .top-grid{grid-template-columns:1fr;gap:34px}
    .company-row{grid-template-columns:110px minmax(0,1fr) auto}
    .company-signal{grid-column:2 / -1}
    .timeline{grid-template-columns:repeat(2,minmax(0,1fr))}
    .timeline-item:nth-child(3){border-left:0;border-top:1px solid var(--line);padding-left:0}
    .timeline-item:nth-child(4){border-top:1px solid var(--line)}
  }
  @media(max-width:650px){
    .home-hero{padding:23px 0 16px}
    .home-hero h1{font-size:34px}
    .top-grid{margin-top:29px}
    .section-title{font-size:28px}
    .brief-row{padding:18px 0}
    .brief-row h3{font-size:21px;line-height:1.25}
    .brief-row>p{font-size:16px;line-height:1.48}
    .story-foot{gap:0 13px}
    .metric-grid{grid-template-columns:1fr}
    .metric-card:last-child:nth-child(odd){grid-column:auto}
    .metric-card{padding:12px 13px 10px}
    .metric-value{font-size:28px}
    .metric-compare{min-height:0}
    .company-row{grid-template-columns:1fr;gap:5px;padding:15px 0}
    .company-signal{grid-column:auto}
    .company-source{padding-top:5px}
    .timeline{grid-template-columns:1fr}
    .timeline-item{padding:14px 0 15px}
    .timeline-item+.timeline-item,.timeline-item:nth-child(3),.timeline-item:nth-child(4){border-left:0;border-top:1px solid var(--line);padding-left:0}
  }
</style>

<div class="home">
  <section class="home-hero">
    <div class="home-topline">
      <span id="today">Today</span>
      <a class="fresh" id="fresh" href="/sources.html"><span class="dot"></span><span id="status">Checking the data</span></a>
    </div>
    <h1>Mexico this morning.</h1>
  </section>

  <section class="morning-summary" aria-label="Morning summary">
    <div class="section-k">The brief</div>
    <p id="morning-summary">{{ dailyBrief.summaryLead }}</p>
    <span id="summary-next" hidden>{{ dailyBrief.summaryNext }}</span>
  </section>

  <div class="top-grid">
    <section class="section-rule" aria-labelledby="news-title">
      <div class="section-headline"><div class="section-k">Latest</div><div class="asof" id="news-asof" data-date="{{ dailyBrief.newsThrough }}">News through {{ dailyBrief.newsThrough }}</div></div>
      <h2 class="section-title" id="news-title">Today's news</h2>
      <div class="brief-list">
        {% for story in dailyBrief.stories %}
        <article class="brief-row">
          <div class="story-meta"><span class="beat">{{ story.beat }}</span><span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span></div>
          <h3>{{ story.title }}</h3>
          <p>{{ story.context }}</p>
          <div class="story-foot">
            <a href="{{ story.url }}" target="_blank" rel="noopener">{{ story.source }} ↗</a>
            <a href="{{ story.topicUrl }}">{{ story.topic }} →</a>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>

    <aside class="rail">
      <section class="section-rule" aria-labelledby="now-title">
        <div class="section-k">Current readings</div>
        <h2 class="section-title" id="now-title">Mexico now</h2>
        <div id="mexico-now"><div class="now-loading">Loading the latest readings…</div></div>
        <a class="section-link" href="/chart.html">Open all charts →</a>
      </section>
    </aside>
  </div>

  <section class="companies section-rule" aria-labelledby="companies-title">
    <div class="section-headline"><div class="section-k">Companies</div><div class="asof">Latest signal and why I am watching</div></div>
    <h2 class="section-title" id="companies-title">Companies worth following</h2>
    <div class="company-list">
      {% for company in dailyBrief.companies %}
      <article class="company-row">
        <div class="company-name">{{ company.name }}<span>{{ company.sector }}</span></div>
        <div class="company-thesis"><h3>{{ company.title }}</h3><p>{{ company.thesis }}</p></div>
        <p class="company-signal"><b>Latest:</b> {{ company.signal }}</p>
        <a class="company-source" href="{{ company.url }}" target="_blank" rel="noopener"><span class="js-date" data-date="{{ company.date }}">{{ company.date }}</span> ↗</a>
      </article>
      {% endfor %}
    </div>
  </section>

  <section class="topics section-rule" aria-labelledby="topics-title">
    <div class="section-headline"><div class="section-k">By topic</div><div class="asof" id="areas-asof"></div></div>
    <h2 class="section-title" id="topics-title">Mexico by topic</h2>
    <div class="areas" id="areas"></div>
  </section>

  <section class="coming section-rule" aria-labelledby="next-title">
    <div class="section-headline"><div class="section-k">Next</div><div class="asof">Four dates to watch</div></div>
    <h2 class="section-title" id="next-title">Coming up</h2>
    <div class="timeline" id="timeline"><div class="now-loading">Loading the calendar…</div></div>
    <a class="section-link" href="/sources.html#calendar">Open the full calendar →</a>
  </section>

  <section class="subscribe-section">
    <div class="sub">
      <div class="lab">The email</div>
      <p class="line">Once a week, I send the few things that changed in Mexico's economy, politics, and relationship with the United States that I think are worth knowing. The original sources are included if you want to go deeper. <a href="/weekly.html" style="color:var(--green-d);font-weight:600">See an example →</a></p>
      <form class="subform" method="post" action="/api/subscribe" novalidate>
        <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" autocomplete="email" inputmode="email" required />
        <label class="hp-field" aria-hidden="true">Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        <button type="submit">Subscribe</button>
      </form>
      <div class="fine submsg" aria-live="polite">One email a week. Unsubscribe whenever you want.</div>
      <div class="privacy-note">Your email is handled by Beehiiv for this newsletter. <a href="/privacy.html">Privacy</a>.</div>
    </div>
  </section>
</div>

<script type="module">
import { loadSeries, S, EVENTS, relTime } from '/assets/mb.js?v=18';

const RD={'#q3':'/economy.html','#q4':'/economy.html','#q5':'/economy.html','#q6':'/society.html','#q7':'/politics.html','#q8':'/us-mexico.html','#q9':'/society.html','#q10':'/economy.html','#q11':'/model.html'};
if(RD[location.hash]) location.replace(RD[location.hash]);

const esc=(s)=>String(s==null?'':s).replace(/[&<>\"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]));
const point=(id)=>S[id]?.data?.at(-1)||null;
const prior=(id)=>S[id]?.data?.at(-2)||null;
function nearAgo(id,days,tolerance=60){
  const a=S[id]?.data||[]; if(!a.length) return null;
  const end=Date.parse(a.at(-1).date),target=end-days*864e5; let best=null,dist=Infinity;
  for(const p of a){const d=Math.abs(Date.parse(p.date)-target);if(d<dist){dist=d;best=p;}}
  return dist<=tolerance*864e5?best:null;
}
const n=(v,d=2)=>Number(v).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
const signed=(v,d=2)=>`${Number(v)>=0?'+':''}${n(v,d)}%`;
function dateLabel(iso,withYear=false){
  if(!iso) return '';
  const d=new Date(/^\d{4}-\d{2}-\d{2}$/.test(iso)?iso+'T00:00:00':iso);
  return isNaN(d)?'':d.toLocaleDateString('en-US',{month:'short',day:'numeric',...(withYear?{year:'numeric'}:{})});
}
function periodLabel(id,iso){
  if(!iso) return '';
  const d=new Date(/^\d{4}-\d{2}-\d{2}$/.test(iso)?iso+'T00:00:00':iso);
  if(isNaN(d)) return '';
  if(S[id]?.meta?.cadence==='monthly') return d.toLocaleDateString('en-US',{month:'long',year:'numeric'});
  return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
}
function monthLabel(iso){
  if(!iso) return '';
  const d=new Date(/^\d{4}-\d{2}-\d{2}$/.test(iso)?iso+'T00:00:00':iso);
  return isNaN(d)?'':d.toLocaleDateString('en-US',{month:'long'});
}
function currentStreak(id){
  const a=S[id]?.data||[]; if(!a.length) return null;
  const value=a.at(-1).value; let i=a.length-1;
  while(i>0&&a[i-1].value===value)i--;
  return {date:a[i].date,value,previous:i>0?a[i-1]:null};
}
function metricCard({id,name,cadence,value,unit='',arrow='→',move,compare='',stamp,tone='neutral',why}){
  return `<article class="metric-card"><a class="metric-main" href="/chart.html?v=${esc(id)}"><div class="metric-top"><span class="metric-name">${esc(name)}</span><span class="metric-cadence">${esc(cadence)}</span></div><div class="metric-value">${esc(value)}${unit?` <small>${esc(unit)}</small>`:''}</div><div class="metric-move ${esc(tone)}"><span aria-hidden="true">${esc(arrow)}</span> ${esc(move)}</div>${compare?`<div class="metric-compare">${esc(compare)}</div>`:'<div class="metric-compare"></div>'}<div class="metric-stamp">${esc(stamp)}</div></a><details class="now-more"><summary>Why it matters</summary><p>${esc(why)}</p></details></article>`;
}
function renderNow(){
  const peso=point('banxico-usdmxn-fix'),pesoP=prior('banxico-usdmxn-fix'),pesoY=nearAgo('banxico-usdmxn-fix',365,10);
  const inf=point('banxico-inflacion'),infP=prior('banxico-inflacion'),core=point('banxico-inflacion-subyacente');
  const rate=point('banxico-tasa-objetivo'),rateStreak=currentStreak('banxico-tasa-objetivo'),igae=point('banxico-igae'),igaeP=prior('banxico-igae');
  const rem=point('banxico-remesas'),remP=prior('banxico-remesas'),remY=nearAgo('banxico-remesas',365,45);
  const res=point('banxico-reservas'),resP=prior('banxico-reservas'),resY=nearAgo('banxico-reservas',365,60);
  const ipc=point('banxico-bmv-ipc'),ipcP=prior('banxico-bmv-ipc'),ipcY=nearAgo('banxico-bmv-ipc',365,10);
  const cetes=point('banxico-cetes-28d'),cetesP=prior('banxico-cetes-28d'),cetesY=nearAgo('banxico-cetes-28d',365,10);
  const ust=point('fred-ust10'),ustP=prior('fred-ust10'),ustY=nearAgo('fred-ust10',365,10);
  const daily=[]; const releases=[];
  if(peso){const stronger=pesoP&&peso.value<pesoP.value;const weaker=pesoP&&peso.value>pesoP.value;const dayMove=pesoP?Math.abs((peso.value/pesoP.value-1)*100):null;const yearMove=pesoY?Math.abs((peso.value/pesoY.value-1)*100):null;daily.push(metricCard({id:'banxico-usdmxn-fix',name:'Peso',cadence:'Daily',value:n(peso.value,2),unit:'MXN / US$',arrow:stronger?'▲':weaker?'▼':'→',move:pesoP?`${n(dayMove,2)}% ${stronger?'stronger':weaker?'weaker':'unchanged'}`:'Comparison unavailable',compare:pesoY?`${n(yearMove,1)}% ${peso.value<pesoY.value?'stronger':'weaker'} over 1Y`:'',stamp:`${periodLabel('banxico-usdmxn-fix',peso.date)} · Banxico`,tone:stronger?'good':weaker?'bad':'neutral',why:'A lower exchange-rate quote means a stronger peso. That makes imports cheaper, but each export or remittance dollar converts into fewer pesos.'}));}
  if(ipc){const move=ipcP?(ipc.value/ipcP.value-1)*100:null;const year=ipcY?(ipc.value/ipcY.value-1)*100:null;daily.push(metricCard({id:'banxico-bmv-ipc',name:'S&P/BMV IPC',cadence:'Daily',value:n(ipc.value,0),arrow:move>0?'▲':move<0?'▼':'→',move:move==null?'Comparison unavailable':`${n(Math.abs(move),2)}% ${move>0?'higher':move<0?'lower':'unchanged'}`,compare:year==null?'':`${n(Math.abs(year),1)}% ${year>0?'higher':year<0?'lower':'unchanged'} over 1Y`,stamp:`${periodLabel('banxico-bmv-ipc',ipc.date)} · Banxico / BMV`,tone:move>0?'good':move<0?'bad':'neutral',why:'The main index of large companies listed in Mexico. It is a useful market signal, but it is not the whole economy.'}));}
  if(cetes){const move=cetesP?cetes.value-cetesP.value:null;const year=cetesY?cetes.value-cetesY.value:null;daily.push(metricCard({id:'banxico-cetes-28d',name:'Cetes · 28 days',cadence:'Daily',value:`${n(cetes.value,2)}%`,arrow:move>0?'▲':move<0?'▼':'→',move:move==null?'Comparison unavailable':`${n(Math.abs(move),2)} pp ${move>0?'higher':move<0?'lower':'unchanged'}`,compare:year==null?'':`${n(Math.abs(year),2)} pp ${year>0?'higher':year<0?'lower':'unchanged'} over 1Y`,stamp:`${periodLabel('banxico-cetes-28d',cetes.date)} · Banxico`,tone:'neutral',why:'The market yield on very short-term Mexican government debt. Unlike the policy rate, it can move between Banxico meetings.'}));}
  if(ust){const move=ustP?ust.value-ustP.value:0;const year=ustY?ust.value-ustY.value:null;daily.push(metricCard({id:'fred-ust10',name:'U.S. 10-year yield',cadence:'Daily',value:`${n(ust.value,2)}%`,arrow:move>0?'▲':move<0?'▼':'→',move:ustP?`${n(Math.abs(move),2)} pp ${move>0?'higher':move<0?'lower':'unchanged'}`:'Comparison unavailable',compare:year==null?'':`${n(Math.abs(year),2)} pp ${year>0?'higher':year<0?'lower':'unchanged'} over 1Y`,stamp:`${periodLabel('fred-ust10',ust.date)} · U.S. Fed`,tone:'neutral',why:'A benchmark for dollar borrowing costs. Higher U.S. yields can reduce the relative appeal of peso assets, but they are only one input into the exchange rate.'}));}
  if(inf){const delta=infP?inf.value-infP.value:0;const inside=inf.value>=2&&inf.value<=4;releases.push(metricCard({id:'banxico-inflacion,banxico-inflacion-subyacente',name:'Inflation',cadence:'Monthly',value:`${n(inf.value,2)}%`,arrow:delta>0?'▲':delta<0?'▼':'→',move:infP?`${n(Math.abs(delta),2)} pp ${delta>0?'higher':delta<0?'lower':'unchanged'}`:'Comparison unavailable',compare:`${inside?'Inside':'Outside'} the 2–4% target · vs ${infP?monthLabel(infP.date):'prior month'}`,stamp:`${periodLabel('banxico-inflacion',inf.date)} · INEGI`,tone:inside?'good':'bad',why:`Prices are still rising, just more slowly. Core inflation is ${core?n(core.value,2)+'%':'not available'}.`}));}
  if(rate){const prev=rateStreak?.previous,delta=prev?rate.value-prev.value:0;const gap=core?n(rate.value-core.value,2):null;releases.push(metricCard({id:'banxico-tasa-objetivo,banxico-inflacion-subyacente',name:'Banxico rate',cadence:'Policy meetings',value:`${n(rate.value,2)}%`,arrow:delta>0?'▲':delta<0?'▼':'→',move:prev?`${n(Math.abs(delta),2)} pp ${delta>0?'higher':delta<0?'lower':'unchanged'} at latest change`:'No earlier change available',compare:gap?`${gap} pp above core inflation`:'',stamp:`Current since ${dateLabel(rateStreak?.date)} · Banxico`,tone:'neutral',why:'Higher rates help contain inflation and support the peso, but make borrowing more expensive.'}));}
  if(igae){const delta=igaeP?igae.value-igaeP.value:0;releases.push(metricCard({id:'banxico-igae',name:'Economic activity',cadence:'Monthly',value:signed(igae.value,2),unit:'YoY',arrow:delta>0?'▲':delta<0?'▼':'→',move:igaeP?`from ${signed(igaeP.value,2)} prior month`:`${igae.value>=0?'Growing':'Contracting'} from a year earlier`,compare:'Year-over-year growth · IGAE',stamp:`${periodLabel('banxico-igae',igae.date)} · INEGI`,tone:igae.value>=0?'good':'bad',why:"The closest monthly reading of whether Mexico's economy is growing before quarterly GDP arrives."}));}
  if(rem){let arrow='→',move='Comparison unavailable',compare='';let tone='neutral';if(remY){const delta=(rem.value/remY.value-1)*100;arrow=delta>0?'▲':delta<0?'▼':'→';move=`${n(Math.abs(delta),1)}% ${delta>=0?'higher':'lower'}`;compare='Versus the same month last year';tone=delta>=0?'good':'bad';}else if(remP){const delta=rem.value-remP.value;arrow=delta>0?'▲':delta<0?'▼':'→';move=`US$${n(Math.abs(delta),0)}m ${delta>=0?'more':'less'}`;compare=`Versus ${monthLabel(remP.date)} · monthly totals are seasonal`;}releases.push(metricCard({id:'banxico-remesas',name:'Remittances',cadence:'Monthly',value:`US$${n(rem.value/1000,2)}bn`,arrow,move,compare,stamp:`${periodLabel('banxico-remesas',rem.date)} · Banxico`,tone,why:'Money sent home from abroad, mostly the US. It supports household spending and brings dollars into Mexico. The same month a year earlier is the better comparison.'}));}
  if(res){const delta=resP?res.value-resP.value:0;const year=resY?(res.value/resY.value-1)*100:null;releases.push(metricCard({id:'banxico-reservas',name:'International reserves',cadence:'Weekly',value:`US$${n(res.value/1000,0)}bn`,arrow:delta>0?'▲':delta<0?'▼':'→',move:resP?`US$${n(Math.abs(delta),0)}m ${delta>0?'higher':delta<0?'lower':'unchanged'}`:'Comparison unavailable',compare:year==null?'':`${n(Math.abs(year),1)}% ${year>=0?'higher':'lower'} over 1Y`,stamp:`${periodLabel('banxico-reservas',res.date)} · Banxico`,tone:'neutral',why:"Banxico's foreign-currency buffer against external shocks."}));}
  const el=document.getElementById('mexico-now');
  if(el) el.innerHTML=`<div class="now-group"><div class="now-group-head"><div class="now-group-title">Daily movers</div><div class="now-group-note">Previous close</div></div><div class="metric-grid">${daily.join('')}</div></div><div class="now-group"><div class="now-group-head"><div class="now-group-title">Latest official readings</div><div class="now-group-note">Latest available</div></div><div class="metric-grid">${releases.join('')}</div></div>`;
}

function renderAreas(data){
  const areas=(data&&data.areas)||[];
  return areas.map(a=>{const hls=(a.headlines||[]).slice(0,3);const links=hls.map(h=>`<a class="hl" href="${esc(h.url||'#')}"${/^https?:/.test(h.url||'')?' target="_blank" rel="noopener"':''}><span class="hl-t">${esc(h.title)}</span><span class="hl-m">${esc([h.source,dateLabel(h.date)].filter(Boolean).join(' · '))}</span></a>`).join('');return `<div class="area"><a class="area-h" href="${esc(a.href||'#')}"><span class="area-k">${esc(a.label)}</span><span class="area-go">more →</span></a>${a.synthesis?`<p class="area-syn">${esc(a.synthesis)}</p>`:''}<div class="area-hl">${links}</div></div>`;}).join('');
}
function eventCopy(e){
  const t=String(e.label||'');
  if(/USMCA talks/i.test(t)) return {title:'Mexico–U.S. trade talks',why:'The next round after the first USMCA review.'};
  if(/first-fortnight July/i.test(t)) return {title:'First-half July inflation',why:'Shows whether the June decline continued.'};
  if(/IGAE/i.test(t)) return {title:'May economic activity',why:'The best monthly check on growth before GDP.'};
  if(/GDP flash/i.test(t)) return {title:'First estimate of Q2 GDP',why:'Shows whether the economy left the Q1 slowdown behind.'};
  return {title:t.split(/\s+[—–]\s+/)[0],why:e.mechanism||''};
}
function renderTimeline(){
  const today=new Date(); today.setHours(0,0,0,0);
  const future=((EVENTS&&EVENTS.events)||[]).filter(e=>Date.parse(e.date)>=today.getTime()-864e5).sort((a,b)=>String(a.date).localeCompare(String(b.date)));
  const wanted=[/USMCA talks/i,/first-fortnight July/i,/IGAE/i,/GDP flash/i];
  const ev=wanted.map(pattern=>future.find(e=>pattern.test(String(e.label||'')))).filter(Boolean);
  for(const e of future){if(ev.length>=4)break;if(!ev.includes(e))ev.push(e);}
  const html=ev.map(e=>{const c=eventCopy(e),d=new Date(e.date+'T00:00:00'),label=e.approx?`Week of ${dateLabel(e.date)}`:dateLabel(e.date);return `<article class="timeline-item"><div class="timeline-date">${esc(label)}</div><div class="timeline-title">${esc(c.title)}</div><div class="timeline-why">${esc(c.why)}</div><div class="timeline-source">${esc(e.source||'')}</div></article>`;}).join('');
  const el=document.getElementById('timeline'); if(el)el.innerHTML=html||'<div class="now-loading">No dated releases are on the calendar yet.</div>';
}

(async()=>{
  document.getElementById('today').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  document.querySelectorAll('.js-date').forEach(el=>{el.textContent=dateLabel(el.dataset.date);});
  const newsAsof=document.getElementById('news-asof'); if(newsAsof){const d=new Date(newsAsof.dataset.date);newsAsof.textContent=`News through ${d.toLocaleDateString('en-US',{month:'short',day:'numeric'})} · ${d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}`;}
  const [loaded,health,areasData]=await Promise.all([
    loadSeries(['banxico-usdmxn-fix','banxico-bmv-ipc','banxico-cetes-28d','banxico-inflacion','banxico-inflacion-subyacente','banxico-tasa-objetivo','banxico-igae','banxico-remesas','banxico-reservas','fred-ust10']),
    fetch('/data/health.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('/data/areas.json').then(r=>r.ok?r.json():null).catch(()=>null)
  ]);
  renderNow(); renderTimeline();
  const areas=document.getElementById('areas'); if(areas){areas.innerHTML=renderAreas(areasData);if(!areas.innerHTML)areas.closest('section')?.remove();}
  const aa=document.getElementById('areas-asof'); if(aa&&areasData?.meta?.updated)aa.textContent='updated '+dateLabel(areasData.meta.updated);
  const sources=health?.sources||[],sm=health?{current:0,reviews:0,expected:0,issues:0}:null;
  if(sm)for(const source of sources){if(source.status==='failed')sm.issues++;else if(source.status==='ok_flagged'){const flags=source.flags||[];if(flags.some(flag=>String(flag).startsWith('stale_')))sm.expected++;else sm.reviews++;}else if(source.status==='ok')sm.current++;else if(source.status!=='skipped')sm.expected++;}
  const status=document.getElementById('status'),fresh=document.getElementById('fresh');
  if(sm&&status){const checked=health.generatedAt?Date.parse(health.generatedAt):null;const parts=[`${(sm.current||0)+(sm.reviews||0)+(sm.expected||0)} feeds checked`];if(sm.issues)parts.push(`${sm.issues} issue${sm.issues===1?'':'s'}`);if(sm.expected)parts.push(`${sm.expected} expected`);if(checked)parts.push(`checked ${relTime(checked)}`);status.textContent=parts.join(' · ');fresh.classList.add(sm.issues?'has-issue':sm.expected?'has-expected':'all-current');}
  else if(status)status.textContent='Feed status unavailable';
  const summary=document.getElementById('morning-summary'),tail=document.getElementById('summary-next')?.textContent?.trim();
  if(summary){const parts=[summary.textContent.trim()];const p=point('banxico-usdmxn-fix'),py=nearAgo('banxico-usdmxn-fix',365,10),i=point('banxico-inflacion'),c=point('banxico-inflacion-subyacente');if(p&&py)parts.push(`The exchange rate is ${n(Math.abs((p.value/py.value-1)*100),1)}% ${p.value<py.value?'lower':'higher'} than a year ago, which means a ${p.value<py.value?'stronger':'weaker'} peso.`);if(i)parts.push(`${monthLabel(i.date)} inflation was ${n(i.value,2)}% and ${i.value>=2&&i.value<=4?'inside':'outside'} Banxico's target. Core inflation is ${c?n(c.value,2)+'%':'not available'}.`);if(tail)parts.push(tail);summary.textContent=parts.join(' ');}
})().catch(err=>{
  const now=document.getElementById('mexico-now');if(now)now.innerHTML='<div class="now-loading">The current readings could not be loaded. The source links remain available.</div>';
  window.reportMexicoDataError?.('homepage',err);
});
</script>
