     `<span class="stamp">ANNUAL · 2024</span><span class="tsrc">SESNSP / INEGI</span></div></a>`;
  h+=`<a class="tilelink extra" href="/politics.html"><div class="tile"><div class="tl">Presidential approval</div>`+
