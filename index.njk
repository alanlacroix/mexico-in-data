  // year-end expectation, turning the date list into an economic calendar (Fable move #2).
  const xInf=point('banxico-exp-inflacion'),xPib=point('banxico-exp-pib');
  const html=ev.map(e=>{const c=eventCopy(e),d=new Date(e.date+'T00:00:00'),label=e.approx?`Week of ${dateLabel(e.date)}`:dateLabel(e.date);const t=String(e.label||'')+' '+c.title;const cons=(/cpi|inflaci|inflation|precios|fortnight/i.test(t)&&xInf)?`Consensus ${n(xInf.value,2)}% · year-end`:((/igae|gdp|pib|activity|actividad|econom/i.test(t)&&xPib)?`Consensus ${n(xPib.value,1)}% GDP · 2026`:'');return `<article class="timeline-item"><div class="timeline-date">${esc(label)}</div><div class="timeline-title">${esc(c.title)}</div><div class="timeline-why">${esc(c.why)}</div>${cons?`<div class="timeline-cons">${esc(cons)}</div>`:''}<div class="timeline-source">${esc(e.source||'')}</div></article>`;}).join('');
  const el=document.getElementById('timeline'); if(el&&ev.length)el.innerHTML=html;   // else keep the baked floor
}

(async()=>{
  document.getElementById('today').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  // Live, time-aware hero greeting: "Mexico Thursday morning/afternoon/evening" (visitor's
  // local day + time). No-JS fallback stays "Mexico this morning" (the daily-starting-point line).
  {const now=new Date();const wd=now.toLocaleDateString('en-US',{weekday:'long'});const hr=now.getHours();const tod=hr<12?'morning':hr<18?'afternoon':'evening';const ht=document.getElementById('hero-title');if(ht)ht.textContent=`Mexico ${wd} ${tod}`;}
  document.querySelectorAll('.js-date').forEach(el=>{el.textContent=dateLabel(el.dataset.date);});
  // Personal daily delta: quietly mark the stories this visitor has not seen yet (localStorage,
