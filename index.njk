}
const n=(v,d=2)=>Number(v).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});
const signed=(v,d=2)=>`${Number(v)>=0?'+':''}${n(v,d)}%`;
function dateLabel(iso,withYear=false){
