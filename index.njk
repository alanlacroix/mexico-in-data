    const rows=[...document.querySelectorAll('.brief-row[data-url]')];
    let fresh=0;
    for(const row of rows){
      const u=row.dataset.url; if(!u) continue;
      if(!first&&!seen.has(u)){
        fresh++;
        const meta=row.querySelector('.story-meta');
        if(meta){const tag=document.createElement('span');tag.className='tag-new';tag.textContent='New';meta.insertBefore(tag,meta.querySelector('.js-date'));}
      }
    }
    const urls=rows.map(r=>r.dataset.url).filter(Boolean);
    localStorage.setItem(KEY,JSON.stringify([...new Set([...urls,...seen])].slice(0,300)));
    const chip=document.getElementById('delta-chip');
    if(chip&&fresh>0){chip.textContent=`${fresh} new ${fresh===1?'story':'stories'}`;chip.hidden=false;}
  }catch(e){}
  const newsAsof=document.getElementById('news-asof'); if(newsAsof){const d=new Date(newsAsof.dataset.date);newsAsof.textContent=`Updated ${d.toLocaleDateString('en-US',{month:'short',day:'numeric'})} · ${d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}`;}
  const [loaded,health,areasData]=await Promise.all([
    loadSeries(['banxico-usdmxn-fix','banxico-bmv-ipc','banxico-cetes-28d','banxico-inflacion','banxico-inflacion-subyacente','banxico-tasa-objetivo','banxico-igae','banxico-remesas','banxico-reservas','fred-ust10','banxico-exp-inflacion','banxico-exp-cete','banxico-exp-usdmxn','banxico-exp-pib','shcp-deuda-neta']),
    fetch('/data/health.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('/data/areas.json').then(r=>r.ok?r.json():null).catch(()=>null)
  ]);
