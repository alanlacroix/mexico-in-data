/* ============ WHAT CHANGED (block 2, the lead) — the event-log queue ============
   Leads with detected official releases/revisions since your last visit; when the log
   is still sparse it falls back to the SAME series-delta computation the old "what moved"
   strip used, so the block is never empty. A private, public-safe lens ranks
   threshold-crossers first. Never invents a figure; every path degrades to a quiet line. */

/* series → owning section + short label (event rows + fallback rows share this) */
const SERIES_META={
  'banxico-usdmxn-fix':{label:'Peso',href:'/money.html'},
  'banxico-inflacion':{label:'Inflation',href:'/money.html'},
  'banxico-inflacion-subyacente':{label:'Core inflation',href:'/money.html'},
  'banxico-tasa-objetivo':{label:'Policy rate',href:'/money.html'},
  'banxico-reservas':{label:'Reserves',href:'/money.html'},
  'banxico-remesas':{label:'Remittances',href:'/money.html'},
  'banxico-pib-crecimiento':{label:'Growth',href:'/economy.html'},
  'banxico-igae':{label:'Economic activity',href:'/economy.html'},
};
const metaFor=(id)=>SERIES_META[id]||{label:id,href:'/data.html'};

/* the lens — generic, public-safe defaults; Al can override it in his own browser via
   localStorage 'mb_lens'. It only personalizes RANKING (crossers sort first + get a flag). */
const DEFAULT_LENS={
  watch:['banxico-usdmxn-fix','banxico-inflacion','banxico-tasa-objetivo','banxico-pib-crecimiento','banxico-remesas'],
  thresholds:{'banxico-usdmxn-fix':{band:[17.0,18.0]},'banxico-inflacion':{move:0.3},'banxico-tasa-objetivo':{anyChange:true}}
};
function getLens(){ try{ const o=JSON.parse(localStorage.getItem('mb_lens')||'null'); if(o&&Array.isArray(o.watch)) return o; }catch(e){} return DEFAULT_LENS; }

/* ---- IMPACT SCORE — the transparent, tunable ranker -----------------------
   Every row (event OR series-delta fallback) is scored the SAME way:

     impact = magnitude^wM · exposure^wE · freshness^wF · surprise^wS · confidence^wC

   A product of five ~1.0-centred factors, each raised to a per-factor weight.
   Weights are EXPONENTS on purpose, not multipliers: a plain multiplier on a
   product is the same scalar on every row, so it can never change the RANKING —
   only an exponent lets a weight actually re-order the queue (0 = ignore the
   factor · 1 = as-is · >1 = amplify). Defaults are all 1.0, so by default the
   score is exactly the plain product above.
   surprise & confidence are honest, named placeholders fixed at 1.0 (we have no
   forecast/expectation data yet, so we NEVER invent a surprise): they are real
   weighted slots, wired to data later — nothing here gets rebuilt when they are. */
const DEFAULT_SCORE_WEIGHTS={magnitude:1,exposure:1,freshness:1,surprise:1,confidence:1};
function getWeights(){
  try{ const o=JSON.parse(localStorage.getItem('mb_score_weights')||'null');
    if(o&&typeof o==='object'){ const w={...DEFAULT_SCORE_WEIGHTS};
      for(const k of Object.keys(DEFAULT_SCORE_WEIGHTS)) if(isFinite(Number(o[k]))) w[k]=Number(o[k]);
      return w; } }catch(e){}
  return {...DEFAULT_SCORE_WEIGHTS};
}
const hasSeries=(id)=>{ const s=S[id]; return !!(s&&s.data&&s.data.length>=3); };
/* magnitude scale = how much THIS series usually moves — stdev of its recent
   period-over-period changes; degrades to mean-abs-change, then to |prev|. */
function scaleFor(id,prevAbs){
  const s=S[id], d=s&&s.data;
  if(d&&d.length>=3){
    const vals=d.slice(-13).map(p=>Number(p.value)).filter(isFinite);
    if(vals.length>=3){
      const diffs=[]; for(let i=1;i<vals.length;i++) diffs.push(vals[i]-vals[i-1]);
      const mean=diffs.reduce((a,b)=>a+b,0)/diffs.length;
      const sd=Math.sqrt(diffs.reduce((a,b)=>a+(b-mean)*(b-mean),0)/diffs.length);
      if(sd>0) return sd;
      const mad=diffs.reduce((a,b)=>a+Math.abs(b),0)/diffs.length;
      if(mad>0) return mad;
    }
  }
  return (isFinite(prevAbs)&&prevAbs>0)?prevAbs:1;
}
function magnitudeOf(chg,id,prevAbs){
  const c=Number(chg);
  if(!isFinite(c)) return 1;   // move unknown → neutral (never zero a real crosser)
  if(c===0) return 0;          // genuinely flat → no magnitude
  const m=Math.abs(c)/scaleFor(id,prevAbs);
  return (isFinite(m)&&m>0)?Math.min(m,8):1;   // cap so one factor can't run away
}
const exposureOf=(watched,crosser)=>crosser?3:(watched?1.5:1);   // act-now > on-watch > off-watch
const FRESH_HALFLIFE_DAYS=7;
function freshnessOf(ts){ if(!isFinite(ts)) return 1; const age=Math.max(0,(Date.now()-ts)/864e5); return Math.pow(2,-age/FRESH_HALFLIFE_DAYS); }
function scoreRow(r,w){
  const factors=[
    {key:'magnitude', label:'Magnitude', v:r.mag,        weight:w.magnitude,  ph:false, note:r.magNote||''},
    {key:'exposure',  label:'Exposure',  v:r.exposure,   weight:w.exposure,   ph:false, note:r.crosser?'crosses a threshold':(r.watched?'on the watch list':'not on watch')},
    {key:'freshness', label:'Freshness', v:r.freshness,  weight:w.freshness,  ph:false, note:r.freshNote||''},
    {key:'surprise',  label:'Surprise',  v:(isFinite(r.surprise)?r.surprise:1),   weight:w.surprise,   ph:true, note:'not yet wired (=1)'},
    {key:'confidence',label:'Confidence',v:(isFinite(r.confidence)?r.confidence:1),weight:w.confidence, ph:true, note:'not yet wired (=1)'},
  ];
  let score=1;
  for(const f of factors){ const c=Math.pow(Math.max(Number(f.v)||0,0),f.weight); f.contribution=isFinite(c)?c:0; score*=f.contribution; }
  return {score:isFinite(score)?score:0, factors};
}

/* the "since" point: the last visit (localStorage 'mb_lastvisit'), else the last ~3 days */
function readSince(){
  let raw=null; try{ raw=localStorage.getItem('mb_lastvisit'); }catch(e){}
  const t=raw?Date.parse(raw):NaN;
  if(raw&&!isNaN(t)) return {since:t,first:false,label:'Since '+new Date(t).toLocaleDateString('en-US',{month:'short',day:'numeric'})};
  return {since:Date.now()-3*864e5,first:true,label:'Recently'};
}
function writeVisit(){ try{ localStorage.setItem('mb_lastvisit',new Date().toISOString()); }catch(e){} }

/* prev_value → value with units, e.g. "4.0% → 3.4%" (decimals matched across the pair) */
function decs(n){ const s=String(n),i=s.indexOf('.'); return i<0?0:Math.min(2,s.length-i-1); }
function evNum(x,d){ x=Number(x); return Math.abs(x)>=1000?enNum(Math.round(x)):x.toFixed(d); }
function evPair(e){
  const u=(e.units||'').trim(), short=u.length>0&&u.length<=3, suf=short?u:(u?' '+u:'');
  const hasP=e.prev_value!=null&&e.prev_value!==''&&!isNaN(Number(e.prev_value));
  const hasV=e.value!=null&&e.value!==''&&!isNaN(Number(e.value));
  if(!hasV&&!hasP) return '';
  const d=Math.max(hasP?decs(Number(e.prev_value)):0,hasV?decs(Number(e.value)):0);
  if(!hasV) return evNum(e.prev_value,d)+suf;
  if(!hasP) return evNum(e.value,d)+suf;
  return short?evNum(e.prev_value,d)+u+' → '+evNum(e.value,d)+u:evNum(e.prev_value,d)+' → '+evNum(e.value,d)+suf;
}
function evChange(e){ const v=Number(e.value),p=Number(e.prev_value); if(e.change!=null&&!isNaN(Number(e.change))) return Number(e.change); return (isFinite(v)&&isFinite(p))?v-p:NaN; }
function evRel(e){ const chg=evChange(e),base=Math.abs(Number(e.prev_value))||Math.abs(Number(e.value))||1; return isFinite(chg)?Math.abs(chg)/base:0; }
function crosses(e,lens){
  if(!lens||!Array.isArray(lens.watch)||lens.watch.indexOf(e.series)<0) return false;
  const th=(lens.thresholds||{})[e.series]; if(!th) return false;
  const v=Number(e.value),chg=evChange(e);
  if(th.band&&isFinite(v)&&(v<th.band[0]||v>th.band[1])) return true;       // value left the band
  if(th.move!=null&&isFinite(chg)&&Math.abs(chg)>=th.move) return true;     // moved at least `move`
  if(th.anyChange&&(!isFinite(chg)||chg!==0)) return true;                  // any change at all
  return false;
}
function eventRow(e,lens){
  const m=metaFor(e.series), whenT=Date.parse(e.published_at||e.detected_at||'');
  const freshT=Date.parse(e.detected_at||e.published_at||'');   // freshness decays from detected_at
  const bits=[e.period||'',isNaN(whenT)?'':relTime(whenT),e.kind==='revision'?'revised':''].filter(Boolean);
  const chg=evChange(e);
  const prevN=Math.abs(Number(e.prev_value)), prevAbs=(isFinite(prevN)&&prevN>0)?prevN:Math.abs(Number(e.value));
  const watched=Array.isArray(lens&&lens.watch)&&lens.watch.indexOf(e.series)>=0, crosser=crosses(e,lens);
  return {series:e.series,href:m.href,label:e.metric||m.label,move:evPair(e),meta:bits.join(' · '),
          crosser,watched,rel:evRel(e),sourceUrl:e.sourceUrl||'',source:e.source||'source',
          mag:magnitudeOf(chg,e.series,prevAbs),exposure:exposureOf(watched,crosser),
          freshness:freshnessOf(freshT),surprise:1,confidence:1,
          magNote:hasSeries(e.series)?'move ÷ recent volatility':'move ÷ previous level',
          freshNote:isFinite(freshT)?('detected '+relTime(freshT)):'detection time unknown'};
}

/* fallback = the series-delta computation the old "what moved" strip used, reused here.
   For each mover, find the point nearest N days back and compare with the latest; skip
   when there's no point far enough back (never invent a delta) or the change is tiny. */
const MOVERS=[
  {id:'banxico-usdmxn-fix',    label:'Peso',              href:'/money.html', days:7,  unit:'pct', when:'past week'},
  {id:'banxico-inflacion',     label:'Inflation',         href:'/money.html', days:32, unit:'pp',  when:'past month'},
  {id:'banxico-tasa-objetivo', label:'Banxico policy rate',href:'/money.html',days:50, unit:'pp',  when:'past 6 weeks'},
  {id:'banxico-reservas',      label:'International reserves',href:'/money.html',days:8,unit:'pct', when:'past week'},
  {id:'banxico-remesas',       label:'Remittances',       href:'/money.html', days:32, unit:'pct', when:'past month'},
  {id:'banxico-igae',          label:'Economic activity (IGAE)',href:'/economy.html',days:32,unit:'pp',when:'past month'},
];
function moveOver(s,days){
  const d=s&&s.data; if(!d||d.length<2) return null;
  const last=d[d.length-1], lastT=+new Date(last.date), tgt=lastT-days*864e5;
  let best=d[0],bd=1e18; for(const p of d){const dd=Math.abs(+new Date(p.date)-tgt); if(dd<bd){bd=dd;best=p;}}
  if(best.date===last.date) return null;                       // no earlier point → no delta
  if(lastT-(+new Date(best.date)) < days*0.4*864e5) return null; // comparison point too close to now
  return {cur:last.value, prev:best.value};
}
function fallbackRows(exclude,lens){
  const out=[];
  for(const m of MOVERS){
    if(exclude.has(m.id)) continue;
    const mv=moveOver(S[m.id],m.days); if(!mv) continue;
    const diff=mv.cur-mv.prev; if(diff===0) continue;
    let move;
    if(m.unit==='pp'){ if(Math.abs(diff)<0.05) continue; move=(diff>0?'+':'−')+Math.abs(diff).toFixed(2)+' pp'; }
    else { const pct=diff/mv.prev*100; if(Math.abs(pct)<0.25) continue; move=(pct>0?'+':'−')+Math.abs(pct).toFixed(1)+'%'; }
    // scored the SAME way as an event: run it through crosses() with a pseudo-event
    const pseudo={series:m.id,value:mv.cur,prev_value:mv.prev,change:diff};
    const watched=Array.isArray(lens&&lens.watch)&&lens.watch.indexOf(m.id)>=0, crosser=crosses(pseudo,lens);
    const prevAbs=Math.abs(mv.prev);
    // no detection event here — the delta is computed NOW from the freshest print, so
    // freshness is neutral (1). It must NOT decay with data vintage: that would penalise
    // slow-cadence series (a monthly inflation print is structurally ~weeks old) and sink
    // real crossers. freshness goes live once the event log (detected_at) feeds this queue.
    out.push({series:m.id,href:m.href,label:m.label,move,meta:m.when,crosser,watched,
      rel:Math.abs(diff)/(Math.abs(mv.prev)||1),
      mag:magnitudeOf(diff,m.id,prevAbs),exposure:exposureOf(watched,crosser),
      freshness:1,surprise:1,confidence:1,
      magNote:hasSeries(m.id)?'move ÷ recent volatility':'move ÷ previous level',
      freshNote:'computed now (series-delta)'});
  }
  return out;
}
/* compact number + weight labels for the breakdown */
const fmtN=(n)=>{ n=Number(n); if(!isFinite(n)) return '—'; const a=Math.abs(n); return a>=100?n.toFixed(0):a>=10?n.toFixed(1):n.toFixed(2); };
const wLbl=(w)=>'w'+(Number.isInteger(w)?w:(+w).toFixed(2));
/* the expand panel: the final score + every factor's value, weight and contribution.
   surprise/confidence are shown in amber and labelled "not yet wired (=1)" so it's
   always clear they're placeholders, not real signal. */
function chgBreakdown(sc){
  const fr=sc.factors.map(f=>
    `<div class="bd-f${f.ph?' ph':''}"><span class="bd-fn">${f.label}</span>`+
    `<span class="bd-fv">${fmtN(f.v)}</span><span class="bd-fw">${wLbl(f.weight)}</span>`+
    `<span class="bd-fc">${fmtN(f.contribution)}</span>`+
    (f.note?`<span class="bd-note">${f.note}</span>`:'')+`</div>`).join('');
  return `<div class="bd-head"><span class="bd-k">Impact score</span><span class="bd-score">${fmtN(sc.score)}</span></div>`+
    `<div class="bd-grid"><div class="bd-hd"><span>factor</span><span>value</span><span>wt</span><span>=contrib</span></div>${fr}</div>`+
    `<div class="bd-eq">score = magnitude × exposure × freshness × surprise × confidence, each raised to its weight. Tune the weights per-browser via <code>mb_score_weights</code>.</div>`;
}
function chgRow(r,i){
  const sc=r.sc||{score:0,factors:[]};
  const flag=r.crosser?`<span class="cg-flag">Act</span>`:'';
  const move=r.move?`<span class="cg-move">${r.move}</span>`:'';
  const right=r.sourceUrl?`<a class="cg-src" href="${r.sourceUrl}" target="_blank" rel="noopener">${r.source} ↗</a>`:`<span class="cg-go">→</span>`;
  const bid='cgbd-'+i;
  return `<div class="chg-item"><div class="chgrow${r.crosser?' cross':''}">`+
    `<a class="cg-body" href="${r.href}"><div class="cg-line">${flag}<span class="cg-lbl">${r.label}</span>${move}</div>`+
    (r.meta?`<div class="cg-meta">${r.meta}</div>`:'')+`</a>${right}`+
    `<button class="cg-caret" type="button" aria-expanded="false" aria-controls="${bid}" title="Impact score & how it's built">▸</button>`+
    `</div><div class="cg-breakdown" id="${bid}" hidden>${chgBreakdown(sc)}</div></div>`;
}
function renderChanged(releases,since,lens){
  const weights=getWeights();
  const evs=((releases&&releases.events)||[]).map(e=>({e,t:Date.parse(e&&e.detected_at)})).filter(x=>!isNaN(x.t));
  // return visit: events detected since your last visit · first visit: the most recent ~5
  const picked=(since.first?evs.sort((a,b)=>b.t-a.t):evs.filter(x=>x.t>since.since).sort((a,b)=>b.t-a.t)).slice(0,5).map(x=>x.e);
  let rows=picked.map(e=>eventRow(e,lens));
  if(rows.length<2){ const have=new Set(rows.map(r=>r.series)); rows=rows.concat(fallbackRows(have,lens)); } // supplement, never empty
  rows.forEach(r=>{ r.sc=scoreRow(r,weights); });                                   // transparent impact score
  rows.sort((a,b)=>(b.sc.score-a.sc.score)||(b.crosser-a.crosser)||(b.rel-a.rel));  // score is the ranker (crossers rise via exposure)
  rows=rows.slice(0,5);
  if(!rows.length) return `<div class="chg-quiet">${since.first?'Nothing material to report in the last few days.':'Nothing material changed since your last visit.'}</div>`;
  return `<div class="chg">`+rows.map((r,i)=>chgRow(r,i)).join('')+`</div>`;
}

/* ============ WHAT'S HAPPENING (the lead) — curated cross-domain event log ============
   The daily reason to open: the developments moving Mexico across every domain — economy,
   money, politics, security, U.S.–Mexico — each dated and linked to a first-party or record
   source, with one line on why it matters. Ranked by importance, then recency. Seeded and
   hand-curated in data/happening.json for now; the auto-pipeline (DOF, Banxico, SESNSP, USTR
   connectors) appends to the same log as the additive next layer. */
const HAP_SECTIONS={
  'economy':{label:'Economy',href:'/economy.html'},
  'money':{label:'Money',href:'/money.html'},
  'politics':{label:'Politics',href:'/politics.html'},
  'security':{label:'Security',href:'/security.html'},
  'us-mexico':{label:'U.S.–Mexico',href:'/us-mexico.html'},
  'society':{label:'Society',href:'/society.html'},
};
function hapDate(iso){ if(!iso) return ''; const m=/^(\d{4})-(\d{2})-(\d{2})/.exec(iso); const d=m?new Date(+m[1],+m[2]-1,+m[3]):new Date(iso); if(isNaN(d)) return ''; return d.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }
function renderHappening(feed,since){
  const evs=((feed&&feed.events)||[]).slice();
  if(!evs.length) return `<div class="chg-quiet">No developments logged yet — the next run will post them here.</div>`;
  evs.forEach(e=>{ e._t=Date.parse(e.date)||0; });
  evs.sort((a,b)=>(b.importance-a.importance)||(b._t-a._t));
  // diversity-aware pick: at most 2 per section so the lead stays cross-domain (the whole point),
  // then fill any remaining slots by importance. Keeps security/politics from being buried under econ.
  const CAP=2, N=8, seen={}, rows=[];
  for(const e of evs){ if(rows.length>=N) break; const c=seen[e.section]||0; if(c<CAP){ rows.push(e); seen[e.section]=c+1; } }
  for(const e of evs){ if(rows.length>=N) break; if(rows.indexOf(e)<0) rows.push(e); }
  return `<div class="chg hap">`+rows.map(e=>{
    const sec=HAP_SECTIONS[e.section]||{label:e.section||'',href:'#'};
    const isNew=since&&!since.first&&e._t>since.since;
    return `<div class="chg-item"><div class="chgrow hap-row">`+
      `<a class="hap-tag" href="${sec.href}">${sec.label}</a>`+
      `<div class="cg-body hap-b">`+
        `<div class="hap-line"><span class="hap-date">${hapDate(e.date)}</span>`+(isNew?`<span class="cg-flag">New</span>`:``)+`<span class="hap-title">${e.title}</span></div>`+
        (e.why?`<div class="hap-why">${e.why}</div>`:``)+
      `</div>`+
      (e.url?`<a class="cg-src" href="${e.url}" target="_blank" rel="noopener">${e.source||'source'} →</a>`:``)+
    `</div></div>`;
  }).join('')+`</div>`;
}

/* ============ SECTION CARDS (block 5) ============ */
function renderCards(){
  const A=(NEWS&&NEWS.articles)||[];
  const first=(fn)=>{const m=A.find(fn);return m?m.title:'';};
  const g=S['banxico-pib-crecimiento'], gv=g?g.data.at(-1).value:null;
  const gStat=gv!=null?((gv>=0?'+':'')+gv.toFixed(1)+'%'):'≈1.4%';
  const peso=S['banxico-usdmxn-fix'], pStat=peso?peso.data.at(-1).value.toFixed(2):'—';
  const tw=(TRADE&&TRADE.latest)?('$'+Math.round(TRADE.latest.twoway_bn)):'$87';
  const cards=[
    {name:'Economy',     href:'/economy.html',  stat:gStat,   unit:'real GDP · YoY',   hl:first(a=>a.tag==='economy'||ECON_RX.test(a.title||''))},
    {name:'Money',       href:'/money.html',    stat:pStat,   unit:'MXN/USD · peso',   hl:first(a=>a.tag==='markets'||MONEY_RX.test(a.title||''))},
    {name:'Politics',    href:'/politics.html', stat:'49–68', unit:'% approval',       hl:first(a=>POL_RX.test(a.title||''))},
    {name:'Security',    href:'/security.html', stat:'~26',   unit:'per 100k · homicide',hl:first(a=>SEC_RX.test(a.title||''))},
    {name:'Society',     href:'/society.html',  stat:'29.6',  unit:'% in poverty',     hl:first(a=>SOC_RX.test(a.title||''))},
    {name:'U.S.–Mexico', href:'/us-mexico.html',stat:tw,      unit:'bn/mo two-way',    hl:first(a=>a.tag==='trade'||USMX_RX.test(a.title||''))},
  ];
  return cards.map(c=>`<a class="seccard" href="${c.href}"><div class="sc-k">${c.name}</div>`+
    `<div class="sc-stat">${c.stat} <small>${c.unit}</small></div>`+
    `<div class="sc-wire">${c.hl?c.hl:'<span class="sc-none">Open the section →</span>'}</div>`+
    `<span class="sc-go">${c.name} →</span></a>`).join('');
}

/* ============ WHAT TO WATCH (block 6, left) — next 3 dated catalysts ============ */
function renderWatch(){
  const ev=(EVENTS&&EVENTS.events)||[]; const now=Date.now();
  const up=ev.filter(e=>new Date(e.date)>=now-864e5).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,3);
  if(!up.length) return `<div class="cb-empty">No dated catalysts on the calendar yet.</div>`;
  return `<div class="watchtbl">`+up.map(e=>{const d=evDate(e);
    return `<div class="wtr"><div class="wd">${d.mo} ${d.day}<small>${d.y}${e.approx?' ~':''}</small></div><div class="wk ${e.kind||''}"></div>`+
      `<div class="wt">${e.label}<div class="wm">${e.mechanism||''}${e.sourceUrl?` · <a class="wsrc" href="${e.sourceUrl}" target="_blank" rel="noopener" style="color:var(--green)">${e.source||'source'}</a>`:''}</div></div></div>`;}).join('')+`</div>`;
}

/* ============ THE WIRE (block 6, right) — latest ~10, each tagged to its section ============ */
function secOf(a){
  const t=(a.tag||'').toLowerCase(), s=(a.title||'')+' '+(a.beat||'');
  if(SEC_RX.test(a.title||'')) return {l:'Security',h:'/security.html'};
  if(['politics','government','policy'].includes(t)||POL_RX.test(s)) return {l:'Politics',h:'/politics.html'};
  if(t==='trade'||USMX_RX.test(a.title||'')) return {l:'U.S.–Mexico',h:'/us-mexico.html'};
  if(SOC_RX.test(a.title||'')) return {l:'Society',h:'/society.html'};
  if(t==='markets'||MONEY_RX.test(a.title||'')) return {l:'Money',h:'/money.html'};
  return {l:'Economy',h:'/economy.html'};
}
function renderWire(){
  const A=(NEWS&&NEWS.articles)||[];
  if(!A.length) return `<div class="cb-empty">No headlines in the latest run — the next scheduled fetch will post them here.</div>`;
  return `<div class="wire">`+A.slice(0,10).map(a=>{const sec=secOf(a);const dd=a.date?new Date(a.date):null;const w=dd&&!isNaN(dd)?relTime(dd.getTime()):'';
    return `<div class="wi"><a class="wtag" href="${sec.h}">${sec.l}</a><div class="wbody"><a class="wt" href="${a.url}" target="_blank" rel="noopener">${a.title}</a><div class="wm">${a.domain||''}${w?' · '+w:''}</div></div></div>`;}).join('')+`</div>`;
}

/* ============ boot ============ */
(async()=>{
  const since=readSince();          // read the last-visit point BEFORE we overwrite it
  const lens=getLens();
  await loadSeries(['banxico-usdmxn-fix','banxico-inflacion','banxico-inflacion-subyacente','banxico-tasa-objetivo','banxico-reservas','banxico-remesas','banxico-pib-crecimiento','banxico-igae','wb-gdp-usd','wb-population','wb-gdp-per-capita']);
  const [health,trade,releases]=await Promise.all([
    fetch('./data/health.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('./data/trade-us.json').then(r=>r.ok?r.json():null).catch(()=>null),
    fetch('./data/releases.json').then(r=>r.ok?r.json():null).catch(()=>null),
  ]);
  TRADE=trade;

  // dateline: N sources · updated Xh ago (from data health + freshest series fetch)
  const times=Object.values(S).map(s=>new Date(s.meta.fetchedAt).getTime()).filter(t=>t&&!isNaN(t));
  const newest=times.length?Math.max(...times):0;
  const ok=(health&&health.summary&&health.summary.ok)||0;
  const st=document.getElementById('status'); if(st) st.textContent=(ok?`● ${ok} sources · `:'● ')+(newest?'updated '+relTime(newest):'updated live');
  const ba=document.getElementById('board-asof'); if(ba&&newest) ba.textContent='as of '+new Date(newest).toLocaleDateString('en-US',{month:'short',day:'numeric'});

  document.getElementById('tablero').innerHTML=renderBoard();

  // the lead: what changed since your last visit (event log → series-delta fallback)
  const changedEl=document.getElementById('changed');
  changedEl.innerHTML=renderHappening(HAPPENING,since);
  // expand a row (caret) to reveal its impact-score breakdown — delegated, one listener
  changedEl.addEventListener('click',(ev)=>{
    const btn=ev.target.closest('.cg-caret'); if(!btn||!changedEl.contains(btn)) return;
    const item=btn.closest('.chg-item'), panel=item&&item.querySelector('.cg-breakdown'); if(!panel) return;
    const opening=panel.hasAttribute('hidden');
    if(opening) panel.removeAttribute('hidden'); else panel.setAttribute('hidden','');
    btn.classList.toggle('open',opening); btn.setAttribute('aria-expanded',opening?'true':'false');
  });
  const cs=document.getElementById('chg-since'); if(cs) cs.textContent=(HAPPENING&&HAPPENING.meta&&HAPPENING.meta.updated)?('Updated '+hapDate(HAPPENING.meta.updated)):since.label;
  writeVisit();                     // stamp this visit so the next one has a "since" point

  document.getElementById('seccards').innerHTML=renderCards();
  document.getElementById('watch-list').innerHTML=renderWatch();
  document.getElementById('wire-list').innerHTML=renderWire();

  // "Show all indicators" — reveals the .extra tiles on mobile
  const bm=document.getElementById('board-more'), tbl=document.getElementById('tablero');
  if(bm&&tbl) bm.addEventListener('click',()=>{ const on=tbl.classList.toggle('show-all'); bm.setAttribute('aria-expanded',on?'true':'false'); bm.textContent=on?'Show fewer':'Show all indicators'; });

  // #q12 / #wire from an old link → scroll to the Wire block on this page
  if(location.hash==='#q12'||location.hash==='#wire'){const w=document.getElementById('wire'); if(w)w.scrollIntoView();}
})().catch(e=>{
  const h=document.getElementById('seccards'); if(h)h.innerHTML='<p style="font-family:var(--mono);font-size:12px;color:var(--red)">Error loading data: '+e.message+'</p>';
});
</script>
