---
layout: base.njk
permalink: /
title: "The Mexico Brief"
description: "The major developments in Mexico, the numbers moving today, and the dates coming next — with links to the original sources."
ogTitle: "The Mexico Brief"
ogDescription: "Mexico's major developments, key numbers, and original sources."
---
<style>
  .home{max-width:var(--maxw);margin:0 auto;padding:0 clamp(18px,4vw,44px)}
  .home a{text-underline-offset:3px}
  .home-head{padding:32px 0 14px;display:flex;align-items:center;justify-content:space-between;gap:12px 24px;flex-wrap:wrap;border-bottom:1px solid var(--line)}
  .home-date{font-size:clamp(20px,2.2vw,28px);font-weight:650;letter-spacing:-.015em}
  .home-status{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);text-decoration:none}
  .home-status:hover{color:var(--green-d)}
  .kicker{font-family:var(--mono);font-size:var(--fs-label);font-weight:650;letter-spacing:.055em;text-transform:uppercase;color:var(--green-d)}
  .section-top{display:flex;align-items:baseline;justify-content:space-between;gap:12px 20px;flex-wrap:wrap}
  .section-title{font-size:var(--fs-h2);line-height:1.12;letter-spacing:-.018em;margin:5px 0 0}
  .section-note,.asof{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .text-link{font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d)}

  .brief{border-top:2px solid var(--green);border-bottom:1px solid var(--line);padding:16px 0 20px;margin-top:28px}
  .brief-copy{font-size:clamp(18px,1.65vw,22px);line-height:1.58;color:var(--ink-2);max-width:78ch;margin-top:13px}
  .brief-view{font-size:var(--fs-small);line-height:1.55;color:var(--ink-2);max-width:76ch;margin-top:13px;padding-left:14px;border-left:2px solid var(--green)}
  .brief-view b{color:var(--ink)}
  .brief-sources{display:flex;align-items:center;gap:5px 14px;flex-wrap:wrap;margin-top:14px;font-family:var(--mono);font-size:11px;color:var(--mut)}
  .brief-sources a{color:var(--green-d)}

  .news{margin-top:46px;max-width:920px}
  .story-list{border-top:1px solid var(--line);margin-top:12px}
  .brief-story{padding:20px 0;border-bottom:1px solid var(--line);background:transparent}
  .story-meta{display:flex;align-items:center;gap:5px 11px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.025em;text-transform:uppercase;color:var(--mut);margin-bottom:7px}
  .story-topic{font-weight:650;color:var(--green-d);text-decoration:none}
  .story-title-row{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:10px;align-items:start}
  /* Story thumbnail: the article's own link-preview image — tucked top-right of the story
     with the headline and summary wrapping beside it (news-list convention), same size on
     every screen. Clicks through to the source named on the meta line; removed if it fails. */
  .story-copy{display:flow-root}
  .story-thumb{float:right;width:132px;height:88px;margin:4px 0 10px 14px;border-radius:4px;overflow:hidden;background:var(--paper-2)}
  .story-thumb img{width:100%;height:100%;object-fit:cover;display:block}
  @media(max-width:650px){.story-thumb{width:112px;height:74px;margin:3px 0 8px 12px}}
  .story-copy{min-width:0}
  .story-link{color:var(--ink);text-decoration:none}
  .story-link:hover{color:var(--green-d)}
  .brief-story h3{font-size:clamp(19px,1.55vw,23px);line-height:1.32;letter-spacing:-.008em;font-weight:600;margin:0;max-width:60ch}
  .major-list>.brief-story:first-child h3{font-size:clamp(23px,1.9vw,27px);line-height:1.27;font-weight:650;max-width:50ch}
  .story-summary{font-size:15.5px;line-height:1.5;color:var(--ink-2);max-width:72ch;margin:7px 0 0}
  .major-list>.brief-story:first-child .story-summary{font-size:16px}

  .context{position:relative;z-index:2}
  .context[open]{z-index:30}
  .context summary{white-space:nowrap}
  .context-pop{display:none;position:absolute;right:0;top:42px;width:min(440px,calc(100vw - 48px));padding:13px 15px;background:#fff;border:1px solid var(--line);border-radius:6px;box-shadow:0 10px 28px rgba(0,0,0,.09);font-size:13px;line-height:1.55;color:var(--ink-2);font-weight:400;text-align:left;z-index:20}
  .context-pop p+p{margin-top:8px;padding-top:8px;border-top:1px solid var(--line)}
  .context-pop .context-source{font-family:var(--mono);font-size:10px;color:var(--mut)}
  .context-pop .ck{font-family:var(--mono);font-size:10px;font-weight:650;letter-spacing:.05em;text-transform:uppercase;color:var(--green-d);margin-right:7px}
  .context[open] .context-pop{display:block}
  .story-title-row>.context[open]{grid-column:1/-1}
  .story-title-row>.context[open] summary{margin-left:auto}
  .story-title-row .context-pop{position:static;width:auto;margin-top:10px;padding:12px 14px;background:#f8f7f2;border:0;border-left:2px solid var(--green);border-radius:0;box-shadow:none;font-size:14px;line-height:1.55}
  .all-news{margin-top:24px;border-bottom:1px solid var(--line)}
  .all-news>summary{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px 0;color:var(--green-d);font-family:var(--mono);font-size:var(--fs-label);font-weight:650;letter-spacing:.035em;text-transform:uppercase;cursor:pointer}
  .all-news>summary::-webkit-details-marker{display:none}
  .all-news>summary::after{content:'+';font-size:17px;line-height:1}
  .all-news[open]>summary::after{content:'–'}
  .all-news-body{padding:2px 0 12px}
  .filters{display:flex;gap:7px;overflow-x:auto;padding:2px 0 13px;border-bottom:1px solid var(--line);scrollbar-width:none}
  .filters::-webkit-scrollbar{display:none}
  .filter{flex:0 0 auto;border:1px solid var(--line);border-radius:999px;background:#fff;color:var(--ink-2);padding:8px 13px;font-size:12px;cursor:pointer}
  .filter:hover,.filter.active{border-color:var(--green);color:var(--green-d);background:#f2f8f5}
  .all-story[hidden]{display:none}
  .empty{font-size:var(--fs-small);color:var(--mut);padding:24px 0}

  .markets,.week,.subscribe-section{margin-top:54px}
  .markets{border-top:2px solid var(--green);padding-top:14px}
  .market-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border:1px solid var(--line);border-radius:5px;overflow:visible;margin-top:14px}
  .market-card{position:relative;min-width:0;padding:15px 16px 14px;background:var(--paper)}
  .market-card+.market-card{border-left:1px solid var(--line)}
  .market-link{display:block;color:inherit;text-decoration:none}
  .market-name{font-family:var(--mono);font-size:11px;line-height:1.3;text-transform:uppercase;letter-spacing:.035em;color:var(--mut);padding-right:94px}
  .market-value{font-size:clamp(28px,3vw,39px);font-weight:650;line-height:1.04;letter-spacing:-.025em;margin-top:10px;font-variant-numeric:tabular-nums;white-space:nowrap}
  .market-unit{font-family:var(--mono);font-size:10px;color:var(--mut);letter-spacing:0;margin-left:3px}
  .market-move{font-size:13px;line-height:1.35;font-weight:650;margin-top:8px;font-variant-numeric:tabular-nums}
  .market-move.up{color:var(--green-d)}
  .market-move.down{color:var(--red)}
  .market-move.flat{color:var(--ink-2)}
  .market-compare{font-size:12px;line-height:1.4;color:var(--ink-2);margin-top:3px;min-height:34px}
  .market-date{font-family:var(--mono);font-size:10px;line-height:1.4;text-transform:uppercase;letter-spacing:.02em;color:var(--mut);margin-top:9px}
  .market-card>.context{position:absolute;right:13px;top:12px}
  .market-floor .market-compare{min-height:0}

  .week{border-top:1px solid var(--line);padding-top:14px}
  .timeline{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-top:13px}
  .timeline-item{padding:17px 18px 18px 0}
  .timeline-item+.timeline-item{border-left:1px solid var(--line);padding-left:18px}
  .timeline-date{font-size:var(--fs-body);font-weight:700;letter-spacing:-.01em;color:var(--ink)}
  .timeline-title{font-size:var(--fs-small);line-height:1.35;font-weight:650;margin-top:6px}
  .timeline-why{font-size:var(--fs-meta);line-height:1.48;color:var(--ink-2);margin-top:5px}
  .timeline-source{display:inline-block;font-family:var(--mono);font-size:10px;color:var(--mut);margin-top:8px}

  .sub{border:1px solid var(--line);border-radius:7px;padding:20px 22px 17px;background:#fbfaf6}
  .sub .line{font-size:var(--fs-small);color:var(--ink-2);margin-top:7px;line-height:1.5;max-width:74ch}
  .sub form{display:flex;gap:10px;flex-wrap:wrap;margin-top:13px}
  .sub input[type=email]{flex:1;min-width:220px;font-family:var(--sans);font-size:var(--fs-small);padding:12px 14px;border:1px solid var(--line);border-radius:7px;background:#fff;color:var(--ink)}
  .sub button{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:#fff;background:var(--green);border:0;border-radius:7px;padding:12px 24px;cursor:pointer}
  .sub .fine{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:10px}

  @media(max-width:900px){
    .market-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .market-card:nth-child(3){border-left:0;border-top:1px solid var(--line)}
    .market-card:nth-child(4){border-top:1px solid var(--line)}
    .timeline{grid-template-columns:repeat(2,minmax(0,1fr))}
    .timeline-item:nth-child(3){border-left:0;border-top:1px solid var(--line);padding-left:0}
    .timeline-item:nth-child(4){border-top:1px solid var(--line)}
  }
  @media(max-width:650px){
    .home-head{padding-top:24px}
    .brief{margin-top:22px}
    .brief-copy{font-size:18px;line-height:1.52}
    .news{margin-top:38px}
    .brief-story{padding:17px 0}
    .brief-story h3,.major-list>.brief-story:first-child h3{font-size:20px;line-height:1.32;font-weight:600}
    .story-title-row{grid-template-columns:1fr}
    .story-title-row>.context{justify-self:start}
    .market-grid{grid-template-columns:1fr}
    .market-card+.market-card,.market-card:nth-child(3){border-left:0;border-top:1px solid var(--line)}
    .market-value{font-size:32px}
    .market-compare{min-height:0}
    .timeline{grid-template-columns:1fr}
    .timeline-item,.timeline-item+.timeline-item,.timeline-item:nth-child(3),.timeline-item:nth-child(4){padding:14px 0 15px;border-left:0;border-top:1px solid var(--line)}
    .timeline-item:first-child{border-top:0}
  }
</style>

<div class="home">
  <header class="home-head">
    <div class="home-date" id="today">Mexico this morning</div>
    <a class="home-status" id="status" href="/sources.html">Checking the data</a>
  </header>

  <section class="brief" aria-labelledby="brief-title">
    <div class="section-top"><div class="kicker" id="brief-title">The brief</div><div class="asof" id="brief-asof" data-date="{{ dailyBrief.newsThrough }}">Updated {{ dailyBrief.newsThrough }}</div></div>
    <p class="brief-copy">{{ dailyBrief.summaryLead }}</p>
    {% if dailyBrief.view %}<p class="brief-view"><b>My view:</b> {{ dailyBrief.view }}</p>{% endif %}
    {% if dailyBrief.briefSources.length %}<div class="brief-sources"><span>Sources:</span>{% for item in dailyBrief.briefSources %}<a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.source }} ↗</a>{% endfor %}</div>{% endif %}
  </section>

  <section class="news" aria-labelledby="news-title">
    <div class="section-top"><div><h2 class="section-title" id="news-title">What happened</h2></div></div>
    <div class="be-key"><span class="be-mark" aria-hidden="true">BE</span><span><b>Briefly Explained.</b> Open it for more context behind a headline.</span></div>
    <div class="story-list major-list">
      {% for story in dailyBrief.stories %}
      <article class="brief-story">
        <div class="story-meta"><a class="story-topic" href="{{ story.topicUrl }}">{{ story.beat }}</a><span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span>{% if story.source %}<span>{{ story.source }}</span>{% endif %}</div>
        <div class="story-title-row">
          <div class="story-copy">{% if story.image %}<a class="story-thumb" href="{{ story.url }}" target="_blank" rel="noopener" title="Image: {{ story.source }}" aria-hidden="true" tabindex="-1"><img src="{{ story.image }}" alt="" loading="lazy" referrerpolicy="no-referrer" /></a>{% endif %}<a class="story-link" href="{{ story.url }}" target="_blank" rel="noopener"><h3>{{ story.title }}</h3></a>{% if story.summary %}<p class="story-summary">{{ story.summary }}</p>{% endif %}</div>
          <details class="context"><summary class="be-summary" aria-label="Briefly Explained" title="Briefly Explained"><span class="be-mark" aria-hidden="true">BE</span></summary><div class="context-pop">{% if story.drivers or story.implications or story.next %}{% if story.bg %}<p><span class="ck">Background</span>{{ story.bg }}</p>{% endif %}{% if story.drivers %}<p><span class="ck">Drivers</span>{{ story.drivers }}</p>{% endif %}{% if story.implications %}<p><span class="ck">Implications</span>{{ story.implications }}</p>{% endif %}{% if story.next %}<p><span class="ck">What's next</span>{{ story.next }}</p>{% endif %}{% else %}<p>{{ story.explanation }}</p>{% endif %}</div></details>
        </div>
      </article>
      {% endfor %}
    </div>

    <details class="all-news" id="all-news">
      <summary>More headlines</summary>
      <div class="all-news-body">
        <nav class="filters" aria-label="Filter headlines">
          <button class="filter active" type="button" data-topic="all">All</button>
          <button class="filter" type="button" data-topic="economy">Economy &amp; business</button>
          <button class="filter" type="button" data-topic="politics">Politics</button>
          <button class="filter" type="button" data-topic="society">Society &amp; security</button>
          <button class="filter" type="button" data-topic="us-mexico">U.S.–Mexico</button>
        </nav>
        <div class="story-list" id="all-news-list">
          {% for story in latestStories %}{% if not story.inBrief %}
          <article class="brief-story all-story" data-topic="{{ story.topic }}">
            <div class="story-meta"><a class="story-topic" href="/?topic={{ story.topic }}#all-news">{{ story.topicLabel }}</a><span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span>{% if story.source %}<span>{{ story.source }}</span>{% endif %}</div>
            <div class="story-title-row">
              <div class="story-copy"><a class="story-link" href="{{ story.url }}" target="_blank" rel="noopener"><h3>{{ story.title }}</h3></a>{% if story.summary %}<p class="story-summary">{{ story.summary }}</p>{% endif %}</div>
              <details class="context"><summary class="be-summary" aria-label="Briefly Explained" title="Briefly Explained"><span class="be-mark" aria-hidden="true">BE</span></summary><div class="context-pop">{% if story.drivers or story.implications or story.next %}{% if story.bg %}<p><span class="ck">Background</span>{{ story.bg }}</p>{% endif %}{% if story.drivers %}<p><span class="ck">Drivers</span>{{ story.drivers }}</p>{% endif %}{% if story.implications %}<p><span class="ck">Implications</span>{{ story.implications }}</p>{% endif %}{% if story.next %}<p><span class="ck">What's next</span>{{ story.next }}</p>{% endif %}{% else %}<p>{{ story.explanation }}</p>{% endif %}</div></details>
            </div>
          </article>
          {% endif %}{% endfor %}
        </div>
        <p class="empty" id="news-empty" hidden>No stories in this section yet.</p>
      </div>
    </details>
  </section>

  <section class="markets" aria-labelledby="markets-title">
    <div class="section-top"><div><h2 class="section-title" id="markets-title">Markets today</h2></div><a class="text-link" href="/chart.html">All numbers →</a></div>
    <div class="market-grid market-floor" id="market-grid">
      {% for item in nowBoard %}<article class="market-card"><a class="market-link" href="{{ item.href }}"><div class="market-name">{{ item.label }}</div><div class="market-value">{{ item.display }}</div><div class="market-date"><span class="js-date" data-date="{{ item.date }}">{{ item.date }}</span></div></a></article>{% endfor %}
    </div>
  </section>

  <section class="week" aria-labelledby="week-title">
    <div class="section-top"><div><h2 class="section-title" id="week-title">What’s happening this week</h2></div><span class="section-note">Official releases and meetings</span></div>
    <div class="timeline">
      {% for event in calendar %}<article class="timeline-item"><div class="timeline-date">{% if event.approx %}Week of {% endif %}<span class="js-date" data-date="{{ event.date }}">{{ event.date }}</span></div><div class="timeline-title">{{ event.title }}</div>{% if event.why %}<div class="timeline-why">{{ event.why }}</div>{% endif %}{% if event.sourceUrl %}<a class="timeline-source" href="{{ event.sourceUrl }}" target="_blank" rel="noopener">{{ event.source }} ↗</a>{% else %}<div class="timeline-source">{{ event.source }}</div>{% endif %}</article>{% endfor %}
    </div>
  </section>

  <section class="subscribe-section">
    <div class="sub"><div class="kicker">The email</div><p class="line">Once a week, I send the few things that changed in Mexico that I think are worth knowing. The original sources are there if you want to go deeper. <a href="/weekly.html">See an example →</a></p><form class="subform" method="post" action="/api/subscribe" novalidate><input type="email" name="email" placeholder="you@email.com" aria-label="Email address" autocomplete="email" inputmode="email" required /><label class="hp-field" aria-hidden="true">Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label><button type="submit">Subscribe</button></form><div class="fine submsg" aria-live="polite">One email a week. Unsubscribe whenever you want.</div></div>
  </section>
</div>

<script type="module">
import { loadSeries, S, relTime } from '/assets/mb.js?v=18';

const esc=(value)=>String(value==null?'':value).replace(/[&<>\"]/g,(c)=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]));
const last=(id)=>S[id]?.data?.at(-1)||null;
const prior=(id)=>S[id]?.data?.at(-2)||null;
const nearAgo=(id,days)=>{const rows=S[id]?.data||[];if(!rows.length)return null;const target=Date.parse(rows.at(-1).date)-days*864e5;let best=null,dist=Infinity;for(const row of rows){const d=Math.abs(Date.parse(row.date)-target);if(d<dist){dist=d;best=row;}}return dist<45*864e5?best:null;};
const num=(value,digits=2)=>Number(value).toLocaleString('en-US',{minimumFractionDigits:digits,maximumFractionDigits:digits});
const date=(iso,year=false)=>{if(!iso)return'';const d=new Date(/^\d{4}-\d{2}-\d{2}$/.test(iso)?iso+'T00:00:00':iso);return isNaN(d)?iso:d.toLocaleDateString('en-US',{month:'short',day:'numeric',...(year?{year:'numeric'}:{})});};

document.addEventListener('toggle',(event)=>{const detail=event.target;if(detail.matches?.('details.context')&&detail.open)document.querySelectorAll('details.context[open]').forEach((other)=>{if(other!==detail)other.open=false;});},true);

const newsFilters=[...document.querySelectorAll('.filter')];
const allStories=[...document.querySelectorAll('.all-story')];
const allNews=document.getElementById('all-news');
const newsEmpty=document.getElementById('news-empty');
function showNews(topic,push=false){
  let count=0;
  newsFilters.forEach((button)=>button.classList.toggle('active',button.dataset.topic===topic));
  allStories.forEach((story)=>{const show=topic==='all'||story.dataset.topic===topic;story.hidden=!show;if(show)count++;});
  if(newsEmpty)newsEmpty.hidden=count>0;
  if(push){const url=new URL(location.href);if(topic==='all')url.searchParams.delete('topic');else url.searchParams.set('topic',topic);url.hash='all-news';history.replaceState({},'',url);}
}
newsFilters.forEach((button)=>button.addEventListener('click',()=>showNews(button.dataset.topic,true)));
let initialTopic=new URLSearchParams(location.search).get('topic')||'all';
if(!newsFilters.some((button)=>button.dataset.topic===initialTopic))initialTopic='all';
if(initialTopic!=='all'&&allNews)allNews.open=true;
showNews(initialTopic);

function card({id,name,value,unit='',move='',direction='flat',compare='',stamp,context,source}){
  return `<article class="market-card"><a class="market-link" href="/chart.html?v=${esc(id)}"><div class="market-name">${esc(name)}</div><div class="market-value">${esc(value)}${unit?`<span class="market-unit">${esc(unit)}</span>`:''}</div><div class="market-move ${esc(direction)}">${esc(move)}</div>${compare?`<div class="market-compare">${esc(compare)}</div>`:'<div class="market-compare"></div>'}<div class="market-date">${esc(stamp)}</div></a><details class="context"><summary class="be-summary" aria-label="Briefly Explained" title="Briefly Explained"><span class="be-mark" aria-hidden="true">BE</span></summary><div class="context-pop"><p>${esc(context)}</p><p class="context-source">Source: ${esc(source)}</p></div></details></article>`;
}

function renderMarkets(){
  const cards=[];
  const peso=last('banxico-usdmxn-fix'),pesoP=prior('banxico-usdmxn-fix'),pesoY=nearAgo('banxico-usdmxn-fix',365);
  if(peso){const change=pesoP?(peso.value/pesoP.value-1)*100:0;const stronger=change<0;const year=pesoY?(peso.value/pesoY.value-1)*100:null;cards.push(card({id:'banxico-usdmxn-fix',name:'Peso · per US dollar',value:num(peso.value),move:pesoP?`${change<0?'↓':'↑'} ${num(Math.abs(change),2)}% today · ${stronger?'stronger':'weaker'}`:'Latest reading',direction:stronger?'up':'down',compare:year==null?'':`${num(Math.abs(year),1)}% ${year<0?'stronger':'weaker'} than a year ago`,stamp:`${date(peso.date,true)} · daily`,context:'A lower number means a stronger peso. Imports become cheaper, while each dollar earned by exporters or sent home as a remittance converts into fewer pesos.',source:'Banco de México (FIX)'}));}
  const ipc=last('banxico-bmv-ipc'),ipcP=prior('banxico-bmv-ipc'),ipcY=nearAgo('banxico-bmv-ipc',365);
  if(ipc){const change=ipcP?(ipc.value/ipcP.value-1)*100:0;const year=ipcY?(ipc.value/ipcY.value-1)*100:null;cards.push(card({id:'banxico-bmv-ipc',name:'S&P/BMV IPC',value:num(ipc.value,0),move:ipcP?`${change>=0?'↑':'↓'} ${num(Math.abs(change),2)}% today`:'Latest close',direction:change>0?'up':change<0?'down':'flat',compare:year==null?'':`${num(Math.abs(year),1)}% ${year>=0?'higher':'lower'} than a year ago`,stamp:`${date(ipc.date,true)} · close`,context:'Mexico’s main stock index. It tracks large listed companies, so it is useful for market sentiment but should not be read as the whole economy.',source:'Banco de México / BMV'}));}
  const cetes=last('banxico-cetes-28d'),cetesP=prior('banxico-cetes-28d');
  if(cetes){const change=cetesP?cetes.value-cetesP.value:0;cards.push(card({id:'banxico-cetes-28d',name:'Cetes · 28 days',value:`${num(cetes.value)}%`,move:cetesP?`${change>=0?'↑':'↓'} ${num(Math.abs(change),2)} points today`:'Latest yield',direction:change>0?'up':change<0?'down':'flat',compare:'Short-term Mexican government debt',stamp:`${date(cetes.date,true)} · daily`,context:'The market yield on very short-term Mexican government debt. It can move between Banxico meetings and is a useful check on near-term rate expectations.',source:'Banco de México'}));}
  const ust=last('fred-ust10'),ustP=prior('fred-ust10');
  if(ust){const change=ustP?ust.value-ustP.value:0;cards.push(card({id:'fred-ust10',name:'U.S. 10-year',value:`${num(ust.value)}%`,move:ustP?`${change>=0?'↑':'↓'} ${num(Math.abs(change),2)} points today`:'Latest yield',direction:change>0?'up':change<0?'down':'flat',compare:'Benchmark for dollar borrowing costs',stamp:`${date(ust.date,true)} · daily`,context:'Higher U.S. yields can make peso assets relatively less attractive and raise dollar borrowing costs for Mexican companies. They are one input, not a complete explanation for the peso.',source:'Federal Reserve (FRED)'}));}
  const grid=document.getElementById('market-grid');if(grid&&cards.length){grid.classList.remove('market-floor');grid.innerHTML=cards.join('');}
}

document.getElementById('today').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
document.querySelectorAll('.js-date').forEach((el)=>{el.textContent=date(el.dataset.date);});
const asof=document.getElementById('brief-asof');if(asof){const d=new Date(asof.dataset.date);asof.textContent=isNaN(d)?'':`Updated ${d.toLocaleDateString('en-US',{month:'short',day:'numeric'})} · ${d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'})}`;}

Promise.all([
  loadSeries(['banxico-usdmxn-fix','banxico-bmv-ipc','banxico-cetes-28d','fred-ust10']),
  fetch('/data/health.json').then((r)=>r.ok?r.json():null).catch(()=>null)
]).then(([,health])=>{
  renderMarkets();
  const status=document.getElementById('status');
  if(status&&health?.generatedAt){const checked=Date.parse(health.generatedAt);const failed=(health.sources||[]).filter((s)=>s.status==='failed').length;status.textContent=`Data checked ${relTime(checked)}${failed?` · ${failed} feed ${failed===1?'issue':'issues'}`:''}`;}
  else if(status)status.textContent='Open data sources';
}).catch(()=>{const status=document.getElementById('status');if(status)status.textContent='Open data sources';});

// Story thumbnails fail soft: a blocked or rotten image removes itself and the card
// reverts to text. The image is an enhancement, never a dependency.
document.querySelectorAll('.story-thumb img').forEach((img)=>{
  const kill=()=>{const t=img.closest('.story-thumb');if(t)t.remove();};
  if(img.complete&&img.naturalWidth===0)kill();else img.addEventListener('error',kill,{once:true});
});
</script>
