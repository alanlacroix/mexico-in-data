}
// Sparkline (Fable 2026-07-16, narrowly un-banning them for board tiles only): the recent
// shape of the series, one ink color, no fill, no axes. Cadence-aware window — last 30 days
// for daily series, last 12 observations for weekly/monthly, 8 for quarterly — so the line
// always shows a real shape, never one or two points.
function sparkOf(id){
  const s=S[id]; const a=s?.data||[]; if(a.length<3) return '';
  const cad=String(s?.meta?.cadence||'');
  let pts;
  if(/daily/i.test(cad)){const cut=Date.parse(a.at(-1).date)-30*864e5;pts=a.filter(p=>Date.parse(p.date)>=cut);}
  else if(/quarter/i.test(cad)) pts=a.slice(-8);
  else pts=a.slice(-12);
  if(pts.length<3) return '';
  const vs=pts.map(p=>+p.value).filter(Number.isFinite); if(vs.length<3) return '';
  const min=Math.min(...vs),max=Math.max(...vs),range=(max-min)||1;
  const W=96,H=24,P=2;
  const d=vs.map((v,i)=>((i?'L':'M')+(P+i*(W-2*P)/(vs.length-1)).toFixed(1)+' '+(H-P-((v-min)/range)*(H-2*P)).toFixed(1))).join('');
  return `<svg class="spark" viewBox="0 0 ${W} ${H}" width="${W}" height="${H}" aria-hidden="true" focusable="false"><path d="${d}" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
}
function metricCard({id,name,cadence,value,unit='',arrow='→',move,compare='',stamp,tone='neutral',why,consensus=''}){
  const spark=sparkOf(String(id).split(',')[0]);
  return `<article class="metric-card"><a class="metric-main" href="/chart.html?v=${esc(id)}"><div class="metric-top"><span class="metric-name">${esc(name)}</span><span class="metric-cadence">${esc(cadence)}</span></div><div class="metric-value">${esc(value)}${unit?` <small>${esc(unit)}</small>`:''}</div><div class="metric-move ${esc(tone)}"><span aria-hidden="true">${esc(arrow)}</span> ${esc(move)}</div>${compare?`<div class="metric-compare">${esc(compare)}</div>`:'<div class="metric-compare"></div>'}${spark}${consensus?`<div class="metric-consensus">${esc(consensus)}</div>`:''}<div class="metric-stamp">${esc(stamp)}</div></a><details class="now-more"><summary>Why it matters</summary><p>${esc(why)}</p></details></article>`;
}
function renderNow(){
  const peso=point('banxico-usdmxn-fix'),pesoP=prior('banxico-usdmxn-fix'),pesoY=nearAgo('banxico-usdmxn-fix',365,10);
