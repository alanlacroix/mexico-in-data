---
layout: base.njk
permalink: /
title: "The Mexico Brief: Mexico in official numbers"
description: "A daily starting point for Mexico's economy, politics, trade, society, and relationship with the US, with dates and links to the original sources."
ogTitle: "The Mexico Brief"
ogDescription: "Mexico's important numbers, what changed, and the original sources."
---
<style>
  body{font-size:var(--fs-body)}
  .home{max-width:var(--maxw);margin:0 auto;padding:0 clamp(18px,4vw,44px)}
  .home a{text-underline-offset:2px}
  .home-hero{padding:44px 0 18px}
  .home-topline{display:flex;align-items:center;justify-content:space-between;gap:10px 24px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.035em;text-transform:uppercase;color:var(--mut)}
  .home-topline .fresh{display:inline-flex;align-items:center;gap:7px;color:var(--mut);text-decoration:none}
  .home-topline .fresh:hover{color:var(--green-d)}
  .home-topline .dot{width:6px;height:6px;border-radius:50%;background:var(--green)}
  .home-topline .fresh.has-expected .dot{background:#a87813}
  .home-topline .fresh.has-issue .dot{background:var(--red)}
  .home-hero h1{font-size:var(--fs-display);line-height:1.04;letter-spacing:-.025em;margin:10px 0 6px}
  .section-k{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.055em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .morning-summary{border-top:2px solid var(--green);border-bottom:1px solid var(--line);padding:13px 0 15px}
  .morning-summary p{font-size:var(--fs-body);line-height:1.6;color:var(--ink-2);max-width:66ch}
  .brief-head{display:flex;align-items:center;justify-content:space-between;gap:12px}
  .delta-chip{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;font-weight:700;color:var(--green-d);white-space:nowrap}
  .delta-chip.quiet{color:var(--mut);font-weight:600}
  .tag-new{font-family:var(--mono);font-size:10px;letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:var(--green-d);border:1px solid var(--green);border-radius:3px;padding:0 5px;line-height:1.5}

  .top-grid{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(330px,.85fr);gap:36px;margin-top:56px}
  .section-rule{border-top:1px solid var(--line);padding-top:12px}
  .section-headline{display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:4px}
  .section-headline .asof{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .section-title{font-size:var(--fs-h2);line-height:1.12;margin:4px 0 8px}

  .brief-list{border-top:1px solid var(--line)}
  .brief-row{padding:24px 0;border-bottom:1px solid var(--line)}
  .story-meta{display:flex;align-items:center;gap:6px 10px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.025em;text-transform:uppercase;color:var(--mut);margin-bottom:6px}
  .story-meta .beat{color:var(--green-d);font-weight:600;text-decoration:none}
  a.beat:hover{text-decoration:underline;text-underline-offset:3px}
  .brief-row h3{font-size:var(--fs-h3);line-height:1.25;letter-spacing:-.006em;margin:0 0 6px;max-width:42ch}
  .brief-row>p{font-size:var(--fs-small);line-height:1.6;color:var(--ink-2);max-width:66ch}
  /* The LEAD: the ranking, expressed. h2 scale, full context, the top of the column. */
  .brief-lead h3{font-size:var(--fs-h2);line-height:1.16;letter-spacing:-.012em;max-width:34ch}
  .brief-lead>p{font-size:var(--fs-body);line-height:1.55;max-width:62ch}
  /* Compact rows (stories 4+): headline + tag + date; context via the hover preview. */
  .brief-compact{padding:13px 0;position:relative}
  .brief-compact h3{font-size:var(--fs-small);font-weight:600;line-height:1.4;margin:0;max-width:60ch;display:inline}
  .brief-compact .story-meta{margin-bottom:3px}
  .story-foot{display:flex;align-items:center;gap:2px 14px;flex-wrap:wrap;margin-top:10px;min-height:44px;font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .story-foot a{color:var(--green-d)}

  .now-group{margin-top:15px}
  .now-group+.now-group{margin-top:22px}
  .now-group-head{display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:7px}
  .now-group-title{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.045em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .now-group-note{font-family:var(--mono);font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.025em}
  .metric-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1px;background:var(--line);border:1px solid var(--line);border-radius:4px;overflow:hidden}
  .metric-card{display:flex;flex-direction:column;min-width:0;background:var(--paper);padding:12px 13px 10px;color:var(--ink)}
  .metric-card:last-child:nth-child(odd){grid-column:1 / -1}
  .metric-main{display:block;color:var(--ink);text-decoration:none;min-width:0}
  .metric-main:hover{text-decoration:none}
  .metric-top{display:flex;align-items:baseline;justify-content:space-between;gap:8px}
  .metric-name,.metric-cadence{font-family:var(--mono);font-size:10px;line-height:1.25;letter-spacing:.035em;text-transform:uppercase}
  .metric-name{color:var(--mut);font-weight:600}
  .metric-cadence{color:var(--green-d);white-space:nowrap}
  .metric-main:hover .metric-name{color:var(--green-d)}
  .metric-value{font-size:clamp(25px,2.1vw,31px);line-height:1;font-weight:650;letter-spacing:-.02em;font-variant-numeric:tabular-nums;margin-top:9px;white-space:nowrap}
  .metric-value small{font-family:var(--mono);font-size:10px;letter-spacing:0;color:var(--mut);font-weight:400;margin-left:3px}
  .metric-move{font-size:13px;line-height:1.3;font-weight:650;margin-top:8px;font-variant-numeric:tabular-nums}
  .metric-move.good{color:var(--green-d)}
  .metric-move.bad{color:var(--red)}
  .metric-move.neutral{color:var(--ink-2)}
  .metric-compare{font-size:11px;line-height:1.35;color:var(--ink-2);margin-top:3px;min-height:29px}
  .metric-stamp{font-family:var(--mono);font-size:10px;line-height:1.35;color:var(--mut);text-transform:uppercase;letter-spacing:.02em;margin-top:7px}
  .metric-consensus{font-family:var(--mono);font-size:10px;line-height:1.35;color:var(--green-d);text-transform:uppercase;letter-spacing:.02em;margin-top:5px}
  .spark{display:block;margin-top:8px;color:var(--mut);opacity:.55;max-width:100%}
  .now-more{margin-top:auto;padding-top:8px}
  .now-more summary{display:flex;align-items:center;justify-content:space-between;gap:8px;min-height:24px;font-family:var(--mono);font-size:10px;line-height:1.3;color:var(--green-d);cursor:pointer;list-style:none}
  .now-more summary::-webkit-details-marker{display:none}
  .now-more summary::after{content:"+";font-size:14px}
  .now-more[open] summary::after{content:"–"}
  .now-more p{font-size:12px;line-height:1.45;color:var(--ink-2);margin-top:6px;background:var(--green-bg);border-left:3px solid var(--green);border-radius:0 4px 4px 0;padding:7px 10px 8px}
  .section-link{display:inline-block;margin-top:11px;font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d)}
  .now-loading{border-top:1px solid var(--line);padding:16px 0;font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .now-floor{list-style:none;border-top:1px solid var(--line)}
  .now-floor .nf-row{display:flex;flex-direction:column;gap:3px;padding:11px 0;border-bottom:1px solid var(--line)}
  .now-floor a{display:flex;align-items:baseline;justify-content:space-between;gap:12px;text-decoration:none;color:var(--ink)}
  .now-floor a:hover .nf-label{color:var(--green-d)}
  .nf-label{font-family:var(--mono);font-size:var(--fs-label);text-transform:uppercase;letter-spacing:.03em;color:var(--mut);font-weight:600}
  .nf-val{font-weight:650;font-variant-numeric:tabular-nums;white-space:nowrap}
  .nf-meta{font-family:var(--mono);font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.02em}

  .companies,.topics,.coming,.subscribe-section{margin-top:56px}
  .company-list{border-top:1px solid var(--line)}
  .company-row{display:grid;grid-template-columns:140px minmax(0,1fr) auto;gap:8px 20px;align-items:start;padding:17px 0;border-bottom:1px solid var(--line)}
  .company-name{font-family:var(--mono);font-size:var(--fs-label);line-height:1.45;text-transform:uppercase;letter-spacing:.035em;color:var(--green-d);font-weight:600}
  .company-name span{display:block;color:var(--mut);font-weight:400;text-transform:none;letter-spacing:0}
  .company-body h3{font-size:var(--fs-body);line-height:1.3;margin:0 0 3px}
  .company-body p,.company-signal{font-size:var(--fs-small);line-height:1.5;color:var(--ink-2);margin:0}
  .company-signal b{color:var(--ink);font-weight:600}
  .company-source{font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d);white-space:nowrap}

  /* "Where things stand" — six one-line syntheses, each a door to its room (Fable 2026-07-16:
     the repeated headlines are gone; the synthesis is the unique value). */
  .areas{border-top:1px solid var(--line)}
  .stand{display:grid;grid-template-columns:150px minmax(0,1fr);gap:8px 20px;align-items:baseline;padding:13px 0;border-bottom:1px solid var(--line);text-decoration:none}
  .stand:hover .stand-k{text-decoration:underline;text-underline-offset:3px}
  .stand-k{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;color:var(--green-d);font-weight:600;white-space:nowrap}
  .stand-s{font-size:var(--fs-small);line-height:1.55;color:var(--ink-2);max-width:76ch}
  @media(max-width:650px){.stand{grid-template-columns:1fr;gap:3px}}
  .hl{position:relative}
  .hl-a{display:block;text-decoration:none}
  .hl-t{display:block;font-size:var(--fs-small);color:var(--ink);font-weight:500;line-height:1.36}
  .hl-t-ctx{text-decoration:underline dotted var(--line-2);text-underline-offset:3px}
  .hl-a:hover .hl-t,.hl-a:hover h3{color:var(--green-d)}
  .hl-m{display:block;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.02em;text-transform:uppercase;color:var(--mut);margin-top:3px}
  /* Hover preview (Fable 2026-07-16): reveal the pre-generated, gated context. No fetch, no
     model, no mascot — the record explaining itself. Desktop = hover/focus; touch = tap the ¿. */
  /* "Why it matters" — the site's signature layer (same phrase as the board tiles).
     Boxed callout: light green tint + a green left rule, visible by default (mobile has
     no hover), deepens on hover. Existing tokens only: --green-bg, --green, 4px radius. */
  .why-k{display:block;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.045em;text-transform:uppercase;color:var(--green-d);font-weight:700;margin:0 0 4px}
  .story-ctx{background:var(--green-bg);border-left:3px solid var(--green);border-radius:0 4px 4px 0;padding:10px 14px 11px;transition:border-color .12s ease}
  .brief-row:hover .story-ctx{border-left-color:var(--green-d)}
  .hl-info{display:block;margin-top:5px;padding:2px 0;border:none;background:none;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.045em;text-transform:uppercase;color:var(--green-d);font-weight:700;cursor:pointer;min-height:24px}
  .hl-info::after{content:" +"}
  .hl.is-open .hl-info::after{content:" –"}
  .hl-info:hover{text-decoration:underline;text-underline-offset:3px}
  .hl-pop{position:absolute;left:0;right:0;top:100%;z-index:20;margin-top:5px;background:var(--green-bg);border:1px solid var(--line-2);border-left:3px solid var(--green);border-radius:0 4px 4px 0;padding:11px 14px;opacity:0;visibility:hidden;transition:opacity .12s ease;pointer-events:none}
  .hl-pop p{font-size:var(--fs-meta);line-height:1.5;color:var(--ink-2);margin:0}
  .hl-pop-src{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.02em;color:var(--mut);margin-top:8px}
  .hl:hover .hl-pop,.hl:focus-within .hl-pop,.hl.is-open .hl-pop{opacity:1;visibility:visible}
  @media(hover:none){.hl:hover .hl-pop,.hl:focus-within .hl-pop{opacity:0;visibility:hidden}.hl.is-open .hl-pop{opacity:1;visibility:visible}}

  .timeline{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .timeline-item{padding:16px 18px 17px 0}
  .timeline-item+.timeline-item{border-left:1px solid var(--line);padding-left:18px}
  .timeline-date{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.035em;text-transform:uppercase;color:var(--green-d);font-weight:600}
  .timeline-title{font-size:var(--fs-small);line-height:1.35;color:var(--ink);font-weight:600;margin-top:6px}
  .timeline-why{font-size:var(--fs-meta);line-height:1.45;color:var(--ink-2);margin-top:5px}
  .timeline-cons{font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d);margin-top:6px;text-transform:uppercase;letter-spacing:.02em}
  .timeline-source{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);margin-top:7px}

  .sub{border:1px solid var(--line);border-radius:8px;padding:20px 22px 16px;background:#fbfaf6}
  .sub .lab{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);font-weight:700}
  .sub .line{font-size:var(--fs-small);color:var(--ink-2);margin-top:8px;line-height:1.5;max-width:76ch}
  .sub form{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
  .sub input[type=email]{flex:1;min-width:220px;font-family:var(--sans);font-size:var(--fs-small);padding:12px 14px;border:1px solid var(--line);border-radius:8px;background:#fff;color:var(--ink)}
  .sub input[type=email]:focus{outline:none;border-color:var(--green)}
  .sub button{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:#fff;background:var(--green);border:none;border-radius:8px;padding:12px 24px;cursor:pointer}
  .sub button:hover{background:var(--green-d)}
  .sub .fine{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:11px;line-height:1.6}

  @media(max-width:900px){
    .top-grid{grid-template-columns:1fr;gap:34px}
    .company-row{grid-template-columns:120px minmax(0,1fr) auto}
    .timeline{grid-template-columns:repeat(2,minmax(0,1fr))}
    .timeline-item:nth-child(3){border-left:0;border-top:1px solid var(--line);padding-left:0}
    .timeline-item:nth-child(4){border-top:1px solid var(--line)}
  }
  @media(max-width:650px){
    .home-hero{padding:32px 0 16px}
    .top-grid{margin-top:40px}
    .section-title{font-size:28px}
    .brief-row{padding:18px 0}
    .brief-row h3{line-height:1.25}
    .brief-row>p{line-height:1.48}
    .story-foot{gap:0 13px}
    .metric-grid{grid-template-columns:1fr}
    .metric-card:last-child:nth-child(odd){grid-column:auto}
    .metric-card{padding:12px 13px 10px}
    .metric-value{font-size:28px}
    .metric-compare{min-height:0}
    .company-row{grid-template-columns:1fr;gap:5px;padding:15px 0}
    .company-signal{grid-column:auto}
    .company-source{padding-top:5px}
    .timeline{grid-template-columns:1fr}
    .timeline-item{padding:14px 0 15px}
    .timeline-item+.timeline-item,.timeline-item:nth-child(3),.timeline-item:nth-child(4){border-left:0;border-top:1px solid var(--line);padding-left:0}
  }
</style>

<div class="home">
  <section class="home-hero">
    <div class="home-topline">
      <span id="today">Today</span>
      <a class="fresh" id="fresh" href="/sources.html"><span class="dot"></span><span id="status">Checking the data</span></a>
    </div>
    <h1 id="hero-title">Mexico this morning</h1>
  </section>

  <section class="morning-summary" aria-label="Morning summary">
    <div class="brief-head">
      <div class="section-k">The brief</div>
      {% if dailyBrief.quiet %}<span class="delta-chip quiet">Quiet stretch</span>{% else %}<span class="delta-chip" id="delta-chip" hidden></span>{% endif %}
    </div>
    <p id="morning-summary">{{ dailyBrief.summaryLead }}</p>
    <span id="summary-next" hidden>{{ dailyBrief.summaryNext }}</span>
  </section>

  <div class="top-grid">
    <section class="section-rule" aria-labelledby="news-title">
      <div class="section-headline"><div class="section-k">Latest</div><div class="asof" id="news-asof" data-date="{{ dailyBrief.newsThrough }}">Updated {{ dailyBrief.newsThrough }}</div></div>
      <h2 class="section-title" id="news-title">Today's news</h2>
      <div class="brief-list">
        {# Lead hierarchy (Fable 2026-07-16): the front page expresses the ranking the pipeline
           computes. Story 1 = the LEAD (h2 scale, full context); 2-3 = secondaries; 4+ = a
           compact list (headline + tag + date; context lives in the hover preview). The topic
           TAG is the link to its room — one story, one home, one tag. #}
        {% for story in dailyBrief.stories %}
        {% if loop.index == 1 %}
        <article class="brief-row brief-lead" data-url="{{ story.url }}">
          <div class="story-meta"><a class="beat" href="{{ story.topicUrl }}">{{ story.beat }}</a><span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span></div>
          <h3>{{ story.title }}</h3>
          <p class="story-ctx"><span class="why-k">Why it matters</span>{{ story.context }}</p>
          <div class="story-foot"><a href="{{ story.url }}" target="_blank" rel="noopener">{{ story.source }} ↗</a></div>
        </article>
        {% elif loop.index <= 3 %}
        <article class="brief-row" data-url="{{ story.url }}">
          <div class="story-meta"><a class="beat" href="{{ story.topicUrl }}">{{ story.beat }}</a><span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span></div>
          <h3>{{ story.title }}</h3>
          <p class="story-ctx"><span class="why-k">Why it matters</span>{{ story.context }}</p>
          <div class="story-foot"><a href="{{ story.url }}" target="_blank" rel="noopener">{{ story.source }} ↗</a></div>
        </article>
        {% else %}
        <article class="brief-row brief-compact hl" data-url="{{ story.url }}">
          <div class="story-meta"><a class="beat" href="{{ story.topicUrl }}">{{ story.beat }}</a><span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span></div>
          <a class="hl-a" href="{{ story.url }}" target="_blank" rel="noopener"><h3 class="{% if story.context %}hl-t-ctx{% endif %}">{{ story.title }}</h3></a>
          {% if story.context %}<button class="hl-info" type="button" aria-expanded="false">Why it matters</button>
          <div class="hl-pop" role="tooltip"><p><span class="why-k">Why it matters</span>{{ story.context }}</p><div class="hl-pop-src">{{ story.source }} · <span class="js-date" data-date="{{ story.date }}">{{ story.date }}</span></div></div>{% endif %}
        </article>
        {% endif %}
        {% endfor %}
      </div>
    </section>

    <aside class="rail">
      <section class="section-rule" aria-labelledby="now-title">
        <div class="section-k">Current readings</div>
        <h2 class="section-title" id="now-title">Mexico now</h2>
        <div id="mexico-now">
          <ul class="now-floor">
            {% for m in nowBoard %}
            <li class="nf-row"><a href="{{ m.href }}"><span class="nf-label">{{ m.label }}</span><span class="nf-val">{{ m.display }}</span></a><span class="nf-meta"><span class="js-date" data-date="{{ m.date }}">{{ m.date }}</span> · {{ m.source }}</span></li>
            {% endfor %}
          </ul>
        </div>
        <a class="section-link" href="/chart.html">Open all charts →</a>
      </section>
    </aside>
  </div>

{% if dailyBrief.companies.length %}
  <section class="companies section-rule" aria-labelledby="companies-title">
    <div class="section-headline"><div class="section-k">Companies</div><div class="asof">Latest signal and why I am watching</div></div>
    <h2 class="section-title" id="companies-title">Companies worth following</h2>
    <div class="company-list">
      {% for company in dailyBrief.companies %}
      <article class="company-row">
        <div class="company-name">{{ company.name }}<span>{{ company.sector }}</span></div>
        <div class="company-body">{% if company.thesis %}<h3>{{ company.title }}</h3><p>{{ company.thesis }}</p>{% endif %}<p class="company-signal"><b>Latest:</b> {{ company.signal }}</p></div>
        <a class="company-source" href="{{ company.url }}" target="_blank" rel="noopener"><span class="js-date" data-date="{{ company.date }}">{{ company.date }}</span> ↗</a>
      </article>
      {% endfor %}
    </div>
  </section>
{% endif %}

  <section class="topics section-rule" aria-labelledby="topics-title">
    <div class="section-headline"><div class="section-k">By topic</div><div class="asof" id="areas-asof"></div></div>
    <h2 class="section-title" id="topics-title">Where things stand</h2>
    <div class="areas" id="areas"></div>
  </section>

  <section class="coming section-rule" aria-labelledby="next-title">
    <div class="section-headline"><div class="section-k">Next</div><div class="asof">Four dates to watch</div></div>
    <h2 class="section-title" id="next-title">Coming up</h2>
    <div class="timeline" id="timeline">
      {% for e in calendar %}
      <article class="timeline-item"><div class="timeline-date">{% if e.approx %}Week of {% endif %}<span class="js-date" data-date="{{ e.date }}">{{ e.date }}</span></div><div class="timeline-title">{{ e.title }}</div>{% if e.why %}<div class="timeline-why">{{ e.why }}</div>{% endif %}<div class="timeline-source">{{ e.source }}</div></article>
      {% endfor %}
