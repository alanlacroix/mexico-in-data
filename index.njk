function renderAreas(data){
  // "Where things stand": one synthesis line per topic, the label linking to its room.
  // The repeated headlines are gone (they already live in Today's news + the rooms).
  const areas=(data&&data.areas)||[];
  return areas.filter(a=>a.synthesis).map(a=>`<a class="stand" href="${esc(a.href||'#')}"><span class="stand-k">${esc(a.label)} →</span><span class="stand-s">${esc(a.synthesis)}</span></a>`).join('');
}
function eventCopy(e){
  const t=String(e.label||'');
  if(/USMCA talks/i.test(t)) return {title:'Mexico–U.S. trade talks',why:'The next round after the first USMCA review.'};
  if(/first-fortnight July/i.test(t)) return {title:'First-half July inflation',why:'Shows whether the June decline continued.'};
  if(/IGAE/i.test(t)) return {title:'May economic activity',why:'The best monthly check on growth before GDP.'};
  if(/GDP flash/i.test(t)) return {title:'First estimate of Q2 GDP',why:'Shows whether the economy left the Q1 slowdown behind.'};
  return {title:t.split(/\s+[—–]\s+/)[0],why:e.mechanism||''};
}
function renderTimeline(){
  const today=new Date(); today.setHours(0,0,0,0);
  const future=((EVENTS&&EVENTS.events)||[]).filter(e=>Date.parse(e.date)>=today.getTime()-864e5).sort((a,b)=>String(a.date).localeCompare(String(b.date)));
  const wanted=[/USMCA talks/i,/first-fortnight July/i,/IGAE/i,/GDP flash/i];
  const ev=wanted.map(pattern=>future.find(e=>pattern.test(String(e.label||'')))).filter(Boolean);
  for(const e of future){if(ev.length>=4)break;if(!ev.includes(e))ev.push(e);}
