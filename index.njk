  if(rem){let arrow='→',move='Comparison unavailable',compare='';let tone='neutral';if(remY){const delta=(rem.value/remY.value-1)*100;arrow=delta>0?'▲':delta<0?'▼':'→';move=`${n(Math.abs(delta),1)}% ${delta>=0?'higher':'lower'}`;compare='Versus the same month last year';tone=delta>=0?'good':'bad';}else if(remP){const delta=rem.value-remP.value;arrow=delta>0?'▲':delta<0?'▼':'→';move=`US$${n(Math.abs(delta),0)}m ${delta>=0?'more':'less'}`;compare=`Versus ${monthLabel(remP.date)} · monthly totals are seasonal`;}releases.push(metricCard({id:'banxico-remesas',name:'Remittances',cadence:'Monthly',value:`US$${n(rem.value/1000,2)}bn`,arrow,move,compare,stamp:`${periodLabel('banxico-remesas',rem.date)} · Banxico`,tone,why:'Money sent home from abroad, mostly the US. It supports household spending and brings dollars into Mexico. The same month a year earlier is the better comparison.'}));}
  if(res){const delta=resP?res.value-resP.value:0;const year=resY?(res.value/resY.value-1)*100:null;releases.push(metricCard({id:'banxico-reservas',name:'International reserves',cadence:'Weekly',value:`US$${n(res.value/1000,0)}bn`,arrow:delta>0?'▲':delta<0?'▼':'→',move:resP?`US$${n(Math.abs(delta),0)}m ${delta>0?'higher':delta<0?'lower':'unchanged'}`:'Comparison unavailable',compare:year==null?'':`${n(Math.abs(year),1)}% ${year>=0?'higher':'lower'} over 1Y`,stamp:`${periodLabel('banxico-reservas',res.date)} · Banxico`,tone:'neutral',why:"Banxico's foreign-currency buffer against external shocks."}));}
  if(debt){const dMove=debtP?debt.value-debtP.value:null;releases.push(metricCard({id:'shcp-deuda-neta',name:'Public debt · net',cadence:'Monthly',value:`MX$${n(debt.value/1000,1)}tn`,arrow:dMove>0?'▲':dMove<0?'▼':'→',move:dMove==null?'':`MX$${n(Math.abs(dMove),0)}bn ${dMove>0?'higher':dMove<0?'lower':'unchanged'}`,compare:'Net public-sector debt',stamp:`${periodLabel('shcp-deuda-neta',debt.date)} · SHCP`,tone:'neutral',why:"The government's net debt. The cost of supporting Pemex on top of structural deficits is the story behind the Baa3 credit rating."}));}
  const el=document.getElementById('mexico-now');
