---
layout: base.njk
permalink: /
title: "The Mexico Brief"
description: "Today’s important Mexico headlines, the latest official numbers, and the connections between them, with links to the original sources."
ogTitle: "The Mexico Brief"
ogDescription: "Today’s Mexico headlines, official numbers, and the connections worth watching."
---
<style>
  .home{max-width:var(--maxw);margin:0 auto;padding:0 clamp(18px,4vw,44px)}
  .home a{text-underline-offset:3px}
  .home-head{padding:32px 0 15px;display:flex;align-items:flex-end;justify-content:space-between;gap:14px 24px;flex-wrap:wrap;border-bottom:1px solid var(--line)}
  .home-title{font-size:clamp(25px,2.8vw,36px);font-weight:650;line-height:1.1;letter-spacing:-.025em;margin:0}
  .home-date,.home-status{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .home-date{margin-top:6px}
  .home-status{text-decoration:none}
  .home-status:hover{color:var(--green-d)}
  .kicker{font-family:var(--mono);font-size:var(--fs-label);font-weight:650;letter-spacing:.055em;text-transform:uppercase;color:var(--green-d)}
  .section-top{display:flex;align-items:baseline;justify-content:space-between;gap:12px 20px;flex-wrap:wrap}
  .section-title{font-size:var(--fs-h2);line-height:1.12;letter-spacing:-.018em;margin:5px 0 0}
  .section-note,.asof{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}
  .text-link{font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d)}

  .brief{border-top:2px solid var(--green);border-bottom:1px solid var(--line);padding:16px 0 20px;margin-top:28px}
  .brief-copy{font-size:clamp(18px,1.65vw,22px);line-height:1.58;color:var(--ink-2);max-width:78ch;margin-top:13px}
  .my-read{max-width:78ch;margin-top:17px;padding:13px 15px;border-left:2px solid var(--green);background:#f8f7f2}
  .my-read p{font-size:var(--fs-small);line-height:1.56;color:var(--ink-2)}
  .my-read strong{color:var(--ink)}
  .read-evidence{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
  .read-number{display:inline-flex;gap:6px;align-items:baseline;padding:6px 9px;border:1px solid var(--line);border-radius:4px;background:#fff;color:var(--ink);text-decoration:none;font-family:var(--mono);font-size:10px}
  .read-number b{font-size:11px}
  .read-story{display:inline-flex;align-items:center;padding:6px 9px;color:var(--green-d);font-family:var(--mono);font-size:10px;text-decoration:none}
  .source-state{margin-top:13px;padding:11px 13px;border-left:2px solid var(--red);background:#fff7f7;font-size:var(--fs-small);line-height:1.5;color:var(--ink-2)}
  .source-state strong{color:var(--ink)}
  .source-state a{margin-left:8px;color:var(--green-d)}
  .brief-sources{display:flex;align-items:center;gap:5px 14px;flex-wrap:wrap;margin-top:14px;font-family:var(--mono);font-size:11px;color:var(--mut)}
  .brief-sources a{color:var(--green-d)}

  .news{margin-top:46px;max-width:920px}
  .story-list{border-top:1px solid var(--line);margin-top:12px}
  .brief-story{padding:20px 0;border-bottom:1px solid var(--line);background:transparent}
  .story-meta{display:flex;align-items:center;gap:5px 10px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.025em;text-transform:uppercase;color:var(--mut);margin-bottom:7px}
  .story-topic{font-weight:650;color:var(--green-d);text-decoration:none}
  .story-title-row{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;align-items:start}
  .story-copy{display:flow-root;min-width:0}
  .story-thumb{float:right;width:132px;height:88px;margin:4px 0 10px 14px;border-radius:4px;overflow:hidden;background:var(--paper-2)}
  .story-thumb img{width:100%;height:100%;object-fit:cover;display:block}
  .story-link{color:var(--ink);text-decoration:none}
  .story-link:hover{color:var(--green-d)}
  .brief-story h3{font-size:clamp(19px,1.55vw,23px);line-height:1.32;letter-spacing:-.008em;font-weight:600;margin:0;max-width:60ch}
  .story-summary{font-size:15.5px;line-height:1.5;color:var(--ink-2);max-width:72ch;margin:7px 0 0}
  .context-btn{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:4px;background:#fff;color:var(--green-d);padding:7px 9px;font-family:var(--mono);font-size:10px;font-weight:650;letter-spacing:.04em;text-transform:uppercase;cursor:pointer}
  .context-btn:hover,.context-btn[aria-expanded="true"]{border-color:var(--green);background:#f2f8f5}
  .context-btn .context-icon{font-size:14px;line-height:1;transition:transform .15s ease}
  .context-btn[aria-expanded="true"] .context-icon{transform:rotate(45deg)}
  .story-context{margin:13px 0 2px;padding:13px 16px;background:#f8f7f2;border-left:2px solid var(--green);font-size:14px;line-height:1.56;color:var(--ink-2)}
  .story-context[hidden]{display:none}
  .story-context p+p,.story-context .coverage{margin-top:9px;padding-top:9px;border-top:1px solid var(--line)}
  .context-label{font-family:var(--mono);font-size:10px;font-weight:650;letter-spacing:.05em;text-transform:uppercase;color:var(--green-d);margin-right:7px}
  .coverage-links{display:flex;gap:6px 12px;flex-wrap:wrap;margin-top:5px;font-family:var(--mono);font-size:10px}
  .coverage-links a{color:var(--green-d)}

  .all-news{margin-top:24px;border-bottom:1px solid var(--line)}
  .all-news>summary{list-style:none;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px 0;color:var(--green-d);font-family:var(--mono);font-size:var(--fs-label);font-weight:650;letter-spacing:.035em;text-transform:uppercase;cursor:pointer}
  .all-news>summary::-webkit-details-marker{display:none}
  .all-news>summary::after{content:'+';font-size:17px;line-height:1}
  .all-news[open]>summary::after{content:'–'}
  .all-news-body{padding:2px 0 12px}
  .filters{display:flex;gap:7px;overflow-x:auto;padding:2px 0 13px;border-bottom:1px solid var(--line);scrollbar-width:none}
  .filters::-webkit-scrollbar{display:none}
  .filter{flex:0 0 auto;border:1px solid var(--line);border-radius:999px;background:#fff;color:var(--ink-2);padding:8px 13px;font-size:12px;cursor:pointer}
  .filter:hover,.filter.active{border-color:var(--green);color:var(--green-d);background:#f2f8f5}
  .all-story[hidden]{display:none}
  .empty{font-size:var(--fs-small);color:var(--mut);padding:24px 0}
  .show-more{display:block;width:100%;margin-top:2px;padding:13px 0;background:none;border:0;border-top:1px solid var(--line);color:var(--green-d);font-family:var(--mono);font-size:var(--fs-label);font-weight:650;letter-spacing:.035em;text-transform:uppercase;cursor:pointer}
  .show-more:hover{color:var(--green)}
  .show-more[hidden]{display:none}

  .markets,.week,.subscribe-section{margin-top:54px}
  .markets{border-top:2px solid var(--green);padding-top:14px}
  .market-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:14px}
  .market-card{min-width:0;padding:15px 16px 14px;border:1px solid var(--line);border-radius:5px;background:var(--paper)}
  .market-link{display:block;color:inherit;text-decoration:none}
  .market-name{font-family:var(--mono);font-size:11px;line-height:1.3;text-transform:uppercase;letter-spacing:.035em;color:var(--mut)}
  .market-value{font-size:clamp(27px,3vw,38px);font-weight:650;line-height:1.04;letter-spacing:-.025em;margin-top:10px;font-variant-numeric:tabular-nums;white-space:nowrap}
  .market-unit{font-family:var(--mono);font-size:10px;color:var(--mut);letter-spacing:0;margin-left:3px}
  .market-compare{font-size:12px;line-height:1.4;color:var(--ink-2);margin-top:8px;min-height:34px}
  .market-date,.market-source{font-family:var(--mono);font-size:10px;line-height:1.4;color:var(--mut)}
  .market-date{text-transform:uppercase;letter-spacing:.02em;margin-top:9px}
  .market-source{margin-top:2px}

  .week{border-top:1px solid var(--line);padding-top:14px}
  .timeline{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-top:13px}
  .timeline-item{padding:17px 18px 18px 0}
  .timeline-item+.timeline-item{border-left:1px solid var(--line);padding-left:18px}
  .timeline-date{font-size:var(--fs-body);font-weight:700;letter-spacing:-.01em;color:var(--ink)}
  .timeline-rel{font-family:var(--mono);font-size:var(--fs-label);color:var(--mut);margin-top:2px}
  .timeline-rel:empty{display:none}
  .timeline-title{font-size:var(--fs-small);line-height:1.35;font-weight:650;margin-top:6px}
  .timeline-why{font-size:var(--fs-meta);line-height:1.48;color:var(--ink-2);margin-top:5px}
  .timeline-source{display:inline-block;font-family:var(--mono);font-size:10px;color:var(--mut);margin-top:8px}

  .sub{border:1px solid var(--line);border-radius:7px;padding:20px 22px 17px;background:#fbfaf6}
  .sub .line{font-size:var(--fs-small);color:var(--ink-2);margin-top:7px;line-height:1.5;max-width:74ch}
  .sub form{display:flex;gap:10px;flex-wrap:wrap;margin-top:13px}
  .sub input[type=email]{flex:1;min-width:220px;font-family:var(--sans);font-size:var(--fs-small);padding:12px 14px;border:1px solid var(--line);border-radius:7px;background:#fff;color:var(--ink)}
  .sub button{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:#fff;background:var(--green);border:0;border-radius:7px;padding:12px 24px;cursor:pointer}
  .sub .fine{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:10px}

  @media(max-width:900px){
    .market-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .timeline{grid-template-columns:repeat(2,minmax(0,1fr))}
    .timeline-item:nth-child(3){border-left:0;border-top:1px solid var(--line);padding-left:0}
    .timeline-item:nth-child(4){border-top:1px solid var(--line)}
  }
  @media(max-width:650px){
    .home-head{padding-top:24px;align-items:flex-start}
    .brief{margin-top:22px}
    .brief-copy{font-size:18px;line-height:1.52}
    .news{margin-top:38px}
    .brief-story{padding:17px 0}
    .brief-story h3{font-size:20px;line-height:1.32}
    .story-title-row{grid-template-columns:1fr}
    .context-btn{justify-self:start}
    .story-thumb{width:112px;height:74px;margin:3px 0 8px 12px}
    .market-grid{grid-template-columns:1fr}
    .market-compare{min-height:0}
    .timeline{grid-template-columns:1fr}
    .timeline-item,.timeline-item+.timeline-item,.timeline-item:nth-child(3),.timeline-item:nth-child(4){padding:14px 0 15px;border-left:0;border-top:1px solid var(--line)}
    .timeline-item:first-child{border-top:0}
  }
</style>

{% macro storyCard(story, isAll=false) %}
{% set topicHref = story.topicUrl if story.topicUrl else ('/us-mexico.html' if story.topic == 'us-mexico' else '/' + story.topic + '.html') %}
{% set hasContext = story.bg or story.implications or story.next or story.sourceCount > 1 %}
{% set contextId = 'story-context-' + story.id %}
<article class="brief-story{% if isAll %} all-story{% endif %}"{% if isAll %} data-topic="{{ story.topic }}" data-interests="{{ story.interestTags | join(',') if story.interestTags else '' }}"{% endif %}>
  <div class="story-meta"><a class="story-topic" href="{{ topicHref }}">{{ story.topicLabel if isAll else story.beat }}</a><span class="js-storydate" data-date="{{ story.date }}">{{ story.date }}</span>{% if story.reportTime %}<span class="js-storytime" data-date="{{ story.reportTime }}" data-label="{{ 'Latest report' if story.sourceCount > 1 else 'Published' }}"></span>{% endif %}{% if story.source %}<span>{{ story.source }}</span>{% endif %}{% if story.sourceCount > 1 %}<span>{{ story.sourceCount }} reports</span>{% endif %}</div>
  <div class="story-title-row">
    <div class="story-copy">{% if story.image %}<a class="story-thumb" href="{{ story.url }}" target="_blank" rel="noopener" title="Image: {{ story.source }}" aria-hidden="true" tabindex="-1"><img src="{{ story.image }}" alt="" loading="lazy" referrerpolicy="no-referrer" /></a>{% endif %}<a class="story-link" href="{{ story.url }}" target="_blank" rel="noopener"><h3>{{ story.title }}</h3></a>{% if story.summary %}<p class="story-summary">{{ story.summary }}</p>{% endif %}</div>
    {% if hasContext %}<button class="context-btn" type="button" aria-expanded="false" aria-controls="{{ contextId }}"><span>Context</span><span class="context-icon" aria-hidden="true">+</span></button>{% endif %}
  </div>
  {% if hasContext %}<div class="story-context" id="{{ contextId }}" hidden>{% if story.bg %}<p><span class="context-label">Background</span>{{ story.bg }}</p>{% endif %}{% if story.implications %}<p><span class="context-label">Why it matters</span>{{ story.implications }}</p>{% endif %}{% if story.next %}<p><span class="context-label">Watch next</span>{{ story.next }}</p>{% endif %}{% if story.sourceCount > 1 %}<div class="coverage"><span class="context-label">Reporting</span><div class="coverage-links">{% for source in story.sources %}<a href="{{ source.url }}" target="_blank" rel="noopener">{{ source.source or 'Source' }} ↗</a>{% endfor %}</div></div>{% endif %}</div>{% endif %}
</article>
{% endmacro %}

<div class="home" data-editorial-date="{{ dailyBrief.editorialDate }}">
  <header class="home-head">
    <div><h1 class="home-title">Mexico this morning</h1><div class="home-date" id="today">{{ dailyBrief.editorialDate }}</div></div>
    <a class="home-status" id="status" href="/sources.html">Checking the data</a>
  </header>

  <section class="brief" aria-labelledby="brief-title">
    <div class="section-top"><div class="kicker" id="brief-title">What changed</div><div class="asof" id="brief-asof" data-date="{{ dailyBrief.newsThrough }}">Updated {{ dailyBrief.newsThrough }}</div></div>
    <p class="brief-copy">{{ dailyBrief.summaryLead }}</p>
    {% if homeEditorial and homeEditorial.myRead %}<div class="my-read"><p><strong>{{ homeEditorial.myRead.label or 'My read' }}:</strong> {{ homeEditorial.myRead.text }}</p><div class="read-evidence">{% for item in homeEditorial.myRead.numbers %}<a class="read-number" href="{{ item.href }}"><span>{{ item.label }}</span><b>{{ item.display }}{% if item.unit %} {{ item.unit }}{% endif %}</b><span>{{ item.observed }}</span></a>{% endfor %}<a class="read-story" href="{{ homeEditorial.myRead.storyUrl }}" target="_blank" rel="noopener">Related: {{ homeEditorial.myRead.storyLabel }} ↗</a></div></div>{% endif %}
    {% if homeEditorial and homeEditorial.sourceState %}<div class="source-state"><strong>Sources disagree:</strong> {{ homeEditorial.sourceState.note }}{% for source in homeEditorial.sourceState.sources %}<a href="{{ source.url }}" target="_blank" rel="noopener">{{ source.label }} ↗</a>{% endfor %}</div>{% endif %}
    {% if dailyBrief.briefSources.length %}<div class="brief-sources"><span>Sources:</span>{% for item in dailyBrief.briefSources %}<a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.source }} ↗</a>{% endfor %}</div>{% endif %}
  </section>

  <section class="news" aria-labelledby="news-title">
    <div class="section-top"><div><h2 class="section-title" id="news-title">Worth knowing</h2></div><span class="section-note">Today only</span></div>
    <div class="story-list major-list">
      {% for story in dailyBrief.stories %}{{ storyCard(story) }}{% else %}<p class="empty">No major stories have cleared the brief yet today.</p>{% endfor %}
    </div>

    {% if latestStories.length %}<details class="all-news" id="all-news" open>
      <summary>All headlines</summary>
      <div class="all-news-body">
        <nav class="filters" aria-label="Filter today’s headlines">
          <button class="filter active" type="button" data-topic="all">All</button>
          <button class="filter" type="button" data-topic="mine">My topics</button>
          <button class="filter" type="button" data-topic="economy">Economy</button>
          <button class="filter" type="button" data-topic="politics">Politics</button>
          <button class="filter" type="button" data-topic="society">Society &amp; security</button>
          <button class="filter" type="button" data-topic="us-mexico">US–Mexico</button>
        </nav>
        <div class="story-list" id="all-news-list">
          {% for story in latestStories %}{{ storyCard(story, true) }}{% endfor %}
        </div>
        <p class="empty" id="news-empty" hidden>No stories in this section yet today.</p>
        <button class="show-more" id="news-more" type="button" hidden>Show more</button>
      </div>
    </details>{% endif %}
  </section>

  <section class="markets" aria-labelledby="markets-title">
    <div class="section-top"><div><h2 class="section-title" id="markets-title">Latest numbers</h2></div><a class="text-link" href="/chart.html">Compare the numbers →</a></div>
    <div class="market-grid" id="market-grid">
      {% for item in nowBoard %}<article class="market-card"><a class="market-link" href="{{ item.href }}"><div class="market-name">{{ item.label }}</div><div class="market-value">{{ item.display }}{% if item.unit %}<span class="market-unit">{{ item.unit }}</span>{% endif %}</div><div class="market-compare">{{ item.compare }}</div><div class="market-date">{{ item.observed }} · {{ item.cadence }}</div><div class="market-source">{{ item.source }}</div></a></article>{% endfor %}
    </div>
  </section>

  <section class="week" aria-labelledby="week-title">
    <div class="section-top"><div><h2 class="section-title" id="week-title">Coming up</h2></div><span class="section-note">Known next</span></div>
    <div class="timeline">
      {% for event in calendar %}<article class="timeline-item"><div class="timeline-date">{% if event.approx %}Week of <span class="js-date" data-date="{{ event.date }}">{{ event.date }}</span>{% else %}<span class="js-caldate" data-date="{{ event.date }}">{{ event.date }}</span>{% endif %}</div><div class="timeline-rel js-rel" data-date="{{ event.date }}" data-approx="{{ 'y' if event.approx else '' }}"></div><div class="timeline-title">{{ event.title }}</div>{% if event.why %}<div class="timeline-why">{{ event.why }}</div>{% endif %}{% if event.sourceUrl %}<a class="timeline-source" href="{{ event.sourceUrl }}" target="_blank" rel="noopener">{{ event.source }} ↗</a>{% else %}<div class="timeline-source">{{ event.source }}</div>{% endif %}</article>{% endfor %}
    </div>
  </section>

  <section class="subscribe-section">
    <div class="sub"><div class="kicker">Weekly email</div><p class="line">Once a week, I send the few things that changed in Mexico that I think are worth knowing. The original sources are there if you want to go deeper. <a href="/weekly.html">See an example →</a></p><form class="subform" method="post" action="/api/subscribe" novalidate><input type="email" name="email" placeholder="you@email.com" aria-label="Email address" autocomplete="email" inputmode="email" required /><label class="hp-field" aria-hidden="true">Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label><button type="submit">Subscribe</button></form><div class="fine submsg" aria-live="polite">One email a week. Unsubscribe whenever you want.</div></div>
  </section>
</div>

<script type="module">
import { relTime } from '/assets/mb.js?v=18';

const editorialDate=document.querySelector('.home')?.dataset.editorialDate||'';
const date=(iso,year=false)=>{if(!iso)return'';const d=new Date(/^\d{4}-\d{2}-\d{2}$/.test(iso)?iso+'T12:00:00Z':iso);return isNaN(d)?iso:d.toLocaleDateString('en-US',{timeZone:'America/Mexico_City',month:'short',day:'numeric',...(year?{year:'numeric'}:{})});};

function closeContext(except){
  document.querySelectorAll('.context-btn[aria-expanded="true"]').forEach((button)=>{
    if(button===except)return;
    button.setAttribute('aria-expanded','false');
    const panel=button.closest('.brief-story')?.querySelector(':scope > .story-context');
    if(panel)panel.hidden=true;
  });
}
document.querySelectorAll('.context-btn').forEach((button)=>{
  const panel=button.closest('.brief-story')?.querySelector(':scope > .story-context');
  if(!panel)return;
  button.addEventListener('click',(event)=>{event.stopPropagation();const open=button.getAttribute('aria-expanded')==='true';closeContext(open?null:button);button.setAttribute('aria-expanded',String(!open));panel.hidden=open;});
});
document.addEventListener('pointerdown',(event)=>{if(!event.target.closest?.('.context-btn,.story-context'))closeContext(null);});
document.addEventListener('keydown',(event)=>{if(event.key==='Escape')closeContext(null);});

const newsFilters=[...document.querySelectorAll('.filter')];
const allStories=[...document.querySelectorAll('.all-story')];
const newsEmpty=document.getElementById('news-empty');
const newsMore=document.getElementById('news-more');
const NEWS_LIMIT=4;
const FILTER_KEY='mexico-brief-headline-filter';
let newsTopic='all',newsExpanded=false;
function matchesTopic(story){if(newsTopic==='all')return true;if(newsTopic==='mine')return Boolean(story.dataset.interests);return story.dataset.topic===newsTopic;}
function renderNews(){
  newsFilters.forEach((button)=>button.classList.toggle('active',button.dataset.topic===newsTopic));
  let matched=0,shown=0;
  allStories.forEach((story)=>{const match=matchesTopic(story);if(!match){story.hidden=true;return;}matched++;const within=newsExpanded||shown<NEWS_LIMIT;story.hidden=!within;if(within)shown++;});
  if(newsEmpty)newsEmpty.hidden=matched>0;
  if(newsMore){const rest=matched-Math.min(matched,NEWS_LIMIT);newsMore.hidden=newsExpanded||rest<=0;newsMore.textContent='Show '+rest+' more';}
}
function showNews(topic,push=false){
  newsTopic=topic;newsExpanded=false;renderNews();
  try{localStorage.setItem(FILTER_KEY,topic);}catch{}
  if(push){const url=new URL(location.href);if(topic==='all')url.searchParams.delete('topic');else url.searchParams.set('topic',topic);url.hash='all-news';history.replaceState({},'',url);}
}
newsFilters.forEach((button)=>button.addEventListener('click',()=>showNews(button.dataset.topic,true)));
if(newsMore)newsMore.addEventListener('click',()=>{newsExpanded=true;renderNews();});
let initialTopic=new URLSearchParams(location.search).get('topic');
if(!initialTopic){try{initialTopic=localStorage.getItem(FILTER_KEY);}catch{}}
if(!newsFilters.some((button)=>button.dataset.topic===initialTopic))initialTopic='all';
showNews(initialTopic);

const headerDay=new Date((editorialDate||new Date().toISOString().slice(0,10))+'T12:00:00Z');
document.getElementById('today').textContent=headerDay.toLocaleDateString('en-US',{timeZone:'America/Mexico_City',weekday:'long',month:'long',day:'numeric',year:'numeric'});
document.querySelectorAll('.js-date').forEach((element)=>{element.textContent=date(element.dataset.date);});
document.querySelectorAll('.js-storydate').forEach((element)=>{element.textContent=element.dataset.date===editorialDate?'Today':date(element.dataset.date,true);});
document.querySelectorAll('.js-storytime').forEach((element)=>{const d=new Date(element.dataset.date);element.textContent=isNaN(d)?'':`${element.dataset.label||'Published'} ${d.toLocaleTimeString('en-US',{timeZone:'America/Mexico_City',hour:'numeric',minute:'2-digit'})}`;});
const calDate=(iso)=>{const d=new Date(iso+'T12:00:00Z');return isNaN(d)?iso:d.toLocaleDateString('en-US',{timeZone:'America/Mexico_City',weekday:'short',month:'short',day:'numeric'});};
document.querySelectorAll('.js-caldate').forEach((element)=>{element.textContent=calDate(element.dataset.date);});
const weekStart=(d)=>{const x=new Date(d.getTime());x.setUTCHours(0,0,0,0);x.setUTCDate(x.getUTCDate()-((x.getUTCDay()+6)%7));return x;};
const relDay=(iso,approx)=>{const d=new Date(iso+'T00:00:00Z'),t=new Date(editorialDate+'T00:00:00Z');if(isNaN(d)||isNaN(t))return'';const n=Math.round((d-t)/864e5);if(n<0)return'';if(approx){const w=Math.round((weekStart(d)-weekStart(t))/(7*864e5));return w<=0?'this week':w===1?'next week':'in '+w+' weeks';}if(n===0)return'today';if(n===1)return'tomorrow';return'in '+n+' days';};
document.querySelectorAll('.js-rel').forEach((element)=>{element.textContent=relDay(element.dataset.date,element.dataset.approx==='y');});
const asof=document.getElementById('brief-asof');if(asof){const d=new Date(asof.dataset.date);asof.textContent=isNaN(d)?'':`Updated ${d.toLocaleDateString('en-US',{timeZone:'America/Mexico_City',month:'short',day:'numeric'})} · ${d.toLocaleTimeString('en-US',{timeZone:'America/Mexico_City',hour:'numeric',minute:'2-digit'})}`;}

fetch('/data/health.json').then((response)=>response.ok?response.json():null).then((health)=>{
  const status=document.getElementById('status');
  if(status&&health?.generatedAt){const checked=Date.parse(health.generatedAt);const failed=(health.sources||[]).filter((source)=>source.status==='failed').length;status.textContent=`Data checked ${relTime(checked)}${failed?` · ${failed} feed ${failed===1?'issue':'issues'}`:''}`;}
  else if(status)status.textContent='Open data sources';
}).catch(()=>{const status=document.getElementById('status');if(status)status.textContent='Open data sources';});

document.querySelectorAll('.story-thumb img').forEach((image)=>{const remove=()=>image.closest('.story-thumb')?.remove();if(image.complete&&image.naturalWidth===0)remove();else image.addEventListener('error',remove,{once:true});});
</script>
