---
layout: base.njk
permalink: /
title: "The Mexico Brief — a live briefing on Mexico's economy in official numbers."
description: "Mexico's economy in official numbers: growth, the peso, inflation, jobs, investment, politics and security. Every figure links to its official source, with the date it was published."
ogTitle: "The Mexico Brief"
ogDescription: "Mexico's economy in official numbers, each linked to its official source and dated."
---
{% raw %}
<style>
  :root{--ink-3:#4d4d4d;--amber2:#8f6a15;--amber-bg2:#f6efdc}
  body{font-size:17px}
  .home{max-width:1120px;margin:0 auto;padding:0 clamp(16px,4vw,44px)}

  /* 1 · HERO */
  .hero{padding:26px 0 4px}
  .hero h1{font-family:var(--serif);font-size:clamp(32px,6vw,50px);line-height:1.0;letter-spacing:-.025em;margin:9px 0 0;color:var(--ink)}
  .country{font-size:16.5px;line-height:1.62;color:var(--ink-2);margin:18px 0 4px;max-width:66ch}
  .country b{color:var(--ink);font-weight:600}
  .country .ref{font-family:var(--mono);font-size:9.5px;color:var(--green);vertical-align:super;text-decoration:none;padding:0 1px}
  .bottomline{font-size:15px;line-height:1.5;color:var(--ink-2);margin:16px 0 2px;max-width:70ch;padding:12px 15px;background:var(--paper-2);border-left:3px solid var(--green);border-radius:0 8px 8px 0}
  .bottomline b{color:var(--ink)}
  .bottomline .bl-k{font-family:var(--mono);font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--green-d);font-weight:600}

  /* block headers */
  .bh{display:flex;align-items:baseline;justify-content:space-between;gap:10px;border-top:2px solid var(--green);padding-top:11px;margin:38px 0 10px}
  .bh .k{font-family:var(--mono);font-size:12px;letter-spacing:.05em;text-transform:uppercase;color:var(--green);font-weight:600}
  .bh h2{font-family:var(--serif);font-size:clamp(19px,2.6vw,24px);color:var(--ink);display:inline;letter-spacing:-.01em}
  .bh .a{font-family:var(--mono);font-size:11px;color:var(--green-d);white-space:nowrap}
  .bh .asof{font-family:var(--mono);font-size:12px;color:var(--mut);white-space:nowrap}

  /* 2 · THE BOARD */
  .board-lbl{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin:26px 0 8px;border-top:2px solid var(--green);padding-top:11px}
  .board-lbl .k{font-family:var(--mono);font-size:12px;letter-spacing:.05em;text-transform:uppercase;color:var(--green);font-weight:600}
  .board-lbl h2{font-family:var(--serif);font-size:clamp(19px,2.6vw,24px);color:var(--ink);display:inline;letter-spacing:-.01em}
  .board-lbl .asof{font-family:var(--mono);font-size:12px;color:var(--mut);white-space:nowrap}
  .tablero{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:11px;overflow:hidden;margin:2px 0 4px}
  @media(min-width:560px){.tablero{grid-template-columns:repeat(4,1fr)}}
  .tilelink{display:contents}
  .tile{background:var(--paper);padding:16px 17px 15px;cursor:pointer;height:100%}
  .tilelink:hover .tile{background:var(--paper-2)}
  .tile .tl{font-family:var(--mono);font-size:12px;letter-spacing:.02em;text-transform:uppercase;color:var(--mut);line-height:1.3;min-height:2.4em}
  .tile .tv{font-family:var(--serif);font-size:34px;color:var(--ink);margin-top:6px;font-variant-numeric:tabular-nums;line-height:1;letter-spacing:-.015em}
  .tile .tv small{font-size:13px;color:var(--mut);font-weight:400}
  .tile .dl{font-family:var(--mono);font-size:12.5px;color:var(--ink);margin-top:6px;font-variant-numeric:tabular-nums;display:block}
  .tile .dl.up::before{content:"▲ ";font-size:10px} .tile .dl.dn::before{content:"▼ ";font-size:10px}
  .tile .dl.fl{color:var(--mut)} .tile .dl small{color:var(--mut)}
  .tile svg.spark{margin-top:7px}
  .tile svg.spark path{stroke:var(--ink-3);stroke-width:1.5}
  .tile .tb{font-family:var(--mono);font-size:12px;color:var(--ink-2);margin-top:7px;line-height:1.4}
  .tile .tb .arw{font-weight:700}
  .tile .stamp{margin-top:6px;display:block}
  .tile .tsrc{font-family:var(--mono);font-size:9.5px;letter-spacing:.02em;color:var(--mut);margin-top:4px;display:block;line-height:1.35}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.02em;text-transform:uppercase;color:var(--mut);white-space:nowrap}
  .stamp.live{color:var(--green-d);font-weight:600}
  .chip-ph{font-family:var(--mono);font-size:9px;letter-spacing:.02em;text-transform:uppercase;color:var(--amber2);background:var(--amber-bg2);padding:1px 6px;border-radius:4px;margin-left:6px}

  /* 2b · WHAT CHANGED — the lead queue (event log + series-delta fallback, one treatment) */
  .chg{border:1px solid var(--line-2);border-radius:11px;overflow:hidden;margin:2px 0 4px}
  .chg-item{border-bottom:1px solid var(--line);background:var(--paper)}
  .chg-item:last-child{border-bottom:none}
  .chgrow{display:flex;align-items:center;gap:12px;padding:12px 15px}
  .chgrow:hover{background:var(--paper-2)}
  .chgrow.cross{background:var(--green-bg)}
  .chgrow.cross:hover{background:#dcefe3}
  .cg-body{flex:1;min-width:0;display:block;text-decoration:none}
  .cg-line{display:flex;align-items:baseline;gap:9px;flex-wrap:wrap}
  .cg-flag{font-family:var(--mono);font-size:9px;letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:#fff;background:var(--green);border-radius:3px;padding:1px 6px;white-space:nowrap}
  .cg-lbl{font-size:15px;color:var(--ink);font-weight:600}
  .cg-move{font-family:var(--serif);font-size:17px;color:var(--ink);font-variant-numeric:tabular-nums;letter-spacing:-.01em}
  .cg-meta{font-family:var(--mono);font-size:10.5px;letter-spacing:.02em;text-transform:uppercase;color:var(--mut);margin-top:3px}
  .cg-src{font-family:var(--mono);font-size:11px;color:var(--green-d);white-space:nowrap;text-decoration:none;flex:none}
  .cg-src:hover{text-decoration:underline}
  .cg-go{font-family:var(--mono);font-size:13px;color:var(--green-d);flex:none}
  .chg-quiet{border:1px solid var(--line-2);border-radius:11px;background:var(--paper);padding:15px 16px;font-size:15px;color:var(--ink-2);margin:2px 0 4px}

  /* 2c · IMPACT SCORE — expand a row (caret) to see its components + weights */
  .cg-caret{flex:none;font-family:var(--mono);font-size:12px;line-height:1;color:var(--mut);background:none;border:none;cursor:pointer;padding:4px 3px;transition:transform .15s ease}
  .cg-caret:hover{color:var(--green-d)}
  .cg-caret.open{transform:rotate(90deg)}
  .cg-breakdown{background:var(--paper-2);border-top:1px solid var(--line);padding:11px 15px 12px;font-family:var(--mono)}
  .bd-head{display:flex;align-items:baseline;justify-content:space-between;gap:10px;margin-bottom:9px}
  .bd-k{font-size:10px;letter-spacing:.05em;text-transform:uppercase;color:var(--green-d);font-weight:700}
  .bd-score{font-family:var(--serif);font-size:21px;color:var(--ink);font-variant-numeric:tabular-nums;letter-spacing:-.01em}
  .bd-grid{display:flex;flex-direction:column;gap:6px}
  .bd-hd,.bd-f{display:grid;grid-template-columns:1fr 46px 32px 52px;gap:2px 8px;align-items:baseline}
  .bd-hd{font-size:8.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--mut);padding-bottom:4px;border-bottom:1px solid var(--line)}
  .bd-hd span:nth-child(n+2){text-align:right}
  .bd-fn{font-size:11px;color:var(--ink)}
  .bd-fv,.bd-fw,.bd-fc{font-size:11px;text-align:right;font-variant-numeric:tabular-nums}
  .bd-fv{color:var(--ink-2)} .bd-fw{color:var(--mut)} .bd-fc{color:var(--ink);font-weight:600}
  .bd-note{grid-column:1 / -1;font-size:9px;color:var(--mut);letter-spacing:.02em;line-height:1.35}
  .bd-f.ph .bd-fv,.bd-f.ph .bd-fc,.bd-f.ph .bd-note{color:var(--amber2)}
  .bd-eq{font-size:9px;color:var(--mut);margin-top:10px;line-height:1.55}
  .bd-eq code{font-family:var(--mono);color:var(--ink-2)}

  /* what's happening — the cross-domain lead; reuses the .chg row shell, adds a why line */
  .hap-row{align-items:flex-start;gap:13px}
  .hap-tag{flex:none;font-family:var(--mono);font-size:9px;letter-spacing:.05em;text-transform:uppercase;color:var(--mut);border:1px solid var(--line-2);border-radius:3px;padding:3px 7px;white-space:nowrap;margin-top:2px;text-decoration:none}
  .hap-tag:hover{color:var(--green-d);border-color:var(--green-bg)}
  .hap-b{padding:0}
  .hap-line{display:flex;align-items:baseline;gap:9px;flex-wrap:wrap}
  .hap-date{font-family:var(--mono);font-size:10.5px;letter-spacing:.02em;text-transform:uppercase;color:var(--mut);flex:none}
  .hap-title{font-size:15px;color:var(--ink);font-weight:600;line-height:1.32}
  .hap-why{font-size:13.5px;color:var(--ink-2);line-height:1.5;margin-top:5px;max-width:82ch}
  .hap .cg-src{align-self:flex-start;margin-top:3px}
  /* mobile: the 3-column row (tag / body / source) can't fit — stack it cleanly */
  @media(max-width:640px){
    .hap-row{flex-direction:column;align-items:stretch;gap:7px}
    .hap-tag{align-self:flex-start;margin-top:0}
    .hap-b{width:100%}
    .hap .cg-src{align-self:flex-start;margin-top:2px}
  }

  /* 4 · NEWSLETTER (from weekly.njk .sub) */
  .sub{margin:8px 0 4px;border:1.5px solid var(--line);border-radius:12px;padding:20px 22px 16px;background:#fbfaf6}
  .sub .lab{font-family:var(--mono);font-size:12px;letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);font-weight:700}
  .sub .line{font-size:16px;color:var(--ink-2);margin-top:8px;line-height:1.5}
  .sub .line b{color:var(--ink)}
  .sub form{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
  .sub input[type=email]{flex:1;min-width:220px;font-family:var(--sans);font-size:16px;padding:12px 14px;border:1.5px solid var(--line);border-radius:9px;background:#fff;color:var(--ink)}
  .sub input[type=email]:focus{outline:none;border-color:var(--green)}
  .sub button{font-family:var(--mono);font-size:12px;letter-spacing:.05em;text-transform:uppercase;font-weight:700;color:#fff;background:var(--green);border:none;border-radius:9px;padding:12px 24px;cursor:pointer}
  .sub button:hover{background:var(--green-d)}
  .sub .fine{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:11px;line-height:1.6}
  .sub .samplelink{display:inline-block;margin-top:13px;font-family:var(--mono);font-size:12px;letter-spacing:.03em;text-transform:uppercase;color:var(--green-d);text-decoration:none;border-bottom:2px solid #daf0e2;padding-bottom:1px}

  /* 5 · SECTION CARDS */
  .seccards{display:grid;grid-template-columns:1fr;gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:11px;overflow:hidden;margin:2px 0 4px}
  @media(min-width:560px){.seccards{grid-template-columns:repeat(2,1fr)}}
  @media(min-width:900px){.seccards{grid-template-columns:repeat(3,1fr)}}
  .seccard{background:var(--paper);padding:17px 18px 15px;text-decoration:none;display:flex;flex-direction:column;gap:0}
  .seccard:hover{background:var(--paper-2)}
  .seccard .sc-k{font-family:var(--mono);font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:var(--green);font-weight:600}
  .seccard .sc-stat{font-family:var(--serif);font-size:28px;color:var(--ink);margin-top:8px;font-variant-numeric:tabular-nums;line-height:1;letter-spacing:-.015em}
  .seccard .sc-stat small{font-size:12px;color:var(--mut);font-weight:400}
  .seccard .sc-wire{font-size:13px;color:var(--ink-2);line-height:1.4;margin-top:11px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .seccard .sc-wire .sc-none{color:var(--mut);font-family:var(--mono);font-size:11px}
  .seccard .sc-go{font-family:var(--mono);font-size:11.5px;color:var(--green-d);margin-top:12px}

  /* 6 · WHAT TO WATCH + THE WIRE */
  .coverband{display:grid;grid-template-columns:1fr;gap:22px;margin:2px 0 4px}
  @media(min-width:760px){.coverband{grid-template-columns:minmax(240px,320px) 1fr;gap:34px}}
  .cb-h{display:flex;align-items:baseline;justify-content:space-between;border-top:2px solid var(--green);padding-top:9px;margin-bottom:6px}
  .cb-h .k{font-family:var(--mono);font-size:11px;letter-spacing:.05em;text-transform:uppercase;color:var(--green);font-weight:600}
  .cb-h .a{font-family:var(--mono);font-size:10px;color:var(--green-d)}
  .watchtbl .wtr{display:flex;gap:11px;padding:10px 0;border-bottom:1px solid var(--line);align-items:baseline}
  .watchtbl .wtr:last-child{border-bottom:none}
  .watchtbl .wtr .wd{font-family:var(--mono);font-size:11px;color:var(--ink);min-width:50px;font-variant-numeric:tabular-nums;line-height:1.3}
  .watchtbl .wtr .wd small{color:var(--mut);display:block;font-size:9px}
  .watchtbl .wtr .wk{width:3px;align-self:stretch;border-radius:2px;background:var(--line-2)}
  .watchtbl .wtr .wk.banxico,.watchtbl .wtr .wk.fomc,.watchtbl .wtr .wk.inegi{background:var(--green)}
  .watchtbl .wtr .wk.political,.watchtbl .wtr .wk.election{background:var(--red)}
  .watchtbl .wtr .wk.trade,.watchtbl .wtr .wk.fiscal{background:var(--amber2)}
  .watchtbl .wtr .wt{font-size:13.5px;color:var(--ink);flex:1;line-height:1.35}
  .watchtbl .wtr .wm{font-family:var(--mono);font-size:9.5px;color:var(--mut);margin-top:2px}
  .watchtbl .wtr .wsrc{font-family:var(--mono);font-size:9.5px}
  .cb-empty{font-family:var(--mono);font-size:11px;color:var(--mut);padding:12px 0}
  .wire .wi{padding:11px 0;border-bottom:1px solid var(--line);display:flex;gap:11px;align-items:baseline}
  .wire .wi:last-child{border-bottom:none}
  .wire .wtag{font-family:var(--mono);font-size:8.5px;letter-spacing:.04em;text-transform:uppercase;color:var(--mut);border:1px solid var(--line-2);border-radius:3px;padding:1px 5px;white-space:nowrap;margin-top:2px;text-decoration:none}
  .wire .wtag:hover{color:var(--green-d);border-color:var(--green-bg)}
  .wire .wbody{flex:1}
  .wire .wt{font-size:14px;color:var(--ink);line-height:1.35;text-decoration:none}
  .wire .wt:hover{color:var(--green-d);text-decoration:underline}
  .wire .wm{font-family:var(--mono);font-size:9.5px;color:var(--mut);margin-top:3px}
  .wire-note{font-family:var(--mono);font-size:10.5px;color:var(--mut);margin-top:10px;line-height:1.6}
  .wire-note a{color:var(--green)}

  /* 7 · PRIMER — evergreen orientation, moved out of the top and collapsed */
  .primer{margin-top:30px}
  .primerbox{border:1px solid var(--line);border-radius:11px;background:var(--paper)}
  .primerbox summary{font-family:var(--mono);font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--green-d);font-weight:600;cursor:pointer;padding:14px 16px;list-style:none;display:flex;justify-content:space-between;gap:10px}
  .primerbox summary::-webkit-details-marker{display:none}
  .primerbox summary::after{content:"+";color:var(--mut)}
  .primerbox[open] summary::after{content:"–"}
  .primerbox .country{margin:0;padding:0 16px 16px}

  /* board "show all indicators" toggle — appears on mobile only */
  .board-more{display:none}

  /* MOBILE — real usability fix at ≤480px (390px target) */
  @media(max-width:480px){
    .tablero{grid-template-columns:1fr}                       /* was 2-up: clipped labels/sources */
    .tile{padding:14px 15px 13px}
    .tile .tl{min-height:0}
    .tile .tb,.tile .tsrc,.tile svg.spark{display:none}       /* benchmark + source + sparkline behind the tile tap */
    .tilelink.extra{display:none}                             /* only the four core tiles by default */
    .tablero.show-all .tilelink.extra{display:contents}
    .board-more{display:block;width:100%;font-family:var(--mono);font-size:11px;letter-spacing:.05em;text-transform:uppercase;font-weight:600;color:var(--green-d);background:var(--paper);border:1px solid var(--line-2);border-radius:9px;padding:11px;margin:8px 0 4px;cursor:pointer}
  }
</style>

<div class="home">

  <!-- 1 · HERO -->
  <section class="hero">
    <a class="dateline" href="/data.html"><span class="dot"></span><span id="status">Official data · updated live</span></a>
    <h1>Mexico, right now.</h1>
  </section>

  <!-- 2 · WHAT'S HAPPENING — the lead: the cross-domain event log, what's moving Mexico now -->
  <section>
    <div class="bh"><div><span class="k">What's happening</span> &nbsp; <h2 style="display:inline">This week in Mexico</h2></div><span class="asof" id="chg-since">Recently</span></div>
    <div id="changed"></div>
  </section>

  <p class="bottomline"><span class="bl-k">The bottom line</span> — <b>sound money</b> (inflation near Banxico's target, a firm peso), <b>weak growth</b>, and <b>near-total dependence on the United States</b>. The swing factor is the unresolved 2026 USMCA review.</p>

  <!-- 3 · THE BOARD -->
  <section>
    <div class="board-lbl">
      <div><span class="k">The board</span> &nbsp; <h2 style="display:inline">Mexico by the numbers</h2></div>
      <span class="asof" id="board-asof"></span>
    </div>
    <div class="tablero" id="tablero"></div>
    <button class="board-more" id="board-more" type="button" aria-expanded="false">Show all indicators</button>
    <p class="wire-note">Every tile links to the section that owns it, where the same figure is shown with its full history and source. Every number on the brief is first-party and dated — <a href="/sources.html">see all sources &rarr;</a></p>
  </section>

  <!-- 4 · NEWSLETTER -->
  <section>
    <div class="sub">
      <div class="lab">The brief — free</div>
      <p class="line"><b>The brief, in your inbox</b> — two or three mornings a week.</p>
      <!-- Buttondown embed. Replace `mexicobrief` with the Buttondown username once the account exists. Keyless: posts straight to Buttondown, works on a static host. -->
      <form action="https://buttondown.email/api/emails/embed-subscribe/mexicobrief" method="post" target="popupwindow" onsubmit="window.open('https://buttondown.email/mexicobrief','popupwindow')">
        <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
        <input type="hidden" value="1" name="embed" />
        <button type="submit">Get the brief</button>
      </form>
      <div class="fine">The address is used only for the brief and never shared, and one tap unsubscribes.</div>
      <a class="samplelink" href="/weekly-sample.html">See a past issue →</a>
    </div>
  </section>

  <!-- 5 · SECTION CARDS -->
  <section>
    <div class="bh"><div><span class="k">The sections</span> &nbsp; <h2 style="display:inline">Mexico in one glance</h2></div></div>
    <div class="seccards" id="seccards"></div>
  </section>

  <!-- 6 · WHAT TO WATCH + THE WIRE -->
  <section id="wire">
    <div class="coverband">
      <div>
        <div class="cb-h"><span class="k">What to watch</span></div>
        <div id="watch-list"></div>
      </div>
      <div>
        <div class="cb-h"><span class="k">The Wire</span><a class="a" href="/weekly.html">The Weekly →</a></div>
        <div id="wire-list"></div>
        <p class="wire-note">Headlines from a trusted-source allowlist, each dated and linked to its origin, unsummarized. The tag links to the section it belongs to.</p>
      </div>
    </div>
  </section>

  <!-- 7 · PRIMER — new to Mexico? the evergreen basics, moved out of the top -->
  <section class="primer">
    <details class="primerbox">
      <summary>New to Mexico? — the basics</summary>
      <p class="country">
        Mexico is a country of <b>131 million people</b> with a <b>~$1.9 trillion economy</b>, the world's ~14th-largest and the <b>largest US trading partner</b>.<a class="ref" href="/economy.html" title="World Bank; US Census Bureau">1</a>
        It manufactures and exports: about <b>80% of its exports go to the United States</b>.<a class="ref" href="/us-mexico.html" title="INEGI / Banxico balance of trade">2</a>
        It elects a president every six years, now <b>Claudia Sheinbaum (Morena)</b>, through 2030.<a class="ref" href="/politics.html" title="INE; Presidencia">3</a>
      </p>
    </details>
  </section>

</div>

<script type="module">
import { loadSeries, S, NEWS, EVENTS, HAPPENING, tile, relTime, evDate, enNum } from '/assets/mb.js?v=2';

/* ---- anchor redirect: old one-page briefing #q anchors → their new section pages ----
   Every topic now owns a page, so a bookmarked #q link should land on it. */
const RD={'#q3':'/money.html','#q4':'/economy.html','#q5':'/economy.html','#q6':'/society.html','#q7':'/politics.html','#q8':'/us-mexico.html','#q9':'/security.html','#q10':'/economy.html','#q11':'/model.html'};
if(RD[location.hash]){ location.replace(RD[location.hash]); }

let TRADE=null;

/* section keyword filters — reused verbatim from the section pages so a homepage
   headline matches what the section page itself would surface first. */
const POL_RX=/sheinbaum|morena|gobierno|pol[ií]tic|\belecc|\belect|comicios|congreso|senado|diputad|judicial|oposici|\bpan\b|\bpri\b|gobernador|gubernatur|informe|constituc|government|\bcongress|senate|\belection|midterm|opposition|\bpresident|\bminister|cabinet/i;
const SEC_RX=/seguridad|homicid|violenc|cartel|crimen|delito|desaparec|narco|secuestr|extorsi|drone attack/i;
const USMX_RX=/usmca|t-?mec|arancel|tariff|ee\.?uu|estados unidos|frontera|\bborder\b|comercio|exportaci|trump|remesa|remittance|\bice\b|migra|deportaci|\bustr\b|washington/i;
const SOC_RX=/pobreza|salario|salarial|empleo|desempleo|desigualdad|migraci|migrante|remesas|remittance|poblaci|imss|trabajador|informal|welfare|bienestar|coneval|conasami|pension|jornada|desarrollo humano|social|wage|poverty|inequality|\bjobs\b|\blabor\b/i;
const ECON_RX=/econom|\bgdp\b|\bpib\b|growth|crecimiento|manufactur|industri|inversi|invest|nearshor|export|import|sector|f[aá]brica|factory/i;
const MONEY_RX=/peso|inflaci|inflation|banxico|\brate\b|\btasa\b|remittance|remesas|market|mercado|tariff|arancel|usmca|nearshor|invest|inversi|bolsa|divisa/i;

/* ============ THE BOARD (block 3) — same tile() render + same JSON as the sections ============ */
const CORE=new Set(['banxico-usdmxn-fix','banxico-inflacion','banxico-tasa-objetivo','banxico-pib-crecimiento']); // shown by default on mobile
const TILES=[
  {id:'banxico-usdmxn-fix',   l:'Peso · MXN/USD',      href:'/money.html'},
