  if(cetes){const move=cetesP?cetes.value-cetesP.value:null;const year=cetesY?cetes.value-cetesY.value:null;daily.push(metricCard({id:'banxico-cetes-28d',name:'Cetes · 28 days',cadence:'Daily',value:`${n(cetes.value,2)}%`,arrow:move>0?'▲':move<0?'▼':'→',move:move==null?'Comparison unavailable':`${n(Math.abs(move),2)} pp ${move>0?'higher':move<0?'lower':'unchanged'}`,compare:year==null?'':`${n(Math.abs(year),2)} pp ${year>0?'higher':year<0?'lower':'unchanged'} over 1Y`,stamp:`${periodLabel('banxico-cetes-28d',cetes.date)} · Banxico`,tone:'neutral',consensus:expCete?`Consensus ${n(expCete.value,2)}% · year-end`:'',why:'The market yield on very short-term Mexican government debt. Unlike the policy rate, it can move between Banxico meetings.'}));}
  if(ust){const move=ustP?ust.value-ustP.value:0;const year=ustY?ust.value-ustY.value:null;daily.push(metricCard({id:'fred-ust10',name:'U.S. 10-year yield',cadence:'Daily',value:`${n(ust.value,2)}%`,arrow:move>0?'▲':move<0?'▼':'→',move:ustP?`${n(Math.abs(move),2)} pp ${move>0?'higher':move<0?'lower':'unchanged'}`:'Comparison unavailable',compare:year==null?'':`${n(Math.abs(year),2)} pp ${year>0?'higher':year<0?'lower':'unchanged'} over 1Y`,stamp:`${periodLabel('fred-ust10',ust.date)} · U.S. Fed`,tone:'neutral',why:'A benchmark for dollar borrowing costs. Higher U.S. yields can reduce the relative appeal of peso assets, but they are only one input into the exchange rate.'}));}
  if(inf){const delta=infP?inf.value-infP.value:0;const inside=inf.value>=2&&inf.value<=4;releases.push(metricCard({id:'banxico-inflacion,banxico-inflacion-subyacente',name:'Inflation',cadence:'Monthly',value:`${n(inf.value,2)}%`,arrow:delta>0?'▲':delta<0?'▼':'→',move:infP?`${n(Math.abs(delta),2)} pp ${delta>0?'higher':delta<0?'lower':'unchanged'}`:'Comparison unavailable',compare:`${inside?'Inside':'Outside'} the 2–4% target · vs ${infP?monthLabel(infP.date):'prior month'}`,stamp:`${periodLabel('banxico-inflacion',inf.date)} · INEGI`,tone:inside?'good':'bad',consensus:expInf?`Consensus ${n(expInf.value,2)}% · year-end`:'',why:`Prices are still rising, just more slowly. Core inflation is ${core?n(core.value,2)+'%':'not available'}.`}));}
