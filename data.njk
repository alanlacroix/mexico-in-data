---
layout: base.njk
permalink: /data.html
title: "Data health — The Mexico Brief"
description: "Every source behind The Mexico Brief: its cadence, vintage, license, last run and status. The trust room. Nothing invented."
---
{% raw %}
<style>
  :root{--ink-3:#555;--masth:49px}
  body{font-size:16px}
  .wrap{max-width:1120px;margin:0 auto;padding:0 clamp(16px,5vw,32px)}
  .hero{padding:22px 0 6px}
  .hero h1{font-family:var(--serif);font-size:clamp(26px,6vw,38px);line-height:1.04;letter-spacing:-.02em;margin:8px 0 0;color:var(--ink)}
  .hero .dek{font-size:15px;color:var(--ink-2);margin-top:10px;max-width:70ch}
  .summ{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:10px;overflow:hidden;margin:18px 0 6px}
  @media(min-width:620px){.summ{grid-template-columns:repeat(4,1fr)}}
  .summ .s{background:var(--paper);padding:14px 16px}
  .summ .s .sk{font-family:var(--mono);font-size:9.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--mut)}
  .summ .s .sv{font-family:var(--serif);font-size:30px;color:var(--ink);margin-top:3px;font-variant-numeric:tabular-nums}
  .summ .s .sv.ok{color:var(--green-d)}.summ .s .sv.bad{color:var(--red)}.summ .s .sv.warn{color:var(--amber)}
  .genl{font-family:var(--mono);font-size:11px;color:var(--mut);margin:6px 0 2px}
  /* feeds table — 8 columns, owner bands, no horizontal scroll on desktop */
  .tblwrap{margin-top:14px;overflow:visible}
  table.mck{font-size:13.5px;table-layout:fixed}
  table.mck th,table.mck td{padding:9px 12px;vertical-align:middle}
  table.mck thead th{position:sticky;top:var(--masth);z-index:5;background:var(--paper-2);border-bottom:1.5px solid var(--line-2)}
  table.mck th.r,table.mck td.r{text-align:right}
  tr.band td{position:sticky;top:calc(var(--masth) + 31px);z-index:4;background:var(--paper);
    font-family:var(--mono);font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--mut);
    padding:8px 12px 6px;border-top:2px solid var(--line-2);border-bottom:1px solid var(--line)}
  tr.band td .bar{display:inline-block;width:8px;height:8px;border-radius:2px;margin-right:8px;vertical-align:-1px}
  tr.band td .bandn{float:right;letter-spacing:.04em;text-transform:none}
  td.c-name .nm{font-size:13.5px;font-weight:600;color:var(--ink);line-height:1.25}
  td.c-name .fd{font-size:11.5px;color:var(--mut);line-height:1.35;margin-top:1px}
  td.c-name .idm{font-family:var(--mono);font-size:9.5px;color:#9a9a94;margin-top:3px;letter-spacing:.01em}
  td.c-owner .ow{font-size:12px;color:var(--ink-2);line-height:1.28}
  .tchip{display:inline-block;font-family:var(--mono);font-size:8.5px;font-weight:600;letter-spacing:.04em;
    text-transform:uppercase;padding:1.5px 6px;border-radius:3px;border:1px solid;margin-top:4px;white-space:nowrap}
  td.c-cad{font-family:var(--mono);font-size:11.5px;color:var(--ink-2);white-space:nowrap}
  td.c-num{font-family:var(--mono);font-size:12px;font-variant-numeric:tabular-nums;color:var(--ink);white-space:nowrap}
  td.c-num.mut{color:var(--mut)}
  .dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:6px;vertical-align:-1px}
  .dot.green{background:var(--green)}.dot.amber{background:var(--amber)}.dot.red{background:var(--red)}.dot.grey{background:var(--line-2)}
  td.c-src{font-family:var(--mono);font-size:10px;line-height:1.4;overflow-wrap:break-word}
  td.c-src a{color:var(--green)}
  td.c-status{white-space:normal}
  td.c-status .lic{font-family:var(--mono);font-size:9px;color:var(--mut);margin-top:4px;line-height:1.3}
  td.c-status .lic.warn{color:var(--amber);font-weight:600}
  td.c-status .gate{font-family:var(--mono);font-size:9px;color:var(--mut);margin-top:3px}
  @media(max-width:820px){
    .tblwrap{overflow-x:auto}
    table.mck{min-width:860px}
    table.mck thead th,tr.band td{position:static}
  }
  .badge{font-family:var(--mono);font-size:9px;letter-spacing:.05em;text-transform:uppercase;padding:2px 7px;border-radius:3px;font-weight:600;white-space:nowrap}
  .badge.ok{background:var(--green-bg);color:var(--green-d)}
  .badge.skip{background:var(--paper-3);color:var(--mut)}
  .badge.fail{background:var(--red-bg);color:var(--red)}
  .badge.flag{background:var(--amber-bg);color:var(--amber)}
  .can{font-family:var(--mono);font-size:9px;color:var(--green-d)}
  .ctx{font-family:var(--mono);font-size:9px;color:var(--mut)}
</style>
<div class="wrap">
  <section class="hero">
    <span class="eyebrow">Every source, laid out</span>
    <h1>Sources &amp; data health</h1>
    <p class="dek">Every source behind this site — its cadence, the vintage of its latest data, its license, when it last ran, and whether it's healthy. If a feed fails, the last valid value is served and marked; nothing is invented.</p>
  </section>
  <div class="genl" id="genl"></div>
  <div class="summ" id="summ"></div>
  <div class="tblwrap"><table class="mck" id="tbl"></table></div>
</div>

<script>
const $=(s)=>document.querySelector(s);
async function J(p){const r=await fetch(p);if(!r.ok)throw new Error(p+' '+r.status);return r.json();}
function when(iso){if(!iso)return '—';const d=new Date(iso);return isNaN(d)?iso:d.toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});}
function esc(s){return String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));}

// ---- Source enrichment (REDESIGN-SPEC §6), inlined — the page can't import. ----
// Keyed by feed id. ownerType drives the band + chip. cadence is controlled vocab.
const SRC_META = {
  'banxico-pib-crecimiento':      { name: 'Real GDP growth',         feeds: 'Q4 · growth',                owner: 'Banco de México',            ownerType: 'central-bank',   cadence: 'Quarterly', db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-igae':                 { name: 'Monthly activity (IGAE)', feeds: 'Q4 · activity',              owner: 'Banco de México / INEGI',    ownerType: 'central-bank',   cadence: 'Monthly',   db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-inflacion':            { name: 'Headline inflation (CPI)',feeds: 'Q2 board · Q3 · money',      owner: 'Banco de México / INEGI',    ownerType: 'central-bank',   cadence: 'Monthly',   db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-inflacion-subyacente': { name: 'Core inflation',          feeds: 'Q3 · money',                 owner: 'Banco de México / INEGI',    ownerType: 'central-bank',   cadence: 'Monthly',   db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-tasa-objetivo':        { name: 'Policy rate',             feeds: 'Q2 board · Q3 · markets strip',owner: 'Banco de México',          ownerType: 'central-bank',   cadence: 'Daily',     db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-usdmxn-fix':           { name: 'Peso (FIX rate)',         feeds: 'Q2 board · Q3 · markets strip',owner: 'Banco de México',          ownerType: 'central-bank',   cadence: 'Daily',     db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-reservas':             { name: "Int'l reserves",          feeds: 'Q3 · money',                 owner: 'Banco de México',            ownerType: 'central-bank',   cadence: 'Weekly',    db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-remesas':              { name: 'Remittances',             feeds: 'Q6 · households',            owner: 'Banco de México',            ownerType: 'central-bank',   cadence: 'Monthly',   db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'banxico-salario-minimo':       { name: 'Minimum wage',            feeds: 'Q6 · households',            owner: 'Banco de México / CONASAMI', ownerType: 'central-bank',   cadence: 'Annual',    db: 'https://www.banxico.org.mx/SieAPIRest/' },
  'cre-gasolina-regular':         { name: 'Gasoline · regular',      feeds: 'Q2 board · Q6',              owner: 'CNE / Sener (ex-CRE)',       ownerType: 'energy',         cadence: 'Every 4h',  db: 'https://www.gob.mx/cre' },
  'cre-gasolina-premium':         { name: 'Gasoline · premium',      feeds: 'Q6 · households',            owner: 'CNE / Sener (ex-CRE)',       ownerType: 'energy',         cadence: 'Every 4h',  db: 'https://www.gob.mx/cre' },
  'cre-diesel':                   { name: 'Diesel',                  feeds: 'Q6 · households',            owner: 'CNE / Sener (ex-CRE)',       ownerType: 'energy',         cadence: 'Every 4h',  db: 'https://www.gob.mx/cre' },
  'se-ied':                       { name: 'Foreign direct investment',feeds: 'Q5 · nearshoring',          owner: 'Secretaría de Economía',     ownerType: 'national-stats', cadence: 'Quarterly', db: 'https://www.economia.gob.mx/datamexico/' },
  'coneval-pobreza':              { name: 'Poverty by municipality', feeds: 'Atlas map',                  owner: 'CONEVAL (via INEGI)',        ownerType: 'national-stats', cadence: '5-yr',      db: 'https://www.coneval.org.mx/' },
  'sesnsp-delitos':               { name: 'Reported crime by muni.', feeds: 'not mapped (see Q9)',        owner: 'SESNSP',                     ownerType: 'security',       cadence: 'Monthly',   db: 'https://www.gob.mx/sesnsp' },
  'imss-empleo':                  { name: 'Formal jobs (registered)',feeds: 'Q6 · households',            owner: 'IMSS (Datos Abiertos)',      ownerType: 'social-security',cadence: 'Monthly',   db: 'https://www.imss.gob.mx/' },
  'wb-gdp-usd':                   { name: 'GDP (current US$)',       feeds: 'Orientation · fact strip',   owner: 'World Bank',                 ownerType: 'multilateral',   cadence: 'Annual',    db: 'https://data.worldbank.org/country/mexico' },
  'wb-gdp-per-capita':            { name: 'GDP per capita (US$)',    feeds: 'Q4 · context',               owner: 'World Bank',                 ownerType: 'multilateral',   cadence: 'Annual',    db: 'https://data.worldbank.org/country/mexico' },
  'wb-inflation':                 { name: 'Inflation (annual, WB)',  feeds: 'context',                    owner: 'World Bank',                 ownerType: 'multilateral',   cadence: 'Annual',    db: 'https://data.worldbank.org/country/mexico' },
  'wb-population':                { name: 'Population',              feeds: 'Orientation · fact strip',   owner: 'World Bank',                 ownerType: 'multilateral',   cadence: 'Annual',    db: 'https://data.worldbank.org/country/mexico' },
  'wb-unemployment':              { name: 'Unemployment',            feeds: 'Q2 board',                   owner: 'World Bank',                 ownerType: 'multilateral',   cadence: 'Annual',    db: 'https://data.worldbank.org/country/mexico' },
};
// Band order + labels + chip colors for the 6 owner-type groupings (§6).
const OWNER_BANDS = [
  { key: 'central-bank',   label: 'Central bank (Banxico)',                    chip: '#075b38' },
  { key: 'national-stats', label: 'National statistics (INEGI · CONEVAL · SE)',chip: '#0a7d4d' },
  { key: 'social-security',label: 'Social security (IMSS)',                    chip: '#5c5c55' },
  { key: 'security',       label: 'Security & justice (SESNSP)',               chip: '#5c5c55' },
  { key: 'energy',         label: 'Energy (CRE / Sener)',                      chip: '#a6791a' },
  { key: 'multilateral',   label: 'Multilateral context (World Bank)',         chip: '#6f6f6f' },
];

// ---- cadence model — controlled vocab → sort rank + next-due delta ----
const MON=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function addMonths(d,n){const x=new Date(d.getTime());const day=x.getDate();x.setMonth(x.getMonth()+n);if(x.getDate()<day)x.setDate(0);return x;}
const CAD={
  'Every 4h':{rank:0,add:d=>new Date(d.getTime()+4*3600e3)},
  'Daily':   {rank:1,add:d=>new Date(d.getTime()+864e5)},
  'Weekly':  {rank:2,add:d=>new Date(d.getTime()+7*864e5)},
  'Monthly': {rank:3,add:d=>addMonths(d,1)},
  'Quarterly':{rank:4,add:d=>addMonths(d,3)},
  'Annual':  {rank:5,add:d=>addMonths(d,12)},
  '5-yr':    {rank:6,add:d=>addMonths(d,60)},
};
function cadRank(c){return CAD[c]?CAD[c].rank:99;}
function parseVintage(v){
  if(v==null||v==='')return null;
  const s=String(v).trim();
  if(/^\d{4}$/.test(s))return {d:new Date(+s,0,1),g:'y'};
  let m=/^(\d{4})-(\d{2})$/.exec(s);
  if(m)return {d:new Date(+m[1],+m[2]-1,1),g:'m'};
  m=/^(\d{4})-(\d{2})-(\d{2})/.exec(s);
  if(m)return {d:new Date(+m[1],+m[2]-1,+m[3]),g:'d'};
  const d=new Date(s);
  return isNaN(d)?null:{d,g:'d'};
}
function fmtVintage(v){
  const p=parseVintage(v);
  if(!p)return v?String(v):'—';
  if(p.g==='y')return String(p.d.getFullYear());
  if(p.g==='m')return MON[p.d.getMonth()]+' '+p.d.getFullYear();
  const now=new Date();
  return MON[p.d.getMonth()]+' '+p.d.getDate()+(p.d.getFullYear()!==now.getFullYear()?' '+p.d.getFullYear():'');
}
function fmtDay(iso){const d=new Date(iso);if(isNaN(d))return '—';return MON[d.getMonth()]+' '+d.getDate();}
function nextDue(meta,vintage){
  if(!meta||!CAD[meta.cadence])return null;
  const p=parseVintage(vintage);
  return p?CAD[meta.cadence].add(p.d):null;
}
function fmtDue(dt){
  if(!dt)return '—';
  const now=new Date();
  return MON[dt.getMonth()]+' '+dt.getDate()+(dt.getFullYear()!==now.getFullYear()?' '+dt.getFullYear():'');
}
// Health-monitor dot: green=fresh/not yet due · amber=overdue or vintage stale ·
// red=failed · grey=behind a flag. Driven off next-due (vintage+cadence) vs now,
// with two granularity corrections so the freshest feeds don't read as late:
//  · sub-daily feeds carry only a day-granular vintage → judge by last fetch instead;
//  · slower feeds get one cadence of publication-lag grace before flagging.
function statusColor(r,meta,now){
  if(r.status==='skipped'||r.gatedBy)return 'grey';
  if(r.status==='failed')return 'red';
  const C=meta&&CAD[meta.cadence];
  const p=parseVintage(r.vintage);
  if(!C||!p)return r.status==='ok'?'green':'grey';
  if(C.rank<=1){ // Every 4h · Daily — a same-day successful fetch is fresh
    const f=new Date(r.finishedAt||r.fetchedAt);
    return (!isNaN(f)&&(now-f)<=36*3600e3)?'green':'amber';
  }
  const graceDue=C.add(C.add(p.d)); // next point + one cadence of lag tolerance
  return now<=graceDue?'green':'amber';
}
const CHIP=Object.fromEntries(OWNER_BANDS.map(b=>[b.key,b.chip]));
const TYPE_LABEL={'central-bank':'Central bank','national-stats':"Nat'l stats",'social-security':'Social security','security':'Security','energy':'Energy','multilateral':'Multilateral'};
function licenseTag(meta){
  if(!meta)return null;
  if(meta.ownerType==='central-bank')return {t:'⚠ Banxico — not open',cls:'warn'};
  if(meta.ownerType==='multilateral')return {t:'CC BY-4.0',cls:''};
  return {t:'Libre Uso MX',cls:''};
}
function host(u){try{return new URL(u).host.replace(/^www\./,'');}catch(e){return u;}}

(async()=>{
  let h; try{h=await J('./data/health.json');}catch(e){$('#tbl').innerHTML='<tbody><tr><td style="color:var(--red)">Could not load health.json — '+e.message+'</td></tr></tbody>';return;}
  const s=h.summary||{};
  $('#genl').textContent='Last pipeline run: '+when(h.generatedAt)+(h.runId?'  ·  run '+h.runId:'')+(h.geoEpoch?'  ·  geo epoch '+h.geoEpoch.epoch+' ('+h.geoEpoch.count+' municipalities)':'');
  $('#summ').innerHTML=[
    {k:'Feeds healthy',v:s.ok||0,c:'ok'},
    {k:'Flagged',v:s.flagged||0,c:(s.flagged?'warn':'')},
    {k:'Failed',v:s.failed||0,c:(s.failed?'bad':'')},
    {k:'Behind a flag',v:s.skipped||0,c:''}
  ].map(x=>`<div class="s"><div class="sk">${x.k}</div><div class="sv ${x.c}">${x.v}</div></div>`).join('');

  const now=new Date();
  // group by owner-type band; any id missing from SRC_META falls into 'other'
  const byBand={};
  (h.sources||[]).forEach(r=>{
    const meta=SRC_META[r.id];
    const key=(meta&&meta.ownerType)||'other';
    (byBand[key]=byBand[key]||[]).push(r);
  });
  const bands=OWNER_BANDS.slice();
  if(byBand.other)bands.push({key:'other',label:'Other sources',chip:'#9a9a94'});

  let html='<colgroup><col><col style="width:150px"><col style="width:90px"><col style="width:90px"><col style="width:132px"><col style="width:100px"><col style="width:112px"><col style="width:112px"></colgroup>'+
    '<thead><tr><th>Dataset / what it feeds</th><th>Owner</th><th>Cadence</th><th class="r">Vintage</th><th class="r">Last updated</th><th class="r">Next due</th><th>Source</th><th>Status</th></tr></thead><tbody>';

  bands.forEach(band=>{
    const list=(byBand[band.key]||[]).slice().sort((a,b)=>{
      const ma=SRC_META[a.id],mb=SRC_META[b.id];
      const ra=cadRank(ma&&ma.cadence),rb=cadRank(mb&&mb.cadence);
      if(ra!==rb)return ra-rb;
      const na=(ma&&ma.name)||a.id, nb=(mb&&mb.name)||b.id;
      return na.localeCompare(nb);
    });
    if(!list.length)return;
    html+=`<tr class="band"><td colspan="8"><span class="bar" style="background:${band.chip}"></span>${esc(band.label)}<span class="bandn">· ${list.length} feed${list.length>1?'s':''}</span></td></tr>`;
    list.forEach(r=>{
      const meta=SRC_META[r.id];
      const name=(meta&&meta.name)||r.source||r.id;
      const feeds=(meta&&meta.feeds)||'';
      const owner=(meta&&meta.owner)||'—';
      const cad=(meta&&meta.cadence)||'—';
      const chipCol=meta?(CHIP[meta.ownerType]||'#9a9a94'):'#9a9a94';
      const typeLbl=meta?(TYPE_LABEL[meta.ownerType]||meta.ownerType):'';
      const col=statusColor(r,meta,now);
      const due=nextDue(meta,r.vintage);
      const upd=r.finishedAt||r.fetchedAt;
      const badge=r.status==='ok'?'<span class="badge ok">live</span>':r.status==='skipped'?'<span class="badge skip">flagged off</span>':r.status==='failed'?'<span class="badge fail">failed</span>':`<span class="badge flag">${esc(r.status)}</span>`;
      const lic=licenseTag(meta);
      const srcCell=(meta&&meta.db)?`<a href="${esc(meta.db)}" target="_blank" rel="noopener">${host(meta.db).replace(/\./g,'.<wbr>')}&nbsp;↗</a>`:esc(r.source||'—');
      html+=`<tr>
        <td class="c-name"><div class="nm">${esc(name)}</div>${feeds?`<div class="fd">${esc(feeds)}</div>`:''}<div class="idm">${esc(r.id)}</div></td>
        <td class="c-owner"><div class="ow">${esc(owner)}</div>${typeLbl?`<span class="tchip" style="color:${chipCol};border-color:${chipCol}66;background:${chipCol}14">${esc(typeLbl)}</span>`:''}</td>
        <td class="c-cad">${esc(cad)}</td>
        <td class="c-num r">${esc(fmtVintage(r.vintage))}</td>
        <td class="c-num r"><span class="dot ${col}"></span>${upd?esc(fmtDay(upd)):'—'}</td>
        <td class="c-num r mut">${esc(fmtDue(due))}</td>
        <td class="c-src">${srcCell}</td>
        <td class="c-status">${badge}${lic?`<div class="lic ${lic.cls}">${lic.t}</div>`:''}${r.gatedBy?`<div class="gate">flag: ${esc(r.gatedBy)}</div>`:''}</td>
      </tr>`;
    });
  });
  html+='</tbody>';
  $('#tbl').innerHTML=html;
})();
</script>
{% endraw %}
