# Node
node_modules/
npm-debug.log*

# Eleventy build output (generated by CF Pages at deploy time)
_site/

# Secrets — free API tokens live here locally, never in the repo (CI uses secrets)
pipeline/.env

# Pipeline run artifacts and local source downloads (regenerated each run)
pipeline/alerts.json
pipeline/.lastgood/
tmp/

# Local environment files. Keep examples, never real values.
.env
.env.*
!.env.example

# Geo-epoch RAW reference scratch (large, regenerable). The FROZEN, human-reviewed
# artifacts that the runtime depends on ARE committed:
#   pipeline/crosswalks/*.frozen.json   (the exact-or-fail lookups)
#   pipeline/crosswalks/overrides/*     (human-reviewed ambiguity fixes)
#   data/geo/municipios.topojson        (the map geometry for this geo-epoch)
pipeline/reference/

# OS
.DS_Store
private/

# Local authoring tools, generated email previews, and dated data snapshots.
# Keep these on this computer; publish only reviewed site and pipeline code.
.claude/
data/email/
data/source-snapshots/
email-preview.html
