const initialParams=new URLSearchParams(location.search),initialView=VIEWS[initialParams.get('q')]?initialParams.get('q'):'inflation',initialRange=['1Y','3Y','5Y','MAX'].includes(initialParams.get('r'))?initialParams.get('r'):VIEWS[initialView].range;
let state={view:initialView,range:initialRange,shown:[]};
function displaySeries(){
  const raw=VIEWS[state.view].series();if(state.range==='MAX')return raw;
  const months={"1Y":12,"3Y":36,"5Y":60}[state.range];const latest=Math.max(...raw.flatMap(s=>s.pts.map(p=>+new Date(p.date))));const cutoff=new Date(latest);cutoff.setUTCMonth(cutoff.getUTCMonth()-months);
  return raw.map(s=>({...s,pts:s.pts.filter(p=>+new Date(p.date)>=+cutoff)}));
}
function linePath(pts,X,Y,step){let d='';pts.forEach((p,i)=>{const x=X(new Date(p.date)),y=Y(p.value);if(!i)d=`M${x} ${y}`;else if(step){const px=X(new Date(pts[i-1].date));d+=` L${x} ${Y(pts[i-1].value)} L${x} ${y}`;}else d+=` L${x} ${y}`;});return d;}
function drawOne(series,{height=330,mobileHeight=245,band=null,chartIndex='all'}={}){
  const host=$('#plot'),mobile=host.clientWidth<560,W=Math.max(300,Math.round(host.clientWidth)),H=mobile?mobileHeight:height,pl=mobile?39:46,pr=mobile?12:18,pt=14,pb=30;
  const vals=series.flatMap(s=>s.pts.map(p=>p.value));let lo=Math.min(...vals),hi=Math.max(...vals);if(band){lo=Math.min(lo,band[0]);hi=Math.max(hi,band[1]);}const pad=(hi-lo||1)*.1;lo-=pad;hi+=pad;
  const times=series.flatMap(s=>s.pts.map(p=>+new Date(p.date))),t0=Math.min(...times),t1=Math.max(...times),iw=W-pl-pr,ih=H-pt-pb;
  const X=d=>pl+((+d-t0)/(t1-t0||1))*iw,Y=v=>pt+ih-(v-lo)/(hi-lo||1)*ih;
  let g=''; if(band){const y1=Y(band[1]),y0=Y(band[0]);g+=`<rect class="target" x="${pl}" y="${y1}" width="${iw}" height="${y0-y1}"></rect>`;}
  for(let i=0;i<4;i++){const v=lo+(hi-lo)*i/3,y=Y(v);g+=`<line class="grid" x1="${pl}" x2="${W-pr}" y1="${y}" y2="${y}"></line><text class="axis" x="${pl-7}" y="${y+4}" text-anchor="end" font-size="11">${series[0].axisFmt?.(v)||num(v,1)}</text>`;}
  const ref=series.reduce((a,s)=>s.pts.length>a.length?s.pts:a,[]),xi=mobile?[0,ref.length-1]:[0,Math.floor(ref.length/2),ref.length-1];[...new Set(xi)].forEach((j,i,a)=>{const x=X(new Date(ref[j].date));g+=`<text class="axis" x="${x}" y="${H-7}" text-anchor="${i===0?'start':i===a.length-1?'end':'middle'}" font-size="11">${fmtDate(ref[j].date)}</text>`;});
  series.forEach(s=>{g+=`<path class="${s.step?'step':'line'}" stroke="${s.color}" d="${linePath(s.pts,X,Y,s.step)}"></path>`;});
  g+=`<line class="crosshair" x1="0" x2="0" y1="${pt}" y2="${H-pb}" visibility="hidden"></line>`;
  return `<svg class="chart-svg" data-chart-index="${chartIndex}" data-pl="${pl}" data-pr="${pr}" data-pt="${pt}" data-pb="${pb}" data-t0="${t0}" data-t1="${t1}" viewBox="0 0 ${W} ${H}" role="img" aria-label="${series.map(s=>s.name).join(' and ')} over time"><title>${series.map(s=>s.name).join(' and ')}</title><desc>Move across the chart to inspect all series at the same month.</desc>${g}</svg>`;
}
function drawSmall(series){return series.map((s,i)=>`<div class="chart-wrap"><div class="small-title"><span>${s.name}</span><span>${s.fmt(last(s.pts).value)}</span></div>${drawOne([s],{height:155,mobileHeight:145,chartIndex:i})}<div class="chart-tip"></div></div>`).join('');}
function linkAttrs(href){return href.startsWith('#')?'':' target="_blank" rel="noopener"';}
function linkArrow(href){return href.startsWith('#')?'→':'↗';}
function legend(series){return series.map(s=>`<a class="legend-item" href="${s.href}"${linkAttrs(s.href)}><i style="background:${s.color}"></i>${s.name} ${linkArrow(s.href)}</a>`).join('');}
function deltaText(s){
  const now=last(s.pts);if(s.delta==='sinceStart')return `Since ${fmtDate(s.pts[0].date)}`;
  let prev=s.delta?.includes('Year')?yearPrior(s.pts,now.date):null;if(!prev&&s.delta==='ppAvailable')prev=s.pts[0];if(!prev)prev=s.pts[s.pts.length-2];if(!prev)return 'No earlier observation in this view';
  if(s.delta==='pesoYear'){const pct=(prev.value-now.value)/prev.value*100;return `${pct>=0?'↑':'↓'} ${num(Math.abs(pct),1)}% ${pct>=0?'stronger':'weaker'} vs ${fmtDate(prev.date)}`;}
  const d=now.value-prev.value;if(s.delta==='ppYear'||s.delta==='ppAvailable'||s.delta==='ppPrior')return `${arrow(d)} ${num(Math.abs(d),2)} pp vs ${fmtDate(prev.date)}`;
  return `${arrow(d)} ${num(Math.abs(d),1)} vs ${fmtDate(prev.date)}`;
}
function readings(series){return series.map(s=>{const p=last(s.pts);return `<div class="reading-row"><div class="reading-k">${s.name}</div><div class="reading-v">${s.readingFmt?.(p.value)||s.fmt(p.value)}</div><div class="reading-m">${deltaText(s)}<br><a href="${s.href}"${linkAttrs(s.href)}>${s.source} ${linkArrow(s.href)}</a> · ${fmtDate(p.date)}</div></div>`;}).join('');}
function unionKeys(series){return [...new Set(series.flatMap(s=>s.pts.map(p=>monthKey(p.date))))].sort();}
function table(series){const maps=series.map(s=>map(s.pts)),keys=unionKeys(series);return `<table><thead><tr><th>Period</th>${series.map(s=>`<th>${s.name}</th>`).join('')}</tr></thead><tbody>${keys.slice().reverse().slice(0,18).map(k=>`<tr><td>${fmtDate(k+'-01')}</td>${series.map((s,i)=>`<td>${maps[i][k]==null?'—':s.fmt(maps[i][k])}</td>`).join('')}</tr>`).join('')}</tbody></table>`;}
function bindHovers(series,type){
  $$('.chart-svg').forEach(svg=>{const idx=svg.dataset.chartIndex,shown=idx==='all'?series:[series[Number(idx)]],wrap=svg.closest('.chart-wrap')||$('#plot'),tip=wrap.querySelector('.chart-tip')||$('#plot').appendChild(Object.assign(document.createElement('div'),{className:'chart-tip'})),cross=svg.querySelector('.crosshair'),keys=unionKeys(shown),vb=svg.viewBox.baseVal,pl=+svg.dataset.pl,pr=+svg.dataset.pr,t0=+svg.dataset.t0,t1=+svg.dataset.t1;
    const inspect=e=>{const rect=svg.getBoundingClientRect(),xSvg=(e.clientX-rect.left)/rect.width*vb.width,clamped=Math.max(pl,Math.min(vb.width-pr,xSvg)),target=t0+(clamped-pl)/(vb.width-pl-pr)*(t1-t0),key=keys.reduce((best,k)=>Math.abs(+new Date(k+'-01')-target)<Math.abs(+new Date(best+'-01')-target)?k:best,keys[0]),x=pl+(+new Date(key+'-01')-t0)/(t1-t0||1)*(vb.width-pl-pr),maps=shown.map(s=>map(s.pts));cross.setAttribute('x1',x);cross.setAttribute('x2',x);cross.setAttribute('visibility','visible');tip.innerHTML=`<b>${fmtDate(key+'-01')}</b><br>${shown.map((s,i)=>`${s.name}: ${maps[i][key]==null?'—':s.fmt(maps[i][key])}`).join('<br>')}`;tip.classList.add('open');const left=(x/vb.width)*rect.width;tip.style.left=Math.max(4,Math.min(rect.width-250,left+8))+'px';tip.style.top='8px';};
    svg.addEventListener('pointermove',inspect);svg.addEventListener('click',inspect);svg.addEventListener('pointerleave',()=>{if(!matchMedia('(pointer:coarse)').matches){cross.setAttribute('visibility','hidden');tip.classList.remove('open');}});
  });
}
function render(){
  try{const v=VIEWS[state.view],series=displaySeries();if(series.some(s=>!s.pts.length))throw new Error('one or more feeds have no observations in this period');state.shown=series;
  $('#viewQuestion').textContent=v.question;$('#viewTitle').textContent=typeof v.title==='function'?v.title(series):v.title;$('#viewAnswer').innerHTML=v.answer(series);$('#compareNote').textContent=v.note;$('#plotFoot').textContent=v.foot;$('#whyText').textContent=v.why;$('#cannotText').textContent=v.cannot;$('#methodBody').innerHTML=typeof v.method==='function'?v.method():v.method;$('#editLink').href=v.link.replace(/r=[^&]+/,'r='+state.range);
  $('#legend').innerHTML=legend(series);$('#plot').innerHTML=v.type==='small'?drawSmall(series):`<div class="chart-wrap">${drawOne(series,{band:v.band})}<div class="chart-tip"></div></div>`;$('#readingRows').innerHTML=readings(series);$('#dataTable').innerHTML=table(series);bindHovers(series,v.type);
  $$('[data-view]').forEach(b=>{const on=b.dataset.view===state.view;b.classList.toggle('active',on);b.setAttribute('aria-pressed',String(on));});$$('[data-range]').forEach(b=>{const on=b.dataset.range===state.range;b.classList.toggle('active',on);b.setAttribute('aria-pressed',String(on));});
  history.replaceState(null,'',`${location.pathname}?q=${state.view}&r=${state.range}`);
  }catch(e){$('#viewTitle').textContent='This chart is unavailable.';$('#viewAnswer').textContent=`The data did not load cleanly (${e.message}). The chart stays blank rather than showing an incomplete comparison.`;$('#legend').innerHTML='';$('#plot').innerHTML='';$('#readingRows').innerHTML='';}
}
document.querySelectorAll('[data-view]').forEach(b=>b.addEventListener('click',()=>{state.view=b.dataset.view;state.range=VIEWS[state.view].range;$('#dataTable').classList.remove('open');$('#tableButton').textContent='View data';render();}));
document.querySelectorAll('[data-range]').forEach(b=>b.addEventListener('click',()=>{state.range=b.dataset.range;render();}));
$('#tableButton').addEventListener('click',()=>{const on=$('#dataTable').classList.toggle('open');$('#tableButton').textContent=on?'Hide data':'View data';});
$('#csvButton').addEventListener('click',()=>{const s=state.shown,maps=s.map(x=>map(x.pts)),keys=unionKeys(s),rows=[['period',...s.map(x=>x.name)].join(','),...keys.map(k=>[k,...maps.map(m=>m[k]??'')].join(','))].join('\n'),url=URL.createObjectURL(new Blob([rows],{type:'text/csv'})),a=document.createElement('a');a.href=url;a.download='mexico-brief-'+state.view+'.csv';a.click();setTimeout(()=>URL.revokeObjectURL(url),0);});
document.addEventListener('click',e=>{if(e.target.closest('a[href="#methodDetails"]'))$('#methodDetails').open=true;});
let rt;window.addEventListener('resize',()=>{clearTimeout(rt);rt=setTimeout(render,160)});
render();
</script>
