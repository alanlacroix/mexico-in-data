# Cloudflare Pages cache policy.
# The stylesheet URL is content-hashed (?v=hash in the HTML), so it's safe to cache
# forever — any CSS change ships a brand-new URL. HTML must revalidate so browsers
# pick up the new hash. Data JSON is short-cached (the cron refreshes every ~6h).

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/design/*
  Cache-Control: public, max-age=31536000, immutable

# assets/mb.js is an ES module the HTML imports by a fixed URL (not content-hashed),
# so it MUST revalidate in lockstep with the HTML. If it were cached independently, a
# fresh index.html could pair with a stale cached mb.js that lacks a newly-added export —
# the module throws at load and the whole page renders blank. Revalidate always.
/assets/*
  Cache-Control: public, max-age=0, must-revalidate

/data/*
  Cache-Control: public, max-age=300

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Local design and generated-email previews remain reachable for review but must
# never become search results.
/mockup.html
  X-Robots-Tag: noindex, nofollow

/daily-start-mockup.html
  X-Robots-Tag: noindex, nofollow

/charts-start-mockup.html
  X-Robots-Tag: noindex, nofollow

/topics-start-mockup.html
  X-Robots-Tag: noindex, nofollow

/weekly-sample.html
  X-Robots-Tag: noindex, nofollow
