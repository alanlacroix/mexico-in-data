<script type="module">
import { loadSeries, S, EVENTS, NEWS, tile, mrow, sectionHead, exhibit, dataTable, timeChart, hbarChart, fwd, qtrOf, relTime, evDate, tagChip, wireCharts, valueAgo, monLong, renderDevelopments, srcBadge, storyBlock } from '/assets/mb.js?v=11';

/* US–Mexico keyword filters — the task's keyword set (USMCA/TMEC/arancel/tariff/EEUU/
   Estados Unidos/frontera/border/comercio/exportaciones/Trump) plus the border/migration
   and remittance terms the section explicitly covers. */
const RE_EV = /usmca|t-?mec|arancel|tariff|ee\.?uu|estados unidos|frontera|\bborder\b|comercio|exportaci|trump|united states/i;
const RE_NEWS = /usmca|t-?mec|arancel|tariff|ee\.?uu|estados unidos|frontera|\bborder\b|comercio|exportaci|trump|remesa|remittance|\bice\b|migra|deportaci|\bustr\b|washington/i;

/* the export-destination split — migrated VERBATIM from the homepage's Q4 exhibit 4.2
   (Q8 references this same ~80% figure). A hardcoded government stat, not a live feed. */
const DEST = [{label:'United States',value:80,hi:true},{label:'Canada',value:3},{label:'China',value:2},{label:'Rest of world',value:15}];

/* ---- a static / from-trade-json tile with the same .tile markup tile() emits ---- */
function ctile(o){
  return `<div class="tile"${o.go?` data-go="${o.go}"`:''}><div class="tl">${o.l}</div>`+
    `<div class="tv">${o.v} <small>${o.s||''}</small></div>`+
    (o.dl||'')+(o.spark||'')+
    `<div class="tb">${o.tb||''}</div>`+
    `<span class="stamp ${o.stampCls||''}">${o.stamp||''}</span>`+
    (o.src?`<span class="tsrc">${o.src}</span><div class="tbadge">${srcBadge(o.src)}</div>`:'')+`</div>`;
}
function pctDelta(series){
  if(!series||series.length<13) return '';
  const cur=series.at(-1).value, ago=valueAgo(series,365);
  if(!ago) return '';
  const pct=(cur-ago)/ago*100;
  if(Math.abs(pct)<0.05) return `<span class="dl fl">held <small>vs a year ago</small></span>`;
  return `<span class="dl ${pct>0?'up':'dn'}">${pct>0?'+':''}${pct.toFixed(1)}% <small>vs a year ago</small></span>`;
}

/* block 2 — the live tile board. Hero (~80%) + two-way trade + surplus + tariff come from the
   same JSON their exhibits use; remittances + peso reuse tile() straight off the loaded series. */
function renderTiles(TRADE, PART){
  let out='';
  const usSh=PART&&PART.exports?Math.round(PART.exports.items[0].share):80;   // bound to the same file /trade renders — can't drift
  out+=ctile({l:'Exports to the U.S.', v:'~'+usSh, s:'% of total', tb:'The next buyer, Canada, takes 3%', stamp:'ANNUAL · '+(PART?PART.year:'2024'), src:'UN COMTRADE / Banxico'});
  if(TRADE&&TRADE.latest&&TRADE.series){
    const L=TRADE.latest, mo=monLong(L.month);
    const expByMonth=Object.fromEntries((TRADE.series.exports||[]).map(m=>[m.month,m.value]));
    const twoway=(TRADE.series.imports||[]).filter(m=>expByMonth[m.month]!=null).map(m=>({date:m.month,value:m.value+expByMonth[m.month]}));
    const surplus=(TRADE.series.imports||[]).filter(m=>expByMonth[m.month]!=null).map(m=>({date:m.month,value:m.value-expByMonth[m.month]}));
    out+=ctile({l:'Two-way trade · monthly', v:'$'+Math.round(L.twoway_bn), s:'bn / month', dl:pctDelta(twoway), spark:'', tb:'U.S.–Mexico goods, both directions', stamp:'MONTHLY · '+mo, src:'U.S. Census Bureau'});
    out+=ctile({l:"Mexico's surplus · monthly", v:'$'+Math.round(-L.balance_bn), s:'bn / month', dl:pctDelta(surplus), spark:'', tb:'Mexico sells the U.S. more than it buys', stamp:'MONTHLY · '+mo, src:'U.S. Census Bureau'});
  } else {
    out+=ctile({l:'Two-way trade · monthly', v:'<span style="font-size:15px;color:var(--amber2)">Data unavailable</span>', s:'', tb:'U.S. Census Bureau feed did not load', stamp:''});
    out+=ctile({l:"Mexico's surplus · monthly", v:'<span style="font-size:15px;color:var(--amber2)">Data unavailable</span>', s:'', tb:'U.S. Census Bureau feed did not load', stamp:''});
  }
  out+=ctile({l:'Effective U.S. tariff', v:'~4', s:'%', tb:'The U.S. Supreme Court struck down the blanket IEEPA tariffs', stamp:'AS OF FEB 2026', src:'USTR · U.S. Supreme Court'});
  out+=tile({id:'banxico-remesas',l:'Remittances · month'},{src:true});
  out+=tile({id:'banxico-usdmxn-fix',l:'Peso · MXN/USD'},{src:true});
  return out;
}

/* block 3 — Background. Hero exhibit = the ~80% dependence (migrated from Q4/Q8); then the
   live USMCA/tariff fact card migrated VERBATIM from Q8; then trade flows over time; the peso
   and remittances rows; a deeper "what the US buys" exhibit; the Q8 forward line + a gloss. */
function renderBackground(TRADE, PART){
  // 8.1 retired: the export-destination split now lives on /trade (Fable: one series, one room). Pointer only.
  const usSh=PART&&PART.exports?Math.round(PART.exports.items[0].share):80;
  const ex1=exhibit('8.1',`The United States buys about ${usSh}% of Mexico's goods exports`,'Export destinations · full detail on the Trade page',
    `<p style="font-size:15px;line-height:1.55;color:var(--ink-2);margin:0 0 8px">Canada takes 3% of Mexico's exports and China takes 2%. The Trade page charts the export basket, every trading partner, and the balance over two decades.</p><a href="/trade.html" style="color:var(--green);font-weight:500">See the full trade picture → Trade</a>`,
    `Source: <a href="https://comtradeapi.un.org" target="_blank" rel="noopener">UN COMTRADE</a>, reconciled to <a href="https://www.banxico.org.mx/SieInternet/" target="_blank" rel="noopener">Banxico</a>. Detailed charts on Trade.`,
    '', true);

  // the live story — fact card migrated VERBATIM from the homepage's Q8 (internal ref rewritten to the homepage anchor)
  const fc=`<div class="factcard">`+
      `<div class="fc-row"><span class="fc-k">Trade pact</span><span class="fc-v"><b>USMCA</b> is in force to 2036. The <b>2026 joint review is unresolved</b>: the U.S. declined to renew on schedule (Jul 1, 2026)</span></div>`+
      `<div class="fc-row"><span class="fc-k">Tariffs</span><span class="fc-v">The U.S. Supreme Court struck down the blanket IEEPA tariffs (Feb 2026). The effective U.S. tariff is now <b>~4%</b>. Washington still threatens tariffs on individual sectors</span></div>`+
      `<div class="fc-row"><span class="fc-k">Why it matters</span><span class="fc-v">The U.S. buys ~80% of Mexico's exports, so trade terms are the economy's single biggest external risk. <a href="/#q4">Homepage question 4 →</a></span></div>`+
    `</div>`+
    `<div class="oc-src">Sources: <a href="https://ustr.gov" target="_blank" rel="noopener">USTR</a> · <a href="https://www.gob.mx/se" target="_blank" rel="noopener">Secretaría de Economía</a> · verified Jul 2026.</div>`;

  // exhibit 8.2 — two-way goods trade over time (US Census ledger)
  let ex2='';
  if(TRADE&&TRADE.series){
    const imp=(TRADE.series.imports||[]).slice(-60).map(m=>({date:m.month,value:m.value}));
    const exp=(TRADE.series.exports||[]).slice(-60).map(m=>({date:m.month,value:m.value}));
    if(imp.length&&exp.length){
      const expByMonth=Object.fromEntries((TRADE.series.exports||[]).map(m=>[m.month,m.value]));
      const rows=(TRADE.series.imports||[]).filter(m=>expByMonth[m.month]!=null).slice(-8).map(m=>[monLong(m.month),m.value.toFixed(1),expByMonth[m.month].toFixed(1),(m.value-expByMonth[m.month]).toFixed(1)]);
      ex2=exhibit('8.2','The U.S. buys more from Mexico than it sells, every month','U.S.–Mexico goods trade, monthly, US$ bn · U.S. Census ledger',
        timeChart([{name:'U.S. buys',color:'green',pts:imp},{name:'U.S. sells',color:'var(--ink)',pts:exp}],{unit:'$'}),
        `Source: <a href="https://www.census.gov/foreign-trade/" target="_blank" rel="noopener">U.S. Census Bureau</a>, International Trade · US imports from / exports to Mexico.`,
        dataTable(['Month','U.S. buys','U.S. sells','MX surplus'],rows),true);
    }
  }

  // exhibit 8.3 — what the US actually buys from Mexico (tucked under a "more" disclosure)
  let ex3='';
  if(TRADE&&TRADE.topImports&&TRADE.topImports.length){
    const buys=TRADE.topImports.map((x,i)=>({label:x.name,value:x.value_bn,hi:i===0}));
    ex3=exhibit('8.3','Cars, computers, and electronics top what the U.S. buys from Mexico','Top U.S. goods imports from Mexico, trailing 12 months, US$ bn',
      hbarChart(buys,{vfmt:(v)=>'$'+v+'B'}),
      `Source: <a href="https://www.census.gov/foreign-trade/" target="_blank" rel="noopener">U.S. Census Bureau</a>, HS2 chapters, trailing 12 months.`,
      dataTable(['Product','Imports','HS'],TRADE.topImports.map(x=>[x.name,'$'+x.value_bn+'B',x.hs])),true);
  }

  return sectionHead('Background',"Where the U.S. relationship stands","The effective U.S. tariff is about 4% and the 2026 USMCA review is unresolved. This section tracks the trade terms, the monthly balance, the peso, and remittances.")+
    ex1+ fc+ ex2+
    mrow({id:'banxico-usdmxn-fix',label:'Peso · Banxico reference rate'})+
    mrow({id:'banxico-remesas',label:'Remittances · monthly'})+
    (ex3?`<details class="more"><summary>More: what the U.S. buys from Mexico</summary>${ex3}</details>`:'')+
    fwd(`Watch the <b>USMCA review timeline</b>: scheduled review rounds appear in the calendar below. Test the downside in the model: <a href="/model.html">"USMCA review fails" →</a>.`)+
    `<div class="ctxline">Terms: <b>USMCA / T-MEC</b> = the North American trade pact · <b>IEEPA</b> = the U.S. emergency-powers law behind the blanket tariffs the Supreme Court struck down · <b>USTR</b> = the U.S. Trade Representative.</div>`;
}

/* block 4 — the US–Mexico catalyst calendar (USMCA review rounds + any trade-tagged events) */
function renderWatch(){
  const ev=(EVENTS&&EVENTS.events)||[];
  const rel=ev.filter(e=>e.kind==='trade'||RE_EV.test((e.label||'')+' '+(e.mechanism||'')));
  const now=Date.now();
  const up=rel.filter(e=>new Date(e.date)>=now-864e5).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,6);
  if(!up.length) return `<div class="cb-empty">Nothing on the calendar yet. U.S.–Mexico dates will appear here as they are announced.</div>`;
  return `<div class="watchtbl">`+up.map(e=>{const d=evDate(e);
    return `<div class="wtr"><div class="wd">${d.mo} ${d.day}, ${d.y}${e.approx?' ~':''}</div><div class="wk ${e.kind||''}"></div><div class="wt">${e.label}<div class="wm">${e.mechanism||''}${e.sourceUrl?` · <a class="wsrc" href="${e.sourceUrl}" target="_blank" rel="noopener" style="color:var(--green)">${e.source||'source'}</a>`:''}</div></div></div>`;}).join('')+`</div>`;
}

/* block 5 — latest US-relationship headlines */
function renderWire(){ return renderDevelopments('us-mexico'); }   // curated events for this section, not the raw wire

/* boot */
(async()=>{
  await loadSeries();
  const TRADE = await fetch('./data/trade-us.json').then(r=>r.ok?r.json():null).catch(()=>null);
  const PART = await fetch('./data/trade/exports-by-partner.json').then(r=>r.ok?r.json():null).catch(()=>null);  // same partner file /trade renders (single source)
  // as-of = freshest fetch across the loaded series + the trade ledger
  const times=[...Object.values(S).map(s=>new Date(s.meta.fetchedAt).getTime()), TRADE&&TRADE.meta?new Date(TRADE.meta.fetchedAt).getTime():0].filter(t=>t&&!isNaN(t));
  if(times.length){
    const newest=new Date(Math.max(...times));
    document.getElementById('asof').textContent=newest.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
    document.getElementById('board-asof').textContent='as of '+newest.toLocaleDateString('en-US',{month:'short',day:'numeric'});
  }
  document.getElementById('tablero').innerHTML=renderTiles(TRADE, PART);
  document.getElementById('background').innerHTML=renderBackground(TRADE, PART)+storyBlock({asof:'Jul 2026',
    p1:`About <b>80%</b> of Mexico's exports go to the United States. The U.S. Supreme Court struck down the blanket IEEPA tariffs in February, and the effective rate fell back to about <b>4%</b>. The <b>2026 USMCA review</b> is unresolved: Washington declined to renew on schedule on July 1. Month to month, Mexico still sells the U.S. more than it buys.`,
    p2:`Trade terms, not oil or the peso, are Mexico's single biggest external risk. A stalled review or a new sector tariff would hit most of what the country exports, and the factories, jobs, and growth behind those exports.`,
    src:'U.S. Census Bureau, USTR, Banco de México'});
  document.getElementById('watch-list').innerHTML=renderWatch();
  document.getElementById('wire-list').innerHTML=renderWire();
  wireCharts();
  // tile → scroll to its metric row in Background (peso / remittances tiles carry data-go)
  document.getElementById('tablero').addEventListener('click',(e)=>{const t=e.target.closest('[data-go]');if(!t)return;const row=document.querySelector('[data-metric="'+t.getAttribute('data-go')+'"]');if(row)row.scrollIntoView({behavior:'smooth',block:'center'});});
})().catch(e=>{
  const h=document.getElementById('background'); if(h)h.innerHTML='<p style="font-family:var(--mono);font-size:12px;color:var(--red)">Error loading U.S.–Mexico data: '+e.message+'</p>';
});
</script>
