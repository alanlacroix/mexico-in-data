<script type="module">
import { loadSeries, EVENTS, NEWS, sectionHead, staticRow, fwd, evDate, relTime, tagChip, renderDevelopments, srcBadge } from '/assets/mb.js?v=5';

/* the politics keyword filter — shared by the calendar (block 4) and the wire (block 5).
   Spanish + English institution words; \b guards stop "selecciones" matching "elecci" etc. */
const POL_RX=/sheinbaum|morena|gobierno|pol[ií]tic|\belecc|\belect|comicios|congreso|senado|diputad|judicial|oposici|\bpan\b|\bpri\b|gobernador|gubernatur|informe|constituc|government|\bcongress|senate|\belection|midterm|opposition|\bpresident|\bminister|cabinet/i;

/* block 2 — the state-of-play board. Politics has no live series, so these are dated
   static facts drawn from the SAME q7 source content as the fact card below (never a
   re-authored live number). The one poll figure carries a "not live" chip. */
const TILES=[
  {tl:'Head of government', tv:'Sheinbaum', sz:23, tb:'Claudia Sheinbaum · Morena', stamp:'SWORN IN OCT 2024', tsrc:'Presidencia / INE'},
  {tl:'Presidential term', tv:'2024–2030', sz:29, tb:'The six-year sexenio · no re-election', stamp:'TO 2030', tsrc:'CPEUM'},
  {tl:'Congress', tv:'Supermajority', sz:19, tb:'Morena + allies — a qualified bloc able to amend the constitution', stamp:'SINCE 2024', tsrc:'Cámara de Diputados'},
  {tl:'Judiciary', tv:'Elected', sz:26, tb:'Judges now chosen by popular vote — the 2024–25 reform', stamp:'REFORM 2024–25', tsrc:'DOF / reform'},
  {tl:'Presidential approval', tv:'49–68 <small>%</small>', tb:'By pollster · Mitofsky ~68, AtlasIntel ~49', stamp:'POLL · JUN 2026', chip:'not live', tsrc:'AS/COA tracker'},
  {tl:'Next federal vote', tv:'Jun 2027', sz:27, tb:'Midterms — all 500 deputies + 17 governorships', stamp:'SCHEDULED', tsrc:'INE'},
];
function renderTiles(){
  return TILES.map(t=>`<div class="tile" data-go="background"><div class="tl">${t.tl}</div>`+
    `<div class="tv"${t.sz?` style="font-size:${t.sz}px"`:''}>${t.tv}</div>`+
    `<div class="tb">${t.tb}</div>`+
    `<span class="stamp ${t.stamp&&/POLL/.test(t.stamp)?'':''}">${t.stamp}${t.chip?'<span class="chip-ph">'+t.chip+'</span>':''}</span>`+
    (t.tsrc?`<span class="tsrc">${t.tsrc}</span><div class="tbadge">${srcBadge(t.tsrc)}</div>`:'')+`</div>`).join('');
}

/* block 3 — the migrated Q7 "who governs" fact card + honesty note + approval poll row +
   forward line, built exactly as index.njk builds it. No chart: q7 carries no political
   time series (none exists), so this stays a fact card, not a fabricated exhibit. */
function renderBackground(){
  return sectionHead('Background',"Who governs, and is it stable?","One party governs with a supermajority; the president is popular but slipping.")+
    `<div class="factcard">`+
      `<div class="fc-row"><span class="fc-k">Head of government</span><span class="fc-v"><b>Claudia Sheinbaum</b> (Morena) · sworn in Oct 2024, term to 2030</span></div>`+
      `<div class="fc-row"><span class="fc-k">Legislature</span><span class="fc-v">Morena + allies hold a <b>qualified supermajority</b> — able to amend the constitution</span></div>`+
      `<div class="fc-row"><span class="fc-k">Signature change</span><span class="fc-v">2024–25 judicial reform: judges now <b>elected by popular vote</b></span></div>`+
      `<div class="fc-row"><span class="fc-k">Next federal vote</span><span class="fc-v"><b>Jun 6, 2027</b> — midterms: all 500 deputies + 17 governorships</span></div>`+
    `</div>`+
    `<div class="honesty">No official real-time series exists for political sentiment. The figure below is a named poll, stamped with its polling house and field date.</div>`+
    staticRow({label:'Presidential approval (Sheinbaum)',value:'49–68',unit:'% (by pollster)',stamp:'POLL · Jun 2026',verdict:'Wide range by method: Mitofsky ~68%, AtlasIntel ~49% (first read below 50%). Trend is gently down from very high levels.',bench:'vs ~60% first-year average',srcName:'AS/COA Approval Tracker (Mitofsky · AtlasIntel)',srcUrl:'https://www.as-coa.org/articles/approval-tracker-mexicos-president-claudia-sheinbaum'})+
    fwd(`The <b>2027 midterms</b> are the next scheduled test of the supermajority. <a href="#watch">See what to watch ↓</a>`)+
    `<div class="ctxline">Gloss: <b>Morena</b> = the governing party (founded 2014) · <b>qualified supermajority</b> = a two-thirds bloc able to amend the constitution · <b>midterms</b> = the mid-sexenio federal vote that renews the entire Chamber of Deputies.</div>`;
}

/* block 4 — politics-relevant catalyst calendar (kind political/election + keyword match) */
function renderWatch(){
  const ev=(EVENTS&&EVENTS.events)||[];
  const pol=ev.filter(e=>{const k=(e.kind||'');
    if(k==='political'||k==='election')return true;
    return POL_RX.test((e.label||'')+' '+(e.mechanism||''));});
  const now=Date.now();
  const up=pol.filter(e=>new Date(e.date)>=now-864e5).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,6);
  if(!up.length) return `<div class="cb-empty">Nothing dated on the political calendar yet — scheduled events will appear here as they are set.</div>`;
  return `<div class="watchtbl">`+up.map(e=>{const d=evDate(e);
    return `<div class="wtr"><div class="wd">${d.mo} ${d.day}, ${d.y}${e.approx?' ~':''}</div><div class="wk ${e.kind||''}"></div><div class="wt">${e.label}<div class="wm">${e.mechanism||''}${e.sourceUrl?` · <a class="wsrc" href="${e.sourceUrl}" target="_blank" rel="noopener" style="color:var(--green)">${e.source||'source'}</a>`:''}</div></div></div>`;}).join('')+`</div>`;
}

/* block 5 — latest government/politics headlines */
function renderWire(){ return renderDevelopments('politics'); }   // curated events for this section, not the raw wire

/* boot */
(async()=>{
  await loadSeries([]); // no money series for politics — just populates NEWS + EVENTS
  // as-of = the dated stamp on the facts wired to this page (events feed's updated date)
  let asof='Jul 2026';
  const upd=EVENTS&&EVENTS.meta&&EVENTS.meta.updated;
  if(upd){const d=new Date(upd+'T12:00:00'); if(!isNaN(d)) asof=d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});}
  document.getElementById('asof').textContent=asof;
  document.getElementById('board-asof').textContent='as of '+asof;
  document.getElementById('tablero').innerHTML=renderTiles();
  document.getElementById('background').innerHTML=renderBackground();
  document.getElementById('watch-list').innerHTML=renderWatch();
  document.getElementById('wire-list').innerHTML=renderWire();
  // tile → scroll to the Background detail (fact card + approval poll)
  document.getElementById('tablero').addEventListener('click',(e)=>{if(!e.target.closest('.tile'))return;const b=document.getElementById('background');if(b)b.scrollIntoView({behavior:'smooth',block:'start'});});
})().catch(e=>{
  const h=document.getElementById('background'); if(h)h.innerHTML='<p style="font-family:var(--mono);font-size:12px;color:var(--red)">Error loading politics data: '+e.message+'</p>';
});
</script>
{% endraw %}
