  /* fact card (migrated from index.njk's inline style — q7 uses it) */
  .factcard{border:1px solid var(--line-2);border-radius:10px;padding:15px 17px;margin:10px 0 4px}
  .factcard .fc-row{display:flex;justify-content:space-between;gap:12px;padding:8px 0;border-bottom:1px solid var(--line);font-size:14px}
