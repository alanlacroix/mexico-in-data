  /* 6 · tools & sources */
  .tools-grid{display:grid;grid-template-columns:1fr;gap:1px;background:var(--line);border:1px solid var(--line);border-radius:9px;overflow:hidden;margin:6px 0 4px}
  @media(min-width:560px){.tools-grid{grid-template-columns:1fr 1fr}}
  .tools-grid a{display:block;background:var(--paper);padding:14px 16px;text-decoration:none}
  .tools-grid a:hover{background:var(--paper-2)}
  .tools-grid .tk{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.04em;color:var(--green)}
  .tools-grid .th{font-family:var(--serif);font-size:16px;color:var(--ink);margin:4px 0 3px}
  .tools-grid .td{font-size:13px;color:var(--ink-2);line-height:1.45}
  .srcnote{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:12px;line-height:1.7}
  .srcnote a{color:var(--green)}
</style>

