---
pagination:
  data: topicRoutes
  size: 1
  alias: topicRoute
  addAllPagesToCollections: true
permalink: "{{ topicRoute.permalink }}"
layout: base.njk
eleventyComputed:
  title: "{{ topicRoute.title }}"
  description: "{{ topicRoute.description }}"
  ogTitle: "{{ topicRoute.title }}"
  ogDescription: "{{ topicRoute.description }}"
bodyClass: topic-page
footerBlurb: "The important numbers, the developments behind them, and the original sources when you want to go deeper. Built by Alan Lacroix."
---
{% raw %}
<style>
  body.topic-page{font-size:var(--fs-body)}
  body.topic-page header.mast .navdrop-t{color:var(--ink);font-weight:600;text-decoration:underline;text-decoration-color:var(--green);text-decoration-thickness:2px;text-underline-offset:7px}
  .tp{max-width:var(--maxw);margin:0 auto;padding:0 clamp(18px,4vw,44px)}
  .tp button,.tp select{font:inherit}
  .mono-k{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);font-weight:600}

  .topic-switch-wrap{border-bottom:1px solid var(--line);padding:17px 0 0}
  .topic-switch-label{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.06em;text-transform:uppercase;color:var(--mut);margin-bottom:8px}
  .topic-switch{display:grid;grid-template-columns:1.22fr .8fr .72fr .78fr 1.24fr .95fr;gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-bottom:0;border-radius:4px 4px 0 0;overflow:hidden}
  .topic-switch a{display:flex;align-items:center;justify-content:center;border:0;background:var(--paper);color:var(--ink-2);min-height:47px;padding:10px 12px;cursor:pointer;font-size:var(--fs-meta);line-height:1.2;text-align:center;text-decoration:none}
  .topic-switch a:hover{background:var(--paper-2)}
  .topic-switch a.active{background:var(--green-bg);color:var(--green-d);font-weight:600;box-shadow:inset 0 -2px var(--green)}
  .topic-select{display:none;width:100%;min-height:44px;border:1px solid var(--line-2);border-radius:7px;background:var(--paper);padding:9px 12px;color:var(--ink)}

  .topic-hero{padding:30px 0 22px;display:grid;grid-template-columns:minmax(0,1fr) auto;gap:28px;align-items:start}
  .topic-hero h1{font-size:var(--fs-display);line-height:1.02;letter-spacing:-.025em;margin:6px 0 7px}
  .topic-scope{font-size:var(--fs-small);line-height:1.5;color:var(--ink-2);max-width:66ch}
  .topic-asof{font-family:var(--mono);font-size:var(--fs-label);line-height:1.5;color:var(--mut);text-align:right;padding-top:7px;white-space:nowrap}
  .now{border-top:2px solid var(--green);padding:13px 0 20px;display:grid;grid-template-columns:1fr;gap:7px}
  .now h2{font-size:var(--fs-h2);line-height:1.2;letter-spacing:-.015em;margin:0 0 7px;max-width:38ch}
  .now p{font-size:var(--fs-small);line-height:1.55;color:var(--ink-2);max-width:76ch}
  .now p b{color:var(--ink);font-weight:600}

  .section{margin-top:35px;border-top:2px solid var(--green);padding-top:12px}
  .section-head{display:flex;align-items:end;justify-content:space-between;gap:18px;margin-bottom:12px;border-top:0;padding-top:0}
  .section-head h2{font-size:var(--fs-h2);line-height:1.2;margin:4px 0 0}
  .section-note{font-family:var(--mono);font-size:var(--fs-label);line-height:1.45;color:var(--mut);text-align:right;max-width:46ch}

  .snapshot{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:4px;overflow:hidden}
  .reading-card{display:grid;grid-template-rows:auto auto auto 1fr auto;background:var(--paper);padding:16px 17px;min-height:205px;color:var(--ink);min-width:0}
  .reading-label{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;color:var(--mut);min-height:2.5em}
  .reading-value{font-size:clamp(27px,3vw,38px);line-height:1;font-variant-numeric:tabular-nums;letter-spacing:-.02em;margin-top:4px;white-space:nowrap}
  .reading-value small{font-size:var(--fs-meta);color:var(--mut);letter-spacing:0}
  .reading-change{font-family:var(--mono);font-size:var(--fs-meta);line-height:1.35;color:var(--ink-2);font-variant-numeric:tabular-nums;margin-top:8px;min-height:2.6em}
  .reading-context{font-size:var(--fs-meta);line-height:1.46;color:var(--ink-2);border-top:1px solid var(--line);padding-top:10px;margin-top:9px}
  .reading-guide{margin-top:5px}
  .reading-guide .be-summary{min-width:36px;min-height:36px;justify-content:flex-start}
  .reading-guide-body{padding:3px 0 2px;color:var(--ink-2)}
  .reading-guide-body p{font-size:var(--fs-meta);line-height:1.5}
  .reading-guide-body p+p{margin-top:7px}
  .reading-guide-body b{color:var(--ink);font-weight:600}
  .reading-guide-body a{display:inline-block;margin-top:8px;color:var(--green-d);font-family:var(--mono);font-size:var(--fs-label)}
  .reading-key{margin:0 0 12px}
  .reading-source{display:flex;align-items:baseline;gap:4px 9px;flex-wrap:wrap;font-family:var(--mono);font-size:var(--fs-label);line-height:1.4;color:var(--mut);padding-top:11px}
  .reading-source a{color:var(--green-d)}
  .reading-open{margin-left:auto;white-space:nowrap}

  .evidence-shell{border:1px solid var(--line-2);border-radius:4px;background:var(--paper);overflow:hidden}
  .evidence-head{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:20px;padding:17px 18px 12px;border-bottom:1px solid var(--line)}
  .evidence-head h3{font-size:var(--fs-h3);line-height:1.25;margin:4px 0 4px;max-width:46ch}
  .evidence-sub{font-family:var(--mono);font-size:var(--fs-label);line-height:1.45;color:var(--mut)}
  .view-toggle{display:flex;gap:5px;align-self:start}
  .view-toggle button{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;color:var(--ink-2);background:var(--paper);border:1px solid var(--line-2);border-radius:7px;padding:8px 10px;cursor:pointer;min-width:62px;min-height:44px}
  .view-toggle button.active{background:var(--ink);border-color:var(--ink);color:#fff}
  .evidence-body{padding:15px 18px 0}
  .chart-legend{display:flex;gap:9px 22px;flex-wrap:wrap;min-height:25px;margin-bottom:6px}
  .legend-item{display:inline-flex;gap:7px;align-items:baseline;font-size:var(--fs-meta);color:var(--ink-2)}
  .legend-item i{width:16px;height:2px;display:inline-block;position:relative;top:-3px}
  .legend-item b{font-family:var(--mono);font-size:var(--fs-label);color:var(--ink);font-weight:500}
  .chart-wrap{min-height:286px}
  .chart-wrap svg{display:block;width:100%;height:auto;max-height:310px}
  .chart-mobile{display:none!important}
  .grid-line{stroke:var(--line);stroke-width:1;vector-effect:non-scaling-stroke}
  .chart-line{fill:none;stroke-width:2.5;vector-effect:non-scaling-stroke}
  .chart-hover{position:relative;display:block;cursor:crosshair}
  .hv-line{stroke:var(--ink);stroke-width:1;stroke-dasharray:3 3;vector-effect:non-scaling-stroke;opacity:.55}
  .hv-dot{stroke:var(--paper);stroke-width:2;vector-effect:non-scaling-stroke}
  .chart-tip{position:absolute;z-index:12;pointer-events:none;background:#fff;border:1px solid var(--line);border-radius:7px;box-shadow:0 8px 22px rgba(0,0,0,.10);padding:9px 12px;min-width:150px;max-width:250px}
  .chart-tip[hidden]{display:none}
  .chart-tip .tip-d{font-family:var(--mono);font-size:10.5px;letter-spacing:.03em;text-transform:uppercase;color:var(--mut);margin-bottom:5px}
  .chart-tip .tip-r{display:flex;align-items:baseline;gap:7px;font-size:13px;color:var(--ink-2);line-height:1.5}
  .chart-tip .tip-r i{width:10px;height:3px;flex:none;position:relative;top:-3px}
  .chart-tip .tip-r b{margin-left:auto;font-variant-numeric:tabular-nums;color:var(--ink)}
  .chart-dot{stroke:var(--paper);stroke-width:2;vector-effect:non-scaling-stroke}
  .axis-text{font-family:var(--mono);font-size:12px;fill:var(--mut)}
  .target-band{fill:var(--green-bg)}
  .chart-note{font-family:var(--mono);font-size:var(--fs-label);line-height:1.55;color:var(--mut);border-top:1px solid var(--line);padding:10px 0 12px;margin-top:3px}
  .evidence-source{margin-top:7px;color:var(--ink-2)}
  .evidence-source a{color:var(--green-d)}
  .table-wrap{display:none;overflow-x:auto;padding:0 18px 15px}
  .table-wrap.open{display:block}
  .evidence-body.hidden{display:none}
  .table-wrap table{border-collapse:collapse;width:100%;font-family:var(--mono);font-size:var(--fs-label)}
  .table-wrap th,.table-wrap td{padding:8px 10px;border-bottom:1px solid var(--line);text-align:right;white-space:nowrap}
  .table-wrap th:first-child,.table-wrap td:first-child{text-align:left}
  .table-wrap th{color:var(--mut);text-transform:uppercase;letter-spacing:.03em;font-weight:500}
  .table-wrap caption{caption-side:top;text-align:left;padding:4px 10px 11px;color:var(--mut);line-height:1.45}
  .evidence-read{border-top:1px solid var(--line);display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line)}
  .evidence-read>div{background:var(--paper);padding:13px 18px 15px}
  .evidence-read h4{font-size:var(--fs-meta);margin:0 0 4px}
  .evidence-read p{font-size:var(--fs-meta);line-height:1.48;color:var(--ink-2)}
  .composition-evidence .chart-wrap{min-height:0}
  .composition-evidence .chart-wrap svg{max-height:430px;border:1px solid var(--line);border-radius:3px}
  .composition-legend{display:flex;gap:6px 15px;flex-wrap:wrap}
  .composition-legend span{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:var(--fs-label);color:var(--ink-2)}
  .composition-legend i{width:10px;height:10px;border-radius:2px;display:block}

  .timeline{list-style:none;margin:5px 0 16px;padding:6px 0 0;display:grid;grid-template-columns:repeat(4,minmax(0,1fr))}
  .timeline li{position:relative;border-top:2px solid var(--line-2);padding:18px 15px 0 0;min-height:135px}
  .timeline li::before{content:"";position:absolute;width:9px;height:9px;border-radius:50%;background:var(--paper);border:2px solid var(--green);left:0;top:-6px}
  .timeline-date{font-family:var(--mono);font-size:var(--fs-label);color:var(--green-d);text-transform:uppercase;letter-spacing:.04em}
  .timeline-title{font-size:var(--fs-small);line-height:1.35;font-weight:600;margin-top:5px}
  .timeline-text{font-size:var(--fs-meta);line-height:1.4;color:var(--ink-2);margin-top:5px}

  .topic-modules{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:4px;overflow:hidden}
  .topic-modules.count-4{grid-template-columns:repeat(2,minmax(0,1fr))}
  .topic-module{background:var(--paper);padding:17px 18px;min-height:190px;display:flex;flex-direction:column}
  .topic-module h3{font-size:var(--fs-body);line-height:1.3;margin:6px 0 7px}
  .module-value{font-family:var(--mono);font-size:var(--fs-meta);line-height:1.45;color:var(--green-d);margin-bottom:7px;font-variant-numeric:tabular-nums}
  .topic-module p{font-size:var(--fs-meta);line-height:1.5;color:var(--ink-2)}
  .module-link{font-family:var(--mono);font-size:var(--fs-label);line-height:1.4;color:var(--green-d);margin-top:auto;padding-top:13px}

  .changes-grid{display:grid;grid-template-columns:minmax(0,1.45fr) minmax(270px,.75fr);gap:32px}
  .update-list,.upcoming-list{border-top:1px solid var(--line-2)}
  .update{display:grid;grid-template-columns:88px minmax(0,1fr);gap:17px;padding:13px 0;border-bottom:1px solid var(--line)}
  .update-type{font-family:var(--mono);font-size:var(--fs-label);line-height:1.35;letter-spacing:.04em;text-transform:uppercase;color:var(--green-d)}
  .update h3{font-size:var(--fs-small);line-height:1.35;margin:0 0 4px}
  .update p{font-size:var(--fs-meta);line-height:1.45;color:var(--ink-2)}
  .update-meta{font-family:var(--mono);font-size:var(--fs-label);line-height:1.4;color:var(--mut);margin-top:5px}
  .upcoming{display:grid;grid-template-columns:53px minmax(0,1fr);gap:11px;padding:12px 0;border-bottom:1px solid var(--line)}
  .upcoming-date{font-family:var(--mono);font-size:var(--fs-label);line-height:1.3;color:var(--ink);font-variant-numeric:tabular-nums}
  .upcoming-date small{display:block;color:var(--mut)}
  .upcoming-title{font-size:var(--fs-meta);line-height:1.4;color:var(--ink)}
  .upcoming-meta{font-family:var(--mono);font-size:var(--fs-label);line-height:1.4;color:var(--mut);margin-top:3px}

  details.sources{margin:37px 0 4px;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  details.sources summary{list-style:none;cursor:pointer;font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.05em;text-transform:uppercase;color:var(--green-d);padding:13px 0}
  details.sources summary::-webkit-details-marker{display:none}
  details.sources summary::before{content:"▸ ";color:var(--mut)}
  details.sources[open] summary::before{content:"▾ "}
  .sources-body{display:grid;grid-template-columns:1fr 1fr;gap:20px 34px;padding:0 0 14px}
  .sources-body p,.source-list{font-family:var(--mono);font-size:var(--fs-label);line-height:1.65;color:var(--mut)}
  .source-list a{color:var(--green-d)}
  .source-list div+div{margin-top:4px}
  .topic-foot{font-family:var(--mono);font-size:var(--fs-label);line-height:1.55;color:var(--mut);margin:23px 0 4px}
  .loading{padding:45px 0;font-family:var(--mono);font-size:var(--fs-label);color:var(--mut)}

  /* Story pages (Fable plan 2026-07-20): the page IS a readable walkthrough. Each section
     is a sentence-headline, 80-150 words of prose with live numbers woven in, and at most
     one chart placed right after the sentence it proves. */
  .story-sec h2{font-size:var(--fs-h2);line-height:1.22;letter-spacing:-.015em;margin:4px 0 0;max-width:42ch}
  .story-p{font-size:var(--fs-body);line-height:1.62;color:var(--ink-2);max-width:72ch;margin:11px 0 0}
  .story-p b{color:var(--ink);font-weight:600}
  .story-sec .evidence-shell{margin-top:15px}
  .story-stamp{font-family:var(--mono);font-size:var(--fs-label);line-height:1.5;color:var(--mut)}
  /* SO WHAT (Alan 2026-07-20: "not just telling the information but providing genuine
     insight... but clearly calling it out!! That is what separates us"): every section ends
     with what its numbers MEAN and what to watch next. Mechanism only, computed against the
     same data, never a forecast, never advice. The tinted strip makes it unmissable. */
  .story-so{margin:13px 0 0;padding:12px 15px;background:var(--green-bg,#eef6f1);border-left:3px solid var(--green);font-size:14.5px;line-height:1.55;color:var(--ink)}
  .story-so .ck{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);margin-right:8px}
  .story-so .watch{display:block;margin-top:6px;font-size:13px;color:var(--ink-2)}
  .story-so .watch .ck{color:var(--mut)}

  @media(max-width:900px){
    .topic-switch{grid-template-columns:repeat(3,minmax(0,1fr))}
    .snapshot{grid-template-columns:repeat(2,minmax(0,1fr))}
    .topic-modules{grid-template-columns:1fr}
    .topic-modules.count-4{grid-template-columns:1fr}
    .topic-module{min-height:0}
    .changes-grid{grid-template-columns:1fr;gap:30px}
  }
  @media(max-width:620px){
    .topic-switch{display:none}.topic-select{display:block;margin-bottom:12px}
    .topic-switch-wrap{padding-top:13px}
    .topic-hero{padding:23px 0 17px;grid-template-columns:1fr;gap:6px}
    .topic-asof{text-align:left;padding:0;white-space:normal}
    .now{gap:5px;padding-bottom:17px}
    .section{margin-top:31px}
    .section-head{align-items:start;flex-direction:column;gap:5px}
    .section-note{text-align:left}
    .snapshot{grid-template-columns:1fr;background:transparent;border-left:0;border-right:0;border-radius:0}
    .reading-card{min-height:0;padding:13px 0;grid-template-columns:minmax(0,1fr) auto;grid-template-rows:auto auto auto;gap:3px 14px}
    .reading-label{min-height:0;grid-column:1}
    .reading-value{font-size:var(--fs-h3);grid-column:2;grid-row:1 / span 2;text-align:right;align-self:center}
    .reading-change{min-height:0;grid-column:1;margin-top:2px}
    .reading-context{grid-column:1 / -1;margin-top:7px;padding-top:8px}
    .reading-guide .be-summary{min-width:44px;min-height:44px}
    .reading-source{grid-column:1 / -1;padding-top:3px}
    .evidence-head{grid-template-columns:1fr;gap:10px;padding:14px 13px 11px}
    .evidence-body{padding:12px 9px 0}
    .chart-wrap{min-height:225px}
    .chart-wrap svg{max-height:245px}
    .composition-evidence .chart-wrap svg{max-height:none}
    .chart-desktop{display:none!important}
    .chart-mobile{display:block!important;max-height:none!important}
    .table-wrap{padding:0 9px 12px}
    .evidence-read{grid-template-columns:1fr}
    .evidence-read>div{padding:12px 13px}
    .timeline{grid-template-columns:1fr;padding-left:5px}
    .timeline li{border-top:0;border-left:2px solid var(--line-2);padding:0 0 18px 19px;min-height:0}
    .timeline li::before{left:-6px;top:2px}
    .topic-module{padding:15px 13px}
    .update{grid-template-columns:1fr;gap:4px}
    .sources-body{grid-template-columns:1fr;gap:12px}
  }
</style>

<div class="tp">
  <div class="topic-switch-wrap">
    <div class="topic-switch-label">Topics</div>
    <nav class="topic-switch" aria-label="Topics"></nav>
    <select class="topic-select" aria-label="Choose a topic"></select>
  </div>

  <div id="topicApp" class="loading">Loading the latest data…</div>
</div>

<script type="module">
import {treemapSVG,humanSrc} from '/assets/mb.js?v=18';
import {trendWord,bandWord,stanceWord,staleness,balanceWord} from '/assets/prose.js?v=1';
{% endraw %}
const ROUTE_TOPIC={{ topicRoute.key | dump | safe }};
{% raw %}
const $=(s,r=document)=>r.querySelector(s);
const $$=(s,r=document)=>[...r.querySelectorAll(s)];
const esc=s=>String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
const GREEN='#0a7d4d', INK='#171717', AMBER='#b45a12', GRAY='#8b8b84';
const SOURCE_FALLBACK='/sources.html';
const SERIES_IDS=[
  'banxico-igae','banxico-pib-crecimiento','banxico-inflacion','banxico-inflacion-subyacente','banxico-tasa-objetivo','banxico-usdmxn-fix','banxico-inpc',
  'banxico-spei-operaciones','banxico-spei-monto','banxico-codi-operaciones','banxico-tpv-debito-monto','banxico-tpv-credito-monto',
  'banxico-tpv-debito-ops','banxico-tpv-credito-ops','banxico-cajeros-ops','banxico-ecommerce-monto','banxico-ecommerce-ops',
  'banxico-tarjetas-debito','banxico-tarjetas-credito','banxico-circulante',
  'banxico-exports-total','banxico-imports-total','banxico-trade-balance','banxico-imports-intermediate','banxico-salario-minimo','banxico-remesas','banxico-remesas-electronicas','cre-gasolina-regular','wb-population','wb-unemployment'
];
const DB={series:{},events:[],areas:[],happening:[],partners:null,products:null,tradeUS:null,demographics:null,vitals:null,crime:null,poverty:null};
function validProducts(p){
  if(!p||!Array.isArray(p.items)||p.items.length<50||!p.reconciliation||p.reconciliation.pass!==true||!Number.isFinite(Number(p.total))||Number(p.total)<=0)return false;
  const codes=new Set(),bad=p.items.some(i=>{const c=String(i.code||'').padStart(2,'0');if(codes.has(c))return true;codes.add(c);return !/^\d{2}$/.test(c)||!Number.isFinite(Number(i.value))||Number(i.value)<0||!Number.isFinite(Number(i.share))||Number(i.share)<0;});
  const sum=p.items.reduce((t,i)=>t+Number(i.value),0),shares=p.items.reduce((t,i)=>t+Number(i.share),0);
  return !bad&&Math.abs(sum-Number(p.total))/Number(p.total)<=.005&&Math.abs(shares-100)<=.5;
}

async function json(url){const r=await fetch(url);if(!r.ok)throw new Error(`${url}: ${r.status}`);return r.json();}
await Promise.all([
  ...SERIES_IDS.map(async id=>{try{DB.series[id]=await json(`/data/series/${id}.json`)}catch(e){console.warn(e)}}),
  json('/data/events.json').then(x=>DB.events=x.events||[]).catch(console.warn),
  json('/data/areas.json').then(x=>DB.areas=x.areas||[]).catch(console.warn),
  json('/data/happening.json').then(x=>DB.happening=x.events||[]).catch(console.warn),
  json('/data/trade/exports-by-partner.json').then(x=>DB.partners=x).catch(console.warn),
  json('/data/trade/exports-by-product.json').then(x=>{if(validProducts(x))DB.products=x;else console.warn('Export composition failed validation')}).catch(console.warn),
  json('/data/trade-us.json').then(x=>DB.tradeUS=x).catch(console.warn),
  json('/data/demographics.json').then(x=>DB.demographics=x).catch(console.warn),
  json('/data/vitals.json').then(x=>DB.vitals=x).catch(console.warn),
