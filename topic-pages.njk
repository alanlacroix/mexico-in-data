      {k:'Population',title:'Births and deaths are annual registered events',value:`${compact(births.value)} births · ${compact(deaths.value)} deaths · ${births.year}`,text:'Registration year and occurrence year can differ. The source file keeps that caveat with the series.',href:vitals.births.sourceUrl,link:'Open the births release ↗'},
      {k:'Security',title:'The municipal file shows where reports are concentrated',value:`${compact(crimeTotal)} reported offenses · ${crimePeriod}`,text:'Municipal totals are not risk rates. Reporting behavior, population and offense mix all matter.',href:crime.meta.sourceUrl,link:'Open the SESNSP source ↗'}
    ],
    updates:[
      {type:'Wages',title:`The general minimum wage is MX$${fmt(W.value,2)} a day`,text:'The real comparison above adjusts the full history for consumer prices.',source:'CONASAMI / Banxico',href:sourceUrl('banxico-salario-minimo'),date:dateLabel(W.date)},
      {type:'Population',title:`The ${popYear} population projection is ${fmt(pop/1e6,1)} million`,text:`The same source file reports a median age of ${demo.medianAge}.`,source:'CONAPO',href:demo.sourceUrl,date:String(popYear)},
      {type:'Security data',title:`The municipal layer totals ${compact(crimeTotal)} reported offenses for ${crimePeriod}`,text:'This is a year-to-date count. It stays separate from homicide records and survey measures.',source:'SESNSP',href:crime.meta.sourceUrl,date:crimePeriod}
    ],
    upcoming:eventMatches(/unemployment|remittance|wage|poverty|population|migration|employment/i,5),
    sources:[topicSource('banxico-salario-minimo','CONASAMI / Banxico · minimum wage'),topicSource('banxico-inpc','INEGI / Banxico · consumer prices'),topicSource('banxico-remesas','Banxico · remittances'),{label:'CONAPO · population projections',href:demo.sourceUrl,date:String(popYear)},{label:'INEGI · registered births',href:vitals.births.sourceUrl,date:String(births.year)},{label:'INEGI · registered deaths',href:vitals.deaths.sourceUrl,date:String(deaths.year)},{label:'SESNSP · municipal reported offenses',href:crime.meta.sourceUrl,date:crimePeriod}],
    method:'Every measure keeps its own observation period. Population is a projection; births and deaths are registrations; the security layer is a raw count of reported offenses. Those measures are not blended into one score.'
  };
}

function usMexicoTopic(){
  const tu=DB.tradeUS||{},imports=(tu.series?.imports||[]).map(p=>({date:p.month+'-01',value:p.value})),exports=(tu.series?.exports||[]).map(p=>({date:p.month+'-01',value:p.value})),L=tu.latest||{},partners=DB.partners?.exports?.items||[],us=partners.find(x=>x.name==='USA'),partnerYear=Number(DB.partners?.referenceYear||DB.partners?.year),lines=[{name:'US buys from Mexico',points:imports,color:GREEN,format:v=>'$'+fmt(v,1)+'bn'},{name:'US sells to Mexico',points:exports,color:INK,format:v=>'$'+fmt(v,1)+'bn'}];
  if(!L.month||!Number.isFinite(Number(L.twoway_bn))||!imports.length||!exports.length||!us||!Number.isFinite(partnerYear))throw new Error('U.S.–Mexico inputs are incomplete');
  const tradeMonth=L.month+'-01',mexicoBalance=-(Number(L.balance_bn)||0),balanceSide=mexicoBalance>=0?'surplus':'deficit',balanceAction=mexicoBalance>=0?'buys more goods from Mexico than it sells there':'sells more goods to Mexico than it buys there',censusMexicoUrl='https://www.census.gov/foreign-trade/balance/c2010.html',comtradePartnerUrl='https://comtradeplus.un.org/TradeFlow/',rem=last(s('banxico-remesas')),remY=yearAgo(s('banxico-remesas'),rem),peso=last(s('banxico-usdmxn-fix'));
  const usmca=DB.happening.find(e=>e.id==='usmca-not-renewed-2026-07-01');
  const next=eventMatches(/USMCA|U.S.–Mexico|US–Mexico|tariff|trade talks|border|foreign direct investment/i,5);
  return {
    title:'U.S.–Mexico',scope:'Bilateral goods trade, Mexico’s export exposure, household flows, and the next official dates.',asof:`Trade data through ${dateLabel(tradeMonth)} · export exposure ${partnerYear}.`,
    nowTitle:usmca?esc(usmca.title):'Four out of every five Mexican export dollars go to the US.',
    nowText:usmca?`${esc(usmca.context||'')} The US bought <b>${fmt(us.share,1)}%</b> of Mexico’s goods exports in ${partnerYear}; two-way goods trade was <b>$${fmt(L.twoway_bn,1)}bn</b> in ${dateLabel(tradeMonth)}.`:`The US bought <b>${fmt(us.share,1)}%</b> of Mexico’s goods exports in ${partnerYear}. In ${dateLabel(tradeMonth)}, two-way goods trade was <b>$${fmt(L.twoway_bn,1)}bn</b> in the U.S. Census ledger.`,
    cards:[
      {label:'Two-way goods trade · month',value:'$'+fmt(L.twoway_bn,1),unit:'bn',change:'US-side ledger',context:'US imports from Mexico plus US exports to Mexico.',source:'U.S. Census',sourceHref:censusMexicoUrl,date:dateLabel(tradeMonth)},
      {label:`Mexico's goods ${balanceSide}`,value:'$'+fmt(Math.abs(mexicoBalance),1),unit:'bn',change:'For the month',context:`The US ${balanceAction}.`,source:'U.S. Census',sourceHref:censusMexicoUrl,date:dateLabel(tradeMonth)},
      {label:'Mexican exports to the US',value:fmt(us.share,1),unit:'%',change:`Share of ${partnerYear} goods exports`,context:'Annual export exposure from the reconciled partner file.',source:'UN COMTRADE',sourceHref:comtradePartnerUrl,date:String(partnerYear),href:'/trade.html'},
      {label:'Remittances · month',value:'$'+fmt(rem.value/1000,1),unit:'bn',change:remY?deltaText(pct(rem.value,remY.value),'%',1)+' vs a year ago':'',context:'A household flow from abroad. The peso changes what recipients receive locally.',source:'Banxico',sourceHref:sourceUrl('banxico-remesas'),date:dateLabel(rem.date),href:'/chart.html?v=banxico-remesas,banxico-usdmxn-fix'}
    ],
    evidence:{k:'Bilateral ledger',title:'The US consistently buys more goods from Mexico than it sells there',sub:'Monthly US goods trade with Mexico · US$ billions',visual:chartSVG({series:lines,yFormat:v=>'$'+fmt(v,0),label:'Monthly U.S. imports from and exports to Mexico'}),legend:legend(lines),table:dataTable(lines),note:'U.S. Census ledger. Banxico and Census totals differ because of valuation, timing and re-exports; the two ledgers are not mixed.',sources:[{label:'U.S. Census · trade with Mexico',href:censusMexicoUrl}],read:[`The gap between the lines is Mexico's monthly goods ${balanceSide} in the U.S. Census ledger.`,`It does not capture services, investment, migration, or the full economic effect of a trade dispute.`]},
    modulesTitle:'Exposure, the ledger, and household flows',
    modules:[
      {k:'Exposure',title:'The US takes most Mexican goods exports',value:`${fmt(us.share,2)}% · ${partnerYear}`,text:'The annual partner share is reconciled to Banxico before it appears here.',href:'/trade.html#trade-composition',link:'See the trade structure →'},
      {k:'The ledger',title:`Mexico's monthly goods ${balanceSide} was $${fmt(Math.abs(mexicoBalance),1)}bn`,value:`Two-way trade $${fmt(L.twoway_bn,1)}bn · ${dateLabel(tradeMonth)}`,text:'This is the U.S.-side measure and should not be mixed with Banxico’s national trade totals.',href:censusMexicoUrl,link:'Open Census trade data ↗'},
      {k:'Household flow',title:'Remittances and the peso belong together',value:`$${fmt(rem.value/1000,1)}bn · ${fmt(peso.value,2)} MXN/USD`,text:'The dollar inflow and the exchange rate answer different parts of what reaches Mexican households.',href:'/chart.html?v=banxico-remesas,banxico-usdmxn-fix',link:'Compare the two series →'}
    ],
    updates:[
      ...(usmca?[{type:'Trade policy',title:usmca.title,text:usmca.context||'',source:usmca.source,href:usmca.url,date:shortDate(usmca.date)}]:[]),
      {type:'Official data',title:`Two-way goods trade reached $${fmt(L.twoway_bn,1)}bn in ${dateLabel(tradeMonth)}`,text:`The US imported $${fmt(L.imports_bn,1)}bn from Mexico and exported $${fmt(L.exports_bn,1)}bn to it.`,source:'U.S. Census',href:censusMexicoUrl,date:dateLabel(tradeMonth)},
      {type:'Household flow',title:`Remittances were $${fmt(rem.value/1000,1)}bn in ${dateLabel(rem.date)}`,text:remY?`That was ${fmt(Math.abs(pct(rem.value,remY.value)),1)}% ${rem.value>=remY.value?'above':'below'} a year earlier.`:'The source series does not yet support a year-earlier comparison.',source:'Banxico',href:sourceUrl('banxico-remesas'),date:dateLabel(rem.date)}
    ],
    upcoming:next,
    sources:[...(usmca?[{label:'USTR · USMCA first review',href:usmca.url,date:shortDate(usmca.date)}]:[]),{label:'U.S. Census · trade with Mexico',href:censusMexicoUrl,date:tu.meta.latestMonth},{label:'UN COMTRADE · export exposure',href:comtradePartnerUrl,date:String(partnerYear)},topicSource('banxico-remesas'),topicSource('banxico-usdmxn-fix')],
    method:'The bilateral ledger uses U.S. Census throughout. Banxico remains the owner of Mexico’s national trade accounts. The two series are not spliced together because valuation, timing and re-exports differ.'
  };
}

const BUILDERS={economy:economyTopic,payments:paymentsTopic,trade:tradeTopic,politics:politicsTopic,society:societyTopic,usmexico:usMexicoTopic};
let current=ROUTE_TOPIC;
function validTopic(){return TOPIC_ORDER.includes(ROUTE_TOPIC)?ROUTE_TOPIC:'economy';}
function renderSources(t){return `<div class="source-list">${t.sources.map(x=>`<div><a href="${x.href}" target="_blank" rel="noopener">${x.label} ↗</a>${x.date?` · observation ${x.date}`:''}</div>`).join('')}</div><p>${t.method}</p>`;}
function evidenceBlock(e,id,label='In the data'){
  if(!e)return '';
  const titleId=id+'-title',visualId=id+'-visual',tableId=id+'-table';
  return `<section class="section ${e.css||''}" id="${id}" aria-labelledby="${titleId}"><div class="section-head"><div><div class="mono-k">${label}</div><h2 id="${titleId}">${e.k}</h2></div></div><article class="evidence-shell"><header class="evidence-head"><div><h3>${e.title}</h3><div class="evidence-sub">${e.sub}</div></div><div class="view-toggle" role="group" aria-label="Choose ${e.k} view"><button type="button" class="active" aria-pressed="true" data-evidence-for="${id}" data-evidence="visual">${e.visualLabel||'Chart'}</button><button type="button" aria-pressed="false" data-evidence-for="${id}" data-evidence="table">${e.tableLabel||'Table'}</button></div></header><div class="evidence-body" id="${visualId}">${e.legend?`<div class="chart-legend">${e.legend}</div>`:''}<div class="chart-wrap">${e.visual}</div><div class="chart-note">${e.note}${evidenceSources(e.sources)}</div></div><div class="table-wrap" id="${tableId}">${e.table}</div><div class="evidence-read"><div><h4>What it shows</h4><p>${e.read[0]}</p></div><div><h4>What it does not show</h4><p>${e.read[1]}</p></div></div></article></section>`;
}
// A chart inside a story section: the same trusted shell (chart/table toggle, note,
// what-it-shows / what-it-does-not footers) without its own page-section wrapper.
function chartShell(c,id){
  const visual=chartSVG({series:c.series,yFormat:c.yFormat,label:c.label,band:c.band||null});
  return `<article class="evidence-shell"><header class="evidence-head"><div><h3>${c.title}</h3><div class="evidence-sub">${c.sub}</div></div><div class="view-toggle" role="group" aria-label="Choose view"><button type="button" class="active" aria-pressed="true" data-evidence-for="${id}" data-evidence="visual">Chart</button><button type="button" aria-pressed="false" data-evidence-for="${id}" data-evidence="table">Table</button></div></header><div class="evidence-body" id="${id}-visual"><div class="chart-legend">${legend(c.series)}</div><div class="chart-wrap">${visual}</div><div class="chart-note">${c.note}${evidenceSources(c.sources)}</div></div><div class="table-wrap" id="${id}-table">${dataTable(c.series,24)}</div><div class="evidence-read"><div><h4>What it shows</h4><p>${c.read[0]}</p></div><div><h4>What it does not show</h4><p>${c.read[1]}</p></div></div></article>`;
}
function render(topic){
  current=topic;let t;
  try{t=BUILDERS[topic]();}
  catch(error){
    console.error(error);window.reportMexicoDataError?.(`topic:${topic}`);
    $('#topicApp').className='';
    $('#topicApp').innerHTML=`<section class="topic-hero"><div><div class="mono-k">Topic</div><h1>${LABELS[topic]}</h1><p class="topic-scope">This page is waiting for its required source data.</p></div></section><section class="now"><div class="mono-k">Data check</div><div><h2>This page couldn’t load its source data. Try again, or check feed status.</h2><p><a href="/sources.html#livenow">Open feed status →</a></p></div></section>`;
    return;
  }
  $$('.topic-switch a').forEach(b=>b.classList.toggle('active',b.dataset.topic===topic));$('.topic-select').value=topic;
  // Story pages (Fable plan 2026-07-20): sentence-headline sections, prose with live
  // numbers, at most one chart per section right after the sentence it proves. Topics
  // still on the dashboard shape use the legacy template below until each is converted.
  if(t.story){
    $('#topicApp').className='';
    $('#topicApp').innerHTML=`
      <section class="topic-hero"><div><div class="mono-k">Topic</div><h1>${t.title}</h1><p class="topic-scope">${t.scope}</p></div><div class="topic-asof story-stamp">${t.asof}</div></section>
      ${t.story.map((sec,i)=>`<section class="section story-sec"><h2>${sec.h2}</h2>${sec.prose.map(p=>`<p class="story-p">${p}</p>`).join('')}${sec.chart?chartShell(sec.chart,'story-ev-'+i):''}</section>`).join('')}
      <section class="section"><div class="changes-grid"><div><div class="section-head"><div><div class="mono-k">Latest</div><h2>What's moving</h2></div></div>${updateList(t.updates)}</div><aside><div class="section-head"><div><div class="mono-k">Next</div><h2>${t.upcomingTitle||'Coming up'}</h2></div></div>${upcomingList(t.upcoming)}</aside></div></section>
      <details class="sources"><summary>Sources and method</summary><div class="sources-body">${renderSources(t)}</div></details>`;
    $$('[data-evidence-for]').forEach(b=>b.addEventListener('click',()=>{const id=b.dataset.evidenceFor,table=b.dataset.evidence==='table',group=$$(`[data-evidence-for="${id}"]`);group.forEach(x=>{x.classList.toggle('active',x===b);x.setAttribute('aria-pressed',x===b?'true':'false')});$('#'+id+'-visual').classList.toggle('hidden',table);$('#'+id+'-table').classList.toggle('open',table)}));
    return;
  }
  $('#topicApp').className='';
  $('#topicApp').innerHTML=`
    <section class="topic-hero"><div><div class="mono-k">Topic</div><h1>${t.title}</h1><p class="topic-scope">${t.scope}</p></div><div class="topic-asof">${t.asof}</div></section>
    <section class="now"><div class="mono-k">Now</div><div><h2>${t.nowTitle}</h2>${t.nowText?`<p>${t.nowText}</p>`:''}</div></section>
    <section class="section" aria-labelledby="snapshotTitle"><div class="section-head"><div><div class="mono-k">Snapshot</div><h2 id="snapshotTitle">Key readings</h2></div><div class="section-note">Different observation dates are shown on each reading.</div></div>${t.cards.some(x=>x.guide)?`<div class="be-key reading-key"><span class="be-mark" aria-hidden="true">BE</span><span><b>Briefly Explained.</b> Open it when a number needs more context.</span></div>`:''}<div class="snapshot">${t.cards.map(card).join('')}</div></section>
    ${evidenceBlock(t.evidence,'topic-evidence')}
    ${evidenceBlock(t.composition,'trade-composition','Composition')}
    <section class="section" id="topicModules"><div class="section-head"><div><h2>${t.modulesTitle}</h2></div></div><div class="topic-modules count-${t.modules.length}">${t.modules.map(moduleCard).join('')}</div></section>
    <section class="section"><div class="changes-grid"><div><div class="section-head"><div><div class="mono-k">Latest</div><h2>What changed</h2></div></div>${updateList(t.updates)}</div><aside><div class="section-head"><div><div class="mono-k">Next</div><h2>${t.upcomingTitle||'Coming up'}</h2></div></div>${upcomingList(t.upcoming)}</aside></div></section>
    <details class="sources"><summary>Sources and method</summary><div class="sources-body">${renderSources(t)}</div></details>`;
  $$('[data-evidence-for]').forEach(b=>b.addEventListener('click',()=>{const id=b.dataset.evidenceFor,table=b.dataset.evidence==='table',group=$$(`[data-evidence-for="${id}"]`);group.forEach(x=>{x.classList.toggle('active',x===b);x.setAttribute('aria-pressed',x===b?'true':'false')});$('#'+id+'-visual').classList.toggle('hidden',table);$('#'+id+'-table').classList.toggle('open',table)}));
  if(topic==='trade'&&innerWidth<620){const b=$('[data-evidence-for="trade-composition"][data-evidence="table"]');if(b)b.click();}
}

$('.topic-switch').innerHTML=TOPIC_ORDER.map(t=>`<a href="${ROUTES[t]}" data-topic="${t}"${t===validTopic()?' aria-current="page"':''}>${LABELS[t]}</a>`).join('');
$('.topic-select').innerHTML=TOPIC_ORDER.map(t=>`<option value="${t}">${LABELS[t]}</option>`).join('');
$('.topic-select').addEventListener('change',e=>{location.href=ROUTES[e.target.value]});
render(validTopic());
</script>
{% endraw %}
