function changedMatches(section,n=3){
  const aliases={economy:/^(economy|money)$/,payments:/^payments$/,trade:/^(trade|us-mexico)$/,politics:/^politics$/,society:/^(society|security)$/,usmexico:/^us-mexico$/};
  const rx=aliases[section]||new RegExp(`^${section}$`);
  const words=t=>new Set(String(t||'').toLowerCase().replace(/[^a-z0-9áéíóúñü ]/g,' ').split(/\s+/).filter(w=>w.length>3));
  const overlap=(a,b)=>{const A=words(a),B=words(b);if(!A.size||!B.size)return 0;let i=0;for(const w of A)if(B.has(w))i++;return i/(A.size+B.size-i);};
  const seen=[];
  return DB.happening.filter(e=>rx.test(e.section||'')&&e.date&&e.title&&e.source&&e.url)
    .sort((a,b)=>String(b.date).localeCompare(String(a.date)))
    .filter(e=>{if(seen.some(t=>overlap(t,e.title)>=0.5))return false;seen.push(e.title);return true;})
    .slice(0,n).map(e=>{
    // The four-part Briefly Explained rides along wherever the story appears (the same
    // gated fields as the homepage): Background · Drivers · Implications · What's next.
    const parts=[['Background',e.background],['Drivers',e.drivers],['Implications',e.implications],["What's next",e.next]].filter(p=>p[1]);
    return {type:e.kind==='release'?'Official data':'Dated development',title:e.title,text:e.context||'',source:e.source,href:e.url,date:shortDate(e.date),guide:parts.length?{items:parts.map(([label,text])=>({label,text}))}:null};
  });
}
