  const timelineItems=next.map(e=>({date:(dateObj(e.date).getTime()===todayMid.getTime()?'Today · ':'')+shortDate(e.date)+' '+dateObj(e.date).getUTCFullYear(),title:e.label,text:e.mechanism||'Official dated event.'}));
  const line=(name,points,color,format)=>({name,points,color,format});
  const newest=[last(ex).date,B.date].sort().at(-1);
  return {
    title:'Trade',scope:'What Mexico sells and buys, to whom, and what the USMCA review changes.',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · newest number ${dateLabel(newest)}`,
    story:[
      {h2:'Mexico sells almost everything to one customer.',
       prose:[`In ${DB.partners.year}, <b>${fmt(us.share,1)}%</b> of Mexico's goods exports went to the United States. Canada was second at ${fmt(canada.share,1)}%, China took ${fmt(china.share,1)}%.`],
       soWhat:`With ${fmt(us.share,1)}% of goods exports going to one buyer, a single government's tariff and treaty decisions set the terms for most of what Mexico earns abroad.`,
       watch:watchFor(/USMCA|tariff|trade talks/i)},
      {h2:`Exports run at $${fmt(E.value,0)} billion a year, mostly manufactured goods.`,
       prose:[`Over the latest twelve months Mexico exported <b>$${fmt(E.value,0)} billion</b> of goods and imported $${fmt(I.value,0)} billion. Vehicles, electronics and machinery alone made up ${fmt(leadShare,0)}% of export value in ${pYear}. Mexico does not mainly sell oil or farm goods. It sells factory output.`],
       soWhat:`Vehicles, electronics and machinery are ${fmt(leadShare,0)}% of exports, so Mexico's trade income moves with factory demand for those goods, not with oil.`,
