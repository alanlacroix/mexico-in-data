let current=ROUTE_TOPIC;
function validTopic(){return TOPIC_ORDER.includes(ROUTE_TOPIC)?ROUTE_TOPIC:'economy';}
function renderSources(t){return `<div class="source-list">${t.sources.map(x=>`<div><a href="${x.href}" target="_blank" rel="noopener">${x.label} ↗</a>${x.date?` · observation ${x.date}`:''}</div>`).join('')}</div><p>${t.method}</p>`;}
function evidenceBlock(e,id,label='In the data'){
  if(!e)return '';
  const titleId=id+'-title',visualId=id+'-visual',tableId=id+'-table';
  return `<section class="section ${e.css||''}" id="${id}" aria-labelledby="${titleId}"><div class="section-head"><div><div class="mono-k">${label}</div><h2 id="${titleId}">${e.k}</h2></div></div><article class="evidence-shell"><header class="evidence-head"><div><h3>${e.title}</h3><div class="evidence-sub">${e.sub}</div></div><div class="view-toggle" role="group" aria-label="Choose ${e.k} view"><button type="button" class="active" aria-pressed="true" data-evidence-for="${id}" data-evidence="visual">${e.visualLabel||'Chart'}</button><button type="button" aria-pressed="false" data-evidence-for="${id}" data-evidence="table">${e.tableLabel||'Table'}</button></div></header><div class="evidence-body" id="${visualId}">${e.legend?`<div class="chart-legend">${e.legend}</div>`:''}<div class="chart-wrap">${e.visual}</div><div class="chart-note">${e.note}${evidenceSources(e.sources)}</div></div><div class="table-wrap" id="${tableId}">${e.table}</div><div class="evidence-read"><div><h4>What it shows</h4><p>${e.read[0]}</p></div><div><h4>What it does not show</h4><p>${e.read[1]}</p></div></div></article></section>`;
}
// A chart inside a story section: the same trusted shell (chart/table toggle, note,
// what-it-shows / what-it-does-not footers) without its own page-section wrapper.
function chartShell(c,id){
  // A section chart built from series, or a prebuilt visual (treemap, timeline) with its own table.
  const visual=c.visual||chartSVG({series:c.series,yFormat:c.yFormat,label:c.label,band:c.band||null});
  const legendHtml=c.visual?(c.legend||''):`<div class="chart-legend">${legend(c.series)}</div>`;
  const table=c.table||dataTable(c.series,24);
  return `<article class="evidence-shell ${c.css||''}"><header class="evidence-head"><div><h3>${c.title}</h3><div class="evidence-sub">${c.sub}</div></div><div class="view-toggle" role="group" aria-label="Choose view"><button type="button" class="active" aria-pressed="true" data-evidence-for="${id}" data-evidence="visual">${c.visualLabel||'Chart'}</button><button type="button" aria-pressed="false" data-evidence-for="${id}" data-evidence="table">${c.tableLabel||'Table'}</button></div></header><div class="evidence-body" id="${id}-visual">${legendHtml}<div class="chart-wrap">${visual}</div><div class="chart-note">${c.note}${evidenceSources(c.sources)}</div></div><div class="table-wrap" id="${id}-table">${table}</div><div class="evidence-read"><div><h4>What it shows</h4><p>${c.read[0]}</p></div><div><h4>What it does not show</h4><p>${c.read[1]}</p></div></div></article>`;
}
// The crosshair (Alan 2026-07-20): pointer over any chart snaps to the nearest observation,
// draws a vertical guide and a dot per series, and shows a tooltip with the date and each
// pre-formatted value. pointerdown covers tap-to-inspect on phones. Delegated once on the
// document, so it survives every re-render and needs no per-chart wiring.
(function(){
  function clearHover(holder){const tip=holder.querySelector('.chart-tip');if(tip)tip.hidden=true;holder.querySelectorAll('svg .hv').forEach(g=>{g.innerHTML='';});}
  function onPoint(ev){
    const svg=ev.target.closest?.('.chart-hover svg');
    if(!svg)return;
    const holder=svg.closest('.chart-hover');
    const data=holder._hd||(holder._hd=JSON.parse(holder.dataset.series));
    const a=svg.dataset,W=+a.w,H=+a.h,L=+a.l,R=+a.r,T=+a.t,B=+a.b,x0=+a.x0,x1=+a.x1,y0=+a.y0,y1=+a.y1;
    const rect=svg.getBoundingClientRect();
    const xv=(ev.clientX-rect.left)/rect.width*W;
    if(xv<L-6||xv>W-R+6){clearHover(holder);return;}
    const tt=x0+(Math.min(Math.max(xv,L),W-R)-L)/(W-L-R||1)*(x1-x0||1);
    const rows=[];let snap=null,snapD=Infinity;
    for(const s of data){let best=null,bd=Infinity;for(const p of s.p){const d=Math.abs(p[0]-tt);if(d<bd){bd=d;best=p;}}if(!best)continue;rows.push({s,p:best});if(bd<snapD){snapD=bd;snap=best;}}
    if(!rows.length)return;
    const X=v=>L+(v-x0)/(x1-x0||1)*(W-L-R),Y=v=>T+(y1-v)/(y1-y0||1)*(H-T-B);
    const g=svg.querySelector('.hv');
    const cx=X(snap[0]).toFixed(1);
    g.innerHTML=`<line class="hv-line" x1="${cx}" x2="${cx}" y1="${T}" y2="${H-B}"/>`+rows.map(r=>`<circle class="hv-dot" cx="${X(r.p[0]).toFixed(1)}" cy="${Y(r.p[1]).toFixed(1)}" r="4.5" fill="${r.s.c}"/>`).join('');
    let tip=holder.querySelector('.chart-tip');
    if(!tip){tip=document.createElement('div');tip.className='chart-tip';holder.appendChild(tip);}
    tip.hidden=false;
    tip.innerHTML=`<div class="tip-d">${esc(snap[3])}</div>`+rows.map(r=>`<div class="tip-r"><i style="background:${r.s.c}"></i><span>${esc(r.s.n)}</span><b>${esc(r.p[2])}</b></div>`).join('');
    const hr=holder.getBoundingClientRect();
    let leftPx=ev.clientX-hr.left+16;const tw=tip.offsetWidth||170;
    if(leftPx+tw>hr.width-4)leftPx=Math.max(4,ev.clientX-hr.left-tw-16);
    tip.style.left=leftPx+'px';
    tip.style.top=Math.max(0,ev.clientY-hr.top-tip.offsetHeight-14)+'px';
  }
  document.addEventListener?.('pointermove',onPoint);
  document.addEventListener?.('pointerdown',onPoint);
  document.addEventListener?.('pointerout',(ev)=>{const holder=ev.target.closest?.('.chart-hover');if(holder&&!(ev.relatedTarget&&holder.contains(ev.relatedTarget)))clearHover(holder);});
})();
function render(topic){
  current=topic;let t;
  try{t=BUILDERS[topic]();}
  catch(error){
    console.error(error);window.reportMexicoDataError?.(`topic:${topic}`);
    $('#topicApp').className='';
    $('#topicApp').innerHTML=`<section class="topic-hero"><div><div class="mono-k">Topic</div><h1>${LABELS[topic]}</h1><p class="topic-scope">This page is waiting for its required source data.</p></div></section><section class="now"><div class="mono-k">Data check</div><div><h2>This page couldn’t load its source data. Try again, or check feed status.</h2><p><a href="/sources.html#livenow">Open feed status →</a></p></div></section>`;
    return;
  }
  $$('.topic-switch a').forEach(b=>b.classList.toggle('active',b.dataset.topic===topic));$('.topic-select').value=topic;
  // Story pages (Fable plan 2026-07-20): sentence-headline sections, prose with live
  // numbers, at most one chart per section right after the sentence it proves. Topics
  // still on the dashboard shape use the legacy template below until each is converted.
  if(t.story){
    $('#topicApp').className='';
    $('#topicApp').innerHTML=`
      <section class="topic-hero"><div><div class="mono-k">Topic</div><h1>${t.title}</h1><p class="topic-scope">${t.scope}</p></div><div class="topic-asof story-stamp">${t.asof}</div></section>
      ${t.story.map((sec,i)=>`<section class="section story-sec"><h2>${String(sec.h2).replace(/\.\s*$/,'')}</h2>${sec.prose.map(p=>`<p class="story-p">${p}</p>`).join('')}${sec.soWhat?`<p class="story-so"><span class="ck">So what</span>${sec.soWhat}${sec.watch?`<span class="watch"><span class="ck">Watch</span>${sec.watch}</span>`:''}</p>`:''}${sec.chart?chartShell(sec.chart,'story-ev-'+i):''}</section>`).join('')}
      <section class="section"><div class="changes-grid"><div><div class="section-head"><div><div class="mono-k">Latest</div><h2>What's moving</h2></div></div>${updateList(t.updates)}</div><aside><div class="section-head"><div><div class="mono-k">Next</div><h2>${t.upcomingTitle||'Coming up'}</h2></div></div>${upcomingList(t.upcoming)}</aside></div></section>
      <details class="sources"><summary>Sources and method</summary><div class="sources-body">${renderSources(t)}</div></details>`;
    $$('[data-evidence-for]').forEach(b=>b.addEventListener('click',()=>{const id=b.dataset.evidenceFor,table=b.dataset.evidence==='table',group=$$(`[data-evidence-for="${id}"]`);group.forEach(x=>{x.classList.toggle('active',x===b);x.setAttribute('aria-pressed',x===b?'true':'false')});$('#'+id+'-visual').classList.toggle('hidden',table);$('#'+id+'-table').classList.toggle('open',table)}));
    return;
  }
  $('#topicApp').className='';
  $('#topicApp').innerHTML=`
    <section class="topic-hero"><div><div class="mono-k">Topic</div><h1>${t.title}</h1><p class="topic-scope">${t.scope}</p></div><div class="topic-asof">${t.asof}</div></section>
    <section class="now"><div class="mono-k">Now</div><div><h2>${t.nowTitle}</h2>${t.nowText?`<p>${t.nowText}</p>`:''}</div></section>
    <section class="section" aria-labelledby="snapshotTitle"><div class="section-head"><div><div class="mono-k">Snapshot</div><h2 id="snapshotTitle">Key readings</h2></div><div class="section-note">Different observation dates are shown on each reading.</div></div>${t.cards.some(x=>x.guide)?`<div class="be-key reading-key"><span class="be-mark" aria-hidden="true">BE</span><span><b>Briefly Explained.</b> Open it when a number needs more context.</span></div>`:''}<div class="snapshot">${t.cards.map(card).join('')}</div></section>
    ${evidenceBlock(t.evidence,'topic-evidence')}
    ${evidenceBlock(t.composition,'trade-composition','Composition')}
    <section class="section" id="topicModules"><div class="section-head"><div><h2>${t.modulesTitle}</h2></div></div><div class="topic-modules count-${t.modules.length}">${t.modules.map(moduleCard).join('')}</div></section>
    <section class="section"><div class="changes-grid"><div><div class="section-head"><div><div class="mono-k">Latest</div><h2>What changed</h2></div></div>${updateList(t.updates)}</div><aside><div class="section-head"><div><div class="mono-k">Next</div><h2>${t.upcomingTitle||'Coming up'}</h2></div></div>${upcomingList(t.upcoming)}</aside></div></section>
    <details class="sources"><summary>Sources and method</summary><div class="sources-body">${renderSources(t)}</div></details>`;
  $$('[data-evidence-for]').forEach(b=>b.addEventListener('click',()=>{const id=b.dataset.evidenceFor,table=b.dataset.evidence==='table',group=$$(`[data-evidence-for="${id}"]`);group.forEach(x=>{x.classList.toggle('active',x===b);x.setAttribute('aria-pressed',x===b?'true':'false')});$('#'+id+'-visual').classList.toggle('hidden',table);$('#'+id+'-table').classList.toggle('open',table)}));
  if(topic==='trade'&&innerWidth<620){const b=$('[data-evidence-for="trade-composition"][data-evidence="table"]');if(b)b.click();}
}

$('.topic-switch').innerHTML=TOPIC_ORDER.map(t=>`<a href="${ROUTES[t]}" data-topic="${t}"${t===validTopic()?' aria-current="page"':''}>${LABELS[t]}</a>`).join('');
$('.topic-select').innerHTML=TOPIC_ORDER.map(t=>`<option value="${t}">${LABELS[t]}</option>`).join('');
$('.topic-select').addEventListener('change',e=>{location.href=ROUTES[e.target.value]});
render(validTopic());
</script>
