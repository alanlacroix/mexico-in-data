function paymentsTopic(){
  // Letter register (Fable restart 2026-07-20): one argument, three beats, every number
  // dated and derived. Kill list honored: no ATM, no above-500 share, no CoDi chart, no
  // remittances tangent; the debit-value review note lives in method.
  const spei=s('banxico-spei-operaciones'),codi=s('banxico-codi-operaciones'),debitOps=s('banxico-tpv-debito-ops'),creditOps=s('banxico-tpv-credito-ops'),ecomOps=s('banxico-ecommerce-ops'),circ=s('banxico-circulante');
  const cardOps=sumShared(debitOps,creditOps),S=last(spei),CoDi=last(codi),Card=last(cardOps),Debit=debitOps.find(p=>p.date===Card?.date),E=last(ecomOps),C=last(circ),CYr=yearAgo(circ);
  if(!S||!CoDi||!Card||!Debit||!E||!C||!CYr)throw new Error('Payments inputs are incomplete');
  const FACTS={enifCashSmall:{v:85.2,label:"INEGI's 2024 survey"},enifUrl:'https://inegi.org.mx/contenidos/programas/enif/2024/doc/enif_2024_resultados.pdf'};
  const debitReview=(meta('banxico-tpv-debito-monto').flags||[]).some(f=>String(f).startsWith('series_jump_'));
  const debitShare=Debit.value/Card.value*100,perDay=S.value/new Date(Date.UTC(dateObj(S.date).getUTCFullYear(),dateObj(S.date).getUTCMonth()+1,0)).getUTCDate();
  const codiRatio=(()=>{const m=spei.find(p=>p.date===CoDi.date);return m?Math.round(m.value/CoDi.value):null;})();
  const storeRatio=(()=>{const c=cardOps.find(p=>p.date===E.date);return c?c.value/E.value:null;})();
  const tCirc=trendWord(C.value,CYr.value);
  const cashHolds=tCirc.known&&tCirc.pct>0.5;
  const line=(name,points,color,format)=>({name,points,color,format});
  const newest=[S.date,C.date].sort().at(-1);
  return {
    title:'Payments',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · newest number ${dateLabel(newest)}`,
    lead:`<b>${fmt(FACTS.enifCashSmall.v,1)}%</b> of Mexican adults told ${FACTS.enifCashSmall.label} they still pay cash for everyday purchases. Every digital payment story in this country runs into that number. When money does move digitally, it moves over SPEI, the central bank's transfer system, which carried ${fmt(S.value/1e6,0)} million transfers in ${dateLabel(S.date)}. At the checkout, cards are taking over from cash, and ${fmt(debitShare,1)}% of them are debit. What almost never changes is the plumbing underneath.`,
    next:watchFor(/SPEI|CoDi|tarjeta|currency in circulation/i)||"Banxico's monthly SPEI and currency figures; release dates vary.",
    sections:[
      {h2:`Cash in circulation grew ${tCirc.known?fmt(Math.abs(tCirc.pct),1)+'%':''} in a year`,
       prose:[`The cash itself is growing. Mexicans held <b>MX$${fmt(C.value/1e6,2)} trillion</b> in notes and coins in ${dateLabel(C.date)}${tCirc.known&&Math.abs(tCirc.pct)>=0.5?`, ${fmt(Math.abs(tCirc.pct),1)}% ${tCirc.pct>0?'more':'less'} than a year earlier`:''}. ${cashHolds?'That is not a currency being abandoned. Digital payments are rising and paper is rising with them. The two are not splitting a fixed pot.':'The pile is no longer growing, which is the first sign the habit is loosening.'} Habits at this scale move over years, not quarters.`],
       chart:{title:'Notes and coins in circulation, MX$ trillions',stat:`MX$${fmt(C.value/1e6,2)}tn`,series:[line('Currency in circulation',circ.slice(-72),GREEN,v=>'MX$'+fmt(v/1e6,2)+'tn')],yFormat:v=>'MX$'+fmt(v/1e6,1)+'tn',label:'Notes and coins in circulation, monthly stock',srcId:'banxico-circulante'}},
      {h2:codiRatio?`Banxico's QR product lost to plain transfers, ${fmt(codiRatio,0)} to 1`:`Banxico's QR product lost to plain transfers`,
       prose:[`Banxico built a competitor to its own transfer system and lost. CoDi launched in 2019 so people could pay by scanning a QR code. It ran on the same plumbing as an ordinary bank transfer. In ${dateLabel(CoDi.date)}, Mexicans made <b>${codiRatio?fmt(codiRatio,0):'thousands of'}</b> ordinary transfers for every CoDi payment. The technology worked. It had nothing to replace, because people already knew how to send a transfer.`,
        `The other thing to know is which line to read. Count transfers, not pesos. A handful of large corporate payments dominates the peso total, so the value line describes treasury departments. The count describes households. Payroll lands there. So does rent, and the taco stand that takes transferencia.`],
       chart:{title:'SPEI transfers per month, millions',stat:`${fmt(S.value/1e6,0)}m`,series:[line('SPEI transfers',spei.slice(-72),GREEN,v=>fmt(v/1e6,0)+'m')],yFormat:v=>fmt(v/1e6,0)+'m',label:'SPEI monthly transfer count',srcId:'banxico-spei-operaciones'}},
      {h2:storeRatio?`The counter still beats the internet, ${fmt(storeRatio,1)} to 1`:`The counter still beats the internet`,
       prose:[`Online shopping is smaller here than it sounds. ${storeRatio?`As of ${quarterLabel(E.date)}, Mexicans made about <b>${fmt(storeRatio,1)}</b> card purchases at a physical terminal for every one online. `:''}Terminals handled ${fmt(Card.value/1e9,2)} billion purchases in ${quarterLabel(Card.date)}, roughly ${fmt(Card.value/91/1e6,0)} million a day. That volume runs mostly on debit, so it is money already sitting in the account. Card growth here displaces cash at the counter. It does not extend credit.`],
       chart:{title:'Card purchases at terminals, debit vs credit, millions per quarter',stat:`${fmt(Debit.value/1e6,0)}m debit`,series:[line('Debit',debitOps.slice(-24),GREEN,v=>fmt(v/1e6,0)+'m'),line('Credit',creditOps.slice(-24),INK,v=>fmt(v/1e6,0)+'m')],yFormat:v=>fmt(v/1e6,0)+'m',label:'Quarterly debit and credit card purchases',srcId:'banxico-tpv-debito-ops',srcId2:'banxico-tpv-credito-ops'}}
    ],
    updates:changedMatches('payments',3),
    upcoming:[
      {date:'Monthly',label:'SPEI and CoDi system totals',source:'Banxico · release date varies'},
      {date:'Quarterly',label:'Card and point-of-sale activity',source:'Banxico · release date varies'},
      {date:'Monthly',label:'Currency in circulation',source:'Banxico · release date varies'}
    ],
    sources:[topicSource('banxico-spei-operaciones'),topicSource('banxico-codi-operaciones'),topicSource('banxico-tpv-debito-ops'),topicSource('banxico-tpv-credito-ops'),topicSource('banxico-ecommerce-ops'),topicSource('banxico-circulante'),{label:'INEGI · ENIF 2024',href:FACTS.enifUrl,date:'2024'}],
    method:`Counts lead this page because peso totals are dominated by large transfers. Each chart keeps its own observation date. ${debitReview?'Banxico is reviewing its series for the peso value of debit-card purchases after a jump far outside its history; those pesos are excluded until the review ends.':''} The in-store-to-online ratio compares the same quarter for both series (banxico-ecommerce-ops).`
  };
}

function tradeTopic(){
  const ex=s('banxico-exports-total'),im=s('banxico-imports-total'),bal=s('banxico-trade-balance'),inter=s('banxico-imports-intermediate');
  const ex12=rolling12(ex,1e6),im12=rolling12(im,1e6),inter12=rolling12(inter,1e6),E=last(ex12),I=last(im12),B=last(bal),M=last(inter12);
  const partners=DB.partners?.exports?.items||[],us=partners.find(x=>x.name==='USA');
  const products=DB.products,pYear=Number(products?.referenceYear||products?.year||DB.partners?.referenceYear||DB.partners?.year);
  if(!E||!I||!B||!M||!us||!Number.isFinite(pYear))throw new Error('Trade inputs are incomplete');
  const comp=compositionEvidence(products);
  const leadShare=products?.items?.filter(x=>['84','85','87'].includes(String(x.code).padStart(2,'0'))).reduce((t,x)=>t+Number(x.share),0);
  const balW=balanceWord(B.value),intermediateShare=M.value/I.value*100;
  const usmca=DB.happening.find(e=>e.id==='usmca-not-renewed-2026-07-01');
  const next=eventMatches(/USMCA|tariff|trade talks|export|import/i,6);
  const todayMid=new Date();todayMid.setUTCHours(0,0,0,0);
  const timelineItems=next.map(e=>({date:(dateObj(e.date).getTime()===todayMid.getTime()?'Today · ':'')+shortDate(e.date)+' '+dateObj(e.date).getUTCFullYear(),title:e.label,text:e.mechanism||'Official dated event.'}));
  const line=(name,points,color,format)=>({name,points,color,format});
  return {
    title:'Trade',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · newest number ${dateLabel(last(ex).date)}`,
    lead:`<b>${fmt(us.share,1)}%</b> of Mexico's goods exports go to the United States. That one number explains most of Mexican trade policy, including a treaty review that now happens every year. Mexico sells assembled goods, buys the parts to assemble them, and does both with one customer. Decisions made in Washington move this page more than decisions made in Mexico City.`,
    next:watchFor(/USMCA|tariff|trade talks/i)||'The next USMCA and tariff dates are on the calendar below.',
    sections:[
      {h2:`Cars, electronics and machinery are ${fmt(leadShare,0)}% of exports`,
       prose:[`Vehicles, electronics and machinery are <b>${fmt(leadShare,0)}%</b> of what Mexico sold abroad over the latest twelve months. Not oil. Not farm goods. The total came to $${fmt(E.value,0)} billion, close to $${fmt(E.value/365,1)} billion a day. So Mexican export income tracks one thing: factory demand in the United States. No other sector is large enough to offset a slowdown there.`],
       chart:comp?{title:comp.title,stat:`$${fmt(E.value,0)}bn/yr`,visual:comp.visual,legend:comp.legend,table:comp.table,srcHtml:`<a href="https://comtradeplus.un.org/TradeFlow/" target="_blank" rel="noopener">UN COMTRADE · ${pYear} ↗</a>`,label:'Export composition treemap',css:'composition-evidence'}:null},
      {h2:`${fmt(intermediateShare,0)}% of imports are factory parts, not shopping`,
       prose:[`Most of what Mexico imports never reaches a shopper. Parts and materials bound for factories were <b>${fmt(intermediateShare,1)}%</b> of imports over the same twelve months. Exports and imports therefore rise and fall together instead of trading off. It also changes what a tariff does. A duty on imported parts raises the cost of goods Mexico has not sold yet, so it lands on exports as much as on imports.`],
       chart:{title:'Monthly goods balance, US$ billions',stat:`${B.value>=0?'+':'-'}$${fmt(Math.abs(B.value)/1e6,1)}bn`,series:[line('Trade balance',bal.slice(-72).map(p=>({date:p.date,value:p.value/1e6})),GREEN,v=>(v>=0?'+$':'-$')+fmt(Math.abs(v),1)+'bn')],yFormat:v=>(v>=0?'+$':'-$')+fmt(Math.abs(v),1),label:'Monthly goods trade balance',srcId:'banxico-trade-balance'}},
      {h2:'The US declined the 16-year extension',
       prose:[`${usmca?esc(usmca.title)+'. ':''}The United States turned down a 16-year extension, which would have settled the terms in a single round. Each review can now reopen tariffs and sector rules, the same rules the numbers above sit on. The clock runs to 2036 unless the countries agree to an extension first. This page keeps the dates and the record. It does not predict outcomes.`],
       chart:timelineItems.length?{title:'The next dated events on the trade calendar',visual:timeline(timelineItems),legend:'',table:timelineTable(timelineItems),srcHtml:usmca?`<a href="${usmca.url}" target="_blank" rel="noopener">USTR · USMCA review ↗</a>`:'',label:'Trade calendar timeline'}:null}
    ],
