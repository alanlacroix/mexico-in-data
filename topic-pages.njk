  const demo=DB.demographics,vitals=DB.vitals,crime=DB.crime;
  const pop=demo?.population?.latest,popYear=demo?.latestYear,births=vitals?.births,deaths=vitals?.deaths;
  const crimeTotal=crime?.values?Object.values(crime.values).reduce((t,v)=>t+Number(v||0),0):null,crimePeriod=observationPeriod(crime?.meta);
  if(!R||!Number.isFinite(pop)||!births?.latest||!deaths?.latest||!Number.isFinite(crimeTotal))throw new Error('Society inputs are incomplete');
  const bSeries=(births.series||[]).map(p=>({date:`${p.year}-01-01`,value:p.value})),dSeries=(deaths.series||[]).map(p=>({date:`${p.year}-01-01`,value:p.value}));
  const bFirst=births.series?.[0],tBirths=trendWord(births.latest.value,bFirst?bFirst.value:null);
  const tRem=trendWord(R.value,RY?RY.value:null);
  const line=(name,points,color,format)=>({name,points,color,format});
  return {
    title:'Society & security',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · newest number ${dateLabel(R.date)}`,
    lead:`Registered births fell ${tBirths.known?fmt(Math.abs(tBirths.pct),0)+'%':'sharply'} between ${bFirst?bFirst.year:''} and ${births.latest.year}. Mexico is aging faster than most people following it realize, and that single trend shapes its workforce, its pensions and its consumer market for decades. Meanwhile $${fmt(R.value/1000,1)} billion a month arrives from relatives working abroad, which for millions of households matters as much as wages. The crime data says less than it appears to, and this page explains why.`,
    next:watchFor(/employment|ENOE|unemployment|remittance|population/i)||'INEGI household releases; dates on the calendar below.',
    sections:[
      {h2:'Deaths are climbing toward births',
       prose:[`Mexico still records about two births for every death: <b>${fmt(births.latest.value/1e6,1)} million</b> births in ${births.latest.year} against roughly ${fmt(Math.round(deaths.latest.value/1e3),0)},000 deaths. Births still win. The gap narrows each year, and when the lines meet, the population grows only through migration, which these counts exclude. A smaller working-age base then carries more retirees, and pension and health costs grow into that gap.`],
       chart:bSeries.length>5?{title:'Registered births and deaths per year, millions',stat:`${fmt(births.latest.value/1e6,1)}m births`,series:[line('Births',bSeries,GREEN,v=>fmt(v/1e6,2)+'m'),line('Deaths',dSeries,INK,v=>fmt(v/1e6,2)+'m')],yFormat:v=>fmt(v/1e6,1)+'m',label:'Registered births and deaths per year',srcHtml:`<a href="${births.sourceUrl}" target="_blank" rel="noopener">INEGI · registered births ↗</a>`}:null},
      {h2:'Dollars arrive, pesos get spent',
       prose:[`The exchange rate decides what that money is worth at home. Families are paid in dollars and spend in pesos.${tRem.known?` ${dateLabel(R.date)}'s inflow ran ${fmt(Math.abs(tRem.pct),1)}% ${tRem.pct>=0?'above':'below'} the same month a year earlier.`:''} A stronger peso can erase that gain before it reaches a grocery bill. More dollars do not always mean more groceries.`],
       chart:{title:'Remittances per month, US$ billions',stat:`$${fmt(R.value/1000,1)}bn`,series:[line('Remittances',rem.slice(-72).map(p=>({date:p.date,value:p.value/1000})),GREEN,v=>'$'+fmt(v,1)+'bn')],yFormat:v=>'$'+fmt(v,1)+'bn',label:'Monthly remittance inflows',srcId:'banxico-remesas'}},
      {h2:'The file counts reports, not crimes',
       prose:[`State prosecutors logged <b>${fmt(crimeTotal/1e6,2)} million</b> filings in ${crimePeriod}. Reported is the word doing the work. The file records what people chose to tell a prosecutor, and that willingness differs by state and by offense. A rise can mean more crime or more reporting, and the count cannot tell you which. Treat any move as a question.`,
        `The poverty map is in the <a href="/atlas.html">Atlas</a>. The real wage is on the <a href="/economy.html">Economy</a> page.`]}
    ],
    updates:changedMatches('society',3),
    upcoming:eventMatches(/unemployment|remittance|wage|poverty|population|migration|employment/i,5),
    sources:[topicSource('banxico-remesas'),{label:'CONAPO · population projections',href:demo.sourceUrl,date:String(popYear)},{label:'INEGI · registered births',href:births.sourceUrl,date:String(births.latest.year)},{label:'INEGI · registered deaths',href:deaths.sourceUrl,date:String(deaths.latest.year)},{label:'SESNSP · municipal reported offenses',href:crime.meta.sourceUrl,date:crimePeriod}],
    method:`Population is a projection (${fmt(pop/1e6,1)} million for ${popYear}, median age ${demo.medianAge}); births and deaths are registrations; the security figure is a year-to-date count of reported offenses. The measures keep their own observation periods and are never blended.`
  };
}

function usMexicoTopic(){
  const tu=DB.tradeUS||{},imports=(tu.series?.imports||[]).map(p=>({date:p.month+'-01',value:p.value})),exports=(tu.series?.exports||[]).map(p=>({date:p.month+'-01',value:p.value})),L=tu.latest||{};
  const partners=DB.partners?.exports?.items||[],us=partners.find(x=>x.name==='USA'),partnerYear=Number(DB.partners?.referenceYear||DB.partners?.year);
  if(!L.month||!Number.isFinite(Number(L.twoway_bn))||!imports.length||!exports.length||!us||!Number.isFinite(partnerYear))throw new Error('U.S.-Mexico inputs are incomplete');
  const tradeMonth=L.month+'-01',mexicoBalance=-(Number(L.balance_bn)||0),balW=balanceWord(mexicoBalance);
  const censusMexicoUrl='https://www.census.gov/foreign-trade/balance/c2010.html';
  const usmca=DB.happening.find(e=>e.id==='usmca-not-renewed-2026-07-01');
  const next=eventMatches(/USMCA|U.S.|US-Mexico|tariff|trade talks|border|bilateral/i,6,/Presupuesto|Paquete|Ley de Ingresos|foreign direct investment|IED/i);
  const todayMid=new Date();todayMid.setUTCHours(0,0,0,0);
  const timelineItems=next.map(e=>({date:(dateObj(e.date).getTime()===todayMid.getTime()?'Today · ':'')+shortDate(e.date)+' '+dateObj(e.date).getUTCFullYear(),title:e.label,text:e.mechanism||'Official dated event.'}));
  const line=(name,points,color,format)=>({name,points,color,format});
  return {
    title:'US Mexico',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · newest number ${dateLabel(tradeMonth)}`,
    lead:`Mexico sells the United States <b>$${fmt(L.imports_bn,1)} billion</b> of goods a month and buys $${fmt(L.exports_bn,1)} billion back. Mexico wins that ledger every month, but the dependence runs the other way: ${fmt(us.share,0)}% of its exports go to this one buyer, so the same disruption costs Mexico far more than it costs America. The treaty setting the terms is now reviewed every year. That asymmetry is the lens for everything below.`,
    next:watchFor(/USMCA|tariff|trade talks/i)||'The next bilateral dates are on the calendar below.',
    sections:[
      {h2:`The two countries move about $${fmt(L.twoway_bn/30,1)} billion of goods a day`,
       prose:[`That is the ${dateLabel(tradeMonth)} pace, counting both directions: <b>$${fmt(L.twoway_bn,1)} billion</b> for the month. Volume is the part that gets missed. The surplus tells you who gains from the relationship. The total tells you how much would stop moving if the border slowed down.`,
        `Those goods are a small share of American output and a large share of Mexico's economy. So a tariff round argued as policy in Washington arrives as a payroll question in Monterrey. Goods are one of two big flows between the countries. The other is money sent home, and it sits with the households it supports on the <a href="/society.html">Society</a> page.`],
       chart:{title:'US goods trade with Mexico, monthly, US$ billions',stat:`$${fmt(L.twoway_bn,1)}bn`,series:[line('US buys from Mexico',imports,GREEN,v=>'$'+fmt(v,1)+'bn'),line('US sells to Mexico',exports,INK,v=>'$'+fmt(v,1)+'bn')],yFormat:v=>'$'+fmt(v,0),label:'Monthly US imports from and exports to Mexico',srcHtml:`<a href="${censusMexicoUrl}" target="_blank" rel="noopener">U.S. Census · trade with Mexico ↗</a>`}},
      {h2:'Declining the 16-year extension turned a long treaty into an annual one',
       prose:[`${usmca?esc(usmca.title)+'. ':''}USMCA came with an option to lock the terms in for 16 more years. That option was declined. What replaces it is a review every twelve months, running until the countries agree to an extension or the calendar reaches 2036. Each round can reopen tariffs and sector rules.`,
        `A factory manager choosing where to put a new production line now plans past a deadline that arrives every year. Companies did not lose access to the market. They lost the long horizon. This page reports what is scheduled and what came out of each round.`],
       chart:timelineItems.length?{title:'The next dated events between the two countries',visual:timeline(timelineItems),legend:'',table:timelineTable(timelineItems),srcHtml:usmca?`<a href="${usmca.url}" target="_blank" rel="noopener">USTR · USMCA review ↗</a>`:'',label:'Bilateral calendar timeline'}:null}
    ],
    updates:changedMatches('usmexico',3),
    upcoming:next.slice(0,5),
    sources:[...(usmca?[{label:'USTR · USMCA first review',href:usmca.url,date:shortDate(usmca.date)}]:[]),{label:'U.S. Census · trade with Mexico',href:censusMexicoUrl,date:tu.meta?.latestMonth},{label:'UN COMTRADE · export exposure',href:'https://comtradeplus.un.org/TradeFlow/',date:String(partnerYear)}],
    method:'The bilateral ledger uses U.S. Census throughout; Banxico owns Mexico\'s national accounts, and the two are never spliced. The export-share figure is the reconciled COMTRADE partner file.'
  };
}

const BUILDERS={economy:economyTopic,payments:paymentsTopic,trade:tradeTopic,politics:politicsTopic,society:societyTopic,usmexico:usMexicoTopic};
let current=ROUTE_TOPIC;
function validTopic(){return TOPIC_ORDER.includes(ROUTE_TOPIC)?ROUTE_TOPIC:'economy';}
function renderSources(t){return `<div class="source-list">${t.sources.map(x=>`<div><a href="${x.href}" target="_blank" rel="noopener">${x.label} ↗</a>${x.date?` · observation ${x.date}`:''}</div>`).join('')}</div><p>${t.method}</p>`;}
function evidenceBlock(e,id,label='In the data'){
  if(!e)return '';
  const titleId=id+'-title',visualId=id+'-visual',tableId=id+'-table';
  return `<section class="section ${e.css||''}" id="${id}" aria-labelledby="${titleId}"><div class="section-head"><div><div class="mono-k">${label}</div><h2 id="${titleId}">${e.k}</h2></div></div><article class="evidence-shell"><header class="evidence-head"><div><h3>${e.title}</h3><div class="evidence-sub">${e.sub}</div></div><div class="view-toggle" role="group" aria-label="Choose ${e.k} view"><button type="button" class="active" aria-pressed="true" data-evidence-for="${id}" data-evidence="visual">${e.visualLabel||'Chart'}</button><button type="button" aria-pressed="false" data-evidence-for="${id}" data-evidence="table">${e.tableLabel||'Table'}</button></div></header><div class="evidence-body" id="${visualId}">${e.legend?`<div class="chart-legend">${e.legend}</div>`:''}<div class="chart-wrap">${e.visual}</div><div class="chart-note">${e.note}${evidenceSources(e.sources)}</div></div><div class="table-wrap" id="${tableId}">${e.table}</div><div class="evidence-read"><div><h4>What it shows</h4><p>${e.read[0]}</p></div><div><h4>What it does not show</h4><p>${e.read[1]}</p></div></div></article></section>`;
}
// The chart card, stripped to four elements (Fable restart 2026-07-20): a plain title with
// units folded in, the current value, the chart with its crosshair, and ONE footer line
// carrying provenance and the table toggle. Everything else the old card wore is gone.
function chartSrcLine(c){
  if(c.srcHtml)return c.srcHtml;
  const ids=[c.srcId,c.srcId2].filter(Boolean);
  return ids.map(id=>`<a href="${sourceUrl(id)}" target="_blank" rel="noopener">${sourceName(id)}${seriesId(id)?` · ${seriesId(id)}`:''} ↗</a>`).join(' · ')+(ids.length?` · through ${dateLabel(obs(ids[0]))}`:'');
}
function chartShell(c,id){
  const visual=c.visual||chartSVG({series:c.series,yFormat:c.yFormat,label:c.label,band:c.band||null});
  const table=c.table||dataTable(c.series,24);
  return `<article class="chart-card ${c.css||''}"><header class="chart-head"><h3>${c.title}</h3>${c.stat?`<div class="chart-stat">${c.stat}</div>`:''}</header><div class="evidence-body" id="${id}-visual">${c.visual?(c.legend||''):`<div class="chart-legend">${legend(c.series)}</div>`}<div class="chart-wrap">${visual}</div></div><div class="table-wrap" id="${id}-table">${table}</div><div class="chart-foot"><span>${chartSrcLine(c)}</span><button type="button" class="tbl-toggle" data-evidence-for="${id}" aria-pressed="false">Table</button></div></article>`;
}
// The crosshair (Alan 2026-07-20): pointer over any chart snaps to the nearest observation,
// draws a vertical guide and a dot per series, and shows a tooltip with the date and each
// pre-formatted value. pointerdown covers tap-to-inspect on phones. Delegated once on the
// document, so it survives every re-render and needs no per-chart wiring.
(function(){
  function clearHover(holder){const tip=holder.querySelector('.chart-tip');if(tip)tip.hidden=true;holder.querySelectorAll('svg .hv').forEach(g=>{g.innerHTML='';});}
  function onPoint(ev){
    const svg=ev.target.closest?.('.chart-hover svg');
    if(!svg)return;
    const holder=svg.closest('.chart-hover');
    const data=holder._hd||(holder._hd=JSON.parse(holder.dataset.series));
    const a=svg.dataset,W=+a.w,H=+a.h,L=+a.l,R=+a.r,T=+a.t,B=+a.b,x0=+a.x0,x1=+a.x1,y0=+a.y0,y1=+a.y1;
    const rect=svg.getBoundingClientRect();
    const xv=(ev.clientX-rect.left)/rect.width*W;
    if(xv<L-6||xv>W-R+6){clearHover(holder);return;}
    const tt=x0+(Math.min(Math.max(xv,L),W-R)-L)/(W-L-R||1)*(x1-x0||1);
    const rows=[];let snap=null,snapD=Infinity;
    for(const s of data){let best=null,bd=Infinity;for(const p of s.p){const d=Math.abs(p[0]-tt);if(d<bd){bd=d;best=p;}}if(!best)continue;rows.push({s,p:best});if(bd<snapD){snapD=bd;snap=best;}}
    if(!rows.length)return;
    const X=v=>L+(v-x0)/(x1-x0||1)*(W-L-R),Y=v=>T+(y1-v)/(y1-y0||1)*(H-T-B);
    const g=svg.querySelector('.hv');
    const cx=X(snap[0]).toFixed(1);
    g.innerHTML=`<line class="hv-line" x1="${cx}" x2="${cx}" y1="${T}" y2="${H-B}"/>`+rows.map(r=>`<circle class="hv-dot" cx="${X(r.p[0]).toFixed(1)}" cy="${Y(r.p[1]).toFixed(1)}" r="4.5" fill="${r.s.c}"/>`).join('');
    let tip=holder.querySelector('.chart-tip');
    if(!tip){tip=document.createElement('div');tip.className='chart-tip';holder.appendChild(tip);}
    tip.hidden=false;
    tip.innerHTML=`<div class="tip-d">${esc(snap[3])}</div>`+rows.map(r=>`<div class="tip-r"><i style="background:${r.s.c}"></i><span>${esc(r.s.n)}</span><b>${esc(r.p[2])}</b></div>`).join('');
    const hr=holder.getBoundingClientRect();
    let leftPx=ev.clientX-hr.left+16;const tw=tip.offsetWidth||170;
    if(leftPx+tw>hr.width-4)leftPx=Math.max(4,ev.clientX-hr.left-tw-16);
    tip.style.left=leftPx+'px';
    tip.style.top=Math.max(0,ev.clientY-hr.top-tip.offsetHeight-14)+'px';
  }
  document.addEventListener?.('pointermove',onPoint);
  document.addEventListener?.('pointerdown',onPoint);
  document.addEventListener?.('pointerout',(ev)=>{const holder=ev.target.closest?.('.chart-hover');if(holder&&!(ev.relatedTarget&&holder.contains(ev.relatedTarget)))clearHover(holder);});
})();
function render(topic){
  current=topic;let t;
  try{t=BUILDERS[topic]();}
  catch(error){
    console.error(error);window.reportMexicoDataError?.(`topic:${topic}`);
    $('#topicApp').className='';
    $('#topicApp').innerHTML=`<section class="topic-hero"><div><h1>${LABELS[topic]}</h1><p class="topic-scope">This page is waiting for its required source data.</p></div></section><section class="now"><div class="mono-k">Data check</div><div><h2>This page couldn't load its source data. Try again, or check feed status.</h2><p><a href="/sources.html#livenow">Open feed status →</a></p></div></section>`;
    return;
  }
  $$('.topic-switch a').forEach(b=>b.classList.toggle('active',b.dataset.topic===topic));$('.topic-select').value=topic;
  // One argument with receipts (Fable restart 2026-07-20): lead thesis, single Next line,
  // 2-4 claim sections whose LAST sentence carries the leverage, stripped chart cards,
  // then the record, the calendar, and collapsed sources.
  $('#topicApp').className='';
  $('#topicApp').innerHTML=`
    <section class="topic-hero"><div><h1>${t.title}</h1></div><div class="topic-asof story-stamp">${t.asof}</div></section>
    <p class="lead">${t.lead}</p>
    ${t.next?`<div class="next-line"><span class="nk">Next</span>${t.next}</div>`:''}
    ${t.sections.map((sec,i)=>`<section class="section story-sec"><h2>${String(sec.h2).replace(/\.\s*$/,'')}</h2>${sec.prose.map(p=>`<p class="story-p">${p}</p>`).join('')}${sec.chart?chartShell(sec.chart,'story-ev-'+i):''}</section>`).join('')}
    <section class="section"><div class="changes-grid"><div><div class="section-head"><div><div class="mono-k">The record</div><h2>What's moving</h2></div></div>${updateList(t.updates)}</div><aside><div class="section-head"><div><div class="mono-k">The calendar</div><h2>What could change this page</h2></div></div>${upcomingList(t.upcoming)}</aside></div></section>
    <details class="sources"><summary>Sources and method</summary><div class="sources-body">${renderSources(t)}</div></details>`;
  $$('.tbl-toggle').forEach(b=>b.addEventListener('click',()=>{const id=b.dataset.evidenceFor,showTable=b.getAttribute('aria-pressed')!=='true';b.setAttribute('aria-pressed',String(showTable));b.textContent=showTable?'Chart':'Table';$('#'+id+'-visual').classList.toggle('hidden',showTable);$('#'+id+'-table').classList.toggle('open',showTable)}));
}
$('.topic-switch').innerHTML=TOPIC_ORDER.map(t=>`<a href="${ROUTES[t]}" data-topic="${t}"${t===validTopic()?' aria-current="page"':''}>${LABELS[t]}</a>`).join('');
$('.topic-select').innerHTML=TOPIC_ORDER.map(t=>`<option value="${t}">${LABELS[t]}</option>`).join('');
$('.topic-select').addEventListener('change',e=>{location.href=ROUTES[e.target.value]});
render(validTopic());
</script>
