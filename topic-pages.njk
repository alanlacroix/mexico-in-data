function politicsTopic(){
  const today=new Date();today.setUTCHours(0,0,0,0);
  const official=DB.events.filter(e=>e.date&&dateObj(e.date)>=today&&e.sourceUrl&&(e.kind==='political'||e.kind==='fiscal'||/Congress|election|electoral|budget|informe|presidential/i.test(`${e.label} ${e.mechanism||''}`))).sort((a,b)=>String(a.date).localeCompare(String(b.date)));
  if(!official.length)throw new Error('Political calendar is unavailable');
  const nextEvent=official[0],daysAway=Math.round((dateObj(nextEvent.date)-today)/86400000);
  // Long calendar labels carry dashes and parentheticals that garble a sentence; prose uses
  // the short name and the timeline keeps the full title. (QA 2026-07-20)
  const shortName=l=>esc(String(l).split('\u2014')[0].split('(')[0].trim());
  const sentence=t=>{const x=esc(String(t||'').trim());return x?(/[.!?]$/.test(x)?x+' ':x+'. '):'';};
  const fiscal=official.filter(e=>e.kind==='fiscal');
  const timelineItems=official.slice(0,6).map(e=>({date:shortDate(e.date)+' '+dateObj(e.date).getUTCFullYear(),title:e.label,text:e.mechanism||'Official dated event.'}));
  const updates=changedMatches('politics',3);
  return {
    title:'Politics',scope:'Official political and fiscal dates, and the documented events attached to them.',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · calendar through ${dateLabel(last(official).date)}`,
    story:[
      {h2:'What this page can and cannot tell you.',
       prose:[`This page tracks two things. One is official dates, such as election calendars and budget deadlines. The other is documented events, each with a source attached. It carries no polls, no seat math, and no forecasts. When something here matters for markets or trade, it also appears on those topic pages. This page is the calendar and the record.`],
       soWhat:`Fixed dates are forcing points: budgets must pass and reports are due by law, so each date below marks the moment a decision stops being deferrable.`,
       watch:''},
      {h2:`The next fixed date is ${daysAway===0?'today':daysAway===1?'tomorrow':`${fmt(daysAway,0)} days away`}.`,
       prose:[`<b>${shortName(nextEvent.label)}</b> is scheduled for ${shortDate(nextEvent.date)}, ${dateObj(nextEvent.date).getUTCFullYear()}. ${sentence(nextEvent.mechanism)}Every date in the timeline below links to its original source. Approximate dates are labeled.`],
       chart:{title:'The next official dates, in order',sub:'Political events and fiscal deadlines',visual:timeline(timelineItems),legend:'',table:timelineTable(timelineItems),visualLabel:'Timeline',tableLabel:'Details',
        note:'Dates refer to the event or official publication, not the day this page was checked.',
        sources:official.slice(0,4).map(e=>({label:e.source,href:e.sourceUrl,date:e.date})),
        read:['What is on the official calendar, and what each date controls.','What will happen on those dates. A scheduled event is not a prediction.']},
       soWhat:`Each date locks a piece of the next year: the fall deadlines cap what the government can tax and fix who gets the money, and the midterm decides who holds the chamber that votes the ones after.`,
       watch:watchFor(/Paquete|budget|Informe|election/i)},
      {h2:'The budget cycle is the recurring story.',
       prose:[`Every fall, the federal budget reveals the government's real priorities. The economic package arrives in early September, and the spending budget must pass by mid November.${fiscal.length?` The next fiscal deadline is ${shortDate(fiscal[0].date)}, ${dateObj(fiscal[0].date).getUTCFullYear()}, when ${shortName(fiscal[0].label)} is due.`:''} Between those dates, the documented record below is the running account.`],
       soWhat:`The September package turns priorities into numbers: proposed taxes, debt and spending. The two fall deadlines are when those numbers become law.`,
       watch:watchFor(/Paquete|Ley de Ingresos|Presupuesto/i)}
    ],
    updates:(updates.length?updates:[{type:'Calendar',title:nextEvent.label,text:nextEvent.mechanism||'Open the original source for the full record.',source:nextEvent.source,href:nextEvent.sourceUrl,date:shortDate(nextEvent.date)}])
      // The page promises the calendar and the record, no commentary. Strip the analysis
