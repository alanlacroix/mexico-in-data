       chart:comp?{title:comp.title,sub:comp.sub,visual:comp.visual,legend:comp.legend,table:comp.table,note:comp.note,sources:comp.sources,read:comp.read,css:'composition-evidence',visualLabel:'Map',tableLabel:'Table'}:null},
      {h2:`Exports and imports track each other; ${dateLabel(B.date)} landed a ${balW.word}.`,
       prose:[`In ${dateLabel(B.date)} Mexico ran a goods ${balW.word} of <b>$${fmt(Math.abs(B.value)/1e6,1)} billion</b>. Any single month can swing for reasons that do not last. The trend over many months matters more than the latest point.`],
       soWhat:`Because most imports are factory inputs, a ${balW.word==='surplus'?'surplus month means exports more than paid for the inputs that made them':'deficit month usually means inputs arrived ahead of the exports they will become'}; read the line, not any single month.`,
       watch:'',
       chart:{title:`The monthly goods balance was ${B.value>=0?'+':'-'}$${fmt(Math.abs(B.value)/1e6,1)} billion in ${dateLabel(B.date)}`,sub:'Monthly goods trade balance, US$ billions · exports minus imports',series:[line('Trade balance',bal.slice(-72).map(p=>({date:p.date,value:p.value/1e6})),GREEN,v=>(v>=0?'+$':'-$')+fmt(Math.abs(v),1)+'bn')],yFormat:v=>(v>=0?'+$':'-$')+fmt(Math.abs(v),1),label:'Monthly goods trade balance',
        note:'Banxico\'s national ledger, goods only. Points above zero are surpluses, below are deficits.',
        sources:[topicSource('banxico-trade-balance','Banxico · trade balance')],
