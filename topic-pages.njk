    sources:[topicSource('banxico-exports-total'),topicSource('banxico-imports-total'),topicSource('banxico-trade-balance'),topicSource('banxico-imports-intermediate'),{label:'UN COMTRADE · partner and product shares',href:'https://comtradeplus.un.org/TradeFlow/',date:String(pYear)},...(usmca?[{label:'USTR · USMCA review',href:usmca.url,date:shortDate(usmca.date)}]:[])],
    method:'Export and import totals come from Banxico. Product and partner shares come from UN COMTRADE, checked against Banxico before publication; the two sources are never mixed in one series. The full import and export levels are charted on the Numbers page.'
  };
}

function politicsTopic(){
  const today=new Date();today.setUTCHours(0,0,0,0);
  const official=DB.events.filter(e=>e.date&&dateObj(e.date)>=today&&e.sourceUrl&&(e.kind==='political'||e.kind==='fiscal'||/Congress|election|electoral|budget|informe|presidential/i.test(`${e.label} ${e.mechanism||''}`))).sort((a,b)=>String(a.date).localeCompare(String(b.date)));
  if(!official.length)throw new Error('Political calendar is unavailable');
  const nextEvent=official[0],daysAway=Math.round((dateObj(nextEvent.date)-today)/86400000);
  const fiscal=official.filter(e=>e.kind==='fiscal');
  const shortName=l=>esc(String(l).split('\u2014')[0].split('(')[0].trim());
  const timelineItems=official.slice(0,6).map(e=>({date:shortDate(e.date)+' '+dateObj(e.date).getUTCFullYear(),title:e.label,text:e.mechanism||'Official dated event.'}));
  const updates=changedMatches('politics',3);
  return {
    title:'Politics',
    asof:`Last revised ${shortDate(new Date().toISOString().slice(0,10))}, ${new Date().getUTCFullYear()} · calendar through ${dateLabel(last(official).date)}`,
    lead:`Mexican politics runs on a legal calendar, and this page tracks it: dates fixed by statute, plus events with a source attached. No polls, no seat math, no forecasts. The rhythm worth learning is the budget. Priorities are announced in the September address, priced in the economic package days later, and law by mid November. Watch the deadlines. A missed statutory date is itself the news.`,
    next:`${shortName(nextEvent.label)}, ${shortDate(nextEvent.date)}, ${dateObj(nextEvent.date).getUTCFullYear()}${daysAway>0?` (${fmt(daysAway,0)} days away)`:''}`,
    sections:[
      {h2:'Each date locks one piece of the year ahead',
       prose:[`Every date on this page settles something specific. <b>${shortName(nextEvent.label)}</b> comes first, on ${shortDate(nextEvent.date)}${daysAway>0?`, ${fmt(daysAway,0)} days from now`:''}. ${esc(String(nextEvent.mechanism||'').trim())}${/[.!?]$/.test(String(nextEvent.mechanism||'').trim())?'':'.'} One date sets what the government may tax. One sets who receives the money. One sets who sits in the chamber that votes on the next round. Every entry links to the statute that fixes it.`],
       chart:{title:'Political events and fiscal deadlines, by date',visual:timeline(timelineItems),legend:'',table:timelineTable(timelineItems),srcHtml:official.slice(0,1).map(e=>`<a href="${e.sourceUrl}" target="_blank" rel="noopener">${esc(e.source)} ↗</a>`).join(''),label:'Political calendar timeline'}},
      {h2:'The budget is the one document that puts a number on intent',
       prose:[`A speech can say anything. The budget has to say how much.${fiscal.length?` ${shortName(fiscal[0].label)} must reach Congress by ${shortDate(fiscal[0].date)}, ${dateObj(fiscal[0].date).getUTCFullYear()}, and it states in figures what the government proposes to tax, to borrow and to spend.`:''} Between that package and the November votes, the record below is the running account. When any of it moves markets, the numbers land on the <a href="/economy.html">Economy</a> and <a href="/trade.html">Trade</a> pages.`]}
    ],
    updates:updates.length?updates.map(u=>({...u,text:'',guide:u.guide?{items:u.guide.items.filter(x=>/^(Background|What's next)$/.test(x.label))}:null})):[{type:'Calendar',title:nextEvent.label,text:'',source:nextEvent.source,href:nextEvent.sourceUrl,date:shortDate(nextEvent.date)}],
    upcoming:official.slice(0,5),
    sources:[...new Map(official.slice(0,8).map(e=>[e.source,{label:e.source,href:e.sourceUrl,date:e.date}])).values()],
    method:'Only dates tied to an original source appear here. No polling averages, seat counts, or outcome inference; news items on this page carry their factual background only.'
  };
}

function societyTopic(){
