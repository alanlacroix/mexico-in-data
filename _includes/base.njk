{#- The one page shell. Every page's <head>, masthead, and footer come from here,
   so the favicon, theme-color, OG tags, and nav are baked ONCE and can't go
   missing on a page again (about + weekly used to have no favicon at all).
   Pages provide: title, description; optionally ogTitle/ogDescription, bodyClass,
   pageStyle (page-specific CSS), headExtra, pageScript, wire, status, footerBlurb. -#}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>{{ title }}</title>
<meta name="description" content="{{ description }}" />
<meta name="theme-color" content="#ffffff" />
<meta property="og:type" content="website" />
<meta property="og:title" content="{{ ogTitle or title }}" />
<meta property="og:description" content="{{ ogDescription or description }}" />
<meta property="og:locale" content="en_US" />
<meta name="twitter:card" content="summary" />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%230a7d4d'/%3E%3Cpath d='M8 22.5 L8 10 L16 17.5 L24 10 L24 22.5' fill='none' stroke='white' stroke-width='2.8' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E" />
<link rel="stylesheet" href="/design/mckinsey-mx.css?v={{ cssv }}" />
{% if pageStyle %}<style>{{ pageStyle | safe }}</style>{% endif %}
{% if headExtra %}{{ headExtra | safe }}{% endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
{% include "partials/header.njk" %}
{{ content | safe }}
{% include "partials/footer.njk" %}
<script>document.addEventListener('click',function(e){
  var b=e.target.closest('.navtoggle');
  if(b){b.setAttribute('aria-expanded',b.getAttribute('aria-expanded')==='true'?'false':'true');return;}
  // Topics dropdown: click to open/close (a reliable backstop to hover). Clicking outside closes it.
  var inDrop=e.target.closest('.navdrop');
  document.querySelectorAll('.navdrop.open').forEach(function(o){if(o!==inDrop)o.classList.remove('open');});
  var t=e.target.closest('.navdrop-t');
  if(t){var d=t.closest('.navdrop');var on=d.classList.toggle('open');t.setAttribute('aria-expanded',on?'true':'false');}
});
/* Our own subscribe form -> /api/subscribe (a Cloudflare function that calls beehiiv server-side).
   Any form.subform on any page: inline result, no popup, no third-party UI. */
document.addEventListener('submit',function(e){var f=e.target;if(!f.classList||!f.classList.contains('subform'))return;e.preventDefault();
  var inp=f.querySelector('input[type=email]'),btn=f.querySelector('button'),msg=f.parentNode.querySelector('.submsg');
  var email=(inp&&inp.value||'').trim();
  var say=function(t,ok){if(msg){msg.textContent=t;msg.style.color=ok?'var(--green-d)':'var(--red)';}};
  if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){say('Enter a valid email address.',false);return;}
  var old=btn?btn.textContent:'';if(btn){btn.disabled=true;btn.textContent='Subscribing…';}
  fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:email})})
    .then(function(r){return r.json().catch(function(){return{ok:r.ok};});})
    .then(function(d){if(btn){btn.disabled=false;btn.textContent=old;}
      if(d&&d.ok){f.style.display='none';say('Almost there. Check your inbox to confirm, and see you Monday.',true);}
      else{say((d&&d.error)||'Could not subscribe, please try again.',false);}})
    .catch(function(){if(btn){btn.disabled=false;btn.textContent=old;}say('Network error, please try again.',false);});
});</script>
{% if pageScript %}<script type="module">{{ pageScript | safe }}</script>{% endif %}
</body>
</html>
