{#- The one page shell. Every page's <head>, masthead, and footer come from here,
   so the favicon, theme-color, OG tags, and nav are baked ONCE and can't go
   missing on a page again (about + weekly used to have no favicon at all).
   Pages provide: title, description; optionally ogTitle/ogDescription, bodyClass,
   pageStyle (page-specific CSS), headExtra, pageScript, wire, status, footerBlurb,
   noindex. -#}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" />
<title>{{ title }}</title>
<meta name="description" content="{{ description }}" />
<meta name="author" content="Alan Lacroix" />
{% if noindex %}<meta name="robots" content="noindex, nofollow" />{% else %}<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />{% endif %}
<link rel="canonical" href="https://mexicobrief.com{{ page.url | canonicalPath }}" />
<meta name="theme-color" content="#ffffff" />
<meta property="og:type" content="website" />
<meta property="og:title" content="{{ ogTitle or title }}" />
<meta property="og:description" content="{{ ogDescription or description }}" />
<meta property="og:url" content="https://mexicobrief.com{{ page.url | canonicalPath }}" />
<meta property="og:site_name" content="The Mexico Brief" />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content="https://mexicobrief.com/assets/og.png" />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="The Mexico Brief — Mexico in official numbers" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content="https://mexicobrief.com/assets/og.png" />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%230a7d4d'/%3E%3Cpath d='M8 22.5 L8 10 L16 17.5 L24 10 L24 22.5' fill='none' stroke='white' stroke-width='2.8' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E" />
<link rel="stylesheet" href="/design/mckinsey-mx.css?v={{ cssv }}" />
{% if pageStyle %}<style>{{ pageStyle | safe }}</style>{% endif %}
{% if headExtra %}{{ headExtra | safe }}{% endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "NewsMediaOrganization",
      "@id": "https://mexicobrief.com/#org",
      "name": "The Mexico Brief",
      "url": "https://mexicobrief.com/",
      "logo": { "@type": "ImageObject", "url": "https://mexicobrief.com/assets/og.svg" },
      "founder": { "@type": "Person", "name": "Alan Lacroix" },
      "description": "Mexico's economy, politics, trade, and U.S. relationship in official numbers, dated and linked to the original source."
    },
    {
      "@type": "WebSite",
      "@id": "https://mexicobrief.com/#website",
      "url": "https://mexicobrief.com/",
      "name": "The Mexico Brief",
      "publisher": { "@id": "https://mexicobrief.com/#org" },
      "inLanguage": "en-US"
    },
    {
      "@type": "WebPage",
      "@id": "https://mexicobrief.com{{ page.url | canonicalPath }}#webpage",
      "url": "https://mexicobrief.com{{ page.url | canonicalPath }}",
      "name": {{ (ogTitle or title) | dump | safe }},
      "description": {{ description | dump | safe }},
      "isPartOf": { "@id": "https://mexicobrief.com/#website" },
      "inLanguage": "en-US",
      "dateModified": "{{ buildTime }}"
    }
  ]
}
</script>
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
<a class="skip-link" href="#main">Skip to content</a>
{% include "partials/header.njk" %}
<div class="data-alert" id="data-alert" role="status" hidden>
  <b>Some data did not load.</b> The rest of the page is still available. <a href="/sources.html#livenow">Check the feeds &rarr;</a>
</div>
<main id="main">{{ content | safe }}</main>
{% include "partials/footer.njk" %}
<script>(function(){
  var seen={};
  window.reportMexicoDataError=function(resource){
    seen[String(resource||'unknown')]=1;
    var box=document.getElementById('data-alert');
    if(box)box.hidden=false;
  };
  window.addEventListener('mb:data-error',function(e){window.reportMexicoDataError(e.detail&&e.detail.resource);});
})();
document.addEventListener('click',function(e){
  var b=e.target.closest('.navtoggle');
  if(b){b.setAttribute('aria-expanded',b.getAttribute('aria-expanded')==='true'?'false':'true');return;}
  // Topics dropdown: click to open/close (a reliable backstop to hover). Clicking outside closes it.
  var inDrop=e.target.closest('.navdrop');
  document.querySelectorAll('.navdrop.open').forEach(function(o){if(o!==inDrop){o.classList.remove('open');var ob=o.querySelector('.navdrop-t');if(ob)ob.setAttribute('aria-expanded','false');}});
  var t=e.target.closest('.navdrop-t');
  if(t){var d=t.closest('.navdrop');var on=d.classList.toggle('open');t.setAttribute('aria-expanded',on?'true':'false');}
});
document.addEventListener('keydown',function(e){if(e.key!=='Escape')return;
  document.querySelectorAll('.navdrop.open').forEach(function(d){d.classList.remove('open');var b=d.querySelector('.navdrop-t');if(b){b.setAttribute('aria-expanded','false');b.focus();}});
  var menu=document.querySelector('.navtoggle[aria-expanded="true"]');if(menu){menu.setAttribute('aria-expanded','false');menu.focus();}
});
/* Our own subscribe form -> /api/subscribe (a Cloudflare function that calls beehiiv server-side).
   Any form.subform on any page: inline result, no popup, no third-party UI. */
document.addEventListener('submit',function(e){var f=e.target;if(!f.classList||!f.classList.contains('subform'))return;e.preventDefault();
  var inp=f.querySelector('input[type=email]'),btn=f.querySelector('button'),msg=f.parentNode.querySelector('.submsg');
  var email=(inp&&inp.value||'').trim(),hp=f.querySelector('input[name=website]');
  var say=function(t,ok){if(msg){msg.textContent=t;msg.style.color=ok?'var(--green-d)':'var(--red)';}};
  if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){say('Enter a valid email address.',false);return;}
  var old=btn?btn.textContent:'';if(btn){btn.disabled=true;btn.textContent='Subscribing…';}
  fetch('/api/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:email,website:(hp&&hp.value||'')})})
    .then(function(r){return r.json().catch(function(){return{ok:r.ok};});})
    .then(function(d){if(btn){btn.disabled=false;btn.textContent=old;}
      if(d&&d.ok){f.style.display='none';say('Almost there. Check your inbox to confirm.',true);}
      else{say((d&&d.error)||'Could not subscribe, please try again.',false);}})
    .catch(function(){if(btn){btn.disabled=false;btn.textContent=old;}say('Network error, please try again.',false);});
});</script>
{% if pageScript %}<script type="module">{{ pageScript | safe }}</script>{% endif %}
</body>
</html>
