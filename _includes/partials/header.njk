{#- The masthead: brand + the one nav (see _data/nav.js), current page derived
   from page.url. On narrow screens the links collapse behind the menu button
   (toggled by the small script in base.njk). Live indicators (the Wire, freshness)
   are NOT in the nav — the homepage renders them in its own .livebar strip. -#}
<header class="mast"><div class="wrap">
  <a class="brand" href="/">THE MEXICO <span class="u">BRIEF</span></a>
  <button class="navtoggle" type="button" aria-label="Menu" aria-controls="sitenav" aria-expanded="false"><span></span><span></span><span></span></button>
  <nav class="mnav" id="sitenav">
    {%- for item in nav %}
    <a href="{{ item.href }}"{% if page.url == item.href %} class="here"{% endif %}>{{ item.label }}</a>
    {%- endfor %}
  </nav>
</div></header>
