{#- The footer. Same one nav as the header, so the two can never diverge again
   (the old hand-copied footers dropped Economy + About on some pages). Each page
   may override the blurb via `footerBlurb`. -#}
<footer class="foot"><div class="wrap">
  <nav class="fnav" aria-label="Footer navigation">{% for item in footernav %}<a href="{{ item.href }}">{{ item.label }}</a>{% endfor %}</nav>
  <p class="fblurb">{{ footerBlurb or "The official numbers, the context behind them, and the original sources when you want to go deeper. Built by Alan Lacroix." }}</p>
</div></footer>
