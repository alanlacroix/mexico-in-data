  const draw=(lbl)=>{cur=lbl;const P2=slice(id,lbl);const o={render:m.r,f:m.f,cad};const d=chartSVG(P2,o);
    const wrap=$('#sxWrap');wrap.querySelector('.sx-svg')&&wrap.querySelector('.sx-svg').remove();wrap.insertAdjacentHTML('beforeend',d.svg);wireCross(wrap,d,o);
    const a=P2[0].value,b=P2[P2.length-1].value;const ch=isRate(id)?((b-a>=0?'+':'')+(b-a).toFixed(2)+' pp'):((pct(b,a)>=0?'+':'')+pct(b,a).toFixed(1)+'%');
    $('#sxChg').innerHTML=`${ch} <span class="rl">· ${lbl}</span>`;
