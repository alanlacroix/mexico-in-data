---
layout: base.njk
permalink: /chart.html
title: "Charts · The Mexico Brief"
description: "Mexico’s peso, rates, prices, activity, trade, remittances and payments in one chart. Compare up to three series, inspect the data, and open each source."
---
{% raw %}
<style>
  :root{--ink-3:#4d4d4d}
  body{font-size:var(--fs-body)}
  .cx{max-width:1120px;margin:0 auto;padding:0 clamp(16px,4vw,40px)}
  .cx-hd{padding:24px 0 2px}
  .cx-hd .eyebrow{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);font-weight:700}
  .cx-hd h1{font-family:var(--sans);font-size:var(--fs-h2);line-height:1.08;letter-spacing:-.02em;margin:7px 0 0;color:var(--ink)}
  .cx-hd p{font-size:var(--fs-small);color:var(--ink-2);margin:7px 0 0;max-width:60ch;line-height:1.5}

  /* plain-language questions */
  .cx-views{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:1px;margin-top:18px;background:var(--line-2);border:1px solid var(--line-2);border-radius:8px;overflow:hidden}
  .cx-views button{font-family:var(--sans);font-size:13.5px;line-height:1.3;text-align:left;color:var(--ink-2);background:var(--paper);border:0;padding:10px 12px;cursor:pointer;min-height:52px}
  .cx-views button:hover{background:var(--paper-2);color:var(--green-d)}
  .cx-views button.on{background:var(--green-bg);color:var(--green-d);font-weight:600;box-shadow:inset 0 -2px var(--green)}

  /* calculated answer for a saved question */
  .cx-qa{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(260px,.75fr);gap:16px 24px;margin-top:14px;padding:13px 15px;border:1px solid var(--line);border-left:3px solid var(--green);border-radius:7px;background:var(--paper-2)}
  .cx-qa.unavailable{border-left-color:var(--amber2,#9a6a00)}
  .cx-qa-k{font-family:var(--mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--green-d);font-weight:700;margin-bottom:5px}
  .cx-qa.unavailable .cx-qa-k{color:var(--amber2,#9a6a00)}
  .cx-qa-answer{font-family:var(--sans);font-size:17px;line-height:1.45;color:var(--ink);margin:0;max-width:68ch}
  .cx-qa-side{font-family:var(--sans);font-size:13.5px;line-height:1.45;color:var(--ink-2)}
  .cx-qa-side p{margin:0 0 6px}
  .cx-qa-side b{color:var(--ink)}
  .cx-qa-method{grid-column:1/-1;border-top:1px solid var(--line);padding-top:8px}
  .cx-qa-method summary{font-family:var(--mono);font-size:10px;letter-spacing:.04em;text-transform:uppercase;color:var(--green-d);cursor:pointer;list-style:none}
  .cx-qa-method summary::-webkit-details-marker{display:none}
  .cx-qa-method summary::after{content:' +';color:var(--mut)}
  .cx-qa-method[open] summary::after{content:' –'}
  .cx-qa-method div{font-family:var(--mono);font-size:11px;line-height:1.55;color:var(--mut);margin-top:7px}
  .cx-qa-method a{color:var(--green-d)}

  /* selected chips + add */
  .cx-chips{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:12px;border-top:2px solid var(--green);padding-top:14px}
  .cx-chip{display:inline-flex;align-items:center;gap:8px;font-family:var(--sans);font-size:14px;color:var(--ink);background:var(--paper-2);border:1px solid var(--line-2);border-radius:8px;padding:7px 8px 7px 12px;min-height:38px}
  .cx-chip .sw{width:11px;height:11px;border-radius:3px;flex:none}
  .cx-chip .x{border:none;background:none;cursor:pointer;color:var(--mut);font-size:16px;line-height:1;padding:2px 4px;border-radius:5px}
  .cx-chip .x:hover{background:var(--line);color:var(--ink)}
  .cx-chip.derived .cx-db{font-family:var(--mono);font-size:9px;letter-spacing:.04em;color:var(--green-d);border:1px solid var(--green);border-radius:4px;padding:1px 4px;text-transform:uppercase}
  .cx-add{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.03em;text-transform:uppercase;color:var(--green-d);background:var(--paper);border:1px dashed var(--line-2);border-radius:8px;padding:8px 14px;cursor:pointer;min-height:38px}
  .cx-add:hover{border-color:var(--green);background:var(--green-bg)}
  .cx-add[disabled]{opacity:.4;cursor:not-allowed}

  /* controls row */
  .cx-ctrls{display:flex;gap:14px;flex-wrap:wrap;align-items:center;justify-content:space-between;margin-top:12px}
  .cx-seg{display:flex;gap:6px;flex-wrap:wrap}
  .cx-seg button{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.03em;text-transform:uppercase;color:var(--ink-2);background:var(--paper);border:1px solid var(--line-2);border-radius:8px;padding:9px 13px;cursor:pointer;min-height:44px}
  .cx-seg button.on{background:var(--ink);color:#fff;border-color:var(--ink)}
  .cx-seg button[disabled]{opacity:.35;cursor:not-allowed}
  .cx-modelab{font-family:var(--mono);font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.04em;margin-right:2px;align-self:center}
  .cx-mode-note{font-family:var(--sans);font-size:13px;line-height:1.45;color:var(--ink-2);margin:8px 0 0;max-width:76ch}

  /* chart */
  .cx-chart{margin-top:14px}
  .cw{position:relative;border:1px solid var(--line);border-radius:8px;background:linear-gradient(180deg,#fbfbf9,#f6f6f2);padding:8px 6px 4px}
  .cw + .cw{margin-top:12px}
  svg.cxsvg{width:100%;display:block;touch-action:pan-y}
  svg.cxsvg .grid{stroke:var(--line);stroke-width:1}
  svg.cxsvg .zero{stroke:var(--ink-2);stroke-width:1;stroke-dasharray:2 3}
  svg.cxsvg .axl{font-family:var(--mono);fill:var(--mut)}
  svg.cxsvg .af{opacity:.14;stroke:none}
  svg.cxsvg .mk{}
  svg.cxsvg .cross{stroke:var(--ink-2);stroke-width:1;stroke-dasharray:3 3}
  svg.cxsvg .endlab{font-family:var(--sans);font-weight:600}
  .cw-t{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.03em;text-transform:uppercase;color:var(--mut);padding:4px 4px 0}
  .cw-t b{color:var(--ink);font-family:var(--sans);text-transform:none;font-size:15px;letter-spacing:0;margin-left:6px}

  /* selected-value strip */
  .cx-strip{display:flex;gap:18px;flex-wrap:wrap;align-items:baseline;margin-top:12px;padding:11px 2px;border-top:1px solid var(--line);min-height:44px}
  .cx-strip .sd{font-family:var(--mono);font-size:12px;color:var(--mut);text-transform:uppercase;letter-spacing:.03em}
  .cx-strip .si{display:inline-flex;align-items:baseline;gap:7px;font-family:var(--sans)}
  .cx-strip .si i{width:10px;height:10px;border-radius:3px;align-self:center}
  .cx-strip .si .n{font-size:13px;color:var(--ink-2)}
  .cx-strip .si .v{font-size:16px;color:var(--ink);font-variant-numeric:tabular-nums}

  /* single-variable big value */
  .cx-big{display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;margin-top:10px}
  .cx-big .bv{font-family:var(--sans);font-size:clamp(30px,4vw,40px);color:var(--ink);font-variant-numeric:tabular-nums;line-height:1;letter-spacing:-.02em}
  .cx-big .bv small{font-size:14px;color:var(--mut)}
  .cx-big .bc{font-family:var(--mono);font-size:15px;color:var(--ink-2);font-variant-numeric:tabular-nums}
  .cx-big .bc .rl{color:var(--mut)}
  .cx-def{font-family:var(--sans);font-size:15px;color:var(--ink-2);line-height:1.5;margin-top:8px;max-width:70ch}

  /* disclosure + context */
  .cx-disc{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:11px;line-height:1.5}
  .cx-disc.warn{color:var(--amber2,#9a6a00)}
  .cx-ctx{margin-top:14px;border-top:1px solid var(--line);padding-top:12px}
  .cx-ctx summary{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.03em;text-transform:uppercase;color:var(--ink-2);cursor:pointer;list-style:none}
  .cx-ctx summary::-webkit-details-marker{display:none}
  .cx-ctx summary::after{content:' +';color:var(--mut)}
  .cx-ctx[open] summary::after{content:' –'}
  .cx-ctx .cxc-body{font-family:var(--sans);font-size:14.5px;color:var(--ink-2);line-height:1.55;margin-top:10px;max-width:72ch}
  .cx-ctx .cxc-body p{margin:0 0 8px}
  .cx-ctx .cxc-body b{color:var(--ink)}
  .cx-ctx .cxc-cav{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:6px}

  /* actions */
  .cx-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}
  .cx-actions button,.cx-actions a{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.02em;color:var(--green-d);background:var(--paper);border:1px solid var(--line-2);border-radius:8px;padding:9px 13px;cursor:pointer;min-height:40px;text-decoration:none;display:inline-flex;align-items:center;gap:6px}
  .cx-actions button:hover,.cx-actions a:hover{border-color:var(--green)}
  .cx-actions button.on{background:var(--ink);color:#fff;border-color:var(--ink)}

  /* related / add-to-comparison chips (single view) */
  .cx-rel{margin-top:16px}
  .cx-rel .rl{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;color:var(--mut);margin-bottom:8px}
  .cx-rel .chips{display:flex;gap:8px;flex-wrap:wrap}
  .cx-rel .chip{font-family:var(--sans);font-size:14px;color:var(--ink);background:var(--paper-2);border:1px solid var(--line-2);border-radius:20px;padding:7px 14px;cursor:pointer;min-height:38px}
  .cx-rel .chip:hover{border-color:var(--green);color:var(--green-d)}
  .cx-rel .chip .ar{color:var(--mut);margin-right:5px}

  /* data table */
  .cx-tbl{margin-top:14px;overflow-x:auto}
  .cx-tbl table{border-collapse:collapse;font-family:var(--mono);font-size:12px;width:100%}
  .cx-tbl th,.cx-tbl td{border-bottom:1px solid var(--line);padding:6px 10px;text-align:right;white-space:nowrap;font-variant-numeric:tabular-nums}
  .cx-tbl th:first-child,.cx-tbl td:first-child{text-align:left}
  .cx-tbl th{color:var(--mut);text-transform:uppercase;letter-spacing:.03em;font-weight:600}

  /* source disclosure block reused (.srcd is global) */
  .cx-srcs{margin-top:12px;display:grid;gap:6px}

  /* All series (collapsed catalog) */
  .cx-all{margin-top:30px;border-top:1px solid var(--line);padding-top:6px}
  .cx-all>summary{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.04em;text-transform:uppercase;color:var(--ink-2);cursor:pointer;padding:10px 0;list-style:none}
  .cx-all>summary::-webkit-details-marker{display:none}
  .cx-all>summary::before{content:'▸ ';color:var(--mut)}
  .cx-all[open]>summary::before{content:'▾ '}
  .cat-grp{margin-top:14px}
  .cat-gl{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.05em;text-transform:uppercase;color:var(--green);font-weight:600;margin-bottom:9px}
  .cat-more{font-family:var(--mono);font-size:10px;letter-spacing:.05em;text-transform:uppercase;color:var(--mut);margin:12px 0 8px}
  .cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line-2);border:1px solid var(--line-2);border-radius:4px;overflow:hidden}
  @media(min-width:640px){.cat-grid{grid-template-columns:repeat(3,1fr)}}
  @media(min-width:940px){.cat-grid{grid-template-columns:repeat(4,1fr)}}
  .cc{background:var(--paper);padding:12px 13px;cursor:pointer;text-align:left;border:none;width:100%;font:inherit;display:flex;flex-direction:column;gap:3px}
  .cc:hover{background:var(--paper-2)}
  .cc .cl{font-family:var(--mono);font-size:var(--fs-label);letter-spacing:.02em;text-transform:uppercase;color:var(--mut);line-height:1.3;min-height:2.4em}
  .cc .cv{font-family:var(--sans);font-size:20px;color:var(--ink);font-variant-numeric:tabular-nums;line-height:1;letter-spacing:-.015em}
  .cc .cv small{font-size:10px;color:var(--mut)}
  .cc .cm{font-family:var(--mono);font-size:10px;color:var(--mut);margin-top:2px}

  /* Add-variable sheet */
  .cx-sheet{position:fixed;inset:0;z-index:60;display:none}
  .cx-sheet.open{display:block}
  .cx-sheet .ov{position:absolute;inset:0;background:rgba(20,20,20,.34)}
  .cx-sheet .pan{position:absolute;left:50%;top:8vh;transform:translateX(-50%);width:min(560px,94vw);max-height:84vh;background:var(--paper);border:1px solid var(--line);border-radius:12px;box-shadow:0 24px 60px rgba(0,0,0,.28);display:flex;flex-direction:column;overflow:hidden}
  body.cx-modal-open{overflow:hidden}
  .cx-sheet .ph{padding:14px 16px 10px;border-bottom:1px solid var(--line)}
  .cx-sheet .pht{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:9px}
  .cx-sheet .ph h3{font-family:var(--sans);font-size:17px;color:var(--ink);margin:0}
  .cx-sheet .pc{width:40px;height:40px;border:1px solid var(--line-2);border-radius:8px;background:var(--paper);color:var(--ink-2);font-size:22px;line-height:1;cursor:pointer}
  .cx-sheet .pc:hover{border-color:var(--green);color:var(--green-d)}
  .cx-sheet .ph input{width:100%;font-family:var(--sans);font-size:15px;padding:11px 12px;border:1px solid var(--line-2);border-radius:8px;background:var(--paper-2);color:var(--ink);min-height:44px}
  .cx-sheet .pl{overflow-y:auto;padding:6px 8px 12px}
  .cx-sheet .sg{font-family:var(--mono);font-size:10px;letter-spacing:.05em;text-transform:uppercase;color:var(--green);padding:12px 8px 5px;position:sticky;top:0;background:var(--paper)}
  .pr{display:flex;align-items:center;gap:10px;padding:9px 8px;border-radius:8px}
  .pr:hover{background:var(--paper-2)}
  .pr .prm{flex:1;min-width:0}
  .pr .prn{font-family:var(--sans);font-size:14.5px;color:var(--ink);display:flex;align-items:center;gap:7px}
  .pr .prn .db{font-family:var(--mono);font-size:8.5px;letter-spacing:.04em;color:var(--green-d);border:1px solid var(--green);border-radius:4px;padding:1px 4px;text-transform:uppercase}
  .pr .prd{font-family:var(--mono);font-size:11px;color:var(--mut);margin-top:2px}
  .pr .prd.stale{color:var(--amber2,#9a6a00)}
  .pr .pa{display:flex;gap:6px;flex:none}
  .pr .pa button{font-family:var(--mono);font-size:11px;color:var(--green-d);background:var(--paper);border:1px solid var(--line-2);border-radius:7px;padding:8px 10px;cursor:pointer;min-height:40px}
  .pr .pa button:hover{border-color:var(--green);background:var(--green-bg)}
  .pr .pa button[disabled]{opacity:.35;cursor:not-allowed}

  .cx-skel{height:300px;border:1px solid var(--line);border-radius:8px;background:linear-gradient(90deg,#f4f4f0,#fafaf7,#f4f4f0);background-size:200% 100%;animation:cxsh 1.4s linear infinite;margin-top:16px}
  @keyframes cxsh{0%{background-position:200% 0}100%{background-position:-200% 0}}
  .cx-err{font-family:var(--mono);font-size:14px;color:var(--red);margin-top:20px}
  @media (prefers-reduced-motion: reduce){.cx-skel{animation:none}}
  @media(max-width:560px){
    .cx-views{display:flex;gap:8px;overflow-x:auto;scroll-snap-type:x proximity;background:none;border:0;border-radius:0;padding-bottom:3px}
    .cx-views button{flex:0 0 205px;border:1px solid var(--line-2);border-radius:8px;scroll-snap-align:start;min-height:50px}
    .cx-chip{min-height:44px;padding-top:4px;padding-bottom:4px}
    .cx-chip .x{min-width:40px;min-height:40px;padding:0;display:inline-flex;align-items:center;justify-content:center}
    .cx-add,.cx-actions button,.cx-actions a{min-height:44px}
    .cx-qa{grid-template-columns:1fr;gap:9px;padding:12px}
    .cx-qa-answer{font-size:16px}
    .cx-qa-method{grid-column:1}
    .cx-strip{gap:12px}
    .cx-hd h1{font-size:26px}
  }
</style>

<div class="cx">
  <section class="cx-hd">
    <span class="eyebrow">Charts</span>
    <h1 id="cxTitle">Mexico in charts</h1>
    <p id="cxIntro">Choose a number. Add another to compare. Everything links back to the source.</p>
  </section>
  <div id="cxBody"><div class="cx-skel" aria-hidden="true"></div></div>
</div>

<div class="cx-sheet" id="cxSheet" aria-hidden="true">
  <div class="ov" data-close="1"></div>
  <div class="pan" role="dialog" aria-modal="true" aria-labelledby="cxSheetTitle">
    <div class="ph"><div class="pht"><h3 id="cxSheetTitle">Add a variable</h3><button class="pc" id="cxSheetClose" type="button" aria-label="Close variable picker">×</button></div><input id="cxSearch" type="search" placeholder="Search the peso, inflation, exports…" autocomplete="off"></div>
    <div class="pl" id="cxPickList"></div>
  </div>
</div>

<script type="module">
import { fmt, valueAgo, humanSrc, seriesId, enNum } from '/assets/mb.js?v=17';
const $=(s,r)=>(r||document).querySelector(s);
const dms=864e5;

/* ============================================================================
   THE MEXICO BRIEF — chart explorer. A personal research view: pick 1–3 numbers,
   compare them honestly (aligned to a common frequency), open the source.
   Rewritten 2026-07-12 to the implementation brief. Chart-first, order-independent
   alignment, three honest comparison modes, derived series, responsive renderer.
   ========================================================================== */

/* ---------- the variable registry (canonical explorer metadata) ----------
   cad  = canonical cadence (matches meta.cadence)
   agg  = how to aggregate to a COARSER bucket: avg | end | last | sum | step
   kind = fx | rate | pct | level | index | balance  (drives compat + rebase safety)
   r    = default render for a single view: area | line | step | bars
   core = true → primary catalog; false → "More series"
   def  = plain-English definition · watch = why Alan watches · e = related ids */
const G=['Peso & rates','Prices','Activity & external','Payments & cash'];
const M={
  'banxico-usdmxn-fix':   {g:0,l:'Peso',u:'MXN/USD',cad:'business-daily',agg:'avg',kind:'fx',r:'area',core:1,
    def:'Pesos per US dollar, the Banxico daily fix. A lower number means a stronger peso.',
    watch:'The price that reprices imports, dollar debt and the peso value of remittances.',
    e:['banxico-tasa-objetivo','d-rate-gap','banxico-remesas','fred-usd-broad']},
  'banxico-tasa-objetivo':{g:0,l:'Policy rate',u:'%',cad:'daily',agg:'end',kind:'rate',r:'step',core:1,
    def:"Banxico's overnight target rate, set at scheduled decisions.",
    watch:'The main lever on inflation and, through the gap to the US, on the peso.',
    e:['banxico-inflacion','fred-fedfunds','d-rate-gap']},
  'fred-fedfunds':        {g:0,l:'Fed funds rate',u:'%',cad:'monthly',agg:'avg',kind:'rate',r:'line',core:1,
    def:'The US effective federal funds rate, monthly average (not the target range).',
    watch:"The gap to Banxico's rate is part of what pays investors to hold pesos.",
    e:['banxico-tasa-objetivo','d-rate-gap']},
  'fred-ust10':           {g:0,l:'US 10-year yield',u:'%',cad:'daily',agg:'avg',kind:'rate',r:'area',core:0,
    def:'Yield on the 10-year US Treasury note.',
    watch:'A gauge of global risk appetite that moves the peso.',
    e:['banxico-usdmxn-fix']},
  'banxico-reservas':     {g:0,l:"Int'l reserves",u:'US$bn',cad:'weekly',agg:'end',kind:'level',r:'area',core:0,
    def:"Banxico's international reserves.",
    watch:'The buffer against a currency shock.',
    e:['banxico-usdmxn-fix']},
  'fred-usd-broad':       {g:0,l:'US dollar (broad)',u:'index',cad:'weekly',agg:'avg',kind:'index',r:'area',core:0,
    def:'Trade-weighted US dollar index (Jan 2006 = 100).',
    watch:'A stronger dollar tends to pressure the peso.',
    e:['banxico-usdmxn-fix']},

  'banxico-inflacion':    {g:1,l:'Inflation, headline',u:'%',cad:'monthly',agg:'last',kind:'rate',r:'line',core:1,
    def:'Annual change in consumer prices (INPC), year over year.',
    watch:'Sets how much room Banxico has to move the rate.',
    e:['banxico-tasa-objetivo','banxico-inflacion-subyacente']},
  'banxico-inflacion-subyacente':{g:1,l:'Inflation, core',u:'%',cad:'monthly',agg:'last',kind:'rate',r:'line',core:1,
    def:'Annual core inflation, excluding volatile food and energy.',
    watch:'The cleaner read on the underlying price trend.',
    e:['banxico-inflacion','banxico-tasa-objetivo']},
  'banxico-salario-minimo':{g:1,l:'Minimum wage',u:'MXN/day',cad:'monthly',agg:'step',kind:'level',r:'step',core:1,
    def:'The legal general daily minimum wage. More than tripled in nominal terms since 2018.',
    watch:'A policy-set floor on wages and a cost pressure for employers.',
    e:['d-real-minimo','banxico-inflacion']},
  'banxico-inpc':         {g:1,l:'Prices (INPC index)',u:'index',cad:'monthly',agg:'last',kind:'index',r:'line',core:0,
    def:'The consumer price index (INPC, 2nd half of July 2018 = 100). The level behind the inflation rate.',
    watch:'The yardstick for turning nominal pesos into real ones.',
    e:['banxico-inflacion','banxico-salario-minimo']},
  'cre-gasolina-regular': {g:1,l:'Gasoline, regular',u:'MXN/L',cad:'4-hourly',agg:'avg',kind:'level',r:'line',core:0,
    def:'National average regular-gasoline pump price.',
    watch:'A visible price that feeds headline inflation and sentiment.',
    e:['banxico-inflacion']},

  'banxico-pib-crecimiento':{g:2,l:'GDP growth',u:'% YoY',cad:'quarterly',agg:'last',kind:'pct',r:'bars',core:1,
    def:'Real GDP growth versus a year earlier.',
