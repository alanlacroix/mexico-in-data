function renderOverlay(body,a,b){
  const ma=M[a],mb=M[b],Pa=pts(a),Pb=pts(b);
  $('#cxTitle').textContent=`${ma.l} & ${mb.l}`;
  // shared window = intersection of spans
  const lo=Math.max(asDate(Pa[0].date),asDate(Pb[0].date)),hi=Math.min(asDate(Pa[Pa.length-1].date),asDate(Pb[Pb.length-1].date));
  const A=Pa.filter(p=>asDate(p.date)>=lo&&asDate(p.date)<=hi),B=Pb.filter(p=>asDate(p.date)>=lo&&asDate(p.date)<=hi);
  // normalize both to 100 at the window start so two units share an axis honestly
  const n=P=>{const base=P[0].value||1;return P.map(p=>({date:p.date,value:p.value/base*100}));};
  const An=n(A),Bn=n(B);
  const W=880,H=380,pl=20,pr=20,pt=14,pb=28,iw=W-pl-pr,ih=H-pt-pb;
  const all=An.concat(Bn),ys=all.map(p=>p.value);let ymin=Math.min(...ys),ymax=Math.max(...ys);const pad=((ymax-ymin)||1)*0.1;ymin-=pad;ymax+=pad;
  const xs=An.map(p=>asDate(p.date)),xmin=Math.min(...xs),xmax=Math.max(...xs);
  const X=x=>pl+(xmax===xmin?iw/2:(x-xmin)/(xmax-xmin)*iw),Y=v=>pt+ih-(v-ymin)/(ymax-ymin)*ih;
  const path=P=>{let d='';P.forEach((p,i)=>d+=(i?'L':'M')+X(asDate(p.date)).toFixed(1)+' '+Y(p.value).toFixed(1));return d;};
  let grid='';for(let i=0;i<=2;i++){const y=pt+ih*i/2;grid+=`<line class="grid" x1="${pl}" y1="${y}" x2="${W-pr}" y2="${y}"/>`;}
  let xl='';[0,Math.floor(An.length/2),An.length-1].forEach((i,k)=>{const x=X(asDate(An[i].date));xl+=`<text class="axl" x="${x.toFixed(1)}" y="${H-8}" text-anchor="${k===0?'start':k===2?'end':'middle'}">${fmtDate(An[i].date,cadence(a))}</text>`;});
  const svg=`<svg class="sx-svg" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none">${grid}<path class="ln" d="${path(An)}"/><path class="ln ln2" d="${path(Bn)}"/>${xl}</svg>`;
  $('#cxTitle').textContent=`${ma.l} & ${mb.l}`;
  body.innerHTML=`<button class="sx-back">← All variables</button>
    <div class="sx-head"><div class="sx-name">${ma.l} & ${mb.l}</div><div class="sx-sub">Indexed to 100 at the start of the shared period · ${fmtDate(A[0].date,cadence(a))} to ${fmtDate(A[A.length-1].date,cadence(a))}</div></div>
    <div class="sx-leg"><span><i style="background:var(--ink)"></i>${ma.l} (now ${ma.f(A[A.length-1].value)})</span><span><i style="background:var(--green-d)"></i>${mb.l} (now ${mb.f(B[B.length-1].value)})</span></div>
    <div class="sx-wrap">${svg}</div>
    <div class="sx-ctx">The channel: ${ma.tx}</div>
    <div class="sx-caveat">Both series indexed to 100 at the start of their shared period so two different units can share one axis. This shows how they moved together. It is co-movement, not proof that one caused the other.</div>
    <div class="sx-edges"><div class="el">Open one on its own</div><div class="chips"><button class="chip" data-m="${a}">${ma.l}</button><button class="chip" data-m="${b}">${mb.l}</button></div></div>`;
  $('.sx-back',body).addEventListener('click',()=>go({}));
  body.querySelectorAll('.chip[data-m]').forEach(c=>c.addEventListener('click',()=>go({m:c.dataset.m})));
}

