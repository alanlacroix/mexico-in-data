/* ---------- data store + loader (chart-local: no news/events/happening) ---------- */
const store={};
async function fetchOne(id){ if(store[id]||DERIVED[id])return; const resource='./data/series/'+id+'.json'; try{const r=await fetch(resource);if(!r.ok)throw new Error(String(r.status));const payload=await r.json();if(!Array.isArray(payload.data)||!payload.data.length||payload.data.some(p=>!p||!p.date||!Number.isFinite(Number(p.value))))throw new Error('invalid series payload');store[id]=payload;}catch(e){window.reportMexicoDataError?.(resource);} }
function series(data,title,units){ return {data,meta:{source:'The Mexico Brief (derived)',units,derived:true,title}}; }
async function ensure(ids){
  // expand derived to their raw inputs, fetch all raw, then build derived
  const need=new Set();
  ids.forEach(id=>{ if(DERIVED[id]) DERIVED[id].inputs.forEach(x=>need.add(x)); else need.add(id); });
  await Promise.all([...need].map(fetchOne));
  ids.forEach(id=>{ if(DERIVED[id]&&!store[id]){ try{store[id]=DERIVED[id].build();}catch(e){store[id]=null;} } });
}

/* ---------- primitives ---------- */
function raw(id){ const s=store[id]; return (s&&s.data)?s.data.filter(p=>p&&p.value!=null):[]; }
function meta(id){ const s=store[id]; return (s&&s.meta)||{}; }
function label(id){ return (M[id]&&M[id].l)||(DERIVED[id]&&DERIVED[id].l)||id; }
function reg(id){ return M[id]||DERIVED[id]||{}; }
function unit(id){ return reg(id).u||meta(id).units||''; }
function dataUnit(id){ return meta(id).units||unit(id); }
function kindOf(id){ return reg(id).kind||'level'; }
function aggRule(id){ return reg(id).agg||'last'; }
function cadOf(id){ if(DERIVED[id])return 'monthly'; return reg(id).cad||meta(id).cadence||'monthly'; }
function lastPt(id){ const p=raw(id); return p[p.length-1]; }
function asDate(s){ return +new Date(s.length<=7?s+'-01':s); }
const FREQ={'4-hourly':0,'business-daily':1,'daily':1,'weekly':2,'monthly':3,'quarterly':4,'annual':5};
function freqRank(c){ return FREQ[c]!=null?FREQ[c]:3; }

/* ---------- display formatting (canonical fmt + explorer precision overrides) ---------- */
const PREC={
  'banxico-reservas':v=>({v:'$'+(v/1000).toFixed(1),s:'bn USD'}),           // US$255.5bn, not $255bn
  'banxico-ecommerce-monto':v=>({v:'$'+enNum(Math.round(v/1e3)),s:'bn MXN/qtr'}), // MX$311bn/qtr, not $0.31tn
  'banxico-inflacion':v=>({v:v.toFixed(2),s:'%'}),                          // 3.37%, target needs 2 dp
  'banxico-inflacion-subyacente':v=>({v:v.toFixed(2),s:'%'}),              // 4.03%
  'fred-us-indpro':v=>({v:v.toFixed(1),s:'index'}),                        // 102.6
  'fred-usd-broad':v=>({v:v.toFixed(1),s:'index'}),                        // 120.7
};
function disp(id,v){ if(DERIVED[id])return DERIVED[id].fmt(v); if(PREC[id])return PREC[id](v); return fmt(id,v,meta(id).units||unit(id)); }
function dtext(id,v){
  const o=disp(id,v);
  if(!o.s)return o.v;
  return o.v+(o.s==='%'?'%':' '+o.s);
}

/* ---------- period bucketing + aggregation ---------- */
function bucketKey(dateStr,freq){ const d=new Date(dateStr.length<=7?dateStr+'-01':dateStr);
  const y=d.getUTCFullYear(),m=d.getUTCMonth();
  if(freq>=5)return ''+y;                                  // annual
  if(freq>=4)return y+'-Q'+(Math.floor(m/3)+1);            // quarterly
  return y+'-'+String(m+1).padStart(2,'0');               // monthly (daily/weekly bucket up to month)
}
// aggregate a series id to a target frequency label, using its agg rule → [{k,date,value}]
function agg(id,targetCad){
  const P=raw(id); const tf=freqRank(targetCad); const rule=aggRule(id);
  if(!P.length)return [];
  const groups=new Map();
  for(const p of P){ const k=bucketKey(p.date,tf); if(!groups.has(k))groups.set(k,[]); groups.get(k).push(p); }
  const out=[];
  for(const [k,arr] of groups){
    arr.sort((a,b)=>asDate(a.date)-asDate(b.date));
    let v;
    if(rule==='avg') v=arr.reduce((s,p)=>s+p.value,0)/arr.length;
    else if(rule==='sum') v=arr.reduce((s,p)=>s+p.value,0);
    else if(rule==='end'||rule==='step') v=arr[arr.length-1].value;
    else v=arr[arr.length-1].value; // 'last'
    out.push({k,date:arr[arr.length-1].date,value:v});
  }
  out.sort((a,b)=>asDate(a.date)-asDate(b.date));
  return out;
}
function map(aggd){ const m={}; aggd.forEach(p=>m[p.k]=p.value); return m; }
// year-over-year % on an aggregated (monthly) series
function yoy(aggd){ const m=map(aggd); return aggd.filter(p=>{const d=new Date(p.date);const py=d.getUTCFullYear()-1,pk=py+'-'+String(d.getUTCMonth()+1).padStart(2,'0');return m[pk]!=null&&m[pk]!==0;})
  .map(p=>{const d=new Date(p.date);const pk=(d.getUTCFullYear()-1)+'-'+String(d.getUTCMonth()+1).padStart(2,'0');return {date:p.date,value:(p.value-m[pk])/Math.abs(m[pk])*100};}); }

/* ---------- alignment: shared periods across ALL selected (order-independent) ---------- */
const RANKCAD=['4-hourly','daily','weekly','monthly','quarterly','annual'];   // index === freq rank
function alignAll(ids){
  // common frequency = coarsest of the selected, floored at monthly (the honest floor: we bucket
  // daily/weekly series to the month for comparison; single-variable views keep full granularity)
  const rank=Math.max(3, Math.max(...ids.map(id=>freqRank(cadOf(id)))));
  const targetCad=RANKCAD[rank];
  const per=ids.map(id=>({id,m:map(agg(id,targetCad))}));
  // shared keys = present in EVERY series (set intersection → independent of order)
  let keys=Object.keys(per[0].m);
  for(let i=1;i<per.length;i++){ const mi=per[i].m; keys=keys.filter(k=>mi[k]!=null); }
  keys.sort();  // period keys sort chronologically (YYYY-MM / YYYY-Qn / YYYY)
  const rep={}; // representative display date per key (use last series' date, any is fine)
  agg(ids[0],targetCad).forEach(p=>{ if(keys.includes(p.k))rep[p.k]=p.date; });
  return {freq:targetCad, keys, rep,
    series:ids.map(id=>{ const mi=map(agg(id,targetCad)); return {id,pts:keys.map(k=>({date:rep[k]||k,value:mi[k]}))}; }),
    n:keys.length};
}
function leafInputs(id,seen){
  seen=seen||new Set(); if(seen.has(id))return []; seen.add(id);
  if(!DERIVED[id])return [id];
  return DERIVED[id].inputs.flatMap(input=>leafInputs(input,seen));
}
function periodEndMs(key,freq){
  if(freq==='annual')return Date.UTC(+key,11,31,23,59,59,999);
  if(freq==='quarterly'){ const m=/^(\d{4})-Q([1-4])$/.exec(key); return m?Date.UTC(+m[1],+m[2]*3,0,23,59,59,999):NaN; }
  const m=/^(\d{4})-(\d{2})$/.exec(key); return m?Date.UTC(+m[1],+m[2],0,23,59,59,999):NaN;
}
function completeLeafBucket(id,key,targetCad){
  const targetRank=freqRank(targetCad),sourceRank=freqRank(cadOf(id));
  const points=raw(id).filter(p=>bucketKey(p.date,targetRank)===key);
  if(!points.length)return false;
  // A monthly/quarterly/annual observation is already a completed reference period.
  if(sourceRank>=targetRank)return true;
  // A daily or weekly series must reach the end of the bucket, and the bucket itself must be over.
  const end=periodEndMs(key,targetCad); if(!Number.isFinite(end)||Date.now()<=end)return false;
  const last=Math.max(...points.map(p=>asDate(p.date)));
  const tolerance=sourceRank<=1?4:10;
  return end-last<=tolerance*dms;
}
function completeAlignedIndexes(ids,aligned){
  const leaves=[...new Set(ids.flatMap(id=>leafInputs(id)))];
  return aligned.keys.map((key,i)=>({key,i})).filter(({key})=>leaves.every(id=>completeLeafBucket(id,key,aligned.freq))).map(x=>x.i);
}
function latestCompleteCommon(ids){
  const aligned=alignAll(ids),complete=completeAlignedIndexes(ids,aligned);
  if(!complete.length)return null;
  const index=complete[complete.length-1],key=aligned.keys[index],date=aligned.rep[key]||key;
  const points={}; ids.forEach((id,si)=>{ points[id]=aligned.series[si].pts[index]; });
  return {aligned,complete,index,key,date,asOf:fmtDate(date,aligned.freq),points};
}
function freqWord(c){ return {'4-hourly':'4-hourly','business-daily':'daily','daily':'daily','weekly':'weekly','monthly':'monthly','quarterly':'quarterly','annual':'annual'}[c]||c; }
function aggWord(id,targetCad){ if(!targetCad||freqRank(cadOf(id))>=freqRank(targetCad))return 'as published'; const r=aggRule(id);
  const per=freqRank(targetCad)>=4?'quarter':'month'; return r==='avg'?('averaged by '+per):r==='end'?(per+'-end'):r==='sum'?('summed by '+per):'as published'; }

/* ---------- range slicing (applies to single view + comparison keys) ---------- */
const RANGES=[['1Y',12],['3Y',36],['5Y',60],['MAX',1e4]];
const RANGE_NAMES=new Set(RANGES.map(x=>x[0]));
function validRange(r,fallback){ return RANGE_NAMES.has(r)?r:fallback; }
function monthsBefore(date,n){ const d=new Date(date.length<=7?date+'-01':date); return Date.UTC(d.getUTCFullYear(),d.getUTCMonth()-n,d.getUTCDate()); }
function sliceRange(pts,r){ if(r==='MAX'||!pts.length)return pts; const row=RANGES.find(x=>x[0]===r); if(!row)return pts; const cut=monthsBefore(pts[pts.length-1].date,row[1]);
  const s=pts.filter(p=>asDate(p.date)>=cut); return s.length>=2?s:pts.slice(-Math.min(pts.length,6)); }
function monthSpan(pts){ if(!pts.length)return 0; const a=new Date(pts[0].date),b=new Date(pts[pts.length-1].date); return (b.getUTCFullYear()-a.getUTCFullYear())*12+b.getUTCMonth()-a.getUTCMonth()+1; }
function availableRanges(ids){
  let points=[];
  if(ids.length===1)points=raw(ids[0]);
  else if(ids.length){ const aligned=alignAll(ids),complete=completeAlignedIndexes(ids,aligned); points=complete.map(i=>({date:aligned.rep[aligned.keys[i]]||aligned.keys[i]})); }
  const span=monthSpan(points);
  return new Set(RANGES.filter(([name,months])=>name==='MAX'||span>=months).map(x=>x[0]));
}

/* ---------- freshness (release-calendar aware) ----------
   Data are dated at the START of their period but published weeks-to-months later, so a generous lag
   avoids crying "stale" on a series that is simply the latest official reference (the brief's April-IGAE
   case). These are deliberately loose: they flag a genuinely dropped feed, not normal publication lag. */
const LAG={'4-hourly':1,'business-daily':6,'daily':6,'weekly':14,'monthly':125,'quarterly':250,'annual':430};
function isStale(id){ const last=lastPt(id); if(!last)return false; return (Date.now()-asDate(last.date))/dms > (LAG[cadOf(id)]||125); }
function freshNote(id){ const c=cadOf(id),last=lastPt(id); if(!last)return '';
  return `${freqWord(c)} · latest ${fmtDate(last.date,c)}${isStale(id)?' · awaiting update':''}`;
}
function fmtDate(d,cad){ const x=new Date(d.length<=7?d+'-01':d); const mo=x.toLocaleDateString('en-US',{month:'short',timeZone:'UTC'}),y=x.getUTCFullYear();
  return (cad==='daily'||cad==='business-daily'||cad==='weekly'||cad==='4-hourly')?`${mo} ${x.getUTCDate()}, ${y}`:cad==='quarterly'?`Q${Math.floor(x.getUTCMonth()/3)+1} ${y}`:cad==='annual'?`${y}`:`${mo} ${y}`; }

/* ---------- deterministic answers for the saved questions ----------
   These are calculations and fixed editorial definitions, not generated copy. */
function latestPoint(pts){ return pts&&pts.length?pts[pts.length-1]:null; }
function yearPriorPoint(pts,point){
  if(!point)return null;
  const d=new Date(point.date.length<=7?point.date+'-01':point.date);
  const key=(d.getUTCFullYear()-1)+'-'+String(d.getUTCMonth()+1).padStart(2,'0');
  return pts.find(p=>bucketKey(p.date,3)===key)||null;
}
function qaUnavailable(reason,ids){
  return {unavailable:true,answer:'I can’t answer this from the data that loaded.',explain:reason,
    caveat:'I leave the answer blank instead of filling the gap with an estimate.',
    method:'This needs every listed input and enough complete, overlapping observations.',sources:ids||[]};
}
function qaCheck(ids,min=1){
  const missing=ids.filter(id=>!store[id]||raw(id).length<min);
  return missing.length?qaUnavailable('There is not enough data for '+missing.map(label).join(', ')+'.',ids):null;
}
function ppYearPhrase(now,then){ const d=now-then; return Math.abs(d)<0.005?'unchanged from a year earlier':`${Math.abs(d).toFixed(2)} percentage points ${d<0?'lower':'higher'} than a year earlier`; }
function pctYearPhrase(now,then){ const d=then?((now-then)/Math.abs(then))*100:0; return Math.abs(d)<0.05?'unchanged from a year earlier':`${Math.abs(d).toFixed(1)}% ${d<0?'lower':'higher'} than a year earlier`; }

function answerPesoRates(){
  const ids=['banxico-usdmxn-fix','d-rate-gap']; const bad=qaCheck(ids,2); if(bad)return bad;
  const common=latestCompleteCommon(ids); if(!common)return qaUnavailable('The peso and rate-gap feeds do not yet share a complete month.',ids);
  const p=common.points[ids[0]],g=common.points[ids[1]];
  let py=yearPriorPoint(common.aligned.series[0].pts.slice(0,common.index+1),p),gy=yearPriorPoint(common.aligned.series[1].pts.slice(0,common.index+1),g);
  let comparison='than a year earlier';
  if(!py||!gy){
    const first=common.complete.find(i=>i<common.index);
    if(first!=null){
      py=common.aligned.series[0].pts[first]; gy=common.aligned.series[1].pts[first];
      comparison=`since ${fmtDate(py.date,'monthly')}`;
    }
  }
  let answer=`In ${common.asOf}, the peso averaged ${dtext(ids[0],p.value)}`;
  let pesoStrength=null,gapMove=null;
  if(py){ pesoStrength=(py.value-p.value)/Math.abs(py.value)*100; answer+=`, ${Math.abs(pesoStrength).toFixed(1)}% ${pesoStrength>=0?'stronger':'weaker'} ${comparison}`; }
  answer+=`. The Banxico–Fed gap was ${dtext(ids[1],g.value)}`;
  if(gy){ gapMove=g.value-gy.value; answer+=`, ${Math.abs(gapMove).toFixed(2)} points ${gapMove<0?'narrower':'wider'} ${comparison}`; }
  answer+='.';
  let explain='This puts the monthly exchange-rate average next to the monthly interest-rate difference. A lower MXN/USD reading means a stronger peso.';
  if(pesoStrength!=null&&gapMove!=null){
    if(Math.abs(gapMove)<0.05) explain='The rate gap barely changed over the comparison year, so it does not give a useful directional test for the peso move.';
    else explain=`Those moves over the available period ${pesoStrength*gapMove>0?'fit':'do not fit'} the simple idea that a wider rate gap supports the peso.`;
  }
  return {answer,explain,
    caveat:'This does not measure how much the rate gap caused the peso to move. The broad dollar, risk, trade flows and politics also matter.',
    method:'Peso: monthly average of Banxico FIX observations. Rate gap: Banxico month-end target minus the monthly effective fed funds rate.',
    sources:['banxico-usdmxn-fix','banxico-tasa-objetivo','fred-fedfunds'],asOf:common.asOf};
}

function answerInflation(){
  const ids=['banxico-inflacion','banxico-inflacion-subyacente','banxico-tasa-objetivo']; const bad=qaCheck(ids,2); if(bad)return bad;
  const common=latestCompleteCommon(ids); if(!common)return qaUnavailable('Headline inflation, core inflation and the policy rate do not yet share a complete month.',ids);
  const hp=common.points[ids[0]],cp=common.points[ids[1]],rp=common.points[ids[2]];
  // Use each inflation series' own history for the year comparison. Requiring
  // the policy-rate feed to reach back just as far used to hide a valid answer.
  const hy=yearPriorPoint(agg(ids[0],'monthly'),hp),cy=yearPriorPoint(agg(ids[1],'monthly'),cp);
  let answer=`In ${common.asOf}, headline inflation was ${dtext(ids[0],hp.value)}`;
  if(hy)answer+=`, ${ppYearPhrase(hp.value,hy.value)}`;
  answer+=`. Core was ${dtext(ids[1],cp.value)}`;
  if(cy)answer+=`, ${ppYearPhrase(cp.value,cy.value)}`;
  answer+=`. The policy rate was ${dtext(ids[2],rp.value)}.`;
  let explain='Headline includes the prices households see; core removes the most volatile components and usually moves more slowly.';
  if(hy&&cy){ const hd=hp.value-hy.value,cd=cp.value-cy.value;
    if(hd<0&&cd<0)explain='Yes, on both annual measures. Headline fell more; core remains the slower-moving check on the underlying trend.';
    else if(hd>0&&cd>0)explain='No, not against a year ago. Both annual measures are higher; core shows that the rise extends beyond volatile prices.';
    else explain='Not cleanly. Headline and core moved in different directions over the year, so the latest headline alone is not a complete read.';
  }
  return {answer,explain,
    caveat:'A year-over-year rate can move because of base effects. This comparison does not identify which prices changed or what caused the move.',
    method:'Published annual INPC changes for headline and core inflation, alongside Banxico’s target rate in the same complete month.',sources:ids,asOf:common.asOf};
}

function answerUsDemand(){
  const ids=['d-exports-yoy','d-indpro-yoy']; const bad=qaCheck(ids,7); if(bad)return bad;
  const common=latestCompleteCommon(ids); if(!common)return qaUnavailable('The export and US production feeds do not yet share a complete month.',ids);
  const usable=common.complete.filter(i=>i<=common.index),a=usable.map(i=>common.aligned.series[0].pts[i]),b=usable.map(i=>common.aligned.series[1].pts[i]);
  if(a.length<7)return qaUnavailable(`Only ${a.length} complete matched months are available; at least 7 are needed for this check.`,ids);
  const steps=[]; for(let i=Math.max(1,a.length-12);i<a.length;i++){ const x=a[i].value-a[i-1].value,y=b[i].value-b[i-1].value; steps.push(Math.sign(x)===Math.sign(y)); }
  if(steps.length<6)return qaUnavailable(`Only ${steps.length} comparable monthly moves are available.`,ids);
  const same=steps.filter(Boolean).length,la=common.points[ids[0]],lb=common.points[ids[1]];
  const answer=`In ${common.asOf}, Mexican export growth was ${dtext(ids[0],la.value)} and US industrial-output growth was ${dtext(ids[1],lb.value)}. Their annual growth rates moved in the same direction from one month to the next in ${same} of the latest ${steps.length} matched steps.`;
  return {answer,
    explain:'I count whether the two annual growth rates rose or fell together each month. I am not comparing the size of the two economies.',
    caveat:'Exports are nominal US-dollar values; US industrial output is a real production index. Prices, inventories, autos and demand outside the US can move the series differently.',
    method:'Convert each monthly source series to year-over-year growth, align shared months, then compare the sign of consecutive monthly changes over the latest 12 steps.',
    sources:['banxico-exports-total','fred-us-indpro'],asOf:common.asOf};
}

function answerRemittances(){
  const ids=['banxico-remesas','d-remesas-mxn']; const bad=qaCheck(ids,1); if(bad)return bad;
  const common=latestCompleteCommon(ids); if(!common)return qaUnavailable('The remittance and exchange-rate feeds do not yet share a complete month.',ids);
  const r=common.points[ids[0]],mxn=common.points[ids[1]];
  const usdText='$'+(r.value/1000).toFixed(2)+'bn USD';
  let answer=`In ${common.asOf}, remittances were ${usdText}. At that month’s average exchange rate, that was about ${dtext(ids[1],mxn.value)}.`;
  const ry=yearPriorPoint(common.aligned.series[0].pts.slice(0,common.index+1),r),my=yearPriorPoint(common.aligned.series[1].pts.slice(0,common.index+1),mxn);
  if(ry&&my)answer+=` The dollar amount was ${pctYearPhrase(r.value,ry.value)}; the converted peso amount was ${pctYearPhrase(mxn.value,my.value)}.`;
  return {answer,
    explain:'The peso total is simply the dollar total converted at that month’s average exchange rate. Any difference between the two growth rates comes from the exchange rate.',
    caveat:'The peso amount is not adjusted for Mexican inflation and is not a measure of household purchasing power or income per recipient.',
    method:'Official monthly remittances in US dollars multiplied by the monthly average Banxico FIX exchange rate.',
    sources:['banxico-remesas','banxico-usdmxn-fix'],asOf:common.asOf};
}

function answerWages(){
  const ids=['banxico-salario-minimo','d-real-minimo']; const bad=qaCheck(ids,2); if(bad)return bad;
  const common=latestCompleteCommon(ids); if(!common||common.complete.length<2)return qaUnavailable('The nominal wage and price-adjusted wage do not have two complete shared months.',ids);
  const first=common.complete[0],c0=common.aligned.series[0].pts[first],r0=common.aligned.series[1].pts[first],c1=common.points[ids[0]],r1=common.points[ids[1]];
  if(!c0.value||!r0.value)return qaUnavailable('The starting observation cannot be used as an index base.',ids);
  const cashPct=(c1.value/c0.value-1)*100,realPct=(r1.value/r0.value-1)*100;
  const answer=`In ${common.asOf}, the general minimum wage was ${dtext(ids[0],c1.value)}. Since ${fmtDate(c0.date,'monthly')}, it ${cashPct>=0?'rose':'fell'} ${Math.abs(cashPct).toFixed(1)}% in cash terms and ${realPct>=0?'rose':'fell'} ${Math.abs(realPct).toFixed(1)}% after inflation.`;
  return {answer,
    explain:'The real series divides the statutory wage by the official consumer-price index. Comparing the two shows how inflation changed the buying power of the statutory increase.',
    caveat:'This is the statutory general minimum wage, not typical worker pay. It does not show employment effects, informality or regional differences.',
    method:'Align the published general minimum wage with the INPC, express the wage in constant July-2018 pesos, and compare the first and latest shared months.',
    sources:['banxico-salario-minimo','banxico-inpc'],asOf:common.asOf};
}

function qaSourceLinks(ids){
  const rawIds=[]; (ids||[]).forEach(id=>{ if(DERIVED[id])DERIVED[id].inputs.forEach(x=>rawIds.push(x)); else rawIds.push(id); });
  const unique=[...new Set(rawIds)];
  if(!unique.length)return '<a href="/sources.html">All sources →</a>';
  return unique.map(id=>{ const m=meta(id),href=m.sourceUrl?humanSrc(m.sourceUrl):'/sources.html'; return `<a href="${esc(href)}"${href.startsWith('http')?' target="_blank" rel="noopener"':''}>${esc(label(id))} ${href.startsWith('http')?'↗':'→'}</a>`; }).join(' · ');
}
function questionAnswerHTML(){
  const view=state.view&&VIEWS[state.view]; if(!view||typeof view.answer!=='function')return '';
  let result; try{ result=view.answer(); }catch(e){ result=qaUnavailable('The calculation could not be completed from the loaded observations.',view.v); }
  const stamp=result.unavailable?'Can’t answer this yet':`From the data${result.asOf?' · complete through '+result.asOf:''}`;
  return `<section class="cx-qa${result.unavailable?' unavailable':''}" aria-label="Answer from the data" aria-live="polite">
    <div><div class="cx-qa-k">${esc(stamp)}</div><p class="cx-qa-answer">${esc(result.answer)}</p></div>
    <div class="cx-qa-side"><p>${esc(result.explain)}</p><p><b>Keep in mind:</b> ${esc(result.caveat)}</p></div>
    <details class="cx-qa-method"><summary>How I calculated it</summary><div>${esc(result.method)}<br>${qaSourceLinks(result.sources)}</div></details>
  </section>`;
}

/* ---------- colors for up to 3 lines ---------- */
const COLORS=['#141414','#0a7d4d','#a8541b'];
const AF=['#141414','#0a7d4d','#a8541b'];

/* ---------- responsive chart renderer (real-px viewBox, redraws on resize) ----------
   series: [{id,label,color,pts:[{date,value}],render}]  — already sliced/aligned.
   opts: {mode:'actual'|'relative'|'separate-single', height, rebaseBase, unitLabel, single} */
function drawChart(container,ser,opts){
  opts=opts||{};
  const cw=Math.max(280,Math.round(container.clientWidth||680));
  const mobile=cw<560;
  const H=opts.height||(mobile?250:Math.max(280,Math.min(330,Math.round(cw*0.38))));
  const W=cw;
  const fs=mobile?12:12.5;
  const pr=(opts.single||mobile)?14:Math.min(210,Math.max(70, longestEndLabel(ser)*6.4+16)), pt=12, pb=mobile?24:28;
  // transform values if relative
  let plot=ser.map(s=>{ let pts=s.pts.map(p=>({date:p.date,value:p.value}));
    if(opts.mode==='relative'){ const base=pts.find(p=>p.value!=null&&p.value!==0); const b=base?base.value:1; pts=pts.map(p=>({date:p.date,value:p.value/b*100,raw:p.value})); }
    return {...s,pts}; });
  const allV=plot.flatMap(s=>s.pts.map(p=>p.value)).filter(v=>v!=null);
  const allT=plot.flatMap(s=>s.pts.map(p=>asDate(p.date)));
  const xmin=Math.min(...allT),xmax=Math.max(...allT);
  let ymin=Math.min(...allV),ymax=Math.max(...allV);
  const anyBars=ser.some(s=>s.render==='bars');
  if(anyBars){ymin=Math.min(0,ymin);ymax=Math.max(0,ymax);}
  const pad=((ymax-ymin)||1)*0.10; ymin-=pad; ymax+=pad;
  const yfmtV=v=>{ if(opts.mode==='relative')return v.toFixed(0); const id=ser[0].id; const o=disp(id,v); return o.v; };
  // left padding fits the widest y-axis label (a 5-char value like "19.09" clips at a fixed pl)
  const ylabs=[0,1,2,3].map(i=>String(yfmtV(ymin+(ymax-ymin)*i/3)));
  const pl=Math.max(mobile?34:44, Math.round(Math.max(...ylabs.map(s=>s.length))*(mobile?6.9:7.2)+9));
  const iw=W-pl-pr, ih=H-pt-pb;
  const X=t=>pl+(xmax===xmin?iw/2:(t-xmin)/(xmax-xmin)*iw), Y=v=>pt+ih-(v-ymin)/((ymax-ymin)||1)*ih;
  // grid + y labels
  let g='';
  for(let i=0;i<=3;i++){ const v=ymin+(ymax-ymin)*i/3,y=Y(v);
    g+=`<line class="grid" x1="${pl}" y1="${y.toFixed(1)}" x2="${(W-pr).toFixed(1)}" y2="${y.toFixed(1)}"/><text class="axl" x="${pl-7}" y="${(y+3).toFixed(1)}" text-anchor="end" font-size="${fs}">${yfmtV(v)}</text>`; }
  if((ymin<0&&ymax>0)){ const yz=Y(0); g+=`<line class="zero" x1="${pl}" y1="${yz.toFixed(1)}" x2="${(W-pr).toFixed(1)}" y2="${yz.toFixed(1)}"/>`; }
  // x labels (<=3): first, mid, last
  const ref=plot[0].pts, xi=mobile?[0,ref.length-1]:[0,Math.floor(ref.length/2),ref.length-1];
  xi.forEach((i,k)=>{ if(i<0||i>=ref.length)return; const x=X(asDate(ref[i].date)); const anch=k===0?'start':(k===xi.length-1?'end':'middle');
    g+=`<text class="axl" x="${x.toFixed(1)}" y="${H-8}" text-anchor="${anch}" font-size="${fs}">${fmtDate(ref[i].date, opts.axisCad||cadOf(ser[0].id))}</text>`; });
  // lines / bars
  plot.forEach((s,si)=>{ const col=s.color||COLORS[si%3]; const XY=s.pts.filter(p=>p.value!=null).map(p=>[X(asDate(p.date)),Y(p.value)]);
    if(s.render==='bars'){ const y0=Y(0),bw=Math.min(20,iw/s.pts.length*0.7);
      g+=XY.map(([x,y])=>`<rect x="${(x-bw/2).toFixed(1)}" y="${Math.min(y,y0).toFixed(1)}" width="${bw.toFixed(1)}" height="${Math.abs(y-y0).toFixed(1)}" fill="${col}" opacity="0.85"/>`).join('');
    } else {
      let d='';
      if(s.render==='step'){ XY.forEach(([x,y],i)=>{ d+=i?`L${x.toFixed(1)} ${XY[i-1][1].toFixed(1)} L${x.toFixed(1)} ${y.toFixed(1)}`:`M${x.toFixed(1)} ${y.toFixed(1)}`; }); }
      else { XY.forEach(([x,y],i)=>d+=(i?'L':'M')+x.toFixed(1)+' '+y.toFixed(1)); }
      if(s.render==='area'&&opts.single){ g+=`<path class="af" fill="${col}" d="${d} L${XY[XY.length-1][0].toFixed(1)} ${(pt+ih).toFixed(1)} L${XY[0][0].toFixed(1)} ${(pt+ih).toFixed(1)} Z"/>`; }
      g+=`<path fill="none" stroke="${col}" stroke-width="1.7" vector-effect="non-scaling-stroke" d="${d}"/>`;
      if(XY.length<=30) g+=XY.map(([x,y])=>`<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="2" fill="${col}"/>`).join('');
      // end label for multi-series (direct label, not color-only) — sits in the right gutter (start-anchor).
      // Dropped on mobile, where the value strip below the chart is the legend.
      if(!opts.single&&!mobile&&XY.length){ const [lx,ly]=XY[XY.length-1];
        g+=`<text class="endlab" x="${(lx+6).toFixed(1)}" y="${(ly+4).toFixed(1)}" font-size="${fs}" fill="${col}">${esc(s.label)}</text>`; }
    }});
  // crosshair group
  g+=`<g class="cg" style="display:none"><line class="cross" y1="${pt}" y2="${(pt+ih).toFixed(1)}"/>`+plot.map((s,si)=>`<circle class="cdot" data-i="${si}" r="3.6" fill="${s.color||COLORS[si%3]}" stroke="#fff" stroke-width="1.4"/>`).join('')+`</g>`;
  const title=opts.title||(ser.length===1?label(ser[0].id):ser.map(s=>label(s.id)).join(' vs '));
  const svg=`<svg class="cxsvg" viewBox="0 0 ${W} ${H}" style="height:${H}px" preserveAspectRatio="none" role="img" aria-label="${esc(title)}"><title>${esc(title)}</title><desc>${esc(opts.desc||('Line chart of '+title))}</desc>${g}</svg>`;
  container.__geo={pl,pr,pt,pb,iw,ih,W,H,X,Y,xmin,xmax,plot,ser,opts};
  const old=container.querySelector('.cxsvg'); if(old)old.remove();
  container.insertAdjacentHTML('beforeend',svg);
  wireCross(container);
}
function longestEndLabel(ser){ return ser.length<=1?0:Math.max(...ser.map(s=>s.label.length)); }
function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

/* crosshair → updates the selected-value strip (shared cursor across separate charts too) */
let STRIP_CB=null;
function wireCross(container){
  const svg=container.querySelector('.cxsvg'), cg=container.querySelector('.cg'); if(!svg||!cg)return;
  const line=cg.querySelector('.cross'), dots=[...cg.querySelectorAll('.cdot')];
  const geo=container.__geo;
  const at=(clientX)=>{ const r=svg.getBoundingClientRect(); const px=(clientX-r.left)/r.width*geo.W;
    const ref=geo.plot[0].pts; let bi=0,bd=1e9; ref.forEach((p,i)=>{const dd=Math.abs(geo.X(asDate(p.date))-px);if(dd<bd){bd=dd;bi=i;}});
    const xx=geo.X(asDate(ref[bi].date)); line.setAttribute('x1',xx);line.setAttribute('x2',xx);
    dots.forEach(dot=>{ const si=+dot.dataset.i; const p=geo.plot[si].pts[bi]; if(p&&p.value!=null){dot.setAttribute('cx',xx);dot.setAttribute('cy',geo.Y(p.value));dot.style.display='';}else dot.style.display='none'; });
    cg.style.display='';
    if(STRIP_CB) STRIP_CB(bi);
  };
  const end=()=>{ cg.style.display='none'; if(STRIP_CB)STRIP_CB(-1); };
  svg.addEventListener('pointermove',e=>at(e.clientX));
  svg.addEventListener('pointerdown',e=>at(e.clientX));
  svg.addEventListener('pointerleave',end);
}

/* ============================ STATE ============================ */
let state={v:[DEFAULT_VIEW && VIEWS[DEFAULT_VIEW].v].flat(), r:VIEWS[DEFAULT_VIEW].r, mode:null, view:DEFAULT_VIEW};
const LS='mb-chart-v1';
const MODE_NAMES=new Set(['actual','relative','separate']);
function validMode(mode){ return MODE_NAMES.has(mode)?mode:null; }
function readState(){
  const q=new URLSearchParams(location.search);
  if(q.get('q')&&VIEWS[q.get('q')]){ applyView(q.get('q')); state.r=validRange(q.get('r'),VIEWS[state.view].r); state.mode=validMode(q.get('mode')); return; }
  if(q.get('m')||q.get('v')){ const v=(q.get('m')||q.get('v')).split(',').filter(id=>M[id]||DERIVED[id]).slice(0,3);
    if(v.length){ state.v=v; state.view=viewMatch(v); state.r=validRange(q.get('r'),'3Y'); state.mode=validMode(q.get('mode')); return; } }
  try{ const s=JSON.parse(localStorage.getItem(LS)||'null'); if(s&&s.v&&s.v.length){ state.v=s.v.filter(id=>M[id]||DERIVED[id]).slice(0,3); state.r=validRange(s.r,'3Y'); state.mode=validMode(s.mode); state.view=viewMatch(state.v); return; } }catch(e){}
  applyView(DEFAULT_VIEW);
}
function viewMatch(v){ for(const k in VIEWS){ if(VIEWS[k].v.length===v.length&&VIEWS[k].v.every((x,i)=>x===v[i]))return k; } return null; }
function applyView(k){ state.view=k; state.v=VIEWS[k].v.slice(); state.r=VIEWS[k].r; state.mode=null; }
function persist(){ try{localStorage.setItem(LS,JSON.stringify({v:state.v,r:state.r,mode:state.mode}));}catch(e){} }
function pushURL(){ const u=new URL(location); u.search=state.view?('?q='+state.view+'&r='+state.r+(state.mode?'&mode='+state.mode:'')):(state.v.length?('?v='+state.v.join(',')+'&r='+state.r+(state.mode?'&mode='+state.mode:'')):''); history.replaceState(null,'',u); }

/* ============================ COMPARISON MODE LOGIC ============================ */
function compatClass(id){
  const k=kindOf(id);
  if(k==='rate'||k==='pct')return 'ratelike';
  if(k==='balance')return 'balance';
  // Actual overlays compare the stored numeric values. Use the source/derived
  // data unit, not the friendlier display unit: Banxico trade is stored in
  // thousand US$, while remittances are stored in million US$. Treating both
  // as "US dollars per month" puts values 1,000x apart on one misleading axis.
  return dataUnit(id)||unit(id);
}
function rebaseSafe(id){ const k=kindOf(id); if(!(k==='fx'||k==='level'||k==='index'))return false; const p=raw(id); if(!p.length)return false;
  return p.every(x=>x.value>0); }
function autoMode(ids){ if(ids.length<2)return 'single';
  const classes=new Set(ids.map(compatClass));
  if(classes.size===1)return 'actual';
  if(ids.every(rebaseSafe))return 'relative';
  return 'separate';
}
function modeAvail(ids){ // which modes are selectable
  const cls=new Set(ids.map(compatClass));
  return { actual: cls.size===1, relative: ids.every(rebaseSafe), separate: true };
}

/* ============================ RENDER ============================ */
let RESIZE_BOUND=false;
function render(){
  const body=$('#cxBody');
  const ids=state.v.filter(id=>store[id]&&raw(id).length);
  const rangeAvail=availableRanges(ids); if(!rangeAvail.has(state.r))state.r='MAX';
  if(ids.length<2)state.mode=null; else if(state.mode&&!modeAvail(ids)[state.mode])state.mode=null;
  if(!ids.length){ body.innerHTML=controlsHTML([],rangeAvail)+questionAnswerHTML()+'<div class="cx-err">The selected series could not be loaded. Use another question or add a variable.</div>'+allSeriesHTML(); bindControls(); bindAll(); pushURL(); persist(); return; }
  $('#cxTitle').textContent = ids.length===1 ? label(ids[0]) : 'Mexico in charts';
  let html=controlsHTML(ids,rangeAvail)+questionAnswerHTML();
  if(ids.length===1) html+=singleHTML(ids[0]);
  else html+=compareHTML(ids);
  html+=allSeriesHTML();
  body.innerHTML=html;
  bindControls();
  if(ids.length===1) drawSingle(ids[0]); else drawCompare(ids);
  bindAll();
  if(!RESIZE_BOUND){ RESIZE_BOUND=true; let t; window.addEventListener('resize',()=>{clearTimeout(t);t=setTimeout(()=>{ const cur=state.v.filter(id=>store[id]&&raw(id).length); if(cur.length===1)drawSingle(cur[0]); else if(cur.length)drawCompare(cur); },160);}); }
  pushURL(); persist();
}

/* ---- controls (views, chips, ranges, modes) ---- */
function controlsHTML(ids,rangeAvail){
  rangeAvail=rangeAvail||availableRanges(ids);
  const views=Object.keys(VIEWS).map(k=>`<button data-view="${k}" aria-pressed="${state.view===k}"${state.view===k?' class="on"':''} title="${esc(VIEWS[k].label)}">${esc(VIEWS[k].q)}</button>`).join('');
  const chips=ids.map((id,i)=>{const d=DERIVED[id];return `<span class="cx-chip${d?' derived':''}"><i class="sw" style="background:${COLORS[i%3]}"></i>${label(id)}${d?' <span class="cx-db">derived</span>':''}<button class="x" data-rm="${id}" aria-label="Remove ${label(id)}">×</button></span>`;}).join('');
  const add=`<button class="cx-add" id="cxAdd"${ids.length>=3?' disabled title="Up to three"':''}>+ Add variable</button>`;
  const ranges=`<div class="cx-seg" role="group" aria-label="Time range">${RANGES.map(([r])=>{const ok=rangeAvail.has(r);return `<button data-r="${r}" aria-pressed="${state.r===r}"${state.r===r?' class="on"':''}${ok?'':' disabled title="The selected data do not cover this range"'}>${r}</button>`;}).join('')}</div>`;
  let modes='',modeNote='';
  if(ids.length>=2){ const av=modeAvail(ids), cur=state.mode||autoMode(ids);
    const b=(m,lab)=>`<button data-mode="${m}" aria-pressed="${cur===m}"${cur===m?' class="on"':''}${av[m]?'':' disabled title="Not safe for these series"'}>${lab}</button>`;
    modes=`<div class="cx-seg" role="group" aria-label="Comparison mode"><span class="cx-modelab">Compare</span>${b('actual','Actual')}${b('relative','Relative')}${b('separate','Separate scales')}</div>`;
    if(!av.actual)modeNote='<p class="cx-mode-note">These numbers use different units. Relative compares their movement from a common starting point. Separate scales keeps the dates aligned and gives each number its own axis.</p>'; }
  return `<div class="cx-views" role="group" aria-label="Questions">${views}</div>
    <div class="cx-chips">${chips}${add}</div>
    <div class="cx-ctrls">${ranges}${modes}</div>${modeNote}`;
}
function renderControls(){ /* used on error path */ }

/* ---- single-variable view ---- */
function singleHTML(id){
  const m=reg(id), last=lastPt(id);
  const fv=disp(id,last.value);
  const chg=changeText(id,state.r);
  const rel=(m.e||[]).filter(x=>(M[x]||DERIVED[x])).map(x=>`<button class="chip" data-add="${x}"><span class="ar">＋</span>${label(x)}</button>`).join('');
  return `<div class="cx-chart"><div class="cw" id="cw0"></div></div>
    <div class="cx-big"><span class="bv">${fv.v} <small>${fv.s}</small></span><span class="bc" id="bigChg">${chg}</span></div>
    <div class="cx-def">${m.def||''}</div>
    <div class="cx-disc">${freshNote(id)} · ${raw(id).length} observations</div>
    <details class="cx-ctx"><summary>Why I watch this</summary><div class="cxc-body"><p>${m.watch||''}</p></div></details>
    <div class="cx-actions">${actionsHTML(id)}</div>
    <div class="cx-tbl" id="cxTable" hidden></div>
    <div class="cx-srcs">${srcBlock(id)}</div>
    <div class="cx-rel"><div class="rl">Add to the comparison</div><div class="chips">${rel||'<span style="color:var(--mut);font-family:var(--mono);font-size:12px">—</span>'}</div></div>`;
}
function changeText(id,r){ const p=sliceRange(raw(id),r); if(p.length<2)return ''; const a=p[0].value,b=p[p.length-1].value; const k=kindOf(id);
  if(k==='rate'||k==='pct'){ const d=b-a; return `${d>=0?'+':'−'}${Math.abs(d).toFixed(2)} pp <span class="rl">· ${r}</span>`; }
  if(k==='balance'){ const d=b-a; const o=disp(id,Math.abs(d)); return `${d>=0?'+':'−'}${o.v.replace(/^[+−-]?\$?/,'$')}${o.s?' '+o.s:''} <span class="rl">· change over ${r}</span>`; }
  const pc=a?((b-a)/Math.abs(a)*100):0; return `${pc>=0?'+':''}${pc.toFixed(1)}% <span class="rl">· ${r}</span>`; }

/* ---- comparison view ---- */
function compareHTML(ids){
  const mode=state.mode||autoMode(ids);
  const AL=alignAll(ids);
  const charts = mode==='separate'
    ? ids.map((id,i)=>`<div class="cw" data-cw="${i}"><div class="cw-t">${label(id)}</div></div>`).join('')
    : `<div class="cw" id="cw0"></div>`;
  const strip=`<div class="cx-strip" id="cxStrip"></div>`;
  const disc=discLine(ids,AL,mode);
  const ctx=pairContextHTML(ids);
  return `<div class="cx-chart">${charts}</div>${strip}<div class="cx-disc${AL.n<12?' warn':''}" id="cxDisc">${disc}</div>${ctx}
    <div class="cx-actions">${actionsHTML(null,ids)}</div>
    <div class="cx-tbl" id="cxTable" hidden></div>
    <div class="cx-srcs">${ids.map(srcBlock).join('')}</div>`;
}
function discLine(ids,AL,mode){
  const parts=ids.map(id=>`${label(id)} ${aggWord(id,AL.freq)}`);
  const base= mode==='relative' ? `Rebased to 100 at ${AL.keys.length?fmtDate(AL.rep[AL.keys[0]],AL.freq):''}. Compares movement, not size. ` : '';
  const short= AL.n<12 ? ` Only ${AL.n} matched periods, too few to read as a relationship.` : '';
  return `${base}${freqWord(AL.freq)} · ${parts.join(' · ')} · ${AL.n} matched period${AL.n===1?'':'s'}.${short}`;
}
function pairContextHTML(ids){
  if(ids.length!==2){ return `<details class="cx-ctx"><summary>Why put these together?</summary><div class="cxc-body"><p>The dates line up, so this is useful for spotting timing. It cannot tell me that one of these numbers caused another.</p></div></details>`; }
  const pc=PAIRS[pairKey(ids[0],ids[1])];
  if(!pc){ return `<details class="cx-ctx"><summary>Why put these together?</summary><div class="cxc-body"><p>I haven’t defined a direct relationship between these two. The shared dates can still show timing, but not why they moved.</p></div></details>`; }
  return `<details class="cx-ctx" open><summary>Why put these together?</summary><div class="cxc-body">
    <p>${pc.mech}</p>
    <p>${pc.dir} ${pc.lag}</p>
    <div class="cxc-cav"><b>Keep in mind:</b> ${pc.conf} ${pc.cannot}</div></div></details>`;
}

/* ---- actions (view data / CSV / source) ---- */
function actionsHTML(id,ids){ return `<button data-act="table" aria-pressed="false">View data</button><button data-act="csv">Download CSV</button>`; }
function srcBlock(id){ const m=meta(id); if(m.derived){ const d=DERIVED[id]; return `<details class="srcd"><summary>Source &amp; method — ${label(id)}</summary><div class="src-body"><div><b>Derived series.</b></div><div>Formula: ${d.formula}</div><div>Inputs: ${d.inputs.map(label).join(', ')}</div><div>Built from the sources below at page load.</div>${d.inputs.map(x=>`<div style="margin-top:4px">${srcInner(x)}</div>`).join('')}</div></details>`; }
  return `<details class="srcd"><summary>Source &amp; date — ${label(id)}</summary><div class="src-body">${srcInner(id)}</div></details>`; }
function srcInner(id){ const m=meta(id); const sid=seriesId(m.sourceUrl), ret=m.fetchedAt?new Date(m.fetchedAt).toLocaleDateString('en-US',{day:'numeric',month:'short',year:'numeric'}):'';
  const isBanxico=/banxico|SieAPIRest/i.test(m.source+' '+(m.sourceUrl||''));
  const linkLabel=isBanxico?`Open Banxico SIE${sid?' (series '+sid+')':''} ↗`:'Open the source ↗';
  return `<div><b>${m.source||''}</b>${sid?' · series '+sid:''}</div>`+
    (m.vintage?`<div>Observation date: ${m.vintage}</div>`:'')+
    (ret?`<div>Retrieved: ${ret}</div>`:'')+
    (m.license?`<div>License: ${m.license}</div>`:'')+
    (m.sourceUrl?`<div><a href="${humanSrc(m.sourceUrl)}" target="_blank" rel="noopener">${linkLabel}</a></div>`:''); }

/* ---- all-series catalog ---- */
function catCard(id){ const s=store[id]; const last=s?lastPt(id):null; const fv=last?disp(id,last.value):{v:'—',s:''};
  return `<button class="cc" data-open="${id}"><div class="cl">${M[id].l}</div><div class="cv">${fv.v} <small>${fv.s}</small></div><div class="cm">${s?freqWord(cadOf(id)):'load on open'}</div></button>`; }
function catalogInner(){ let h='';
  G.forEach((gname,gi)=>{ const all=Object.keys(M).filter(id=>M[id].g===gi); if(!all.length)return;
    const core=all.filter(id=>M[id].core), more=all.filter(id=>!M[id].core);
    h+=`<div class="cat-grp"><div class="cat-gl">${gname}</div>`;
    if(core.length) h+=`<div class="cat-grid">${core.map(catCard).join('')}</div>`;
    if(more.length) h+=`<div class="cat-more">More series</div><div class="cat-grid">${more.map(catCard).join('')}</div>`;
    h+='</div>'; });
  return h;
}
function allSeriesHTML(){ return `<details class="cx-all" id="cxAll"><summary>All series</summary><div id="cxAllInner">${catalogInner()}</div></details>`; }

/* ============================ DRAW ============================ */
function drawSingle(id){ const cw=$('#cw0'); if(!cw)return; const pts=sliceRange(raw(id),state.r);
  drawChart(cw,[{id,label:label(id),color:COLORS[0],render:reg(id).r||'line',pts}],{single:true,mode:'actual'});
  STRIP_CB=null;
}
function drawCompare(ids){ const mode=state.mode||autoMode(ids); const AL=alignAll(ids);
  // apply range to shared keys
  const latest=AL.keys.length?AL.rep[AL.keys[AL.keys.length-1]]||AL.keys[AL.keys.length-1]:'';
  const cut = state.r==='MAX'||!latest?-1:monthsBefore(latest,RANGES.find(x=>x[0]===state.r)[1]);
  const idx = AL.keys.map((k,i)=>i).filter(i=>state.r==='MAX'||asDate(AL.rep[AL.keys[i]])>=cut);
  const useIdx = idx.length>=2?idx:AL.keys.map((k,i)=>i);
  const dates=useIdx.map(i=>AL.rep[AL.keys[i]]);
  const ser=ids.map((id,si)=>({id,label:label(id),color:COLORS[si%3],render:reg(id).r==='bars'?'bars':(reg(id).r==='step'?'step':'line'),
    pts:useIdx.map((i,j)=>({date:dates[j],value:AL.series[si].pts[i].value}))}));
  if(mode==='separate'){
    ser.forEach((s,i)=>{ const cw=document.querySelector(`.cw[data-cw="${i}"]`); if(cw){ drawChart(cw,[s],{single:true,height:document.querySelector('.cw[data-cw]')&&window.innerWidth<560?160:175,mode:'actual',axisCad:AL.freq}); } });
  } else {
    const cw=$('#cw0'); if(cw) drawChart(cw,ser,{mode:mode==='relative'?'relative':'actual',axisCad:AL.freq});
  }
  // strip
  const strip=$('#cxStrip'); const setStrip=(bi)=>{ if(!strip)return;
    const j = bi<0? dates.length-1 : bi;
    const d=dates[j];
    strip.innerHTML=`<span class="sd">${fmtDate(d,AL.freq)}</span>`+ser.map((s,si)=>{ const v=s.pts[j]?s.pts[j].value:null; const o=v==null?{v:'—',s:''}:disp(s.id,v);
      return `<span class="si"><i style="background:${COLORS[si%3]}"></i><span class="n">${label(s.id)}</span><span class="v">${o.v} ${o.s}</span></span>`; }).join(''); };
  STRIP_CB=(bi)=>setStrip(bi); setStrip(-1);
}

/* ============================ TABLE + CSV ============================ */
function buildRows(ids){
  if(ids.length===1){ const id=ids[0]; const pts=sliceRange(raw(id),state.r);
    return {cols:['Period',label(id)], rows:pts.map(p=>{const o=disp(id,p.value);return [fmtDate(p.date,cadOf(id)),o.v+(o.s?' '+o.s:'')];}),
      csv:{cols:['period','observation_date','value','unit','series_id','source','retrieved'],
           rows:pts.map(p=>[fmtDate(p.date,cadOf(id)),p.date,p.value,dataUnit(id),seriesId(meta(id).sourceUrl)||id,(meta(id).source||''),meta(id).fetchedAt||''])}}; }
  const AL=alignAll(ids),latest=AL.keys.length?AL.rep[AL.keys[AL.keys.length-1]]||AL.keys[AL.keys.length-1]:''; const cut=state.r==='MAX'||!latest?-1:monthsBefore(latest,RANGES.find(x=>x[0]===state.r)[1]);
  const rowsIdx=AL.keys.map((k,i)=>i).filter(i=>state.r==='MAX'||asDate(AL.rep[AL.keys[i]])>=cut);
  const cols=['Period',...ids.map(label)];
  const rows=rowsIdx.map(i=>[fmtDate(AL.rep[AL.keys[i]],AL.freq),...ids.map((id,si)=>{const v=AL.series[si].pts[i].value,o=disp(id,v);return o.v+(o.s?' '+o.s:'');})]);
  const csv={cols:['aligned_period',...ids.flatMap(id=>[id+'_value',id+'_unit',id+'_series_id',id+'_source'])],
    rows:rowsIdx.map(i=>[AL.keys[i],...ids.flatMap((id,si)=>{const v=AL.series[si].pts[i].value;return [v,dataUnit(id),seriesId(meta(id).sourceUrl)||id,meta(id).source||''];})])};
  return {cols,rows,csv};
}
function toggleTable(ids,btn){ const box=$('#cxTable'); if(!box)return; const on=box.hidden;
  if(on){ const {cols,rows}=buildRows(ids); box.innerHTML=`<table><thead><tr>${cols.map(c=>`<th>${c}</th>`).join('')}</tr></thead><tbody>${rows.map(r=>`<tr>${r.map(c=>`<td>${c}</td>`).join('')}</tr>`).join('')}</tbody></table>`; box.hidden=false; btn.classList.add('on'); btn.setAttribute('aria-pressed','true'); }
  else { box.hidden=true; btn.classList.remove('on'); btn.setAttribute('aria-pressed','false'); }
}
function downloadCSV(ids){ const {csv}=buildRows(ids); const esc=v=>{const s=String(v==null?'':v); return /[",\n]/.test(s)?'"'+s.replace(/"/g,'""')+'"':s;};
  const txt=[csv.cols.join(','),...csv.rows.map(r=>r.map(esc).join(','))].join('\n');
  const blob=new Blob([txt],{type:'text/csv'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download='mexico-brief-'+ids.join('-').replace(/[^a-z0-9-]/gi,'')+'.csv'; a.click(); setTimeout(()=>URL.revokeObjectURL(a.href),2000); }

/* ============================ BINDINGS ============================ */
function bindControls(){
  document.querySelectorAll('[data-view]').forEach(b=>b.addEventListener('click',async()=>{ applyView(b.dataset.view); await ensure(state.v); render(); }));
  document.querySelectorAll('[data-r]').forEach(b=>{ if(b.disabled)return; b.addEventListener('click',()=>{ state.r=b.dataset.r; render(); }); });
  document.querySelectorAll('[data-mode]').forEach(b=>{ if(b.disabled)return; b.addEventListener('click',()=>{ state.mode=b.dataset.mode; render(); }); });
  document.querySelectorAll('[data-rm]').forEach(b=>b.addEventListener('click',()=>{ state.v=state.v.filter(x=>x!==b.dataset.rm); state.view=viewMatch(state.v); state.mode=null; if(state.v.length)render(); }));
  const add=$('#cxAdd'); if(add)add.addEventListener('click',openSheet);
}
async function openAlone(id){ state.v=[id]; state.view=viewMatch(state.v); state.mode=null; await ensure(state.v); render(); window.scrollTo({top:0,behavior:'smooth'}); }
function bindCatalog(root){ (root||document).querySelectorAll('[data-open]').forEach(b=>{ if(b.__b)return; b.__b=1; b.addEventListener('click',()=>openAlone(b.dataset.open)); }); }
function bindAll(){
  document.querySelectorAll('[data-add]').forEach(b=>b.addEventListener('click',async()=>{ await addVar(b.dataset.add); }));
  bindCatalog();
  const all=$('#cxAll'); if(all&&!all.__b){ all.__b=1; all.addEventListener('toggle',()=>{ if(all.open){ const inner=$('#cxAllInner'); if(inner){ inner.innerHTML=catalogInner(); bindCatalog(inner); } } }); }
  const ids=state.v.filter(id=>store[id]&&raw(id).length);
  document.querySelectorAll('[data-act]').forEach(b=>b.addEventListener('click',()=>{ if(b.dataset.act==='table')toggleTable(ids,b); else downloadCSV(ids); }));
}
async function addVar(id){ if(state.v.includes(id)){ return; } if(state.v.length>=3)return; state.v=[...state.v,id]; state.view=viewMatch(state.v); state.mode=null; await ensure(state.v); render(); }

/* ---- add-variable sheet ---- */
let SHEET_RETURN=null;
function openSheet(){ const sh=$('#cxSheet'); if(sh.classList.contains('open'))return; SHEET_RETURN=document.activeElement; sh.classList.add('open'); sh.setAttribute('aria-hidden','false'); document.body.classList.add('cx-modal-open'); fillSheet(''); const s=$('#cxSearch'); s.value=''; setTimeout(()=>s.focus(),30); }
function closeSheet(restore=true){ const sh=$('#cxSheet'); if(!sh.classList.contains('open'))return; sh.classList.remove('open'); sh.setAttribute('aria-hidden','true'); document.body.classList.remove('cx-modal-open'); if(restore&&SHEET_RETURN&&SHEET_RETURN.isConnected)SHEET_RETURN.focus(); SHEET_RETURN=null; }
function sheetFocusable(){ return [...$('#cxSheet').querySelectorAll('button:not([disabled]),input:not([disabled]),[href],[tabindex]:not([tabindex="-1"])')].filter(el=>el.offsetParent!==null); }
function fillSheet(q){ q=(q||'').toLowerCase(); const list=$('#cxPickList');
  const groups=[['Derived',Object.keys(DERIVED)],...G.map((g,gi)=>[g,Object.keys(M).filter(id=>M[id].g===gi)])];
  let h='';
  for(const [gname,ids] of groups){ const show=ids.filter(id=>!state.v.includes(id) && (label(id).toLowerCase().includes(q)|| (reg(id).def||'').toLowerCase().includes(q))).sort((a,b)=>(reg(b).core?1:0)-(reg(a).core?1:0));
    if(!show.length)continue; h+=`<div class="sg">${gname}</div>`;
    for(const id of show){ const s=store[id]; const last=s?lastPt(id):null; const d=DERIVED[id];
      const detail=last?`${freqWord(cadOf(id))} · latest ${fmtDate(last.date,cadOf(id))} · ${unit(id)}`:s?`${freqWord(cadOf(id))} · unavailable · ${unit(id)}`:`${freqWord(cadOf(id))} · loads on add · ${unit(id)}`;
      const stale=last&&isStale(id);
      const full=state.v.length>=3;
      h+=`<div class="pr"><div class="prm"><div class="prn">${label(id)}${d?' <span class="db">derived</span>':''}</div><div class="prd${stale?' stale':''}">${detail}</div></div>
        <div class="pa"><button data-sheet-add="${id}"${full?' disabled title="Up to three"':''}>Add</button><button data-sheet-open="${id}">Alone</button></div></div>`; }
  }
  list.innerHTML=h||'<div class="pr"><div class="prm"><div class="prd">No match.</div></div></div>';
  list.querySelectorAll('[data-sheet-add]').forEach(b=>{ if(b.disabled)return; b.addEventListener('click',async()=>{ closeSheet(false); await addVar(b.dataset.sheetAdd); $('#cxAdd')?.focus(); }); });
  list.querySelectorAll('[data-sheet-open]').forEach(b=>b.addEventListener('click',async()=>{ closeSheet(false); state.v=[b.dataset.sheetOpen]; state.view=viewMatch(state.v); state.mode=null; await ensure(state.v); render(); $('#cxAdd')?.focus(); }));
}

/* ============================ BOOT ============================ */
document.addEventListener('click',e=>{ if(e.target.closest('[data-close]'))closeSheet(); });
$('#cxSheetClose').addEventListener('click',()=>closeSheet());
document.addEventListener('keydown',e=>{ const sh=$('#cxSheet'); if(!sh.classList.contains('open'))return;
  if(e.key==='Escape'){ e.preventDefault(); closeSheet(); return; }
  if(e.key==='Tab'){ const f=sheetFocusable(); if(!f.length){e.preventDefault();return;} const first=f[0],last=f[f.length-1];
    if(e.shiftKey&&document.activeElement===first){e.preventDefault();last.focus();}
    else if(!e.shiftKey&&document.activeElement===last){e.preventDefault();first.focus();}
  }
});
$('#cxSearch').addEventListener('input',e=>fillSheet(e.target.value));

(async()=>{
  readState();
  // fetch selected + preload core catalog + derived inputs in the background
  await ensure(state.v);
  render();
  // warm the rest quietly so the picker + All series show values
  const warm=[...new Set([...Object.keys(M), ...Object.values(DERIVED).flatMap(d=>d.inputs)])];
  ensure(warm.filter(id=>M[id])).then(()=>{ Object.keys(DERIVED).forEach(id=>{ if(!store[id]){try{store[id]=DERIVED[id].build();}catch(e){}} }); });
})().catch(e=>{ $('#cxBody').innerHTML='<div class="cx-err">Could not load the data: '+e.message+'</div>'; });
</script>
{% endraw %}
